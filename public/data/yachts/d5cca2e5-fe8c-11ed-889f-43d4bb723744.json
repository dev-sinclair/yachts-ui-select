:a::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::02c80860-dce5-11ef-98da-c9c0bc009ae4/{imageVariant}","/media/media::image::a::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::02ffe140-dce5-11ef-98da-c9c0bc009ae4/{imageVariant}","/media/media::image::a::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::02fef6e0-dce5-11ef-98da-c9c0bc009ae4/{imageVariant}","/media/media::image::a::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::02eddfe0-dce5-11ef-98da-c9c0bc009ae4/{imageVariant}","/media/media::image::a::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::02daa600-dce5-11ef-98da-c9c0bc009ae4/{imageVariant}","/media/media::image::a::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::03025240-dce5-11ef-97b6-b97a0f5dd316/{imageVariant}","/media/media::image::a::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::02c919d0-dce5-11ef-98da-c9c0bc009ae4/{imageVariant}","/media/media::image::a::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::02fe0c80-dce5-11ef-97b6-b97a0f5dd316/{imageVariant}"],"make":"Codecasa","model":"","maxCrew":9,"sleeps":12,"basePort":{"uri":"a::place::5e595eb8-b3ed-11ed-be02-325096b39f47","name":"Athens","coordinates":{"latitude":37.986174,"longitude":23.7268443},"country":"Greece"},"cruisingCapacity":12,"builtYear":1994,"architect":"","interiorDesigner":"AMK Architecture & Design","refitYear":2021,"topSpeed":18,"cruiseSpeed":15,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Double Cabin","value":"2"},{"label":"Twin Cabin","value":"2"}],"cabins":6,"bathrooms":6,"decks":3,"length":45,"beam":8.5,"draft":2.8,"hullType":"","hullConstruction":"","tonnage":416,"superStructure":[],"engines":"2 X 2240HP","amenities":[{"label":"Jacuzzi on deck"},{"label":"Sunbathing area"},{"label":"Lounge area"},{"label":"Bar"},{"label":"Outdoor Shower"},{"label":"Satellite TV"}],"toys":[{"label":"Fishing equipment"},{"label":"Jetski 3 up"},{"label":"Kayak"},{"label":"Paddle board","quantity":"3"},{"label":"Seabob","quantity":"2"},{"label":"Snorkeling gear"},{"label":"Seadoo Jetski GTI SE 170hp"}],"entertainment":["Satellite TV"],"tenders":["5.70m AEGEAN with Inboard Mercury 170hp","5.70m AEGEAN with outboard Yamaha 115hp"]},"crew":[{"name":"Manthos Markoulis","avatar":"/media/media::image::c::20519556651::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::c98ffce0-e871-11ef-a766-0b5b02b60182/{imageVariant}","role":"Captain","bio":"Captain Manthos holds Diploma Captain Class A’ and certificates in S.S.O., B.M.S, Medical Care, Hazardous Materials, ISPS, Ro-Ro Passenger Ships, A.R.P.A and Fire Fighting. A true expert of the Aegean and Ionian seas, he combines his deep knowledge of local maritime routes, hidden coves, and historic islands with a warm and approachable personality. His calm demeanor and meticulous attention to detail ensure both the safety and luxury of every voyage, while his passion for Greek culture and hospitality creates an unforgettable experience for guests."},{"name":"Giannis Stratigos","avatar":"/media/media::image::c::20519556651::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::772f2920-0027-11f1-84b9-970eb0aa7353/{imageVariant}","role":"Captain","bio":"Giannis brings over 16 years of experience as a Chef, having worked in some of the most prestigious 5-star hotels and\nresorts in Greece and abroad. He has also gained invaluable expertise in renowned 2 and 3 Michelin Star restaurants.\nBeyond his kitchen achievements, Giannis has served as a culinary lecturer, teaching professionals and students pursuing their University Degrees. He also represents Iliada, a premium Greek olive oil company, as their chef ambassador in Germany and Japan. With his vibrant personality and great sense of humor, Giannis is a perfect addition to the XANA team."},{"name":"Efi Diamantakou","avatar":"/media/media::image::c::20519556651::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::5ba328f0-e872-11ef-a766-0b5b02b60182/{imageVariant}","role":"Captain","bio":"Efi is a very experienced stewardess with more than twenty years in luxury yachts. She is an expert in housekeeping, flower decorations and dinner silver service. Her exquisite skills, professionalism, and knowledge can assist towards impeccable service provision to all our guests onboard."},{"name":"Kleopatra Gkini","avatar":"/media/media::image::c::20519556651::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::86f1e410-e872-11ef-a766-0b5b02b60182/{imageVariant}","role":"Captain","bio":"Kleopatra is a dedicated and passionate stewardess. She is eager to provide  high-end guest service. Her exceptional manners and kind smile guarantee an immaculate experience on board."},{"name":"Christina Mehmeti","avatar":"/media/media::image::c::20519556651::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::8d4e9470-3174-11f0-877f-65add2606d56/{imageVariant}","role":"Captain","bio":"Christina has a well-rounded background in hospitality, massage therapy, and childcare. She is\nhighly professional, adaptable and service-oriented, committed to ensuring a pleasant and\ncomfortable experience for all guests on board."},{"name":"Nikos Lymperopoulos","avatar":"/media/media::image::c::20519556651::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::be130cd0-e872-11ef-a766-0b5b02b60182/{imageVariant}","role":"Captain","bio":"Nikos started his career as a sailor and has developed into an outstanding bridge officer. He is a very friendly and gentle person with great interpersonal skills who truly defines the phrase ‘ready, willing and able’, and, along with the rest of the crew, is very attentive to the guests’ needs and desires."},{"name":"Marios Xanthoulis","avatar":"/media/media::image::c::20519556651::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::03fb95b0-e872-11ef-a766-0b5b02b60182/{imageVariant}","role":"Captain","bio":"Marios, is the soul of XANA. Having extensive experience as a Bosun in private yachts ensures the smooth operation of the yacht’s deck and oversees crew and equipment. His deep knowledge of maritime safety and yacht maintenance makes him an invaluable asset, ensuring both guest satisfaction and the highest standards of safety on every voyage."},{"name":"Dimitris Arvanitis","avatar":"/media/media::image::c::20519556651::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::9114a5e0-e872-11ef-a766-0b5b02b60182/{imageVariant}","role":"Captain","bio":"Dimitris turned his dream of working on a yacht into reality. After multiple successful seasons as a deckhand on luxury motor yachts he is now a member of our skilled crew and inseparable member of the team. He is hard worker, discreet and efficient when it comes to our guests’ safety and security."},{"name":"Marios Papadias","avatar":"/media/media::image::c::20519556651::vessel::d5cca2e5-fe8c-11ed-889f-43d4bb723744::assets::42f9fd10-e872-11ef-a766-0b5b02b60182/{imageVariant}","role":"Captain","bio":"Marios is a graduate of the National Merchant Marine Academy and holds an Engineer Class A’ Diploma. His calm, methodical approach guarantees that the yacht runs flawlessly throughout every journey. With a focus on safety and performance, Marios works quietly behind the scenes to ensure a seamless experience for guests, keeping everything in top condition from the engines to the finest details."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":15000000,"displayCurrency":"EUR","displayPrice":15000000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":17800000,"displayCurrency":"EUR","displayPrice":17800000,"unit":"WEEK"},"pricingInfo":[{"name":"Regular Rate","effectiveDates":[{"from":"2025-09-01T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"},{"from":"2025-01-01T00:00:00.000Z","to":"2025-06-30T23:59:59.999Z"},{"from":"2026-01-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z