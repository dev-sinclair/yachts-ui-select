t}","/media/media::image::a::vessel::320853c0-f03a-11ee-848f-314e75eb0e80::assets::46753230-2826-11f1-87e8-fd43b6a5a5b5/{imageVariant}","/media/media::image::a::vessel::320853c0-f03a-11ee-848f-314e75eb0e80::assets::4675f580-2826-11f1-851e-1baf5e6aaf43/{imageVariant}","/media/media::image::a::vessel::320853c0-f03a-11ee-848f-314e75eb0e80::assets::4675ce70-2826-11f1-87e8-fd43b6a5a5b5/{imageVariant}","/media/media::image::a::vessel::320853c0-f03a-11ee-848f-314e75eb0e80::assets::4674bd00-2826-11f1-851d-1baf5e6aaf43/{imageVariant}","/media/media::image::a::vessel::320853c0-f03a-11ee-848f-314e75eb0e80::assets::467495f0-2826-11f1-851e-1baf5e6aaf43/{imageVariant}","/media/media::image::a::vessel::320853c0-f03a-11ee-848f-314e75eb0e80::assets::46746ee0-2826-11f1-87e8-fd43b6a5a5b5/{imageVariant}","/media/media::image::a::vessel::320853c0-f03a-11ee-848f-314e75eb0e80::assets::467420c0-2826-11f1-851d-1baf5e6aaf43/{imageVariant}","/media/media::image::a::vessel::320853c0-f03a-11ee-848f-314e75eb0e80::assets::4674bd01-2826-11f1-87e8-fd43b6a5a5b5/{imageVariant}"],"make":"Marsaudon Composites","model":"ORC 57","maxCrew":2,"sleeps":8,"basePort":{"uri":"a::place::8d5e8c80-61a4-11f0-87fe-896190d7cce3","name":"Lavrio Port","coordinates":{"latitude":37.71336394760595,"longitude":24.05997419531736},"country":"Greece"},"builtYear":2023,"architect":"","interiorDesigner":"Marc Lombard","refitYear":"","topSpeed":20,"cruiseSpeed":15,"cabinLayout":[{"label":"Double Cabins","value":"4"}],"cabins":4,"bathrooms":2,"length":17.58,"beam":9.4,"draft":1.65,"hullType":"Catamaran","hullConstruction":"","amenities":[{"label":"Swim platform"},{"label":"Outdoor Shower"}],"toys":[{"label":"Stand-Up Paddle boards","quantity":"2"},{"label":"Snorkeling Equipment (8 persons)"},{"label":"Fishing Gear"}],"entertainment":["Wi-Fi"],"tenders":["3D Tender/Xpro415"]},"crew":[{"name":"Christian Prié","avatar":"/media/media::image::a::vessel::320853c0-f03a-11ee-848f-314e75eb0e80::assets::c7772010-2825-11f1-87e7-fd43b6a5a5b5/{imageVariant}","role":"Captain","bio":"Christian started to work in the industry as a draftsman and decided he wanted to sail the world instead. He got his Captain license and worked on all kinds of boats for O&G and leisure. Christian has over 20 years of experience. The past few years, he has mostly been working in the Caribbean for major charter companies. Christian has been involved with Avel Vaez for several months, helping take decisions on the boat design and outfitting. Christian joined Avel Vaez during the sea trials and test sail with the certifying authorities. He was Christian started to work in the industry as a draftsman and decided he wanted to sail the world instead. He got his Captain license in XXX and worked on all kinds of boats for O&G and leisure. Christian has over 20 years of experience. The past few years, he has mostly been working in the Caribbeans for major chartering companies. Christian has been involved with Avel Vaez for several months, helping take decisions on the boat design and outfitting. Christian started on joined Avel Vaez during the sea trials and test sail with the certifying authorities. He was also involved in the final commissioning delivery team in Lorient. When he is not sailing, Christian lives in Britany or in Martinique."},{"name":"Pavlina Melicharova","avatar":"/media/media::image::a::vessel::320853c0-f03a-11ee-848f-314e75eb0e80::assets::593550a0-37c4-11f1-99d6-efe7f0cadab5/{imageVariant}","role":"Captain","bio":"Pavlína has an adventurous soul. Her grandmother awakened her love for cooking as a little girl. An excellent cook with whom she spent a lot of time in the kitchen. She continued her studies at a hotel school. She owns a number of certificates from gastronomy and hospitality courses in Europe. She has been involved in professional gastronomy almost her entire life. You will definitely not be bored with her. When you are not tasting one of her specialties, she will surprise you with her stories and interesting facts as she traveled around the world for three years, visiting 60 countries.\nPavlína cooks with love and likes learning new cuisines. She prefers to cook healthy, wholesome food and loves colorful plating. For her it is all about taste and nourishing the body with healthy goodness. She follows a no waste system and always tries to use every part of the ingredient. Pavlína likes to introduce clients to rarely used and neglected foods. Pavlina prefers to prepare everything herself from A to Z. Canning vegetables and fruits, making jams, juices, syrups, herbal tinctures, spreads... Besides her passion for cooking, Pavlína has a lot of other hobbies and interests. She practices yoga. She likes to take pictures. She is writing a book. She has a Youtube channel. \n"}],"pricing":{"weekPricingFrom":{"currency":"USD","price":2395000,"displayCurrency":"USD","displayPrice":2395000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2898000,"displayCurrency":"EUR","displayPrice":2898000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer: Mediterranean - Weekly Rate","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-09-12T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-09-12T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-09-12T23:59:59.999Z"}],"pricing":{"currency":"USD","charterFee":2395000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2395000,"amount":2395000,"conditions":"VAT is Included"}],"total":2395000,"subTotal":2395000,"totalTax":0},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]}],"exclusionZones":[],"petsAllowed":false},{"name":"Winter: Caribbean - High Season","effectiveDates":[{"from":"2026-12-28T00:00:00.000Z","to":"2027-01-04T23:59:59.999Z"},{"from":"20