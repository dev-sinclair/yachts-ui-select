744::assets::02004060-bd7c-11ef-8858-bdde1da97c49/{imageVariant}","/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::0200dca0-bd7c-11ef-9b7b-2927e1cabf03/{imageVariant}","/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::01f65550-bd7c-11ef-ac1f-e5c316829a43/{imageVariant}","/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::0200b590-bd7c-11ef-8858-bdde1da97c49/{imageVariant}","/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::02019ff0-bd7c-11ef-84e2-032b9f9078ff/{imageVariant}","/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::01ffcb30-bd7c-11ef-9b7b-2927e1cabf03/{imageVariant}","/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::01fff240-bd7c-11ef-8859-bdde1da97c49/{imageVariant}","/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::02012ac0-bd7c-11ef-84e2-032b9f9078ff/{imageVariant}","/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::020151d0-bd7c-11ef-84e2-032b9f9078ff/{imageVariant}","/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::01ff5600-bd7c-11ef-84e2-032b9f9078ff/{imageVariant}","/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::01f73fb0-bd7c-11ef-ac1f-e5c316829a43/{imageVariant}"],"make":"Mural Yachts","model":"","maxCrew":4,"sleeps":8,"basePort":{"uri":"a::place::e74d6b24-b3ed-11ed-a0b9-325096b39f47","name":"Göcek","coordinates":{"latitude":36.75344367,"longitude":28.94146511},"country":"Türkiye"},"cruisingCapacity":"","builtYear":2007,"architect":"","interiorDesigner":"","refitYear":2019,"topSpeed":12,"cruiseSpeed":10,"fuelCapacity":4000,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Twin Cabin","value":"2"}],"cabins":4,"bathrooms":4,"decks":"","length":30,"beam":7,"draft":2.84,"hullType":"","hullConstruction":"","tonnage":"","superStructure":[],"engines":"2 × Scania 318 hp","amenities":[{"label":"Air Conditioning"},{"label":"Generators","quantity":"2"},{"label":"Bar"},{"label":"Dining Area"},{"label":"Watermaker"},{"label":"Flybridge"},{"label":"Bimini"}],"toys":[{"label":"Single Canoes","quantity":"2"},{"label":"Paddle Boards","quantity":"2"},{"label":"Adult Water Ski","quantity":"1"},{"label":"Child Water Ski","quantity":"1"},{"label":"Wakeboard","quantity":"1"},{"label":"Mono Ski","quantity":"1"},{"label":"Kneeboard","quantity":"1"},{"label":"Ringos","quantity":"2"},{"label":"Snorkeling Equipment"},{"label":"Fishing Equipment (2x rods, 2x longlines, 6x basic lines)"},{"label":"Sea Scooter","quantity":"2"}],"entertainment":["Satellite TV in Saloon and all Cabins","DVD/CD Player in Saloon and all Cabins","Board Games","Bluetooth Speakers","Wi-Fi"],"tenders":["4.20m Joker Tender 70 hp (8 guests)"]},"crew":[{"name":"Alpay Arslan","avatar":"/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::efa85a40-978f-11ef-8396-aff36cd60682/{imageVariant}","role":"Captain","bio":"Captain Alpay started his career at sea in 2007 as a chef onboard charter vessels. Until then he had been working as a very successful chef at high-end restaurants along the Turkish coast. However, he quickly developed a great interest in deck duties and changed his career path with his aim to becoming a captain. He became a captain in 2020. He has been serving onboard SERENITY 86 since 2009. Alpay has great communications skills and is a great team member. In his free time he loves repairing and riding motorbikes. He speaks Turkish and English."},{"name":"İbrahim Işık","avatar":"/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::a7da4fe0-978d-11ef-856d-b5518f83d4e3/{imageVariant}","role":"Captain","bio":"İbrahim has served as a chef in several high-end seafront restaurants, he started his career at sea in 2024 onboard SERENITY 86. Keeping himself up-to-date with new styles and techniques, he loves to share Mediterranean and Turkish cuisine with his guests and spoils them with fresh bakes during breakfast. İbrahim maintains a good relationship with guests and crew thanks to his humble personality. He speaks Turkish and basic English."},{"name":"Hasan Çeri","avatar":"/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::8744b840-978f-11ef-8396-aff36cd60682/{imageVariant}","role":"Captain","bio":"Hasan is from the small Mediterranean town of Ortaca. He gathered several years of high-end restaurant experience before becoming the deckhand on Serenity 86 in 2021. He is now in charge of all deck duties. His hobbies include swimming and fishing. Hasan speaks Turkish."},{"name":"Mahmut Eşit","avatar":"/media/media::image::c::7819217464::vessel::d5cca4c7-fe8c-11ed-889f-43d4bb723744::assets::febb3060-9790-11ef-8396-aff36cd60682/{imageVariant}","role":"Captain","bio":"Mahmut comes from Mardin which is located in the south-eastern province of  Turkey  and  one  of  the  oldest  settled  areas  in  upper  Mesopotamia.  His career as a steward started in restaurants and continued so until 2013. For over  eleven  years  he  has  worked  as  a  waiter  in  restaurants  with international clientele and in 2013 he decided to carry his talents to the sea  by  joining  the  team  onboard  Serenity  86.  He  likes  to  read  a  lot  and listen  to  music  in  his  spare  time.  Mahmut  speaks  English, Turkish and Kurdish."}],"pricing":{"dayPricingFrom":{"currency":"EUR","price":300000,"displayCurrency":"EUR","displayPrice":300000,"unit":"DAY"},"dayPricingTo":{"currency":"EUR","price":420000,"displayCurrency":"EUR","displayPrice":420000,"unit":"DAY"},"pricingInfo":[{"name":"Daily Charter Rates: April / May / October / November","effectiveDates":[{"from":"2026-04-01T00:00:00.000Z","to"