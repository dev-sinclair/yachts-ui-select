11f0-979f-8b2cc47975aa/{imageVariant}","/media/media::image::c::8164602117::vessel::d5cc4fad-fe8c-11ed-889f-43d4bb723744::assets::a5b36460-777d-11f0-979f-8b2cc47975aa/{imageVariant}","/media/media::image::c::8164602117::vessel::d5cc4fad-fe8c-11ed-889f-43d4bb723744::assets::a857f780-777d-11f0-979f-8b2cc47975aa/{imageVariant}"],"make":"Custom","model":"Custom","maxCrew":3,"sleeps":10,"basePort":{"uri":"a::place::27c28dba-b3ee-11ed-9755-325096b39f47","name":"Split","coordinates":{"latitude":43.51359615,"longitude":16.43884676},"country":"Croatia"},"cruisingCapacity":10,"builtYear":2000,"refitYear":2025,"topSpeed":12,"cruiseSpeed":8,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"5"}],"cabins":5,"bathrooms":5,"decks":2,"length":27,"beam":6.1,"draft":2.7,"hullType":"","hullConstruction":"Wood","tonnage":48.5,"superStructure":["Wood (Mahogany)"],"engines":"350HP Cummins","amenities":[{"label":"Air Conditioning"},{"label":"Sunbeds"}],"toys":[{"label":"Water skiing"},{"label":"Wakeboard"},{"label":"Tube ride"},{"label":" Donut ride"},{"label":"Paddleboards","quantity":"2"},{"label":"Kayak"},{"label":"Floaties"},{"label":"Snorkeling"},{"label":"Fishing Rods","quantity":"2"}],"entertainment":["WIFI","TV"],"tenders":[]},"crew":[{"name":"Dragan Pivac","role":"Captain","bio":"Captain and owner of gulet Anđeo. Born 3th September 1980. After graduating highschool in his home town, worked in tourism for a few years and started a very successful family business. But, he's always been drawn to the sea. Eventually, he decided to pursue his lifelong passion and shifted towards the cruising industry.  He is now a licensed captain and a proud owner of Anđeo.      \nWhen he is ashore, he likes being active, playing football and spending time on the tennis court.                                                                                                                                     \nHe is an easygoing person and calm Captain, confident in his skills and knowledge. He is also extremely passionate about his work and genuinely cares about people. \nGuests' satisfaction and overall experience is always his primary concern and will try his best to make it unforgettable.\nDragan's long-term goals are to further establish his position in the industry and always trying to take the Customer Service to the next level."},{"name":"Miro Bačelić","role":"Captain","bio":"Pave finishes off this crew as excellent addition to the team. \nPave was born in 1996, and lives in Šibenik. He graduated  highschool and started to work in tourism, as waiter.\nHowever, it was only a matter of time before he turned his heart and his eyes to a career at sea. In his words he has: “always loved the sea (after spending childhood years at his family’s  house on the sea and also passion for snorkeling), adventure and travel – working on yachts provides all of this, it also gives me the opportunity to meet people from all around the world and learn about new cultures and ways of life”.\nHe gets qualification of a deck cadet and skipper for sailing yachts.\nThis is Miro's sixth season aboard chartered gulets and he is already recognized as a valuable, hardworking and committed crew member, which is exactly why he was hand-chosen by Anđeo’s Captain and crew to join their team. \nMiro, the deckhand, is a person who has numerous duties on board. He is the right hand of your captain, energetic and hardworking.\nHis passion for yachts and cruising will be expressed at all times. Miro is at guests disposal during the cruise, yet he is discreet and non intrusive. He ads his personal touch to each cruise.\nExperienced and skilled as he is, he will, together with the captain Dragan, take the charter guests safely from one destination to another sharing his knowledge of the industry and local ways of life."},{"name":"Ivan Maršanić","role":"Captain","bio":"Born in Zagreb 1996 and graduated highschool for tourism and hospitality, but his passion for food and ambition to become chef, made him work hard and learn from the best in the branch. \nIvan acquired his culinary knowledge and skills at Pelegrin, the restaurant in Dalmatia with a Michelin star.\nHe himself researched and read professional literature and tried combinations of different flavors and different cooking techniques.\nFirst of all, his intention is to cook honestly, and what he himself believes in and he would like to eat.\nMain guide is always Croatian food, what is available and of good quality. Food is the first and basic thing in the kitchen and there is no compromise."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1980000,"displayCurrency":"EUR","displayPrice":1980000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2420000,"displayCurrency":"EUR","displayPrice":2420000,"unit":"WEEK"},"pricingInfo":[{"name":"Low Season: May 03 - June 06 / September 06 - October 15 ","effectiveDates":[{"from":"2025-05-03T00:00:00.000Z","to":"2025-06-06T23:59:59.999Z"},{"from":"2026-05-03T00:00:00.000Z","to":"2026-06-06T23:59:59.999Z"},{"from":"2027-05-03T00:00:00.000Z","to":"2027-06-06T23:59:59.999Z"},{"from":"2025-09-06T00:00:00.000Z","to":"2025-10-15T23:59:59.999Z"},{"from":"2026-09-06T00:00:00.000Z","to":"2026-10-15T23:59:59.999Z"},{"from":"2027-09-06T00:00:00.000Z","to":"2027-10-15T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1980000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1980000,"amount":1980000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0.13}}],"total":1980000,"subTotal":1980000,"totalTax":257400},"inclusionZones":[{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910156249996,19.400976562500006,46.534619140625]}],"exclusionZones":[],"petsAllowed":false},{"name":"Mid Season: June 07 – July 04 / August 16 - September 05 ","eff