abel":"Inverter"},{"label":"220V power sockets"},{"label":"Water maker"},{"label":"Hot water"},{"label":"Solar panels"},{"label":"Bow thruster"},{"label":"Sunbeds"},{"label":"Bar"},{"label":"Jacuzzi"},{"label":"Swimming platform"},{"label":"Swimming ladder"},{"label":"Cockpit, roof & deck cushions"},{"label":"Deep freezer & Refrigeration"},{"label":"Plancha"},{"label":"Expresso coffee machine"},{"label":"Wine cellar"},{"label":"Water purifier with water fountain"}],"toys":[{"label":"Waterski (size 36-47)","quantity":"1"},{"label":"Wake Board","quantity":"1"},{"label":"Surf electric jobe rumble (1 pax)","quantity":"1"},{"label":"Sea scooters Jobe infinity","quantity":"3"},{"label":"SUP","quantity":"3"},{"label":"Towing ring","quantity":"1"},{"label":"Noodles"},{"label":"Snorkeling equipment","quantity":"8"}],"entertainment":["Salon TV","Indoor/outdoor audio system","Onboard WIFI internet access","Speakers","Radio sound in salon"],"tenders":["Semi-rigid tender GALA 4.5m with 60HP Suzuki"]},"crew":[{"name":"Antoine Poettre","role":"Captain","bio":"French\nAntoine is an experienced catamaran sailor with trips throughout the Mediterranean, French Guiana, and the Caribbean.\nAbundant in local knowledge, he can show you the calanques like no one else and is familiar with all the anchorages and wild bays on Corsica. He is a passionate sailor who will ensure you have a great time sailing this comfortable and performance-oriented catamaran."},{"name":"Maryline Poette-Tarchi","role":"Captain","bio":"French\nHaving chosen to concentrate on the culinary arts and pleasing gourmets on board yachts, Maryline is first and foremost a wonderful assistant to her captain, having earned a diploma as a captain herself. She completed her training in French cooking in Perpignan and has been entertaining guests for nearly two years.\nYou'll enjoy your stay with them aboard NEOW since she loves to pour her generosity into her cuisine, which is always cooked with fresh, local vegetables. Maryline finished her training by learning how to make pastries in a family cooking class with chef Fabien Plane and Michelin-starred chef Houssin!"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":3500000,"displayCurrency":"EUR","displayPrice":3500000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":4500000,"displayCurrency":"EUR","displayPrice":4500000,"unit":"WEEK"},"pricingInfo":[{"name":"May & October","effectiveDates":[{"from":"2026-04-15T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2026-10-01T00:00:00.000Z","to":"2026-10-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":3500000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":3500000,"amount":3500000,"conditions":"Weekly"},{"item":"","conditions":"","quantity":1,"unitPrice":0,"amount":0}],"total":3500000,"subTotal":3500000,"totalTax":0},"inclusionZones":[{"label":"France","type":"Country","category":["Europe","Western Europe","France"],"coordinates":[-3.676762491181631,13.257370810531999],"bbox":[-61.79784094999991,-21.37078215899993,55.854502800000034,51.08754088371883]},{"label":"Corsica","type":"Geo subunit","category":["Europe","Southern Europe","Corsica"],"coordinates":[9.104917129771797,42.161865413836736],"bbox":[8.565625000000011,41.384912109374994,9.556445312500017,43.021484375]},{"label":"Sardinia","type":"Geo subunit","category":["Europe","Southern Europe","Sardinia"],"coordinates":[8.96574354539669,40.12242872762209],"bbox":[8.180859375000011,38.90966796875,9.805273437500006,41.257080078125]},{"label":"Balearic Sea","type":"Custom Area","category":["Balearic Sea"],"coordinates":[2.000410764306259,40.062001742279],"bbox":[-0.32899247883295857,38.65937185317806,4.2816304866803705,41.96296865494908]}],"exclusionZones":[],"petsAllowed":false},{"name":"June & September","effectiveDates":[{"from":"2026-06-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-3