geVariant}","/media/media::image::a::vessel::d5cbfacf-fe8c-11ed-889f-43d4bb723744::assets::890c7600-fdc3-11ef-8183-8bc7ce753142/{imageVariant}","/media/media::image::a::vessel::d5cbfacf-fe8c-11ed-889f-43d4bb723744::assets::88ec43d0-fdc3-11ef-8183-8bc7ce753142/{imageVariant}","/media/media::image::a::vessel::d5cbfacf-fe8c-11ed-889f-43d4bb723744::assets::8900dd40-fdc3-11ef-958e-2b5b7ba4f6f4/{imageVariant}","/media/media::image::a::vessel::d5cbfacf-fe8c-11ed-889f-43d4bb723744::assets::88e69e80-fdc3-11ef-8183-8bc7ce753142/{imageVariant}","/media/media::image::a::vessel::d5cbfacf-fe8c-11ed-889f-43d4bb723744::assets::88eda360-fdc3-11ef-8183-8bc7ce753142/{imageVariant}","/media/media::image::a::vessel::d5cbfacf-fe8c-11ed-889f-43d4bb723744::assets::88eda360-fdc3-11ef-958e-2b5b7ba4f6f4/{imageVariant}","/media/media::image::a::vessel::d5cbfacf-fe8c-11ed-889f-43d4bb723744::assets::318f31a0-fdc4-11ef-9734-7f2cd922237c/{imageVariant}"],"make":"Lagoon-Bénéteau","model":"Lagoon 620","maxCrew":3,"sleeps":10,"basePort":{"uri":"a::place::27c28dba-b3ee-11ed-9755-325096b39f47","name":"Split","coordinates":{"latitude":43.51359615,"longitude":16.43884676},"country":"Croatia"},"builtYear":2018,"architect":"","interiorDesigner":"","topSpeed":0,"cruiseSpeed":10,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"5"}],"cabins":5,"bathrooms":5,"length":18.9,"beam":10,"draft":1.55,"hullType":"Catamaran","hullConstruction":"Fiberglass","tonnage":0,"superStructure":[],"engines":"Volvo (2 x 150 HP)","amenities":[{"label":"Inverter"},{"label":"Generator"},{"label":"Air Conditioning"},{"label":"Teak in cockpit"},{"label":"Tender lift platform"},{"label":"Swim platform"},{"label":"Flybridge"},{"label":"Refrigerator"},{"label":"Freezer"},{"label":"Dishwasher"},{"label":"Washer / Dryer"},{"label":"Coffee Machine"},{"label":"Ice Maker"},{"label":"Watermaker"},{"label":"Walk-in Closet"},{"label":"Hairdryer"}],"toys":[{"label":"Dinghy (9 pax)"},{"label":"Stand-up Paddleboards","quantity":"2"},{"label":"Snorkeling Gear","quantity":"10"},{"label":"Towing Ring"},{"label":"Inflatable Water Toys / Beds"},{"label":"Fishing Gear","quantity":"2"},{"label":"Water skis"},{"label":"Water tube"}],"entertainment":["TV","Printer","Radio","Speakers"]},"crew":[{"name":"Stjepan Ćesić","avatar":"/media/media::image::a::vessel::d5cbfacf-fe8c-11ed-889f-43d4bb723744::assets::04283a50-fdc3-11ef-92b2-41f1eba542a7/{imageVariant}","role":"Captain","bio":"He is a professional sailing coach from Split with six years of experience. He has skippered yachts across the Adriatic Sea and Europe and is currently the captain of a Lagoon 620 catamaran. Safety is his top priority, and he has a passion for working with children. He has a deep understanding of psychology and the Croatian coast and won a silver medal at the Sailing World Championship"},{"name":"Sara Vrabac","avatar":"/media/media::image::a::vessel::d5cbfacf-fe8c-11ed-889f-43d4bb723744::assets::13743e50-fdc3-11ef-92b2-41f1eba542a7/{imageVariant}","role":"Captain","bio":"She was born and raised in Zagreb, Croatia, and graduated from the Faculty of Fashion Design. However, the sea always attracted her more than fashion. In 2021, she had her first experience working as a hostess on a boat, and from that moment on, she has based her life around the nautical industry. People consider her cheerful and communicative, and she is known as a responsible yacht hostess with strong organizational skills, attention to detail, and a commitment to providing excellent guest service. She is responsible for maintaining cleanliness and hygiene in interior spaces, preparing and serving meals and beverages, and ensuring a pleasant atmosphere on board. She excels in communication, has knowledge of foreign languages, and can adapt to dynamic environments. She stands out with her teamwork  spirit, proactive approach to problem-solving, and basic first aid knowledge.\n\nSkills/Expertise/Languages:\n-\tFluent in English  \n-\tBoat licence category B \n\nPersonal Interests:\nShe enjoys photography and drawing, exploring various visual styles and techniques through both artistic and documentary approaches. She travels frequently, discovering new places and meeting people from different cultures. Hiking allows her to spend time in nature and explore new landscapes. Cooking is an important part of her life, especially when preparing meals for family and friends, as she enjoys the process of creating new flavors and recipes."},{"name":"Ivan Bohinc","avatar":"/media/media::image::a::vessel::d5cbfacf-fe8c-11ed-889f-43d4bb723744::assets::3052fd90-fdc3-11ef-99f9-7f06c4e971ea/{imageVariant}","role":"Captain","bio":"Ivan Bohinc is from Zagreb, Croatia, and has a background in hospitality and tourism, having completed his studies in Zagreb. With over 14 years of experience in the culinary world, he discovered his true passion for Mediterranean cuisine. Known for his calm demeanor and attention to detail, Ivan strives to satisfy every guest's unique tastes.\n\nSkills/Expertise/Languages:\n\tCHEF IVAN\t- Hospitality tourism education\n-\tExpertise in Mediterranean kitchen\n-\tHACCP certified\n-\tSkippers academy “Vodan\n"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":2070000,"displayCurrency":"EUR","displayPrice":2070000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":3390000,"displayCurrency":"EUR","displayPrice":3390000,"unit":"WEEK"},"pricingInfo":[{"name":"01.01 - 23.05 & 04.10 - 31.12","effectiveDates":[{"from":"2025-01-01T00:00:00.000Z","to":"2025-05-23T23:59:59.999Z"},{"from":"2026-01-01T00:00:00.000Z","to":"2026-05-23T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-05-23T23:59:59.999Z"},{"from":"2025-10-04T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"},{"from":"2026-10-04T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-10-04T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":2070000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"