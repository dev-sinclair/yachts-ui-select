antity":1},{"label":"Onboard WiFI","quantity":1},{"label":"Flybridge","quantity":1},{"label":"Sunpads","quantity":1},{"label":"Lounge Area","quantity":1},{"label":"TV  in all cabins","quantity":1},{"label":"Sun cushions","quantity":1},{"label":"Special Diets","quantity":1},{"label":"Indoor Audio System","quantity":1}],"toys":[{"label":"Dinghy","quantity":8},{"label":"tubes","quantity":1},{"label":"Floating Mats","quantity":1},{"label":"Paddle-boards Stand Up (SUP)","quantity":2},{"label":"Sea Scooter","quantity":2},{"label":"Fishing Gear","quantity":1},{"label":"Kneeboard","quantity":1},{"label":"Stern Boarding Ladder","quantity":1},{"label":"Trolling and Casting Gear Type","quantity":1},{"label":"Rods","quantity":2},{"label":"Seabob","quantity":1},{"label":"Snorkeling Gear","quantity":1},{"label":"Kayak","quantity":1},{"label":"waterski","quantity":1}]},"crew":[{"name":"Jonathan Taylor","avatar":"/media/media::image::c::8275378522::vessel::d5cbfb17-fe8c-11ed-889f-43d4bb723744::assets::25886de0-ee14-11f0-8a04-7f2c03578fa2/{imageVariant}","role":"Captain","bio":"Jonathan is your easygoing and highly capable skipper, bringing calm, confident energy that keeps everything running smoothly and makes guests feel right at home. Whether your ideal week involves snorkeling, beach bars, and island hopping or quiet, secluded anchorages under the stars, Jonathan tailors the trip to match your vibe. He is a certified PADI Dive Master with a USCG 100-ton license, sailing endorsement, and years of global experience both above and below the water. Fun fact, Jonathan and Charlotte are a dynamic duo both on and off the boat, happily married and creating a seamless team for every guest. Together, they have travelled the world and sailed the Mediterranean, Croatia, Montenegro, Mexico, the British Virgin Islands, Saint Vincent and the Grenadines, and Grenada together."},{"name":"Charlotte Taylor-Wray","avatar":"/media/media::image::c::8275378522::vessel::d5cbfb17-fe8c-11ed-889f-43d4bb723744::assets::4a8879a0-ee14-11f0-8a04-7f2c03578fa2/{imageVariant}","role":"Captain","bio":"Charlotte is your onboard chef, hostess, and all-around vibe curator. She has a warm, welcoming style and a meticulous eye for detail, making every guest feel pampered and relaxed. Charlotte crafts fresh, flavorful meals inspired by the places she has traveled, from casual beach brunches to customized meals for any occasion, always tailored to your preferences. A graduate of Ashburton Chef’s Academy School, she is also a certified health and wellness coach and has led luxury retreats focused on health and wellness. Together with her husband Jonathan, she ensures every journey is effortless, memorable, and full of good vibes."}],"pricing":{"dayPricingFrom":{"currency":"USD","price":280000,"displayCurrency":"USD","displayPrice":280000,"unit":"DAY"},"dayPricingTo":{"currency":"USD","price":280000,"displayCurrency":"USD","displayPrice":280000,"unit":"DAY"},"weekPricingFrom":{"currency":"USD","price":2300000,"displayCurrency":"USD","displayPrice":2300000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":2860000,"displayCurrency":"USD","displayPrice":2860000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer/Winter - Low Season","effectiveDates":[{"from":"2026-05-01T00:00:00.000Z","to":"2026-12-14T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-12-14T23:59:59.999Z"},{"from":"2028-05-01T00:00:00.000Z","to":"2028-12-14T23:59:59.999Z"}],"pricing":{"currency":"USD","charterFee":2300000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2300000,"amount":2300000,"conditions":"VAT & APA Excluded"}],"total":2300000,"subTotal":2300000,"totalTax":0},"inclusionZones":[{"label":"British Virgin Is.","type":"Dependency","category":["North America","Caribbean","British Virgin Is."],"coordinates":[-64.45080373172777,18.568736231458896],"bbox":[-64.69511718749999,18.399121093749997,-64.273583984375,18.752685546875]},{"la