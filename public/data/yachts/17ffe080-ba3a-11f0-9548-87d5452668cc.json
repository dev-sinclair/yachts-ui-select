-2feefc71e56e/{imageVariant}","/media/media::image::c::35182310185::vessel::17ffe080-ba3a-11f0-9548-87d5452668cc::assets::2c8636d0-21fa-11f1-bf80-2feefc71e56e/{imageVariant}","/media/media::image::c::35182310185::vessel::17ffe080-ba3a-11f0-9548-87d5452668cc::assets::3a02f910-21fa-11f1-bf80-2feefc71e56e/{imageVariant}"],"make":"Wally Yachts","maxCrew":3,"sleeps":8,"basePort":{"uri":"a::place::e74d6958-b3ed-11ed-bec4-325096b39f47","name":"Genoa","coordinates":{"latitude":44.40529903869361,"longitude":8.9280946102873},"country":"Italy"},"builtYear":2003,"architect":"German Frers","interiorDesigner":"","refitYear":2025,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"Double Cabins","value":"2"}],"cabins":3,"bathrooms":4,"decks":1,"length":30.6,"beam":6.4,"draft":4.7,"hullType":"Mono","hullConstruction":"Carbon Fiber","tonnage":46,"amenities":[{"label":"Air Conditioning "},{"label":"Generator"},{"label":"Starlink"},{"label":"Sunbathing"},{"label":"B&G H5000 Instruments"},{"label":"Watermaker "}],"toys":[{"label":"Awake Rävik S electric surfboard"},{"label":"Water skis"},{"label":"Wakeboard"},{"label":"Inflatables"},{"label":"Wing foil "},{"label":"Snorkeling equipment"},{"label":"Standup Paddle Board"}],"entertainment":["Starlink","TV Screens"],"tenders":["4m Wiliam TurboJet Tender"]},"crew":[{"name":"Olivier Kobale","avatar":"/media/media::image::c::35182310185::vessel::17ffe080-ba3a-11f0-9548-87d5452668cc::assets::8d0f8b30-bfb4-11f0-afd6-8f67c3d32125/{imageVariant}","role":"Captain","bio":"Oliver grew up racing dinghies in Austria, competing at an international level in both the Oppie and 420. In 2019, he was one of the founding members of Austrian Ocean racing team and has clocked up over 120,000nm offshore with both professional and amateur crews. Oliver has a strong technical background having studied mechanical engineering. Oliver enjoys the combination of cruising and racing on Vantanera and leading his team to ensure guests have a great experience onboard.\n\n• RYA Yacht Master Offshore\n• Powerboat Level 2\n• Basic Paramedic training\n• Languages: English, Spanish, German"},{"name":"Dylan Armstrong","avatar":"/media/media::image::c::35182310185::vessel::17ffe080-ba3a-11f0-9548-87d5452668cc::assets::01baa3c0-bfb5-11f0-890b-4586e30159c2/{imageVariant}","role":"Captain","bio":"Originally from South Africa, Dylan found his passion for yachting in 2018. He enjoys being hands-on and working within a team. With great attention to detail, he keeps on top of maintenance and keeps Vantanera looking her best.\nDylan has worked on both private and charter yachts, supporting tender driving and watersports with a calm, friendly approach. A qualified PADI diver and skilled drone operator, he loves helping guests explore the water and capturing unforgettable moments from above and below the surface.\n\n• RYA Yachtmaster Offshore\n• RYA Ocean Theory\n• RYA PB 2 , GMDSS / SRC\n• STCW & PDSC\n• Languages: English, Spanish, Dutch"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":5500000,"displayCurrency":"EUR","displayPrice":5500000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":5500000,"displayCurrency":"EUR","displayPrice":5500000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Cruising Rate Caribbean ","effectiveDates":[{"from":"2025-12-01T00:00:00.000Z","to":"2026-05-01T23:59:59.999Z"},{"from":"2026-12-01T00:00:00.000Z","to":"2027-05-01T23:59:59.999Z"},{"from":"2027-12-01T00:00:00.000Z","to":"2028-05-01T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":5500000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":5500000,"amount":5500000,"conditions":""},{"item":"APA","conditions":"","quantity":0.25,"unitPrice":5500000,"amount":1375000}],"total":6875000,"subTotal":6875000,"totalTax":0},"inclusionZones":[{"label":"Caribbean Sea","type":"Custom Area","category":["Caribbean Sea"],"coordinates":[-75.20942221363948,15.447039028480969],"bbox":[-88.