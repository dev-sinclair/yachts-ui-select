07c510-818d-11f0-9f79-ab10d1eb8b4b/{imageVariant}","/media/media::image::a::vessel::d5cbd3a4-fe8c-11ed-889f-43d4bb723744::assets::31116200-818d-11f0-9f7a-ab10d1eb8b4b/{imageVariant}","/media/media::image::a::vessel::d5cbd3a4-fe8c-11ed-889f-43d4bb723744::assets::312203d0-818d-11f0-b258-557c5c98d413/{imageVariant}","/media/media::image::a::vessel::d5cbd3a4-fe8c-11ed-889f-43d4bb723744::assets::31066580-818d-11f0-9f79-ab10d1eb8b4b/{imageVariant}","/media/media::image::a::vessel::d5cbd3a4-fe8c-11ed-889f-43d4bb723744::assets::31074fe0-818d-11f0-9f79-ab10d1eb8b4b/{imageVariant}","/media/media::image::a::vessel::d5cbd3a4-fe8c-11ed-889f-43d4bb723744::assets::311336c0-818d-11f0-9f7a-ab10d1eb8b4b/{imageVariant}"],"make":"Azimut","model":"","maxCrew":3,"sleeps":8,"basePort":{"uri":"a::place::27c2846e-b3ee-11ed-84d9-325096b39f47","name":"Sibenik","coordinates":{"latitude":43.73209476,"longitude":15.89377479},"country":"Croatia"},"builtYear":2022,"architect":"Alberto Mancini & Achille Salvagni Architetti","interiorDesigner":"","topSpeed":30,"cruiseSpeed":21,"fuelCapacity":0,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"Double Cabins","value":"2"},{"label":"Twin Cabin","value":"1"}],"cabins":4,"bathrooms":4,"length":22.33,"beam":5.68,"draft":1.75,"hullType":"Displacement","hullConstruction":"GRP","tonnage":0,"superStructure":["Flybridge"],"engines":"3x VOLVO IPS 1350 (1000 hp)","amenities":[{"label":"Air Conditioning"}],"toys":[{"label":"Seabob"},{"label":"SUP"},{"label":"Seadoo Spark Jet Ski"},{"label":"Fun Tube"},{"label":"Water Ski"},{"label":"Snorkeling Equipment"}],"entertainment":["Wi-Fi"],"tenders":["Tender 3.5m"]},"crew":[{"name":"Ante Kovic","avatar":"/media/media::image::a::vessel::d5cbd3a4-fe8c-11ed-889f-43d4bb723744::assets::9e72f3a0-8191-11f0-acb3-7d6b7c07c45f/{imageVariant}","role":"Captain","bio":"Croatian\n\nAnte discovered the sea through rowing and diving from an early age. Ante has 10 years of experience and holds significant certificates related to his job. He has a creative approach to problem-solving, teamwork, good communication, and organizational skills. He is a responsible, hardworking, and easy- going person. Besides the yachting business, Ante expresses his creativity and curiosity through music, woodworking, and reading. Ante is fluent in English."},{"name":"Martina Adrasek","avatar":"/media/media::image::a::vessel::d5cbd3a4-fe8c-11ed-889f-43d4bb723744::assets::ab1cfc90-8191-11f0-acb3-7d6b7c07c45f/{imageVariant}","role":"Captain","bio":"Croatian\n\nBeing from Zagreb but having roots from Šibenik, Martina has spent every summer with Šibenik and developed huge love for the sea. In the meantime, she started to train swimming and spent 16 years in the sport and helped her develop discipline, commitment and spirit for the team work. She is very cheerful and positive person who is ready to work hard and provide the best time possible for the guests. Martina is fluent in English."},{"name":"Luka Panduric","avatar":"/media/media::image::a::vessel::d5cbd3a4-fe8c-11ed-889f-43d4bb723744::assets::daf66ff0-8191-11f0-acb3-7d6b7c07c45f/{imageVariant}","role":"Captain","bio":"Croatian\n\nHe comes from the Croatian countryside and, until recently, was a professional basketball player. In the past few years, his career path led him to the coast, to Šibenik, where he discovered a deep passion for the sea and boats. This realization inspired him to change direction and build a new life and career on the water. He credits his sports background for instilling lasting habits—discipline, organization, and strong teamwork—that he now carries into his new profession. Motivated and eager to grow, he sees this as the beginning of an exciting new chapter and looks forward to acquiring new skills along the way."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":3540000,"displayCurrency":"EUR","displayPrice":3540000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":4690000,"displayCurrency":"EUR","displayPrice":46