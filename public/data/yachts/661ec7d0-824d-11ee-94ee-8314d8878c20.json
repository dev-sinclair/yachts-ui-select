ssel::661ec7d0-824d-11ee-94ee-8314d8878c20::assets::d267fa30-0f08-11f0-b15d-39abf857b800/{imageVariant}","/media/media::image::a::vessel::661ec7d0-824d-11ee-94ee-8314d8878c20::assets::d26b5590-0f08-11f0-b15e-39abf857b800/{imageVariant}","/media/media::image::a::vessel::661ec7d0-824d-11ee-94ee-8314d8878c20::assets::d2597b40-0f08-11f0-8400-3b9989fe747e/{imageVariant}","/media/media::image::a::vessel::661ec7d0-824d-11ee-94ee-8314d8878c20::assets::d26e14b0-0f08-11f0-9059-b7f6a43d4f80/{imageVariant}","/media/media::image::a::vessel::661ec7d0-824d-11ee-94ee-8314d8878c20::assets::d26d7870-0f08-11f0-9059-b7f6a43d4f80/{imageVariant}","/media/media::image::a::vessel::661ec7d0-824d-11ee-94ee-8314d8878c20::assets::d2611c60-0f08-11f0-8400-3b9989fe747e/{imageVariant}","/media/media::image::a::vessel::661ec7d0-824d-11ee-94ee-8314d8878c20::assets::d2682140-0f08-11f0-8a5b-ab2b8616beab/{imageVariant}"],"make":" Saba Yacht","maxCrew":7,"sleeps":12,"basePort":{"uri":"a::place::27c28dba-b3ee-11ed-9755-325096b39f47","name":"Split","coordinates":{"latitude":43.51359615,"longitude":16.43884676},"country":"Croatia"},"builtYear":2010,"architect":"Saba Yacht","interiorDesigner":"","refitYear":2024,"topSpeed":12,"cruiseSpeed":10,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"5"},{"label":"Twin Cabin","value":"1"}],"cabins":6,"bathrooms":6,"length":34.1,"beam":8.1,"draft":2.1,"hullType":" Displacement","hullConstruction":"Steel","tonnage":0,"superStructure":["Flybridge"],"engines":"2 X SERIES 60 MTU 740 BHB","amenities":[{"label":"Air conditioning"},{"label":"Deck Jacuzzi"},{"label":"Stabilisers at anchor"},{"label":"Stabilisers underway"},{"label":"Elevator/lift"},{"label":"Gym/exercise equipment"},{"label":"Flybridge"},{"label":"Sunbathing areas"}],"toys":[{"label":"Jet ski","quantity":"3"},{"label":"SUP","quantity":"2"},{"label":"Sea Kayak","quantity":"1"},{"label":"Sea Pool","quantity":"1"},{"label":"Wakeboard","quantity":"1"}],"entertainment":["WiFi connection"],"tenders":["Joker Boat"]},"crew":[{"name":"Franko Barac","avatar":"/media/media::image::a::vessel::661ec7d0-824d-11ee-94ee-8314d8878c20::assets::36208020-0f08-11f0-b14b-9fdfa60907b0/{imageVariant}","role":"Captain","bio":"Croatian\n\nBorn and raised in Split, Croatia, Franko has been drawn to the sea since childhood. His passion for maritime life led him to the yachting industry, where he began as a mechanic and steadily worked his way up to the role of captain. With extensive experience navigating charter yachts across the West Mediterranean and Adriatic, Franko knows the Adriatic Sea like the back of his hand. A knowledgeable and responsible leader, he embraces the daily challenges of life on board with dedication and professionalism. Friendly and open-minded, Franko enjoys meeting people from all over the world and learning about their cultures. In his free time, he loves running and hiking, always seeking new adventures on land as well as at sea. With Franko at the helm, guests can fully relax and enjoy an unforgettable experience aboard M/Y APNA."},{"name":"Damir Lojdl","avatar":"/media/media::image::a::vessel::661ec7d0-824d-11ee-94ee-8314d8878c20::assets::4a93a370-0f08-11f0-b14b-9fdfa60907b0/{imageVariant}","role":"Captain","bio":"Croatian\n\nChef Damir is a passionate and skilled culinary professional specializing in Mediterranean cuisine. In 2014, he was recognized as the best young chef in the region, a testament to his dedication and talent. With experience in various gastronomic competitions, he continuously hones his craft, creating dishes that celebrate the rich flavors of the Mediterranean.\nDamir thrives in fast-paced environments, seamlessly managing multiple tasks while maintaining exceptional quality and attention to detail. His strong communication and interpersonal skills make him a valuable team player in any kitchen.\nBeyond cooking, Damir enjoys traveling, exploring nature, running, and swimming—activities that inspire his fresh and vibrant culinary creations. His delicious and nourishing dishes promise to awaken your senses as you embark on a flavorful journey through the Mediterranean."},{"name":"Maryna Matviienko","role":"Captain","bio":"Ukraine\n\nMarina’s strong skills are creating coziness, attention to detail, communication, and always maintaining a positive attitude. In yachting, she quickly advanced to roles such as Chief Stewardess on luxury yachts, where she excelled in maintaining immaculate interiors, setting the tables, and managing inventory. With over 10 years of experience in hospitality, she provides excellent service to guests."},{"name":"Marko Džakula","role":"Captain","bio":"Croatian\n\nMarko Dzakula is a dedicated and responsible seafarer with a passion for tackling new challenges and expanding his skill set. Fluent in English and Croatian, Marko has built a reputation for being easy-going and hard-working, traits that have served him well throughout his extensive maritime career. Markoʼs background as a lifelong sports team member has instilled in him a strong belief in teamwork and supporting all departments within a yacht, ensuring the smooth and successful running of operations."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":7000000,"displayCurrency":"EUR","displayPrice":7000000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":9000000,"displayCurrency":"EUR","displayPrice":9000000,"unit":"WEEK"},"pricingInfo":[{"name":"High Season Charter Rate","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":9000000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":9000000,"amount":9000000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.13}},{"item":"APA","conditions":"","quantity":0.4,"u