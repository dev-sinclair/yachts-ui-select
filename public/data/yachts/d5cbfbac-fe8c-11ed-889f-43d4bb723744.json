89f-43d4bb723744::assets::dad23a91-fdc5-11ef-a05f-ebc6e5729354/{imageVariant}","/media/media::image::a::vessel::d5cbfbac-fe8c-11ed-889f-43d4bb723744::assets::dad324f0-fdc5-11ef-a05f-ebc6e5729354/{imageVariant}","/media/media::image::a::vessel::d5cbfbac-fe8c-11ed-889f-43d4bb723744::assets::dad23a90-fdc5-11ef-a05f-ebc6e5729354/{imageVariant}","/media/media::image::a::vessel::d5cbfbac-fe8c-11ed-889f-43d4bb723744::assets::dad324f1-fdc5-11ef-a05f-ebc6e5729354/{imageVariant}","/media/media::image::a::vessel::d5cbfbac-fe8c-11ed-889f-43d4bb723744::assets::03df9130-fdc6-11ef-a223-3b0ab20a67ec/{imageVariant}"],"make":"Catana Group","model":"Bali 5.4","maxCrew":2,"sleeps":12,"basePort":{"uri":"a::place::738f24c0-dada-11ed-befa-d7914edd5e3a","name":"Marina Kastela","coordinates":{"latitude":43.54601254691691,"longitude":16.40283517494042},"country":"Croatia"},"cruisingCapacity":12,"builtYear":2019,"architect":"","interiorDesigner":"","refitYear":0,"topSpeed":12,"cruiseSpeed":8,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"5"},{"label":"Double Cabin with bunk bed","value":"1"}],"cabins":6,"bathrooms":6,"length":16.79,"beam":8.74,"draft":1.48,"hullType":"Catamaran","hullConstruction":"Fiberglass","superStructure":[],"engines":"Yanmar 2 x 57 HP","amenities":[{"label":"Air Conditioning"},{"label":"Generator"},{"label":"Inverter"},{"label":"Solar Panels"},{"label":"Refrigerator"},{"label":"Freezer"},{"label":"Dishwasher"},{"label":"Washer/Dryer"},{"label":"Wine Cooler"},{"label":"Coffee machine"},{"label":"Ice Maker"},{"label":"Sun loungers"},{"label":"Watermaker"},{"label":"Cockpit cushions"},{"label":"Hair dryer"}],"toys":[{"label":"Stand-up paddleboards","quantity":"4"},{"label":"Snorkeling gear","quantity":"10"},{"label":"Inflatable water bed"},{"label":"Fishing gear"}],"entertainment":["Wi-Fi","TV","Hi-Fi","Radio","Speakers"],"tenders":["Dinghy: Highfield CL 380 with 25 HP Yamaha OB (7 pax)"]},"crew":[{"name":"Josip Kovacev","avatar":"/media/media::image::a::vessel::d5cbfbac-fe8c-11ed-889f-43d4bb723744::assets::fea26e50-fdc4-11ef-a47e-0d035601c304/{imageVariant}","role":"Captain","bio":"Croatian\n\nJosip Kovacev was born in 1982 and comes from a small seaside town on the Dalmatian coast not far from Split. From an early age the sea captivated him and his youth was spent swimming, diving, fishing and sailing with his grandfather. He experienced sailing for the first time as a teenage boy and loved it so much that he decided to obtain his skipper license, YM100 and ISAF Offshore certificates. Being a native of the Adriatic Sea he knows it’s coastline and many islands perfectly and is eager to share the Dalmatian culture and heritage with you. You will experience many hidden pearls of the Adriatic with him as your Captain aboard yacht. Josip is outgoing, positive, and really enjoys getting to know new people. He is a responsible, fun, social, and truly loves what he does."},{"name":"Lucija Grabovac","avatar":"/media/media::image::a::vessel::d5cbfbac-fe8c-11ed-889f-43d4bb723744::assets::1d836630-fdc5-11ef-89e7-cf6602a7a27b/{imageVariant}","role":"Captain","bio":"Croatian\n\nShe comes from a family with a restaurant background, so hospitality has been her lifelong career. She's incredibly sociable and friendly, known for her reliability, honesty, and self-motivation. With an optimistic outlook on life, she always seeks the bright side of any situation. She thrives on working with people and embraces adventure and open-mindedness, which is why she loves working on boats.\n\nFor her, working and traveling offer opportunities to meet new people, explore diverse cultures, and broaden her worldview. Ultimately, it's a chance for her to deepen her self-understanding and personal growth."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1820000,"displayCurrency":"EUR","displayPrice":1820000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2890000,"displayCurrency":"EUR","displayPrice":2890000,"unit":"WEEK"},"pricin