ets::c138e540-efc2-11ef-b243-11bf94df7973/{imageVariant}","/media/media::image::a::vessel::073e0a20-42a8-11ef-8a52-8b68dcf4dfb7::assets::c13bcb70-efc2-11ef-a0ce-f7a9fd243b66/{imageVariant}","/media/media::image::a::vessel::073e0a20-42a8-11ef-8a52-8b68dcf4dfb7::assets::c139f6b0-efc2-11ef-a0ce-f7a9fd243b66/{imageVariant}"],"make":"Sirena Yachts","model":"Sirena 88","maxCrew":4,"sleeps":8,"basePort":{"uri":"a::place::f8cee81e-b3ed-11ed-8716-325096b39f47","name":"Miami","coordinates":{"latitude":25.7618435,"longitude":-80.19120085},"country":"United States"},"builtYear":2021,"architect":"","interiorDesigner":"","refitYear":0,"topSpeed":16,"cruiseSpeed":9,"fuelCapacity":0,"cabinLayout":[{"label":"Master Suite","value":"1"},{"label":"Queen Cabins","value":"2"},{"label":"Twin Cabin","value":"1"}],"cabins":4,"bathrooms":0,"length":26.8,"beam":7,"draft":1.8,"hullType":"","hullConstruction":"","tonnage":0,"superStructure":[],"engines":"2 x MAN 1550 2 x Kohler","amenities":[{"label":"Jacuzzi"},{"label":"Lounge area"},{"label":"Wet bar"},{"label":"Beach club"}],"toys":[],"entertainment":[],"tenders":[]},"crew":[{"name":"Nick Burnett","avatar":"/media/media::image::c::7580644256::vessel::073e0a20-42a8-11ef-8a52-8b68dcf4dfb7::assets::6c719200-c5ff-11f0-9bc6-1f1fcf162560/{imageVariant}","role":"Captain","bio":"USA\n\nCaptain Nicholas Burnett is an experienced yacht captain based in Miami Beach, Florida, with over 20 years in the yachting industry. Holding qualifications including a Master 200 Ton license and certifications in safety, vessel operations, and First Aid, he brings extensive knowledge and leadership to every cruise.\n\nThroughout his career, Nicholas has worked on many yachts such as the Lazzara 26m, San Lorenzo 29m, and Princess 72’, cruising extensively along the U.S. East and West Coasts, the Bahamas, and the Caribbean. With over 400 days at sea in recent years, he is a seasoned guide, sharing his expertise on local regions to enhance guests' experiences.\nA passionate explorer and sports enthusiast, Nicholas fosters a welcoming and collaborative atmosphere aboard, ensuring every journey is both safe and enjoyable. He is dedicated to bringing yacht owners’ dreams to life while continuing to expand his skills and knowledge.\n"},{"name":"David Almeyda","avatar":"/media/media::image::c::7580644256::vessel::073e0a20-42a8-11ef-8a52-8b68dcf4dfb7::assets::79d8d070-c5ff-11f0-9bc6-1f1fcf162560/{imageVariant}","role":"Captain","bio":"Cuban/USA\n\nDavid combines years of maritime experience with a background in sailing and tourism, making him a valuable asset to SAINTS Charter program. A former sailing athlete, he excels in technical skills, teamwork, and leadership. With a degree in Tourism from the University of Havana, David enhances client satisfaction by delivering seamless and memorable yacht charter experiences."},{"name":"Yadira Badillo","avatar":"/media/media::image::c::7580644256::vessel::073e0a20-42a8-11ef-8a52-8b68dcf4dfb7::assets::1aa3fde0-c600-11f0-9bc6-1f1fcf162560/{imageVariant}","role":"Captain","bio":"American\n\nYadira Badillo is a dynamic and adventurous professional with a passion for hospitality and wellness. ​ As a bilingual stewardess with four years of experience in the yachting industry, she has mastered the art of creating unforgettable experiences for guests while ensuring safety and efficiency onboard. ​ From assisting with party planning to handling lines and fenders, Yadira thrives in fast-paced environments and adapts seamlessly to any challenge. ​\nBeyond her yachting expertise, Yadira is a certified cardiac nurse, fitness trainer, and wellness coach, embodying a holistic approach to health and happiness. Her interests in running, meditation, and healthy eating reflect her commitment to living life to the fullest. ​ Whether she's crafting floral arrangements, bartending, or organizing summer travel plans, Yadira brings creativity, energy, and a touch of fun to everything she does. ​\nWhen she's not on the water, Yadira loves traveling, reading, and exploring new cultures."}],"pricing":{"weekPricingFrom":{"currency":"USD","price":8500000,"displayCurrency":"USD","displayPrice":8500000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":9600000,"displayCurrency":"USD","displayPrice":9600000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer/Winter: Caribbean & Florida - Low Season","effectiveDates":[{"from":"2026-05-01T00:00:00.000Z","to":"2026-12-14T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-12-14T23:59:59.999Z"},{"from":"2028-05-01T00:00:00.000Z","to":"2028-12-14T23:59:59.999Z"}],"pricing":{"currency":"USD","charterFee":8500000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":8500000,"amount":8500000,"conditions":"VAT & APA Excluded"}],"total":8500000,"subTotal":8500000,"totalTax":0},"inclusionZones":[{"label":"Bahamas","type":"Sovereign country","category":["North America","Caribbean","Bahamas"],"coordinates":[-75.95477530284326,23.98498842185528],"bbox":[-78.98564453124999,20.937402343749994,-72.747265625,26.940087890624994]},{"label":"Florida, US, United States","type":"State","category":["Florida"],"coordinates":[-83.13354787154184,28.36636070660095],"bbox":[-87.6074378816535,24.542349340056262,-80.04130722193477,31.00167331692866]},{"label":"Turks and Caicos Is.","type":"Dependency","category":["North America","Caribbean","Turks and Caicos Is."],"coordinates":[-71.99766427710652,21.831822973009576],"bbox":[-72.34238281249999,21.751708984375,-71.6369140625,21.951904296875]},{"label":"United States of America","type":"Country","category":["North America","Northern America","United States of America"],"coordinates":[-52.64727122207621,46.84073876556497],"bbox":[-179.1435033839999,18.906117143000074,179.78093509200005,71.41250234600005]},{"label":"United States of America","type":"Geo subunit","category":["North America","Northern America","United States of America"],"coordinates":[