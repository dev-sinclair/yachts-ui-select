ed-84d9-325096b39f47","name":"Sibenik","coordinates":{"latitude":43.73209476,"longitude":15.89377479},"country":"Croatia"},"cruisingCapacity":0,"staticCapacity":0,"builtYear":2007,"architect":"Rene Van Der Velden","interiorDesigner":"","refitYear":2023,"topSpeed":24,"cruiseSpeed":16,"fuelCapacity":0,"cabinLayout":[{"label":" Master Cabin","value":"1"},{"label":"Double Cabin","value":"2"},{"label":"Twin Cabin","value":"2"}],"cabins":5,"bathrooms":5,"decks":0,"length":33.3,"beam":7.1,"draft":1.4,"hullType":"Planing","hullConstruction":"GRP","tonnage":0,"superStructure":["Flybridge"],"engines":"2 x Caterpillar C32 V12 1675 HP  / 2 x 40 kW ONAN ","amenities":[{"label":"Air Conditioning"},{"label":"Jacuzzi"}],"toys":[{"label":"Water ski"},{"label":"Wakeboard"},{"label":"Banana"},{"label":"Floating Toys"},{"label":"SUP","quantity":"2"},{"label":"Snorkeling Equipment"},{"label":"Inflatable Flamingo"},{"label":"Jet Ski available on request"}],"entertainment":["Wifi","Sonos/Bose Hi-End Sound System","TV in saloon","TV in all cabins","Starlink"],"tenders":["6M Ribeye RIB with custom seating, fully rebuilt"]},"crew":[{"name":"Nikola Palada","avatar":"/media/media::image::c::7646090758::vessel::c58489d0-79af-11ef-97cc-fdceee217c4c::assets::9dd30e40-f77e-11f0-8872-c760b2f9657b/{imageVariant}","role":"Captain","bio":"Captain Nikola has spent much of his life on the Adriatic and knows the Croatian coastline as only a local can. With years of experience captaining luxury yachts in Croatia, he enjoys sharing his passion for the sea and the islands with his guests, guiding them to quiet anchorages, charming historic towns, and the region’s most beautiful cruising grounds.\nNikola is especially passionate about Croatian food and wine and loves introducing guests to authentic local flavours, whether onboard or ashore. Thanks to his close relationships throughout the islands, he creates relaxed, genuine experiences that go beyond the usual itinerary, ensuring every voyage feels effortless, personal, and truly memorable."},{"name":"Alex Sevostyanov","avatar":"/media/media::image::a::vessel::c58489d0-79af-11ef-97cc-fdceee217c4c::assets::14f8ca30-8193-11f0-9f7a-ab10d1eb8b4b/{imageVariant}","role":"Captain","bio":"Russian\n\nAlex has been a senior engineer in the yacht industry for eight years. He ensures smooth operations and exceptional experiences on board. His teamwork and adherence to safety regulations make him a valuable addition to any charter."},{"name":"Andy Green","avatar":"/media/media::image::a::vessel::c58489d0-79af-11ef-97cc-fdceee217c4c::assets::27397d20-8193-11f0-9f7a-ab10d1eb8b4b/{imageVariant}","role":"Captain","bio":"Andy, born in the UK, has been in the yacht industry since 1999, navigating both the Mediterranean and the Caribbean. Outside the yacht industry, he enjoys running and cycling. His dedication and diverse skills make him a valuable crew member, ensuring exceptional service and unforgettable journeys."},{"name":"Artem Cherednichenko","avatar":"/media/media::image::a::vessel::c58489d0-79af-11ef-97cc-fdceee217c4c::assets::4a87ba30-8193-11f0-9f7a-ab10d1eb8b4b/{imageVariant}","role":"Captain","bio":"Russian\n\nArtem discovered his passion for cooking in 2011 and gained experience in renowned restaurants and a five-star hotel in Moscow. He specializes in Mediterranean, Middle Eastern, and Georgian cuisine. For years, he has worked as a private chef on luxury yachts, providing tailor-made culinary experiences."},{"name":"Natalia Vinnikova","avatar":"/media/media::image::a::vessel::c58489d0-79af-11ef-97cc-fdceee217c4c::assets::5d08d180-8193-11f0-9f7a-ab10d1eb8b4b/{imageVariant}","role":"Captain","bio":"Ukrainian\n\nNatalia is the Chief Stewardess of the M/Y Dream. She speaks fluent English, Croatian, Russian, and Ukrainian. Her experience includes seven years on cruise ships and 15 years of first-class service on the M/Y Dream. Nataliaʼs dedication and attention to detail make every charter an unforgettable experience."},{"name":"Amy Taylor","avatar":"/media/media::image::a::vessel::c58489d0-79af-11ef-97cc-fdceee217c4c::assets::6a0232f0-8193-11f0-9f7a-ab10d1eb8b4b/{imageVariant}","role":"Captain","bio":"South African\n\nEnergetic and attentive stewardess from South Africa, passionate about creating unforgettable guest experiences. With a strong background in hospitality and hands-on yachting experience, I take pride in delivering exceptional service with a smile. Whether it's attention to detail or anticipating your needs, I'm here to help make your time on board everything you dreamed of — and more."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":6200000,"displayCurrency":"EUR","displayPrice":6200000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":6900000,"displayCurrency":"EUR","displayPrice":6900000,"unit":"WEEK"},"pricingInfo":[{"name":"From 1 January till 23 May, From 3 October till 31 December","effectiveDates":[{"from":"2025-01-01T00:00:00.000Z","to":"2025-05-23T23:59:59.999Z"},{"from":"2025-10-03T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":6200000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":6200000,"amount":6200000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.13}},{"item":"APA","conditions":"","quantity":0.3,"unitPrice":6200000,"amount":1860000}],"total":8866000,"subTotal":8060000,"totalTax":806000},"inclusionZones":[{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910156249996,19.400976562500006,46.534619140625]}],"exclusionZones":[],"petsAllowed":false},{"name":"From 23 May till 6 June, From 19 September till 3 October","effectiveDates":[{"from":"2025-05-23T00:00:00.000Z","to":"2025-06-06T23:59:59.999Z"},{"from":"2025-09-19T00:00:00.000Z","to":"2025-10-03T23:59:59.999Z"}],"pricing":{"curren