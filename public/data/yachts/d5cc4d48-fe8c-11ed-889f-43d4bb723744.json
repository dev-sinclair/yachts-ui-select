c-11ed-889f-43d4bb723744::assets::yachts-101501-tx2xfoBje.jpg/{imageVariant}","/media/media::image::a::vessel::d5cc4d48-fe8c-11ed-889f-43d4bb723744::assets::yachts-101501-HuB8zrdBn.jpg/{imageVariant}","/media/media::image::a::vessel::d5cc4d48-fe8c-11ed-889f-43d4bb723744::assets::yachts-101501-yO6FSarfN_.jpg/{imageVariant}"],"make":"Custom","model":"","maxCrew":4,"sleeps":12,"basePort":{"uri":"a::place::a0201e12-b3ee-11ed-9c67-325096b39f47","name":"Trogir","coordinates":{"latitude":43.51634848,"longitude":16.2502206},"country":"Croatia"},"cruisingCapacity":0,"builtYear":2018,"interiorDesigner":"","refitYear":2025,"topSpeed":11,"cruiseSpeed":9,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"5"},{"label":"Twin Cabin","value":"1"}],"cabins":6,"bathrooms":6,"length":28,"beam":6.8,"draft":3,"hullType":"","hullConstruction":"","tonnage":87,"superStructure":[],"engines":"","amenities":[{"label":"Air Conditioning"},{"label":"Wi-Fi"}],"toys":[{"label":"SUP"},{"label":"Kayak"},{"label":"Snorkeling gear"},{"label":"Fishing equipment"},{"label":"Assorted floats"}],"entertainment":["Wi-Fi"]},"crew":[{"name":"Luka Šabić","avatar":"/media/media::image::c::8196078592::vessel::d5cc4d48-fe8c-11ed-889f-43d4bb723744::assets::6fb45130-3ae7-11f0-a69a-93201342f7d5/{imageVariant}","role":"Captain","bio":"30 years old\nLuka's deep connection and affinity for the sea have led him to work as a captain on a yacht. With over 10 years of experience on charter vessels, Luka brings a wealth of knowledge, skills, and a professional attitude to the Sea Breeze team. He finds working with people to be both challenging and fulfilling, and his calm personality and strong leadership ensure the ultimate safety of the guests, crew, environment, and the vessel. Luka's attention to detail, navigational expertise, and problem solving abilities contribute to delivering a wonderful charter experience.\n"},{"name":"Duje Bašić","avatar":"/media/media::image::c::8196078592::vessel::d5cc4d48-fe8c-11ed-889f-43d4bb723744::assets::845d2a80-3ae7-11f0-a69a-93201342f7d5/{imageVariant}","role":"Captain","bio":"20 years old\nWith a year of experience in bartending on a yacht, Duje is eager to continue working in this environment. He is responsible for maintaining cleanliness on the boat, setting tables for meals, and ensuring the comfort of the guests. Duje is committed to providing exceptional customer service, prioritizing guests' safety, and creating a fun and enjoyable experience for everyone onboard. His excellent communication skills and friendly personality make guests from all backgrounds feel right at home. Duje's attention to detail and hardworking nature ensure a high standard of service onboard."},{"name":"David - Fransecso Komadina","avatar":"/media/media::image::c::8196078592::vessel::d5cc4d48-fe8c-11ed-889f-43d4bb723744::assets::8c166660-3ae7-11f0-a69a-93201342f7d5/{imageVariant}","role":"Captain","bio":"35 years old\nA Mediterranean chef with 14 years of experience, dedicated to crafting exceptional yacht dining experiences. With a deep-rooted passion for culinary artistry, I blend tradition with innovation, creating dishes that celebrate the flavors of the sea and the richness of Mediterranean cuisine. From elegant multi-course tastings to relaxed al fresco feasts, my focus is on seasonality, precision, and flawless execution. Adaptable and detail-oriented, I thrive in the dynamic yachting environment, delivering world-class cuisine that transforms every journey into an unforgettable gastronomic adventure."},{"name":"Antonio Ivanišević","avatar":"/media/media::image::c::8196078592::vessel::d5cc4d48-fe8c-11ed-889f-43d4bb723744::assets::a37956a0-3ae7-11f0-a69a-93201342f7d5/{imageVariant}","role":"Captain","bio":"35 years old\nWith 35 years of age and extensive experience working on yachts, I am dedicated to safety, maintenance, and seamless onboard operations. My expertise includes handling lines, mooring, deck maintenance, and tender operations, while also providing attentive support to guests and crew. Passionate about life on the water, I thrive\non exploring new destinations and connecting with people from diverse cultures. Outside of work, I stay active through sports and travel, always ready to embrace new challenges with energy and enthusiasm."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":2300000,"displayCurrency":"EUR","displayPrice":2300000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":3000000,"displayCurrency":"EUR","displayPrice":3000000,"unit":"WEEK"},"pricingInfo":[{"name":"Low Season (Prior to May 17 and after September 13)","effectiveDates":[{"from":"2024-09-14T00:00:00.000Z","to":"2025-05-16T23:59:59.999Z"},{"from":"2025-09-14T00:00:00.000Z","to":"2026-05-16T23:59:59.999Z"},{"from":"2026-09-14T00:00:00.000Z","to":"2027-05-16T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":2300000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2300000,"amount":2300000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0.13}}],"total":2300000,"subTotal":2300000,"totalTax":299000},"inclusionZones":[{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910156249996,19.400976562500006,46.534619140625]}],"exclusionZones":[],"petsAllowed":false},{"name":"Mid Season (May 17 – June 14 and August 30 – September 13)","effectiveDates":[{"from":"2024-05-17T00:00:00.000Z","to":"2024-06-14T23:59:59.999Z"},{"from":"2025-05-17T00:00:00.000Z","to":"2025-06-14T23:59:59.999Z"},{"from":"2026-05-17T00:00:00.000Z","to":"2026-06-14T23:59:59.999Z"},{"from":"2024-08-30T00:00:00.000Z","to":"2024-09-13T23:59:59.999Z"},{"from":"2025-08-30T00:00:00.000Z","to":"2025-09-13T23:59:59.999Z"},{"from":"2026-08-30T00:00:00.000Z","to":"2026-09-13T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":2600000,"inputAmoun