2},{"label":"Inflatable Flamingo","quantity":""},{"label":"SU Paddle Boards","quantity":3},{"label":"Underwater Camera","quantity":""},{"label":"Swim Platform","quantity":""},{"label":"Light Tackle Fishing Gear","quantity":2},{"label":"Underwater Video","quantity":""},{"label":"Boarding Ladder","quantity":""},{"label":"Water Skis Adult","quantity":""},{"label":"Bocce Ball","quantity":""},{"label":"Beach Games","quantity":""},{"label":"Snorkel Gear","quantity":""},{"label":"Inflatable Parrot","quantity":""},{"label":"Inflatable Unicorn","quantity":""}],"entertainment":["Salon TV","Salon Stereo","iPod/Device Hookups","Onboard Wi-Fi","Fusion Stereo System with speakers","JBL Waterproof speakers"],"tenders":["15ft Tender with 50HP engine"]},"crew":[{"name":"Terrance (Bubba) Gainan","avatar":"/media/media::image::c::7580663817::vessel::d5cca35a-fe8c-11ed-889f-43d4bb723744::assets::f93d7dd0-1484-11ef-ad1e-1d9d230d83da.jpeg/{imageVariant}","role":"Captain","bio":"Captain Bubba and Chef Ally form a dynamic maritime team with deep-rooted connections to the ocean. Bubba's lifelong passion for water sports and his extensive experience as a Charter Captain reflect his commitment to exploration and adventure. Ally’s adventurous spirit, coupled with her culinary prowess, adds vibrancy to their journey. With Bubba's navigational expertise and Ally’s culinary artistry, they continue to craft exceptional maritime experiences.\n\n\nBubba was born in the water. Surfing by the age of five, picking up a fishing pole shortly after and becoming fascinated with the ocean throughout his experiences. He bought a Hobie '16 before he even had his driver's license and was a state champion surfer for six years straight. The love and respect he has for the ocean is indescribably fascinating. He is a lover of life and people are drawn to the good energy he brings along with him wherever he explores.\n\nBubba is an experienced and professional Captain that boasts a wealth of worldwide experience. A waterman at heart that loves to explore and guide the world. Ready for an adventure at all times. Health and Happiness are his two biggest motivators."},{"name":"Ally Hansen","avatar":"/media/media::image::c::7580663817::vessel::d5cca35a-fe8c-11ed-889f-43d4bb723744::assets::7d80be90-1485-11ef-ad1e-1d9d230d83da.jpeg/{imageVariant}","role":"Chef","bio":"“Love City Local”, Ally was born in Maine and raised right here in St John USVI. Ally shares her true passion, love, and knowledge for these islands with each one of her guests. As a certified sailing instructor, she strives to share those same experiences. Becoming a yacht chef has allowed her creative side shine and abilities grow."}],"pricing":{"weekPricingFrom":{"currency":"USD","price":2970000,"displayCurrency":"USD","displayPrice":2970000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":3300000,"displayCurrency":"USD","displayPrice":3300000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer/Winter - Low Season","effectiveDates":[{"from":"2026-05-01T00:00:00.000Z","to":"2026-12-14T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-12-14T23:59:59.999Z"},{"from":"2028-05-01T00:00:00.000Z","to":"2028-12-14T23:59:59.999Z"}],"pricing":{"currency":"USD","unit":"WEEK","inputAmountTaxed":"EXCLUSIVE","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2970000,"amount":2970000,"conditions":"VAT & APA Excluded"}],"subTotal":2970000,"totalTax":0,"total":2970000,"note":"","charterFee":2970000},"inclusionZones":[{"label":"British Virgin Is.","type":"Dependency","category":["North America","Caribbean","British Virgin Is."],"coordinates":[-64.45080373172777,18.568736231458896],"bbox":[-64.69511718749999,18.399121093749997,-64.273583984375,18.752685546875]},{"label":"U.S. Virgin Is.","type":"Dependency","category":["North America","Caribbean","U.S. Virgin Is."],"coordinates":[-64.79221690684143,18.050874527948764],"bbox":[-65.0236328125,17.701708984375003,-64.58046875,18.385205078124997]},{"label":"Anguilla"