edia/media::image::c::8344947358::vessel::d5cc4f43-fe8c-11ed-889f-43d4bb723744::assets::aa555020-a036-11ee-a7ac-d7be8742705d.jpeg/{imageVariant}","/media/media::image::c::8344947358::vessel::d5cc4f43-fe8c-11ed-889f-43d4bb723744::assets::aa55c550-a036-11ee-a7ac-d7be8742705d.jpeg/{imageVariant}","/media/media::image::c::8344947358::vessel::d5cc4f43-fe8c-11ed-889f-43d4bb723744::assets::aa561370-a036-11ee-a7ac-d7be8742705d.jpeg/{imageVariant}"],"make":"Canados","model":"","maxCrew":3,"sleeps":10,"basePort":{"uri":"a::place::5e595eb8-b3ed-11ed-be02-325096b39f47","name":"Athens","coordinates":{"latitude":37.986174,"longitude":23.7268443},"country":"Greece"},"builtYear":2004,"architect":"","interiorDesigner":"","refitYear":2022,"topSpeed":28,"cruiseSpeed":23,"fuelCapacity":"","cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Double Cabin","value":"1"},{"label":"Twin Cabin","value":"1"}],"cabins":4,"bathrooms":4,"decks":"","length":22.8,"beam":5.81,"draft":2.72,"hullType":"","hullConstruction":"","tonnage":"","superStructure":[],"engines":"2 x 1300hp MAN","amenities":[{"label":"Bimini","quantity":1},{"label":"Sunpads","quantity":2},{"label":"Sundeck","quantity":1},{"label":"Generator","quantity":2},{"label":"Audio visual equipment","quantity":1}],"toys":[{"label":"Explorer K2 Kayak (2 pax)","quantity":1},{"label":"Stand Up Paddle Boards","quantity":2},{"label":" Inflatable Armchair (1 pax)","quantity":1},{"label":"Donut Tubes (1 x one seat & 1 x two seats)","quantity":2},{"label":"Adult Water skis","quantity":1},{"label":"Child Water skis","quantity":1},{"label":"Various air mattresses","quantity":1},{"label":"Snorkeling equipment (6 x masks & 4 x full-face masks, flippers)","quantity":1}],"entertainment":["Audio visual equipment"],"tenders":["1 x Avon 380DL Tender with Yamaha 4 stroke 50hp outboard engine"]},"crew":[{"name":"Nikolaos Gardikis","avatar":"/media/media::image::c::8344947358::vessel::d5cc4f43-fe8c-11ed-889f-43d4bb723744::assets::2d365050-a811-11f0-b12f-5387bd7c75ba/{imageVariant}","role":"Captain","bio":"Captain Nikolaos was born in Greece in 1976 and has two children. He has been professional Captain on private and charter yachts since 1994. As he has spent almost 20 years at sea, he will take guests to the most beautiful islands and coves with safety. Captain Nikolaos has also sailed in Mediterranean (Spain, France, Italy, Croatia, and Turkey) as he was transferring yachts for several yacht owners and agencies. He is also a teacher in offshore sailing, and he is coaching teams for sailing races. In his free time, he enjoys swimming. Captain Nikolaos is hard-working, professional and has excellent communication and social skills. He speaks Greek, English and he can also communicate in French."},{"name":"Efrosini (Soula) Koraka","avatar":"/media/media::image::c::8344947358::vessel::d5cc4f43-fe8c-11ed-889f-43d4bb723744::assets::f50134a0-a812-11f0-b12f-5387bd7c75ba/{imageVariant}","role":"Captain","bio":"Soula was born in 1968 and has been working in the yachting industry for the last ten years. Her previous experience onboard motor yachts was onboard M/Y MARY. This is her third year onboard M/Y GORGEOUS. Soula always aims to the highest possible service provision standards for the guests’ delight. She loves to prepare delicious Mediterranean dishes with fresh ingredients. Soula is friendly and has a great passion for her job. When not working, she enjoys cooking and spending time with her two children. She speaks Greek and English."},{"name":"Sackil Kayser","avatar":"/media/media::image::c::8344947358::vessel::d5cc4f43-fe8c-11ed-889f-43d4bb723744::assets::33c81140-a813-11f0-b12f-5387bd7c75ba/{imageVariant}","role":"Captain","bio":"Sackil was born in Bangladesh in 1977. He has worked for more than 10 years in charter and private yachts in Spain and Greece. In his free time, he loves playing football. Sackil is always willing, discreet, polite and eager to help the guests. He speaks Greek and English."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":2500000,"displayCurrency":"EUR","displayPrice":2500000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2800000,"displayCurrency":"EUR","displayPrice":2800000,"unit":"WEEK"},"pricingInfo":[{"name":"High season (July - August)","effectiveDates":[{"from":"2025-07-01T00:00:00.000Z","to":"2025-08-31T23:59:59.999Z"},{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","unit":"WEEK","inputAmountTaxed":"NONE","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2800000,"amount":2800000,"conditions":"High season"},{"item":"APA","quantity":0.35,"unitPrice":980000,"amount":343000},{"item":"VAT","conditions":"","quantity":0.065,"unitPrice":336000,"amount":21840}],"subTotal":3164840,"totalTax":0,"total":3164840,"note":"","charterFee":2800000},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]}],"exclusionZones":[],"petsAllowed":false},{"name":"Low season (All other months)","effectiveDates":[{"from":"2025-01-01T00:00:00.000Z","to":"2025-06-30T23:59:59.999Z"},{"from":"2026-01-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2025-09-01T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","unit":"WEEK","inputAmountTaxed":"NONE","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2500000,"amount":2500000,"conditions":"Low season"},{"item":"APA","quantity":0.35,"unitPrice":875000,"amount":306250},{"item":"VAT","conditions":"","quantity":0.065,"un