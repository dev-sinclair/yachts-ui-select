":"Greece"},"cruisingCapacity":8,"staticCapacity":12,"builtYear":2026,"architect":"Aquila","interiorDesigner":"J&J Design","refitYear":0,"topSpeed":24,"cruiseSpeed":16,"fuelCapacity":250,"cabinLayout":[{"label":"King Cabin","value":"1"},{"label":"Queen Cabins","value":"3"}],"cabins":4,"bathrooms":4,"decks":2,"length":16.45,"beam":7.62,"draft":1.22,"engines":"2 x 480 Volvo D6 ","amenities":[{"label":"Air Conditioning"},{"label":"Deck Shower"},{"label":"Bimini"},{"label":"BBQ"},{"label":"Generator"},{"label":"Ice Maker"},{"label":"Inverter"},{"label":"Water Maker"}],"toys":[{"label":"Dinghy (6pax)","quantity":"1"},{"label":"Water ski","quantity":"1"},{"label":"Paddleboards","quantity":"2"},{"label":"Snorkeling gear","quantity":"8"},{"label":"Noodles","quantity":"8"},{"label":"Fishing gear","quantity":"1"},{"label":"Floating mat","quantity":"1"},{"label":"Sea scooters","quantity":"2"}],"entertainment":["Salon TV","Salon Stereo","Sat TV","Onboard WIFI","Board Games","Backgammon","Monopoly","Chess"],"tenders":["Aquila 14 Cat RIB Sport 40 hp Mercury outboard"]},"crew":[{"name":"Antonis ampetis","avatar":"/media/media::image::c::15406789740::vessel::1fef2ad0-01a7-11f1-9813-c983860a136e::assets::03b90040-17a3-11f1-9160-c96d7d051b49/{imageVariant}","role":"Captain","bio":"Antonis Kampetis - An experienced and commercially endorsed RYA/MCA Yachtmaster Offshore (sail & motor), he brings over 15 years of professional yachting experience across the Mediterranean and Caribbean. Having captained in both private and charter operations.\nHe has navigated the Balearics, Malta, Sicily, Tunisia, and Greece, and was present in Barcelona during the America's Cup. With a strong background in yacht maintenance, deliveries, and guest relations, combined with studies in Public Relations & Communication, he is known for his professionalism, calm leadership, and excellent organizational skills. Growing up in Piraeus, the heart of Greek maritime culture, he developed a deep connection to the sea and a natural team-oriented approach to life on board.\n"},{"name":"Maria Thalassinou","avatar":"/media/media::image::c::15406789740::vessel::1fef2ad0-01a7-11f1-9813-c983860a136e::assets::28d451a0-17a2-11f1-9160-c96d7d051b49/{imageVariant}","role":"Captain","bio":"Maria Thalassinou as a yacht chef and deckhand, she has built an impressive culinary career at sea across the Mediterranean, Caribbean, and South Pacific. Having served as Sole Chef, Crew Chef, and Chef/1st Mate on a wide range of motor and sailing yachts, she delivers refined fine-dining cuisine tailored to both charter guests and private owners.\nHer background includes a Master Degree in Fine Dining, pastry training, and sommelier certification, allowing her to create sophisticated menus paired with curated wines, even in the most remote cruising grounds. From the South Pacific during the Oyster World Rally to high-end charters in Greece and the South of France, she combines culinary creativity with strong seamanship, teamwork, and a deep understanding of life at sea.\n"},{"name":"Nikos Marakakis","avatar":"/media/media::image::c::15406789740::vessel::1fef2ad0-01a7-11f1-9813-c983860a136e::assets::23d1f100-17a5-11f1-9160-c96d7d051b49/{imageVariant}","role":"Captain","bio":"A motivated and versatile Deckhand/Steward with a strong background in hospitality and bartending, he combines maritime skills with high-level guest service. He is experienced in docking assistance, line handling, tender operations, deck maintenance, and water sports setup, while also managing full interior duties including housekeeping, provisioning, table service, and onboard cooking.\nWith several years in premium hospitality — including service within the Royal Caribbean Cruise Lines group (Celebrity Cruises) — he brings international standards of safety, service, and professionalism. A former Head Bartender and cocktail menu creator, he adds refined F&B expertise to every yacht environment. Energetic, adaptable, and team-oriented, he is committed to maintaining high standards on deck and delivering exceptional guest experiences onboard.\n"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":2250000,"displayCurrency":"EUR","displayPrice":2250000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2900000,"displayCurrency":"EUR","displayPrice":2900000,"unit":"WEEK"},"pricingInfo":[{"name":"High Season (July - August)","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":2900000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2900000,"amount":2900000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.12}},{"item":"APA","conditions":"","quantity":0.3,"unitPrice":2900000,"amount":870000}],"total":4118000,"subTotal":3770000,"totalTax":348000},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]}],"exclusionZones":[],"petsAllowed":false},{"name":"Mid Season (June & September)","effectiveDates":[{"from":"2026-06-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-06-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2028-06-01T00:00:00.000Z","to":"2028-06-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-30T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-09-30T23:59:59.999Z"},{"from":"2028-09-01T00:00:00.000Z","to":"2028-09-30T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":2600000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2600000,"amount":2600000,"conditions":"VAT & APA Excl