e23fa/{imageVariant}"],"make":"Sunreef Yachts","model":"80 Sunreef Power","maxCrew":5,"sleeps":10,"basePort":{"uri":"a::place::5e595eb8-b3ed-11ed-be02-325096b39f47","name":"Athens","coordinates":{"latitude":37.986174,"longitude":23.7268443},"country":"Greece"},"cruisingCapacity":10,"builtYear":2025,"architect":" Sunreef Yachts","interiorDesigner":"Sunreef Yachts","topSpeed":22,"cruiseSpeed":8,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"Double Cabins","value":"2"},{"label":"Convertible Cabin","value":"1"}],"cabins":4,"bathrooms":4,"length":23.8,"beam":12.2,"draft":1.7,"hullType":"Multi hull","hullConstruction":"Composite","superStructure":["Flybridge"],"engines":"","amenities":[{"label":"Air Conditioning"},{"label":"Deck Jacuzzi"},{"label":"Flybridge"},{"label":"BBQ"},{"label":"Sunpads"},{"label":"Hammock"},{"label":"Hydraulic swim platform"}],"toys":[{"label":"F9 model Seabobs","quantity":"2"},{"label":"Wakeboard"},{"label":"SUP"},{"label":"Snorkeling Gear"},{"label":"Jet Ski Sea-Doo"},{"label":"Towable for 3 people"},{"label":"SiFly eFoil"},{"label":"Kitesurf"}],"entertainment":["Wi-Fi connection"]},"crew":[{"name":"Julien Braconnier","avatar":"/media/media::image::c::9938368400::vessel::0c313760-3a1d-11f0-8892-61970e8f798b::assets::458ea220-c944-11f0-a2d9-53c1fc8182ed/{imageVariant}","role":"Captain","bio":"Julien’s lifelong bond with the sea began in the sheltered coves and bustling harbors of his home, where he first set sail as a young fisherman. The call of the ocean shaped his early years, instilling resilience, adaptability, and a deep respect for the beauty of the ocean.\n\nThough his journey briefly diverged into the world of technology and renewable energy — reflecting his curiosity and drive to innovate — Julien’s heart remained tethered to the sea. Returning to maritime life, he honed his skills through advanced training in safety, anti-piracy, and modern navigation, earning him a Master 500GT and a prestigious role at the Yacht Club de Monaco. There, Julien captained legendary yachts, from classic vessels like Tuiga to cutting-edge motor yachts, before taking on global charters and transoceanic voyages over the course of a distinguished career.\n\nPassionate and endlessly curious, Julien brings a wealth of expertise and an unwavering commitment to the vision of Mattea, uniting sustainability, technology, and elegance. Whether guiding guests through pristine snorkeling spots or navigating uncharted horizons, he ensures every voyage is not only unforgettable but also a step toward a more harmonious relationship with our oceans."},{"name":"To Be Advised","role":"Captain","bio":"To Be Advised"},{"name":"To Be Advised","role":"Captain","bio":"To Be Advised"},{"name":"To Be Advised","role":"Captain","bio":"To Be Advised"},{"name":"To Be Advised","role":"Captain","bio":"To Be Advised"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":8100000,"displayCurrency":"EUR","displayPrice":8100000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":10500000,"displayCurrency":"USD","displayPrice":10500000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer: Mediterranean - High Season","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":9100000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":9100000,"amount":9100000,"conditions":"VAT & APA Excluded"},{"item":"APA","conditions":"","quantity":0.25,"unitPrice":9100000,"amount":2275000}],"total":11375000,"subTotal":11375000,"totalTax":0},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]},{"label":