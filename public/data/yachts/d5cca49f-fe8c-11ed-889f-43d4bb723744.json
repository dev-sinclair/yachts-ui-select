cabinLayout":[{"label":"Master Cabins","value":"2"},{"label":"Double Cabins","value":"2"},{"label":"Twin Cabin","value":"1"}],"cabins":5,"bathrooms":5,"length":28,"beam":6,"draft":2.9,"hullType":"","hullConstruction":"","tonnage":0,"superStructure":[],"engines":"2 x  Iveco Generators 280hp","amenities":[{"label":"Air conditioning"},{"label":"Life Jacket"},{"label":"Fire Extinguisher"},{"label":"Radar"},{"label":"GPS"},{"label":"VHF"},{"label":"AIS"},{"label":"Chartplotter"},{"label":"Autopilot"},{"label":"Wind, Depth & Speed Indicators"},{"label":"Liferaft"}],"toys":[{"label":"Water Ski"},{"label":"Wake Board"},{"label":"Donut"},{"label":"Jet-Ski"},{"label":"Subwing"},{"label":"Paddle Board"},{"label":"Canoe"},{"label":"Knee Board"},{"label":"Games"}],"entertainment":["TV","DVD","Music System","Wi-Fi"],"tenders":["90 Hp Tender"]},"crew":[{"name":"Sinan Baydar","avatar":"/media/media::image::a::vessel::d5cca49f-fe8c-11ed-889f-43d4bb723744::assets::c3b461a0-8e28-11f0-bcab-d985cb3d1cf0/{imageVariant}","role":"Captain","bio":"Turkish\n\nSinan is 25 years old and he is holding A Class Captain's Diploma (Yacht Captain). He has been working for 6 years with\nthe quality yachts as stewardess and deck hand before became the captain and he came from the kitchen of that sector.\nHe also holds Certificates in First Aid and he is an expert in several Survival Techniques, counting many years of experience in the yachting industry. He is very professional and expreinced one with the sailing on board. Captain Sinan will take good care of the guests, being a hardworking and responsible person. The lucky guests will surely enjoy their cruise in the hands of Cpt. Sinan , as they will visit truly amazing destinations with turquoise waters. In his free time, he likes travelling with his family. Speaks Turkish and English.\n"},{"name":"Ufukhan Ufuk","avatar":"/media/media::image::a::vessel::d5cca49f-fe8c-11ed-889f-43d4bb723744::assets::d881d9f0-8e28-11f0-bcab-d985cb3d1cf0/{imageVariant}","role":"Captain","bio":"Turkish\n\nUfukhan 23 is years old and He has all certificates about the kitchen and he is very well in the all various of the kitchens.\nHe has been worked with the high quality restaurants before , and the few luxury yachts and now he will prepare for the our guests delicious dishes of the Mediterranean cuisine, using the freshest ingredients and giving great attention to each detail on the presentation too. He has also some special recipes about the some different cuisine all over the worlds. ufukhan has a pleasant character with a genuine smile on his face that will make the guests feel very comfortable onboard. In his spare time, he likes watching movies and spending time with his friends. He speaks Turkish and middle level English. "},{"name":"Ferdi Tekin","avatar":"/media/media::image::a::vessel::d5cca49f-fe8c-11ed-889f-43d4bb723744::assets::ec53b430-8e28-11f0-bcab-d985cb3d1cf0/{imageVariant}","role":"Captain","bio":"Turkish\n\nFerdi is 35 years old and holds a sailor diploma and he also holds Certificates in first aid and he is an expert in several survival techniques, counting many years of experience in the yachting industry. He has been working onboard luxury\nmotor yachts for the last 15 years with great enthusiasm and passion for his job. Being a very sportive person himself, he will keep the guests active during their charter, helping them with all kind of water toys that are available onboard. He is a very smily person with a gentle character, always trying to assist on everything needed. When not working, Ferdi enjoys reading book and swimming. Speaks Turkish and mideum level English \n"},{"name":"Duru Deniz Urucu","avatar":"/media/media::image::a::vessel::d5cca49f-fe8c-11ed-889f-43d4bb723744::assets::04239710-8e29-11f0-bcab-d985cb3d1cf0/{imageVariant}","role":"Captain","bio":"Turkish\n\nDuru is 22 years old and she has been working for 5 years with the quality yachts as stewardess and deck hand. She is graduated from Seamen high scholl in Bodrum. She is looking forward to welcoming the guests onboard with his wonderful smile, applying his excellent organisational skills and offering the best service. Duru will try to create for the guests an unforgettable cruising experience with her team! In his free time, he likes to watch movie and reading books. Speaks Turkish and and middle level English. "}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1470000,"displayCurrency":"EUR","displayPrice":1470000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2765000,"displayCurrency":"EUR","displayPrice":2765000,"unit":"WEEK"},"pricingInfo":[{"name":"May & October","effectiveDates":[{"from":"2025-05-01T00:00:00.000Z","to":"2025-05-31T23:59:59.999Z"},{"from":"2026-05-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-05-31T23:59:59.999Z"},{"from":"2025-10-01T00:00:00.000Z","to":"2025-10-31T23:59:59.999Z"},{"from":"2026-10-01T00:00:00.000Z","to":"2026-10-31T23:59:59.999Z"},{"from":"2027-10-01T00:00:00.000Z","to":"2027-10-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1470000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1470000,"amount":1470000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.2}},{"item":"APA","conditions":"","quantity":0.3,"unitPrice":1470000,"amount":441000}],"total":2205000,"subTotal":1911000,"totalTax":294000},"inclusionZones":[{"label":"Turkey","type":"Sovereign country","category":["Asia","Western Asia","Turkey"],"coordinates":[35.10531997715448,39.093802942376584],"bbox":[25.6689453125,35.831445312499994,44.81718750000002,42.09326171875]}],"exclusionZones":[],"petsAllowed":false},{"name":"June","effectiveDates":[{"from":"2025-06-01T00:00:00.000Z","to":"2025-06-30T23:59:59.999Z"},{"from":"2026-06-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-06-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"}],"