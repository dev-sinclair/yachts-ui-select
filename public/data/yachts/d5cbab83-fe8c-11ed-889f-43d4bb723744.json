:vessel::d5cbab83-fe8c-11ed-889f-43d4bb723744::assets::b39587c0-b0c2-11ef-9532-7b43d93aab0a/{imageVariant}","/media/media::image::c::8164602117::vessel::d5cbab83-fe8c-11ed-889f-43d4bb723744::assets::b35d39b0-b0c2-11ef-9531-7b43d93aab0a/{imageVariant}","/media/media::image::c::8164602117::vessel::d5cbab83-fe8c-11ed-889f-43d4bb723744::assets::b3920550-b0c2-11ef-9531-7b43d93aab0a/{imageVariant}","/media/media::image::c::8164602117::vessel::d5cbab83-fe8c-11ed-889f-43d4bb723744::assets::b359b740-b0c2-11ef-9531-7b43d93aab0a/{imageVariant}","/media/media::image::c::8164602117::vessel::d5cbab83-fe8c-11ed-889f-43d4bb723744::assets::b3729670-b0c2-11ef-9531-7b43d93aab0a/{imageVariant}","/media/media::image::c::8164602117::vessel::d5cbab83-fe8c-11ed-889f-43d4bb723744::assets::b37d1dc0-b0c2-11ef-9531-7b43d93aab0a/{imageVariant}"],"make":"Aegean Builders","model":"Custom","maxCrew":4,"sleeps":8,"basePort":{"uri":"a::place::a0201e12-b3ee-11ed-9c67-325096b39f47","name":"Trogir","coordinates":{"latitude":43.51634848,"longitude":16.2502206},"country":"Croatia"},"cruisingCapacity":8,"builtYear":2004,"architect":"","interiorDesigner":"","refitYear":2022,"topSpeed":9,"cruiseSpeed":8,"fuelCapacity":"","cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"Double Cabin","value":"3"}],"cabins":4,"bathrooms":4,"decks":2,"length":29.8,"beam":6.5,"draft":2.9,"hullType":"","hullConstruction":"","tonnage":113,"superStructure":["Wood (mahogany)"],"engines":"2 x IVECO 200 HP","amenities":[{"label":"Sundeck"},{"label":"Sunbeds"},{"label":"Air conditioning"},{"label":"Wi-Fi"}],"toys":[{"label":"Jetski"},{"label":"Sea Scooter"},{"label":"Waterskis"},{"label":"Tube ride"},{"label":"Paddle board"},{"label":"Canoe"},{"label":"Snorkeling gear"},{"label":"Fishing Equipment"},{"label":"Board games"}],"entertainment":["PlayStation","Wi-Fi"]},"crew":[{"name":"Tomislav Križanović","avatar":"/media/media::image::c::8164602117::vessel::d5cbab83-fe8c-11ed-889f-43d4bb723744::assets::f2bbd460-b0c0-11ef-9f0d-0b4bdc90a664/{imageVariant}","role":"Captain","bio":"Tomislav grew up on the Dalmatian coast, surrounded by the stunning beauty of the Adriatic Sea. He began his maritime career at the age of 18, working for 4 years on cargo ships and 9 years on the world's largest cruise ships for RCCL. His impressive experience also includes serving on a 60-meter mega yacht, a 108-meter superyacht, and with the ultra-luxury cruise line Ritz Carlton Yacht Collection. Tomislav holds the highest maritime license, Master Mariner Unlimited, and has sailed in all regions of the world except Australia. As the Captain of a sailing yacht, he takes great pride in providing his guests with unforgettable experiences on the water. Whether it’s exploring hidden coves or swimming in crystal-clear waters, Tomislav, fluent in both English and Croatian, ensures that every voyage is a truly memorable adventure."},{"name":"Neno Božiković","avatar":"/media/media::image::c::8164602117::vessel::d5cbab83-fe8c-11ed-889f-43d4bb723744::assets::122bece0-b0c1-11ef-a108-1160a2c9a19d/{imageVariant}","role":"Chef","bio":"Meet our esteemed chef, Dalibor, whose expertise spans the globe. With a rich background as Private Chef at the Egyptian, Argentinian, and Angolan Embassys and regular engagements around Europe and hotels such as Hyatt Regency, our chef brings a wealth of international flavors. He's especially passionate about crafting Serbian cuisine with a modern twist, which he is regularly invited to showcase in cities like Cannes, Paris, and Moscow. A published author of \"Encyclopedia of Taste\" and a member of \"Chefs for Life,\" a solidarity group comprising top-tier Chefs, Pastry Chefs, and Master Bakers, has orchestrated captivating humanitarian evenings since 2019."},{"name":"Margita Perišić","avatar":"/media/media::image::c::8164602117::vessel::d5cbab83-fe8c-11ed-889f-43d4bb723744::assets::51d2c940-b0c1-11ef-a9cf-35e7ed127e52/{imageVariant}","role":"Captain","bio":"Margita Perišić brings a wealth of hospitality experience from her years in the tourism sector to her role as a Yacht Stewardess. With a background in management of tourism and economic studies, Margita is well-versed in providing exceptional guest service, and communication. Her attention to detail, organization skills, and proficiency in English and Croatian, as well as basic Italian ensure seamless interactions with guests from diverse backgrounds. Margita's dedication to creating unforgettable experiences and her adeptness in wine and cuisine service make her a valuable asset to any yacht crew seeking to deliver top-notch service."},{"name":"Mislav Križanović","avatar":"/media/media::image::c::8164602117::vessel::d5cbab83-fe8c-11ed-889f-43d4bb723744::assets::73e3a450-b0c1-11ef-aa77-e1c913ff6402/{imageVariant}","role":"Captain","bio":"Mislav is a dedicated sailor with extensive experience. Armed with certifications including EOOW over 750kW STCW III/1 and UK CEC EOOW over 750kW. Mislav possesses a robust technical acumen and strong leadership and problem-solving skills from his time serving on commerce ships, oil tankers, and emergency response and rescue vessels. Fluent in Croatian and English, Mislav is poised to excel in any challenging role within the maritime industry."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1850000,"displayCurrency":"EUR","displayPrice":1850000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2560000,"displayCurrency":"EUR","displayPrice":2560000,"unit":"WEEK"},"pricingInfo":[{"name":"SEASON A (18 April 2026 till 30 May 2026) & SEASON G (26 September 2026 till 31 October 2026)","effectiveDates":[{"from":"2025-06-07T00:00:00.000Z","to":"2026-05-30T23:59:59.999Z"},{"from":"2025-11-01T00:00:00.000Z","to":"2026-10-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","unit":"WEEK","inputAmountTaxed":"INCLUSIVE","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1850000,"amount":1850000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0.13}}],