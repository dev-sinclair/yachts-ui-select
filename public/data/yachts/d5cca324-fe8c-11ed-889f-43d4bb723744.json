8402bf1b41/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cca324-fe8c-11ed-889f-43d4bb723744::assets::ebac6e20-622a-11f0-96b7-2b8402bf1b41/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cca324-fe8c-11ed-889f-43d4bb723744::assets::ebacbc40-622a-11f0-96b7-2b8402bf1b41/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cca324-fe8c-11ed-889f-43d4bb723744::assets::ebabaad0-622a-11f0-96b6-2b8402bf1b41/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cca324-fe8c-11ed-889f-43d4bb723744::assets::ebace350-622a-11f0-96b7-2b8402bf1b41/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cca324-fe8c-11ed-889f-43d4bb723744::assets::eba912c0-622a-11f0-96b3-2b8402bf1b41/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cca324-fe8c-11ed-889f-43d4bb723744::assets::ebace351-622a-11f0-96b7-2b8402bf1b41/{imageVariant}"],"make":"Ferretti","model":"","maxCrew":5,"sleeps":10,"basePort":{"uri":"a::place::738f24c0-dada-11ed-befa-d7914edd5e3a","name":"Marina Kastela","coordinates":{"latitude":43.54601254691691,"longitude":16.40283517494042},"country":"Croatia"},"cruisingCapacity":"","staticCapacity":"","builtYear":2005,"architect":"CRN Spa","interiorDesigner":"","refitYear":2023,"topSpeed":18.5,"cruiseSpeed":13,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"3"},{"label":"Convertible Cabins","value":"2"}],"cabins":5,"bathrooms":5,"decks":"","length":30.95,"beam":7,"draft":2.6,"hullType":"Semi-displacement","hullConstruction":"GRP","tonnage":"","superStructure":["Flybridge"],"engines":"2 x 1360 BHP MAN V12","amenities":[{"label":"Air conditioning"},{"label":"Stabilisers at anchor"},{"label":"Stabilisers underway"},{"label":"Sunbathing area"},{"label":"Generator"}],"toys":[{"label":"Jet ski Yamaha waverunner","quantity":1},{"label":"Seabob F5","quantity":1},{"label":"SUP","quantity":2},{"label":"Wakeboard"},{"label":"Yachtbeach Pavilion 4.10 Beachclub Setup - new 2025"},{"label":"Couch for 3 person"},{"label":"Snorkeling gear"},{"label":"Freediving gear"},{"label":"Fishing gear (basic)"}],"entertainment":["Wi-Fi"],"tenders":["Tender Sacs 700 Sport 7m","SACS Strider 10 (available on request, for additional surcharge)"]},"crew":[{"name":"Matko Polic","avatar":"/media/media::image::a::vessel::d5cca324-fe8c-11ed-889f-43d4bb723744::assets::de0733c0-0f11-11f0-8273-c924f3b34906/{imageVariant}","role":"Captain","bio":"Croatian\n\nMatko grew up in Split and graduated from the Faculty of Maritime Studies. His love for the sea began at a very young age, and over the past 27 years, he has built a successful career in yachting. Known for his professionalism and in-depth knowledge of the Croatian coastline, Matko is a respected figure in the industry. He looks forward to taking you on an unforgettable cruise aboard M/Y Klobuk, where he will reveal the Adriatic's best-hidden gems. When not on duty, you can find Matko enjoying trail running or sailing.\n\n"},{"name":"Melany Poljski","avatar":"/media/media::image::c::7646090758::vessel::d5cca324-fe8c-11ed-889f-43d4bb723744::assets::d4616720-16de-11f1-82a0-1dff08aee827/{imageVariant}","role":"Captain","bio":"Melany is a dedicated and experienced yacht chef from Croatia with over seven years of experience in the nautical, gastronomy, hospitality, and leisure industries. Since 2019, she has been working aboard motor yachts and catamarans up to 85 meters, delivering high-end culinary service throughout busy charter seasons in both the Mediterranean and Caribbean.\nIn addition to her culinary expertise and education, Melany further refined her pastry skills at Le Cordon Bleu Paris (La Viennoiserie Traditionnelle) and is currently continuing her professional development at Ashburton Cookery School, demonstrating her strong ambition to continuously grow and progress within the superyacht industry."},{"name":"Špiro Orošnjak","avatar":"/media/media::image::c::7646090758::vessel::d5cca324-fe8c-11ed-889f-43d4bb723744::assets::105a2fa0-16df-11f1-82a0-1dff08aee827/{imageVariant}","role":"Captain","bio":"Spiro is a true sea and yacht enthusiast with over ten years of experience in the nautical industry, having worked in various onboard positions throughout his career. He holds a University Bachelor’s Degree in Computer Engineering from the Faculty of Electrical Engineering, Mechanical Engineering and Naval Architecture in Split, which has provided him with strong technical expertise, particularly in electrotechnics and mechanics.\nHe began his maritime career as a seaman (2009–2014) and has since continued to build his professional path at sea. Since 2021, he has been working as a Main Engineer/Deckhand on yachts ranging from 35 to 46 meters, gaining valuable experience in both deck and engine room operations.\nSpiro is passionate about fishing and diving, and he brings that same enthusiasm and dedication to his work. He is reliable, communicative, and always eager to take on new challenges while continuously expanding his knowledge and skills."},{"name":"Jure Utrobičić","avatar":"/media/media::image::c::7646090758::vessel::d5cca324-fe8c-11ed-889f-43d4bb723744::assets::b7cb7b40-16df-11f1-82a0-1dff08aee827/{imageVariant}","role":"Captain","bio":"Jure is an experienced deckhand with over five years of service on offshore vessels and private yachts, bringing solid hands-on knowledge of deck operations and maintenance. He has worked on yachts ranging from 21m to 42m across the Mediterranean, where he gained valuable experience.\nKnown for his adaptability and positive attitude, he integrates easily into new teams and environments while maintaining a strong work ethic. He is safety-conscious, reliable, and always ready to take on new challenges, continuously striving to expand his skills and learn from experienced leaders in the industry."},{"name":"TBA","role":"Captain","bio":"TBA"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":6600000,"displayCurrency":"EUR","displayPrice":6600000,"unit":"WEE