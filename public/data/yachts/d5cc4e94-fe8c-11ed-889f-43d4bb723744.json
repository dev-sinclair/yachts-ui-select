Variant}","/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::a36e2b10-ab34-11ef-94b9-7de7a5ef81d0/{imageVariant}","/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::a35747b0-ab34-11ef-94b9-7de7a5ef81d0/{imageVariant}","/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::a36a8190-ab34-11ef-94b9-7de7a5ef81d0/{imageVariant}","/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::a358ce50-ab34-11ef-94b9-7de7a5ef81d0/{imageVariant}","/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::a36c2f40-ab34-11ef-86a5-4ff26032474c/{imageVariant}","/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::a3323380-ab34-11ef-94b9-7de7a5ef81d0/{imageVariant}","/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::a36ccb80-ab34-11ef-94b9-7de7a5ef81d0/{imageVariant}"],"make":"Aegean Yachts","model":"","maxCrew":4,"sleeps":10,"cruisingCapacity":0,"builtYear":2013,"architect":"In house Aegean Yachts","interiorDesigner":"","refitYear":2023,"topSpeed":13,"cruiseSpeed":10,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"3"},{"label":"Twin Cabins","value":"2"}],"cabins":5,"bathrooms":5,"decks":"","length":28,"beam":7,"draft":2.2,"hullType":"Displacement","hullConstruction":"Steel","tonnage":0,"superStructure":["Flybridge"],"engines":"2 x YANMAR 700 HP","amenities":[{"label":"Air Conditioning"}],"toys":[{"label":"Jet ski Sea Doo (Rotax)100 HP"},{"label":"Sea Bob"},{"label":"Waterskis"},{"label":"Waterskis (for children)"},{"label":"Kayak"},{"label":"Donut"},{"label":"Banana"},{"label":"Paddle boards","quantity":"2"},{"label":"Snorkelling Gear"}],"entertainment":["Wi-Fi"],"tenders":["Highfield DL640 specially &  HONDA BF 150 HP",""]},"crew":[{"name":"Petar Bebic","avatar":"/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::51622570-0eed-11f0-86b6-31c6bf6c29d8/{imageVariant}","role":"Captain","bio":"Nationality: Croatian\n\nPetar was born in Split, Croatia, where he spent his childhood sailing on the Adriatic Sea. After completing his education in Split, he began his career working on motor yachts in 2015. He has served as a deckhand on M/Y Adriatic Jazz (28 m) and as an engine cadet on M/V Cargo carrier “Solin” (198 m). Since 2018, he has been employed on GRACE as both a deckhand and engineer. Petar is very reliable when doing his duties on board and always with a smile. He is committed to a life at sea and is a hard-working and fun person to be around. For the past two years, Petar has been involved in ship management and is set to assume the captaincy of GRACE starting in the 2025 season."},{"name":"Luka Serbo","avatar":"/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::5aeec1c0-0eed-11f0-86b6-31c6bf6c29d8/{imageVariant}","role":"Captain","bio":"Nationality: Croatian\n\nAfter completing his education at a Maritime high school, Luka pursued further studies and acquired all the necessary certifications. He started working as deckhand in 2017 and since then he remained on the same 30m gulet and progress to captain position. Luka has accumulated significant experience aboard sailing gulets and is eager to enhance his skills by transitioning to the motor yacht GRACE. He is known for being communicative, easy-going, and an excellent team player. Luka works closely with his guests to ensure that all their needs and desires are fulfilled."},{"name":"Ivan Borovac","avatar":"/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::953e6e20-0eed-11f0-a405-9f4533e1641f/{imageVariant}","role":"Captain","bio":"Nationality: Croatian\n\nChef Ivan is a talented chef with the last two years spent creating delicious meals on motor yachts. Ivan not only keeps the kitchen spotless and safe but also makes sure every dish is made with the freshest ingredients. He’s great at creating menus that fit the dietary needs and tastes of his guests.\n\nBefore his yacht adventures, Ivan worked in various hotels and restaurants, where he sharpened his skills. He’s especially proud of his Mediterranean, Continental, Vegetarian, and Vegan dishes, and he loves making pastries. When he’s not cooking, you’ll find him swimming or riding his bike, which keeps him energized and ready for his next culinary creation."},{"name":"Petra Buljan","avatar":"/media/media::image::a::vessel::d5cc4e94-fe8c-11ed-889f-43d4bb723744::assets::9e2e0720-0eed-11f0-a405-9f4533e1641f/{imageVariant}","role":"Captain","bio":"Nationality: Croatian\n\nPetra was born in Split. Her four-year work experience as a stewardess has enabled her to become very professional, communicative, hard-working, organized individual. Petra gained many skills in teamwork and working under pressure. She is very friendly and always at the guest's disposal. Her hobby is hiking, fitness, photography. She is fluent in English."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":4400000,"displayCurrency":"EUR","displayPrice":4400000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":4900000,"displayCurrency":"EUR","displayPrice":4900000,"unit":"WEEK"},"pricingInfo":[{"name":"High Season Charter Rate: (July - August)","effectiveDates":[{"from":"2025-07-01T00:00:00.000Z","to":"2025-08-31T23:59:59.999Z"},{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":4900000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":4900000,"amount":4900000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0.13}},{"item":"APA","conditions":"","quantity":0.4,"unitPrice":4900000,"amount":1960000}],"total":7497000,"subTotal":6860000,"totalTax":637000},"inclusionZones":[{"label":"Adriatic Sea","type":"Custom Area","category":["Adriatic Sea"],"coordinates":[16.01030