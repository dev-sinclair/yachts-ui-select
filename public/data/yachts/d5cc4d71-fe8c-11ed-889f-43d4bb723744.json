media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::a8a22a70-777e-11f0-a789-cdf7240ef16e/{imageVariant}"],"make":"Custom","model":"Custom","maxCrew":11,"sleeps":30,"basePort":{"uri":"a::place::27c28dba-b3ee-11ed-9755-325096b39f47","name":"Split","coordinates":{"latitude":43.51359615,"longitude":16.43884676},"country":"Croatia"},"cruisingCapacity":28,"staticCapacity":50,"builtYear":2018,"architect":"Andrija Marasovic","interiorDesigner":"Anja Grubisa & Natasa Grujic","refitYear":2024,"topSpeed":11.5,"cruiseSpeed":8,"fuelCapacity":"","cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"Double Cabin","value":"1"},{"label":"Twin Cabins","value":"2"},{"label":"Convertible Cabins","value":"11"}],"cabins":15,"bathrooms":15,"decks":4,"length":48.9,"beam":8.6,"draft":3,"hullType":"","hullConstruction":"","tonnage":497,"superStructure":["Steel"],"engines":"2x 500 HP Scania","amenities":[{"label":"Air Conditioning"},{"label":"Wi-Fi"},{"label":"Bathing Platform"},{"label":"Movie Theatre"},{"label":"Dance floor"},{"label":"Exercise equipment"},{"label":"Foredeck Seating"},{"label":"Ice maker"},{"label":"Indoor audio system"},{"label":"Deck Jacuzzi"},{"label":"Outdoor audio system"},{"label":"Outdoor Bar"},{"label":"Special diets"},{"label":"Sun Pads"},{"label":"Sun Deck"},{"label":"Sun loungers"},{"label":"TV all cabins"},{"label":"TV master cabin"},{"label":"TV saloon"},{"label":"Bluetooth speakers"}],"toys":[{"label":"Swim platform"},{"label":"Light fishing gear"},{"label":"Jet ski"},{"label":"SeaBobs","quantity":"2"},{"label":"E-Foil"},{"label":"Canoes","quantity":"2"},{"label":"Paddleboards","quantity":"3"},{"label":"Floating platforms"},{"label":"Waterslide"},{"label":"Floaties"},{"label":"Snorkeling gear"}],"entertainment":["Wi-Fi","Movie Theatre","Indoor audio system","Outdoor audio system","TV all cabins","TV master cabin","TV saloon","Bluetooth speakers"]},"crew":[{"name":"Andrija Marasović","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::5cc77380-b0e1-11ef-946d-6d72e7306003/{imageVariant}","role":"Captain","bio":"Professional Background:\nCaptain Andrija is 42 years young and has over 20 years of experience sailing the Adriatic coast. His teacher was his father, who proudly passed down his love and knowledge of the sea.\n\nHe has a degree in Nautical engineering from the Maritime University in Split and is a seasoned entrepreneur. The Cristal is the third boat in his family business, with aspirations of adding others.\n\nPersonal Interests:\nWhen he’s not sailing, he takes pride in upkeeping the Cristal. He enjoys attending town council meetings and sitting as the president of boat owners in Krilo Jesenice. He also enjoys traveling to faraway places.\n\nLanguages Spoken:\nEnglish, Croatian"},{"name":"Petar Bitunjac","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::966a1700-b0e1-11ef-81df-7fd9ad6e489e/{imageVariant}","role":"Chef","bio":"Chef Petar is from Sinj, Croatia. After finishing culinary school, he spent 6 years in Germany cooking at 5-star restaurants. For the past six years, he has been perfecting his culinary skills and creating masterpieces as a Chef on a yacht.\n\nHis love of cooking and attention to detail will surely please all taste buds. His favorite meals to prepare are Croatian specialties with a modern twist. He also loves great steaks and delicious homemade desserts.\n\nLanguages spoken: English, Croatian"},{"name":"Snježana Bego","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::ca69b470-b0e1-11ef-87d7-0f99201db29c/{imageVariant}","role":"Chief Stewardess","bio":"Experienced sous chef with 30 years of hospitality expertise, specializing in desserts and providing significant support to the head chef.\n\nLanguages spoken: English, Italian, Croatian"},{"name":"Boris Gruica","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::eb6c53d0-b0e1-11ef-90d5-63317670b903/{imageVariant}","role":"Captain","bio":"Experienced Waiter with a strong background in hospitality, including 2 years on yachts, 8 years as a Chef de Rang in a 5-star hotel, and 5 years as a manager at Joe's Beach Bar. High school education in culinary arts, certified sommelier, Class Master, and skilled in bartending.\n\nLanguages spoken: English, Croatian"},{"name":"Teo Pajčin","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::0d577e70-b0e2-11ef-b400-85fecd24b1fa/{imageVariant}","role":"Captain","bio":"Waiter with diverse experience, including 1 year in the yacht industry, 3 years in a ski resort in Austria, and 2 years in a beach bar setting. Holder of a college degree in Kinesiology. Detail-oriented and committed to delivering exceptional service.\n\nLanguages spoken: English, Croatian"},{"name":"Nensy Pjanić","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::34005830-b0e2-11ef-b400-85fecd24b1fa/{imageVariant}","role":"Captain","bio":"Experienced hospitality professional with a background in various service roles, including 2 years as a waitress in Split, Croatia, and international experience in Paris and Frankfurt. Skilled in customer service with additional expertise as a bartender and makeup artist. Holder of certifications in Makeup Artistry and Eyebrow Threading. Adaptable, hardworking, and able to quickly adjust to new environments.\n\nLanguages spoken: English, Croatian"},{"name":"Tina Pralija","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::5df2b7a0-b0e2-11ef-b400-85fecd24b1fa/{imageVariant}","role":"Captain","bio":"Dedicated and experienced housekeeper with 4 years of work on yachts and 1 year in a 5-star hotel. Skilled in providing top-notch cleaning services and maintaining high standards of cleanliness and organization.\n\nLanguages spoken: English, Italian, Croatian"},{"name":"Marko Sedlar","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::9b04df60-b0e2-11ef-b400-85fecd24b1fa/{imageVariant}","role":"Captain","bio":"Experienced Chief Mate with 5 years of international navigation experience and 6 years on yachts. Skilled in managing navigation operations, ensuring safety compliance, and leading a team for efficient yacht operations.\n\nLanguages spoken: English, Croatian"},{"name":"Ivan Vrkić","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::e03b87f0-b0e2-11ef-b400-85fecd24b1fa/{imageVariant}","role":"Captain","bio":"Highly experienced Chief Engineer with 12 years of experience on yachts. Skilled in overseeing yacht engine operations, maintenance, and repair. Certified Tender Driver with licenses for 500 BT and Yacht Master 500 BT.\n\nLanguages spoken: English, Croatian"},{"name":"Ivan Maljak","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::f93e4580-b0e2-11ef-b400-85fecd24b1fa/{imageVariant}","role":"Captain","bio":"Junior Deckhand with 2 years of experience in the yachting industry, transitioning from a background in medical technology to pursue a new career at sea. Eager to learn new skills and work in a maritime environment due to a passion for travel and the ocean.\n\nLanguages spoken: English, Italian, Croatian"},{"name":"Ante Lozić","avatar":"/media/media::image::c::8164602117::vessel::d5cc4d71-fe8c-11ed-889f-43d4bb723744::assets::17885490-b0e3-11ef-b400-85fecd24b1fa/{imageVariant}","role":"Captain","bio":"Recent graduate of Maritime High School with a family background in the yacht industry. Eager learner with a keen interest in listening to experienced sailors. Two years of experience working on smaller boats during summer breaks.\n\nLanguages spoken: English, Croatian"}],"pricing":{"weekPricingFrom":{"currency":"EUR",