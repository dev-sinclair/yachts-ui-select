162598::vessel::93319590-7fe6-11ee-84ef-d366ba2abd5b::assets::4e274cc0-858f-11ee-bfb3-fd03bd637d91.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::93319590-7fe6-11ee-84ef-d366ba2abd5b::assets::4ee9d970-858f-11ee-bfb3-fd03bd637d91.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::93319590-7fe6-11ee-84ef-d366ba2abd5b::assets::4fb36b00-858f-11ee-bfb3-fd03bd637d91.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::93319590-7fe6-11ee-84ef-d366ba2abd5b::assets::3ce4a8e0-858f-11ee-bfb3-fd03bd637d91.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::93319590-7fe6-11ee-84ef-d366ba2abd5b::assets::21ee9430-a667-11ee-ae2e-49b5d9817bac.jpeg/{imageVariant}"],"make":"Lagoon-Bénéteau","model":"Lagoon 46","maxCrew":2,"sleeps":12,"basePort":{"uri":"a::place::16e17940-6187-11f0-b716-09fc9d01b6f6","name":"Marina Trogir","coordinates":{"latitude":43.51398901922514,"longitude":16.11026639252227},"country":"Croatia"},"cruisingCapacity":12,"builtYear":2022,"architect":"VPLP Design","interiorDesigner":"Nauta Design","refitYear":2025,"topSpeed":11,"cruiseSpeed":6,"fuelCapacity":1040,"cabinLayout":[{"label":"Double Cabins","value":"4"},{"label":"Single Cabin","value":"1"}],"cabins":4,"bathrooms":4,"length":14.03,"beam":7.96,"draft":1.3,"hullType":"Catamaran","hullConstruction":"GRP","tonnage":16600,"engines":"2 x 57 HP Yanmar","amenities":[{"label":"Air Conditioning In all cabins"},{"label":"Generator "},{"label":"Inverter"},{"label":"Heating in all cabins"},{"label":"Watermaker - desalinator "},{"label":"Flybridge"},{"label":"Teak deck"},{"label":"Coffee machine"},{"label":"Ice maker"},{"label":"Microwave"},{"label":"Kitchen utensils"},{"label":"Refrigerator including freezer","quantity":"3"},{"label":"Underwater lights","quantity":"4"},{"label":"Sprayhood"},{"label":"Cockpit fridge"},{"label":"Bimini top"}],"toys":[{"label":"SEA-DOO underwater scooter","quantity":"2"},{"label":"Stand up paddle ","quantity":"2"},{"label":"Water skis jobe allegre 67\""},{"label":"Jobe Omnia multifunctional water toy"},{"label":"Dinghy "}],"entertainment":["FUSION sound system Fusion RA70N","Wi-Fi Internet 4 LTE"],"tenders":["Dinghy 3.4 m with 20 hp engine"]},"crew":[{"name":"Adam Stobnicki","avatar":"/media/media::image::c::10218162598::vessel::93319590-7fe6-11ee-84ef-d366ba2abd5b::assets::86199060-67b1-11f0-88a7-1530208087fc/{imageVariant}","role":"Captain","bio":"Adam was born in 1988 in Gdansk, Poland where has been sailing since he was a boy. He started to sail when in age of 9 in class Optimist, after Optimist period he sailed in 470 class where he was member of a Croatian National 470 team for a several years and at the end of dinghy sailing he sailed in Laser Class. After his dinghy sailing period he started to work as a skipper and in the same time he was a student on University of Gdansk, Faculty of Economics where he graduated in 2013. Adam holds Certificate of Competency for Yacht Master category A (yacht up to 100 GT) in 2013, STCW VI/1 – Basic Training: Personal Survival Techniques (PST), Personal Safety and Social Responsibilities (PSSR), Fire Prevention and Fire Fighting (FPFF), Elementary First Aid (EFA) in 2017 and HR IV/1 Restricted radio operator’s certificate in 2018. Adam have a lot experiences with Regattas, Luxury charters, his very good skills are high level of responsibility, safeness, efficacy and prompt decision making, systematic and analytical approaches to problem solving as well as good communication skills, flexibility and positive attitude. He is a fluent English speaker. His passions for the sea, nice food and fine wine are easily contagious. He has a calm nature which makes him pleasant to be around and which enables him to keep a cool head to handle any situation that could occur. He is very open for family’s crews and children loves him.\n\nWHAT MAKES HIS HAPPY BESIDE WORK: Beside his passion for sailing and racing he like to go diving. In his free time he like to travel, read a good book, watch a good movie."},{"name":"Kornelia Maj","avatar":"/media/media::image::c::10218162598::vessel::93319590-7fe6-11ee-84ef-d366ba2abd5b::assets::9042e1e0-67b1-11f0-bb8b-dfc9cff9ad23/{imageVariant}","role":"Captain","bio":"Kornelia was born in 1994 in Lebork, Poland where she graduated from Faculty of economics. During the years she grew distinctive enthusiasm for cooking in general, especially Mediterranean cuisine. She is fluent in English, has good knowledge of Spanish and basic of German and Italian language. After abundance of experience working as a hostess on all types of boats (sailing yachts, motor boats and catamarans). She is detailed-oriented, attentive at all times with a willing and helpful manner. Always approachable and cheerful, Kornelia aims to elevate the guest’s experience.\n\nWHAT MAKES HER HAPPY BESIDE WORK: She is a passionate traveller and wherever she goes, she never misses a chance to learn about new cultures, languages or skills. She loves summer and she tries to experience that season 365 days a year!"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":350000,"displayCurrency":"EUR","displayPrice":350000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1350000,"displayCurrency":"EUR","displayPrice":1350000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rate 2025: 06/21/2025 - 08/23/2025","effectiveDates":[{"from":"2025-06-21T00:00:00.000Z","to":"2025-08-23T23:59:59.999Z"},{"from":"2026-06-21T00:00:00.000Z","to":"2026-08-23T23:59:59.999Z"},{"from":"2027-06-21T00:00:00.000Z","to":"2027-08-23T23:59:59.999Z"}],"pricing":{"currency":"EUR","inputAmountTaxed":"INCLUSIVE","subTotal":1650000,"totalTax":175500,"total":1650000,"lineItems":[{"item":"Charter Fee","conditions":"VAT is Inclusive","quantity":1,"unitPrice":1350000,"amount":1350000,"taxRate":{"label":"VAT","value":0.13}},{"item":"Security Deposit","conditions":"","quantity":0,"unitPrice":300000,"amount":0},{"item":"APA","conditions":"","quantity":1,"uni