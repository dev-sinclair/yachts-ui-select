b39f47","name":"George Town","coordinates":{"latitude":23.50696641336832,"longitude":-75.77295400642053},"country":"Bahamas"},"builtYear":2007,"refitYear":2019,"topSpeed":10,"cruiseSpeed":8,"fuelCapacity":360,"cabinLayout":[{"label":"Queen Cabins","value":"3"}],"cabins":3,"bathrooms":3,"length":14.02,"beam":7.92,"draft":1.31,"hullType":"Catamaran","superStructure":[],"engines":" 2 x 40 hp","amenities":[{"label":"Air Conditioning"},{"label":"Cockpit cushions"},{"label":"Sun Awning"},{"label":"Trampoline"},{"label":"Watermaker"},{"label":"Lithium battery bank"},{"label":"Hammock"},{"label":"Deck Shower"},{"label":"Bimini"},{"label":"BBQ"},{"label":"Dine In"},{"label":"Hairdryers"},{"label":"Port Hatches"},{"label":"Generator"},{"label":"Inverter"},{"label":"Ice Maker"},{"label":"Sailing Instructions"},{"label":"Purified drinking water"},{"label":"Re-usable water bottles"}],"toys":[{"label":"Snorkel Gear"},{"label":"Floating Mats"},{"label":"Swim Platform"},{"label":"Boarding Ladder"},{"label":"Beach Games"},{"label":"SU Paddle Boards","quantity":"3"},{"label":"Fishing Gear"},{"label":"Deep Sea Fishing"},{"label":"Underwater Video"},{"label":"Boogie Board"},{"label":"Flotation Noodles","quantity":"6"}],"entertainment":["Salon TV","Salon Stereo","iPod/Device Hookups"],"tenders":["12ft AB inflatable with 25 HP Yamaha outboard"]},"crew":[{"name":"Seth Chase","avatar":"/media/media::image::c::8275378522::vessel::d5cc4e6c-fe8c-11ed-889f-43d4bb723744::assets::41b05610-9f8b-11ee-b85c-256ca1ca5f82.png/{imageVariant}","role":"Captain","bio":"Seth comes from a fast-paced life in NYC but found a new beginning on the waters of the Bahamas and the Florida Keys. He did deliveries on a variety of catamarans, snorkeling, and has spent quite a bit of time sailing in the Bahamas on Destiny lll with Captain Dave Calvert. Captain Seth has been running sunset sailing charters in the Florida Keys, and eventually took up parasailing as captain, with Marissa as one of his first mates for the past few years."},{"name":"Marissa Darrow","avatar":"/media/media::image::c::8275378522::vessel::d5cc4e6c-fe8c-11ed-889f-43d4bb723744::assets::470a1e20-9f8b-11ee-b85c-256ca1ca5f82.png/{imageVariant}","role":"Chef","bio":"Marissa grew up in Islamorada, of the Florida Keys, snorkeling, fishing, and boating her whole life, she has cultivated a passion for nature and living off the sea. Every day now for the last couple of years, they have lived seeking adventure, exploring, and capturing memories for all. From morning snorkeling, to fishing, to breath-taking sunsets and amazing eats throughout, you and yours will never forget your trip with these two!"}],"pricing":{"weekPricingFrom":{"currency":"USD","price":1550000,"displayCurrency":"USD","displayPrice":1550000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":1850000,"displayCurrency":"USD","displayPrice":1850000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer/Winter - Low Season","effectiveDates":[{"from":"2026-05-01T00:00:00.000Z","to":"2026-12-14T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-12-14T23:59:59.999Z"},{"from":"2028-05-01T00:00:00.000Z","to":"2028-12-14T23:59:59.999Z"}],"pricing":{"currency":"USD","charterFee":1550000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1550000,"amount":1550000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.14}}],"total":1767000,"subTotal":1550000,"totalTax":217000.00000000003},"inclusionZones":[{"label":"Florida, US, United States","type":"State","category":["Florida"],"coordinates":[-83.13354787154184,28.36636070660095],"bbox":[-87.6074378816535,24.542349340056262,-80.04130722193477,31.00167331692866]},{"label":"Bahamas","type":"Sovereign country","category":["North America","Caribbean","Bahamas"],"coordinates":[-75.95477530284326,23.98498842185528],"bbox":[-78.98564453124999,20.937402343749994,-72.747265625,26.940087890624994]},{"label":"United States of America",