nt}","/media/media::image::a::vessel::f7365760-3a25-11f0-bfc9-c38d371d38e7::assets::b33c48c0-45f2-11f0-a5c3-c19cf3c3b572/{imageVariant}","/media/media::image::a::vessel::f7365760-3a25-11f0-bfc9-c38d371d38e7::assets::b334ceb0-45f2-11f0-897e-4d47296a31b7/{imageVariant}","/media/media::image::a::vessel::f7365760-3a25-11f0-bfc9-c38d371d38e7::assets::b3387830-45f2-11f0-af14-1d44837ae120/{imageVariant}"],"make":"Sunreef Yachts","model":"Sunreef 70 Power","maxCrew":4,"sleeps":8,"basePort":{"uri":"a::place::03cecaf0-4d93-11ef-897f-8b3f264c9e41","name":"Portisco","coordinates":{"latitude":41.03873516514346,"longitude":9.518687822878418},"country":"Italy"},"cruisingCapacity":12,"staticCapacity":0,"builtYear":2025,"architect":"Sunreef Yachts","interiorDesigner":"","topSpeed":0,"cruiseSpeed":13,"cabinLayout":[{"label":"Double Cabins","value":"4"}],"cabins":4,"bathrooms":4,"length":21.3,"beam":11.35,"draft":1.7,"hullType":"Multi hull","hullConstruction":"GRP","tonnage":86,"superStructure":["Flybridge"],"engines":"2x MAN i6-850 hp","amenities":[{"label":"Sun lounges"},{"label":"Air Conditioning"},{"label":"Stabilisers at anchor"},{"label":"Stabilisers underway"},{"label":"Deck Jacuzzi"},{"label":"Flybridge"},{"label":"Generators","quantity":"2"}],"toys":[{"label":"Seabobs","quantity":"2"},{"label":"Paddleboards","quantity":"2"},{"label":"Water Skis – 1 set for Adults + 1 set of Training child Skis"},{"label":"Wakeboard"},{"label":"Kayaks","quantity":"2"},{"label":"Donut ringo towable","quantity":"1"},{"label":"Jobe Inflatables (for 3 persons, 2 persons)","quantity":"2"},{"label":"JOBE Retrait (6 pax)","quantity":"1"},{"label":"JOBE Manta Mats","quantity":"2"}],"entertainment":["WiFi connection"],"tenders":["Tender Williams 505 (6 pax)"]},"crew":[{"name":"Alessandro Magnanti","avatar":"/media/media::image::a::vessel::f7365760-3a25-11f0-bfc9-c38d371d38e7::assets::36da1870-4066-11f0-a152-d99c5163ad4a/{imageVariant}","role":"Captain","bio":"Italian\n\nCaptain Alessandro, originally from Sicily, has spent over two decades navigating some of the world’s most iconic cruising grounds. His career spans both sailing and motor yachts, charter and private programs, with extensive experience throughout the Mediterranean and Caribbean. His deep understanding of local cruising areas — from Corsica and Sardinia to the Balearics and beyond — allows him to craft smooth, enriching itineraries tailored to his guests.\n\nOver the years, Alessandro has also collaborated with shipyards on new builds and refits, as well as worked within luxury hospitality ashore. This dual expertise — maritime and guest-focused — enables him to run a yacht with a fine balance of operational efficiency and onboard elegance.\n\nHe holds the MCA Master 200GT and RYA Yachtmaster Ocean licenses, among other technical certifications, and places strong emphasis on safety, seamless logistics, and guest satisfaction. Fluent in Italian, English, and Spanish, Alessandro is a clear communicator and calm leader. Whether navigating quiet anchorages or managing busy charter programs, he creates a relaxed, confident atmosphere onboard — allowing guests to fully unwind and enjoy the journey."},{"name":"Giuseppe Luca","avatar":"/media/media::image::a::vessel::f7365760-3a25-11f0-bfc9-c38d371d38e7::assets::6f31ec70-4066-11f0-ad56-c93f5ce9172a/{imageVariant}","role":"Captain","bio":"Italian\n\nChef Giuseppe is a passionate Italian chef with a refined culinary background and a deep love of the sea. Born and raised in Italy, he trained at the prestigious Accademia Gambero Rosso in Rome before refining his craft in several Michelin-starred restaurants, including Coria, La Capinera, and Shalai Resort. His land-based career shaped his appreciation for simplicity, seasonality, and beautiful presentation — values he brings into every dish.\n\nIn recent years, Giuseppe transitioned to the yachting world, working as executive chef aboard yachts such as Perini Heritage, Lady G, Penelope, and Alaska. Onboard, he crafts elegant Mediterranean-inspired menus with balance and finesse, tailored to each guest’s preferences. From fresh seafood pastas to delicate plant-based meals, his cooking is both soulful and technically precise.\n\nGiuseppe takes the time to connect with guests, ensuring that meals are not just about nourishment but about experience. His cuisine is generous, flavorful, and thoughtful — whether it’s a casual al fresco lunch or a fine dining celebration under the stars. Calm, organized, and always smiling, Giuseppe adds a personal and authentic touch to every charter."},{"name":"Cyntia Bulka Goncalves Luru","avatar":"/media/media::image::c::9938368400::vessel::f7365760-3a25-11f0-bfc9-c38d371d38e7::assets::e8bd1170-5cbb-11f0-8545-fba26f17b23b/{imageVariant}","role":"Captain","bio":"Brazilian\n\nCyntia is a dedicated and experienced stewardess with a warm, outgoing personality. With a strong background in luxury hospitality, she has worked aboard both private and charter motor yachts up to 87 metres, as well as premium cruise ships, delivering refined service in dynamic, high-end environments.\n\nKnown for her meticulous housekeeping, elegant table service, and attentive guest care, Cyntia ensures every charter is welcoming, polished, and thoughtfully curated. Her positive energy and calm professionalism make her a valued presence on board."},{"name":"Sacha Oliveri Conti","avatar":"/media/media::image::a::vessel::f7365760-3a25-11f0-bfc9-c38d371d38e7::assets::ded97340-4066-11f0-81fc-519bd65427b6/{imageVariant}","role":"Captain","bio":"Italian\n\nSacha was born in Catania, Sicily, and grew up with a natural connection to the sea. With a solid background in mechanical and metal work, he brings valuable technical skills to the deck team. His yachting experience includes time aboard prestigious vessels such as Spirit of the C’s (Perini Navi), MY Alaska, and Koru, where he developed a hands-on approach to mooring, tender handling, maintenance, and guest support.\n\nHe thrives in dynamic environments and particularly enjoys water sports. Sacha is a certified instructor for jet skis, kitesurfing, laser sailing, and paddleboarding — always ready to guide guests in trying new activities in a safe and relaxed setting. Whether setting up beach days, managing toys, or ensuring smooth deck operations, he works efficiently and with great attention to detail.\n\nCalm, discreet, and responsive, Sacha is appreciated for his reliability and guest-first attitude. He speaks Italian natively and English fluently, and brings both energy and peace of mind to every charter experience."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":6800000,"displayCurrency":"EUR","displayPrice":6800000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":7900000,"displayCurrency":"EUR","displayPrice":7900000,"unit":"WEEK"},"pricingInfo":[{"name":"Med Low Season (all other months)","effectiveDates":[{"from":"2026-01-01T00:00:00.000Z","to":"2026-04-30T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-04-30T23:59:59.999Z"},{"from":"2028-01-01T00:00:00.000Z","to":"2028-04-30T23:59:59.999Z"},{"from":"2026-11-01T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-11-01T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"},{"from":"2028-11-01T00:00:00.000Z","to":"2028-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":6800000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":6800000,"amount":6800000,"conditions":"VAT & APA Excluded"},{"item":"APA","conditions":"","quantity":0.25,"unitPrice":6800000,"amount":1700000}],"total":8500000,"subTotal":8500000,"totalTax":0},"inclusionZones":[{"label":"Corsica","type":"Geo subunit","category":["Europe","Southern Europe","Corsica"],"coordinates":[9.104917129771797,42.161865413836736],"bbox":[8.565625000000011,41.384912109374994,9.556445312500017,43.021484375]},{"label":"France","type":"Country","category":["Europe","Western Eu