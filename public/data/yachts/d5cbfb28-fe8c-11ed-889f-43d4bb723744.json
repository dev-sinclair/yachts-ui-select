8/{imageVariant}","/media/media::image::a::vessel::d5cbfb28-fe8c-11ed-889f-43d4bb723744::assets::e6716dc0-dbf1-11f0-b443-61339ebdcb68/{imageVariant}"],"make":"Sanlorenzo Yachts","model":"","maxCrew":6,"sleeps":10,"cruisingCapacity":0,"builtYear":2007,"architect":"Francesco Paszkowski","interiorDesigner":"Francesco Paszkowski","refitYear":2024,"topSpeed":28,"cruiseSpeed":13,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"3"},{"label":"Twin Cabins","value":"2"}],"cabins":5,"bathrooms":0,"decks":2,"length":39.4,"beam":8.8,"draft":9.4,"hullType":"","hullConstruction":"","tonnage":0,"superStructure":[],"engines":"2 MTU 12V 4000 M90 ,  2775 hp each @2100 rpm,  30 kW Vosper Bow Thruster","amenities":[{"label":"Sun deck"},{"label":"Bar"},{"label":"Daybeds"},{"label":"BBQ"},{"label":"Awning"},{"label":"Sky Lounge"}],"toys":[{"label":"Seabobs","quantity":"2"},{"label":"Stand-up paddleboards","quantity":"4"},{"label":"Snorkelling gear"}],"entertainment":["State of the art TV"],"tenders":["5.3m Novurania outboard tender"]},"crew":[{"name":"Johnny","avatar":"/media/media::image::a::vessel::d5cbfb28-fe8c-11ed-889f-43d4bb723744::assets::8217e250-dbf1-11f0-b443-61339ebdcb68/{imageVariant}","role":"Captain","bio":"Johnny grew up in Sydney shaping landscapes rather than coastlines — working on major projects like the 2012 London Olympics and the Gold Coast Botanical Gardens. A ski season overseas introduced him to yachting… and he’s never looked back.\n\nTwelve years on, Johnny has worked on yachts across the Mediterranean, Caribbean, and the U.S., even earning A Crew’s Best Charter Boat of the Year award in 2018. Now back home, he leads 4A with a steady hand,\nsharp seamanship, and a good sense of humour. \n\nJohnny’s all about keeping things safe, smooth, and seriously fun. Whether it’s water sports, beach BBQs, or off-the-map exploring, he makes sure every trip is one to remember — for all the right reasons."},{"name":"Shelby","avatar":"/media/media::image::a::vessel::d5cbfb28-fe8c-11ed-889f-43d4bb723744::assets::9e6b9fa0-dbf1-11f0-b443-61339ebdcb68/{imageVariant}","role":"Captain","bio":"Originally from Canada’s Lake Country, Shelby grew up on the water — literally. She spent her childhood sailing the world on her dad’s boat, so it’s no surprise she found her way into yachting. Before life at sea, she \nwas designing bars and training hospitality teams, so she knows how to create an atmosphere guests never want to leave.\n\nFor the past four years, Shelby has brought her eye for detail, love of travel, and passion for exceptional service to the world of superyachts. Now based in Australia, she blends a European sense of style with that\nsignature Aussie ease.\n\nThink sunset cocktails, flawless table settings, and the kind of effortless service that makes you feel like the yacht was made just for you. Shelby’s all about those little touches that turn a trip into something truly unforgettable."},{"name":"Luke","avatar":"/media/media::image::a::vessel::d5cbfb28-fe8c-11ed-889f-43d4bb723744::assets::bb52c350-dbf1-11f0-b443-61339ebdcb68/{imageVariant}","role":"Captain","bio":"With over 20 years’ experience in top restaurants, resorts, and remote luxury locations, Luke has built his career around creating food that makes people feel something. He’s worked everywhere from Melbourne’s most celebrated kitchens to island resorts on the Great Barrier Reef — and now brings his impressive skillset (and seriously good flavours) to 4A.\n\nLuke lights up when talking about menu ideas, loves surprising guests with creative touches, and somehow makes dietary requirements feel like a delicious adventure. Whether it’s fresh seafood straight off the line, a fivecourse tasting menu, or a beach BBQ with a twist, he crafts every dish with thought, creativity, and plenty of heart. \n\nIf you’re lucky, you might find him in the galley chatting herbs or geeking out over smoked butter — but most of the time, he’s busy ensuring every guest leaves the table happier than when they sat down."}],"pricing":{"weekPricingFrom":{"currency":"USD","price":12000000,"displayCurrency":"USD","displayPrice":12000000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":12000000,"displayCurrency":"USD","displayPrice":12000000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rate","effectiveDates":[{"from":"2026-01-01T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"},{"from":"2028-01-01T00:00:00.000Z","to":"2028-12-31T23:59:59.999Z"}],"pricing":{"currency":"USD","charterFee":12000000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":12000000,"amount":12000000,"conditions":"VAT & APA Excluded"}],"total":12000000,"subTotal":12000000,"totalTax":0},"inclusionZones":[{"label":"Fiji","type":"Sovereign country","category":["Oceania","Melanesia","Fiji"],"coordinates":[19.643807969695064,-17.661387590807376],"bbox":[-180,-21.705859375000003,180,-12.476953125000009]},{"label":"New Zealand","type":"Country","category":["Oceania","Australia and New Zealand","New Zealand"],"coordinates":[-18.677620423939118,-34.08865541316071],"bbox":[-177.9579971999999,-52.60031327099995,178.84392337300005,-8.543226820999905]},{"label":"Australia","type":"Country","category":["Oceania","Australia and New Zealand","Australia"],"coordinates":[134.10701705798022,-25.516879284507734],"bbox":[112.908203125,-39.1455078125,153.61689453125,-10.0517578125]}],"exclusionZones":[],"petsAllowed":false}]}}