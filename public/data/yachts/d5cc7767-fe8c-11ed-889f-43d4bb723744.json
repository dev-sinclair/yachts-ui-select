c7767-fe8c-11ed-889f-43d4bb723744::assets::1814d370-3635-11f0-8893-8b67956b5122/{imageVariant}","/media/media::image::a::vessel::d5cc7767-fe8c-11ed-889f-43d4bb723744::assets::960849a0-1165-11f0-9c1b-eb5f59ce9e3e/{imageVariant}","/media/media::image::a::vessel::d5cc7767-fe8c-11ed-889f-43d4bb723744::assets::960f7590-1165-11f0-896a-918a04d337e7/{imageVariant}","/media/media::image::a::vessel::d5cc7767-fe8c-11ed-889f-43d4bb723744::assets::95fb0330-1165-11f0-a765-315971a9ce0a/{imageVariant}"],"make":"","model":"","maxCrew":5,"sleeps":17,"basePort":{"uri":"a::place::d51ce592-b3ed-11ed-9373-325096b39f47","name":"Bodrum","coordinates":{"latitude":37.03482562918905,"longitude":27.42932494208488},"country":"Türkiye"},"cruisingCapacity":0,"builtYear":2002,"architect":"","interiorDesigner":"","refitYear":2025,"topSpeed":12,"cruiseSpeed":9,"fuelCapacity":5000,"cabinLayout":[{"label":"Grand Master Cabin","value":"1"},{"label":"Master Cabin","value":"1"},{"label":"Superior Double Cabin","value":"3"},{"label":"Triple Cabin","value":"1"},{"label":"Twin Cabin","value":"2"}],"cabins":8,"bathrooms":8,"decks":"","length":34,"beam":7.9,"draft":3.44,"hullType":"","hullConstruction":"","tonnage":"","superStructure":[],"engines":"2 x 440 Mann","amenities":[{"label":"Air Conditioning"},{"label":"Hair dryers"},{"label":"Indoor and Outdoor Lounge Areas"},{"label":"Bar"},{"label":"Sunbeds","quantity":"18"},{"label":"Generators"},{"label":"Life vests (children and adults)"},{"label":"Fire extinguishers"},{"label":"First aid kit"},{"label":"Portable shaded tents"},{"label":"Inverters"},{"label":"Sunbathing Area"},{"label":"Ice Box"},{"label":"BBQ"},{"label":"Ice Machine"}],"toys":[{"label":"Water Ski"},{"label":"Wakeboard"},{"label":"Ringo"},{"label":"Paddle Boards","quantity":"2"},{"label":"Sea Kayaks","quantity":"2"},{"label":"Snorkeling Equipment (adults & kids)"},{"label":"Board Games"}],"entertainment":["Wi-Fi onboard","TV or Plasma","Bluetooth Speaker"],"tenders":["5.0 mt Zodiac 60 HP Yamaha outboard (6 Pax)"]},"crew":[{"name":"Orhan TOPCU","avatar":"/media/media::image::c::31479982513::vessel::d5cc7767-fe8c-11ed-889f-43d4bb723744::assets::05fcc060-3a15-11f0-9102-71e515894aa4/{imageVariant}","role":"Captain","bio":"Age: 38\nLanguages: English (B1)\nExperience: Since 2003\nOrhan began his maritime career in a small coastal town where he\ndeveloped a deep passion for the sea. He obtained his first license\nin 2003 and became a certified yacht captain in 2010. With over\n15 years of experience, including 11 years sailing throughout the\nGreek Islands, he is highly skilled in navigation, maintenance, and\nguest safety.\nQualifications: 500 GRT Yacht Captain License, STCW ’95, ENG1\nCertificate, VHF, Radio License, Security Duties & Security\nAwareness, Basic First Aid, Fire Prevention & Firefighting,\nPersonal Safety & Social Responsibility, Personal Survival\nTechniques, Survival Boat & Rescue Boat Certificate,\nWatchkeeping Certificate."},{"name":"Ercument DERELI","avatar":"/media/media::image::c::31479982513::vessel::d5cc7767-fe8c-11ed-889f-43d4bb723744::assets::0dc20a30-3a15-11f0-9102-71e515894aa4/{imageVariant}","role":"Captain","bio":"Age: 34\nLanguages: English (B1), German (A1)\nExperience: Since 2012\nA passionate and hardworking chef with a strong background in\n5-star hotels and award-winning restaurants, including Green\nApple Award-recognised venues. Ercument served in key\npositions such as sous chef and chef de partie before\ntransitioning into the yachting industry as a yacht chef.\nFast, efficient, and highly committed to culinary excellence, he\ncombines creativity, discipline, and attention to detail to deliver\nunforgettable flavours and top-tier service."},{"name":"Buse SEVIK","avatar":"/media/media::image::c::31479982513::vessel::d5cc7767-fe8c-11ed-889f-43d4bb723744::assets::16e695e0-3a15-11f0-9102-71e515894aa4/{imageVariant}","role":"Captain","bio":"Age: 24\nLanguages: English (B2)\nExperience: Since 2022\nBuse brings valuable experience to her role as stewardess,\nhaving worked in both the yachting and hospitality industries.\nHer background includes previous stewardess roles as well as\nservice positions in hotels and restaurants, which have refined\nher communication skills and guest-oriented approach.\nFluent in English at a B2 level, Buse provides warm, attentive\nservice and contributes to a welcoming atmosphere on board.\nHer professionalism and cheerful demeanor make her a key part\nof the guest experience aboard Parss."},{"name":"Bayram DURMAZ","avatar":"/media/media::image::c::31479982513::vessel::d5cc7767-fe8c-11ed-889f-43d4bb723744::assets::2138cc20-3a15-11f0-9102-71e515894aa4/{imageVariant}","role":"Captain","bio":"Age: 27\nLanguages: English (A2)\nExperience: Since 2018\nBayram began his maritime career in 2018 and has since gained\nvaluable experience as a deckhand on various yachts. Since\n2019, he has served in the role of Certified Seaman (Usta\nGemici), consistently demonstrating reliability, professionalism,\nand a strong work ethic.\nConfident in guest relations and onboard operations, Bayram is\na dedicated and proactive crew member who contributes to a\nsafe, smooth, and enjoyable experience for all guests on board.\nCertificates: 149 – Certified Seaman (Usta Gemici) Certificate"},{"name":"Murat ERIS","avatar":"/media/media::image::c::31479982513::vessel::d5cc7767-fe8c-11ed-889f-43d4bb723744::assets::2d9f6370-3a15-11f0-9102-71e515894aa4/{imageVariant}","role":"Captain","bio":"Age: 26\nLanguages: English (A2)\nExperience: Since 2022\nMurat has been actively working in the yachting industry since\n2022. Over the past seasons, he has gained solid experience\naboard various yachts, developing his skills in daily operations,\nmaintenance, and guest support.\nResponsible, disciplined, and team-oriented, Murat plays a key\nrole in ensuring that onboard routines run smoothly. He is able\nto meet basic communication needs in English and is committed\nto providing a safe and comfortable experience for guests\nthroughout their voyage."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1680000,"displayCurrency":"EUR","displayPrice":1680000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2800000,"displayCurrency":"EUR","displayPrice":2800000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rates: May & Oct","effectiveDates":[{"from":"2025-01-01T00:00:00.000Z","to":"2025-05-31T23:59:59.999Z"},{"from":"2026-01-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-05-31T23:59:59.999Z"},{"from":"2025-10-01T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"},{"from":"2026-10-01T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-10-01T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1680000,"inputAmountTaxed":"EXCLUSIVE","note":"%20 Broker commission included in subtotal. Last-minute discounts (%20 May and %15 June) already applied in subtotal.","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2100000,"amount":1680000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.2},"discount":{"type":"PERCENTAGE","value":0.2}}],"total":2016000,"subTotal":1680000,"totalTax":336000},"inclusionZones":[{"label":"Turkey","type":"Sovereign country","category":["Asia","Western Asia","Turkey"],"coordinates":[35.10531997715448,39.093802942376584],"bbox":[25.6689453125,35.831445312499994,44.81718750000002,42.09326171875]}],"exclusionZones":[],"petsAllowed":false},{"name":"Weekly Rates: Jun & Sept","effectiveDates":[{"from":"2025-06-01T00:00:00.000Z","to":"2025-06-30T23:59:59.999Z"},{"from":"2026-06-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-06-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2025-09-01T00:00:00.000Z","to":"2025-09-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-30T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-09-30T23:59:59.999Z"}],"pricing":