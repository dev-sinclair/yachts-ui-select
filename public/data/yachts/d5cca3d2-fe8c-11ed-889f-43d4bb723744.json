1f0-be95-497a75d27328/{imageVariant}","/media/media::image::a::vessel::d5cca3d2-fe8c-11ed-889f-43d4bb723744::assets::yachts-100586-Za8B9bDV37.jpg/{imageVariant}"],"make":"Sunreef Yachts","model":"Sunreef 60","maxCrew":3,"sleeps":10,"basePort":{"uri":"a::place::cc26b9c0-5ca3-11f0-8719-c7b4f2fe88de","name":"Sud Cantieri Marina","coordinates":{"latitude":40.82787660089578,"longitude":14.11636792383297},"country":"Italy"},"cruisingCapacity":10,"builtYear":2018,"architect":"Sunreef Yachts","refitYear":2023,"topSpeed":0,"cruiseSpeed":8,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"5"}],"cabins":5,"bathrooms":5,"length":18.3,"beam":10.2,"draft":1.6,"hullType":"Multi hull","hullConstruction":"GRP","tonnage":110,"superStructure":[],"engines":"2 x 110 HP Volvo D3","amenities":[{"label":"Air conditioning"},{"label":"Generator"},{"label":"Flybridge"},{"label":"Sun lounges"},{"label":"Sun pads"},{"label":"Stove"},{"label":"Oven"},{"label":"Teak Deck"},{"label":"Watermakers"}],"toys":[{"label":"Jobe Wakeboards","quantity":"2"},{"label":"Inflatable Canoe f/ 2 Persons"},{"label":"Tow Banana f/ 2 Persons"},{"label":"Tow Floater"},{"label":"Jobe Scout Towable 3 (new)"},{"label":"Jobe Towable Binar Lunar 3 (new)"},{"label":"Sets of Snorkling Equipment","quantity":"6"},{"label":"Fishing Rod","quantity":"2"},{"label":"Fishing Gear"},{"label":"Jobe Paddle Board","quantity":"2"},{"label":"Sets of Diving Equipment","quantity":"2"},{"label":"Seabob F5S (new)"}],"entertainment":["Wi-Fi"],"tenders":["Grand 500 with 100hp"]},"crew":[{"name":"Jose Gomez","avatar":"/media/media::image::c::9938368400::vessel::d5cca3d2-fe8c-11ed-889f-43d4bb723744::assets::e72a0220-609c-11f0-9c5f-b144769fd975/{imageVariant}","role":"Captain","bio":"Portuguese\n\nComing from a family of sailors he has been doing it his all life, and what used to be a hobby became a life commitment. He is a confident, skilled and very helpful captain that has as his main concern the comfort and safety of the people on board."},{"name":"Goncalo Brito","avatar":"/media/media::image::c::9938368400::vessel::d5cca3d2-fe8c-11ed-889f-43d4bb723744::assets::64022700-609d-11f0-91fd-8da6615afb3c/{imageVariant}","role":"Captain","bio":"Portuguese\n\nWith the passion of sports and professional navigator, completed by his experience working in the Mediterranean as a skipper, Goncalo is a lover of nautical sports.\n\nOne of his greatest passions is to explore marine fauna during diving trips. Having PADI license, he is the person that can help you to explore the bottom of the sea. While combining good communication skills with a welcoming attitude, he will be the person that can help you in everything you need on board."},{"name":"Gani Pavlov","avatar":"/media/media::image::c::9938368400::vessel::d5cca3d2-fe8c-11ed-889f-43d4bb723744::assets::27585e00-609d-11f0-b6ed-9b8a40836c53/{imageVariant}","role":"Captain","bio":"Bulgarian\n\nOriginally from Bulgaria, Gani has always had a passion for cooking. After training in pastry, he worked in various restaurants, where he enhanced his culinary style and skills over the years. He also completed a course at the International Academy of Italian Cuisine in Lucca and continued to combine flavors in his own way along with new proficiencies.\n\nBlending his expertise in Mediterranean and Balkan cuisine, while ensuring guests delicious desserts, Gani is a versatile Chef who won’t ever run out of creativity. His catamaran charter experience, professionalism and culinary mastery will delight guests of FEEL THE BLUE."},{"name":"José Oliveira Monteiro","avatar":"/media/media::image::c::9938368400::vessel::d5cca3d2-fe8c-11ed-889f-43d4bb723744::assets::422a8460-609d-11f0-9c5f-b144769fd975/{imageVariant}","role":"Captain","bio":"Portuguese\n\nZeca has always been connected to the nature and the sea. After spending some time sailing on a friend's boat, he had an opportunity to start working on board. It's been 6 years now and he can't imagine himself doing anything else. Being a very welcoming person, he will make the clients feel comfortable from the moment of embarkation. Always with a smile and ready to help, he is definitely a plus to FEEL THE BLUE."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":3500000,"displayCurrency":"EUR","displayPrice":3500000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":4200000,"displayCurrency":"EUR","displayPrice":4200000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer High Season (July, August)","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":4200000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":4200000,"amount":4200000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.22}},{"item":"APA","conditions":"","quantity":0.3,"unitPrice":4200000,"amount":1260000}],"total":6384000,"subTotal":5460000,"totalTax":924000},"inclusionZones":[{"label":"Sardinia","type":"Geo subunit","category":["Europe","Southern Europe","Sardinia"],"coordinates":[8.96574354539669,40.12242872762209],"bbox":[8.180859375000011,38.90966796875,9.805273437500006,41.257080078125]},{"label":"Italy","type":"Sovereign country","category":["Europe","Southern Europe","Italy"],"coordinates":[12.204840429521369,41.61169587639921],"bbox":[6.6027283120000675,35.48924388200004,18.517425977000073,47.08521494500006]}],"exclusionZones":[],"petsAllowed":false},{"name":"Summer Mid-Season (June, September)","effectiveDates":[{"from":"2026-06-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-06-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2028-06-01T00:00:00.000Z","to":"2028-06-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-30T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","