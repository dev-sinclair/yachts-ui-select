ty":"2"},{"label":"Wakeboard (kids)"},{"label":"Water Ski (kids) "},{"label":"Snorkeling Gear"},{"label":"Fishing Gear"},{"label":"Sea Scooter","quantity":"1"},{"label":"Tube","quantity":"1"},{"label":"Noodles"}],"entertainment":[],"tenders":["Rib 3.10 m – 20hp"]},"crew":[{"name":"Christos Filinis","avatar":"/media/media::image::c::7819307041::vessel::d5cc245f-fe8c-11ed-889f-43d4bb723744::assets::5900ac00-caab-11f0-8bb3-cf46cee85715/{imageVariant}","role":"Captain","bio":"Christos is a driven and responsible sailor who continuously challenges and improves his skills, while making you feel right at home on board. He is a high-energy, and fun skipper who is guaranteed to have you laughing while also learning more about sailing. He completed his Masters as a Civil Engineer here in Patras, Greece, and while there, he became an avid windsurfer, spending every spare moment on the sea, no matter the conditions.\nAfter working as an engineer, Christos felt the sea calling and decided to answer by training and working as a qualified skipper. Since this career change in 2016, Christos has devoted his life to the sea and never looked back. He holds his RYA diploma as a Yacht Master Offshore Sailor, and as an RYA Sailing Instructor, and he takes great pleasure in sharing his passion for sailing with others. His patience and outgoing attitude make him an extremely dependable coach and committed skipper. He is waiting to show you all there is to know about sailing the Greek waters."},{"name":"Yiannis Karatzakis","avatar":"/media/media::image::c::7819307041::vessel::d5cc245f-fe8c-11ed-889f-43d4bb723744::assets::6c754b10-caab-11f0-8bb3-cf46cee85715/{imageVariant}","role":"Captain","bio":"Yiannis is a passionate and dedicated culinary professional with a deep connection to the sea and a love for hospitality. Throughout his life, he has had a natural inclination to care for others, which led him to pursue a career in the hospitality industry. His approach is always customer-centered, ensuring that each guest experiences a high level of service, attention to detail, and satisfaction.\nWith a strong relationship with the ocean, he has been surfing for years, further shaping his understanding and respect for nature and the environment. This love for the sea fuels his commitment to creating meals that not only nourish but also reflect his appreciation for the natural world.\nIn his role as a chef, Yiannis brings not only his culinary expertise but also a personal touch centered on quality, creativity, and the joy of sharing good food. He is always eager to create memorable dining experiences and ensure that everyone aboard feels welcome, comfortable, and well taken care of."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1300000,"displayCurrency":"EUR","displayPrice":1300000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1650000,"displayCurrency":"EUR","displayPrice":1650000,"unit":"WEEK"},"pricingInfo":[{"name":"High Season","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1650000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1650000,"amount":1650000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.065}},{"item":"APA","conditions":"","quantity":0.25,"unitPrice":1650000,"amount":412500}],"total":2169750,"subTotal":2062500,"totalTax":107250},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]},{"label":"Aegean Sea","type":"Custom Area","category":["Aegean Sea"],"coordinates":[25.17433827229007,38.821119014422294],"bbox":[22.569093051857664,36.