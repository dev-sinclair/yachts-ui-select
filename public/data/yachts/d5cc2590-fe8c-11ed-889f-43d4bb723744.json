tude":16.54319316,"longitude":-88.36120785},"country":"Belize"},"builtYear":2003,"refitYear":2015,"topSpeed":9,"cruiseSpeed":8,"fuelCapacity":"","cabinLayout":[{"label":"Queen Cabins","value":"3"}],"cabins":3,"bathrooms":3,"length":14.33,"beam":7.32,"draft":1.37,"hullType":"","hullConstruction":"","superStructure":[],"engines":"2 x Yanmar engines","amenities":[{"label":"Air Conditioning","quantity":""},{"label":"Salon TV","quantity":""},{"label":"Salon Stereo","quantity":""},{"label":"iPod/Device Hookups","quantity":""},{"label":"Sun Awning","quantity":""},{"label":"Hammock","quantity":""},{"label":"Windscoops","quantity":""},{"label":"Deck Shower","quantity":""},{"label":"Bimini","quantity":""},{"label":"Special Diets","quantity":""},{"label":"BBQ","quantity":""},{"label":"Dine In","quantity":6},{"label":"Nude","quantity":""},{"label":"Hairdryers","quantity":""},{"label":"Port Hatches","quantity":24},{"label":"Children Allowed","quantity":""},{"label":"Gym/Exercise","quantity":""},{"label":"Generator","quantity":""},{"label":"Wind Generators","quantity":2},{"label":"Inverter","quantity":""},{"label":"Water Maker","quantity":""},{"label":"Ice Maker","quantity":""},{"label":"Sailing Instructions","quantity":""},{"label":"Onboard Wi-Fi","quantity":""},{"label":"Purified drinking water","quantity":""},{"label":"Re-usable water bottles","quantity":""},{"label":"Solar Panels","quantity":4},{"label":"Sunbathing Area","quantity":""},{"label":"Refrigerator","quantity":""}],"toys":[{"label":"Dinghy","quantity":7},{"label":"Snorkel Gear","quantity":6},{"label":"Tube","quantity":""},{"label":"Scurfer","quantity":""},{"label":"Kayaks 1 Pax","quantity":2},{"label":"Floating Mats","quantity":""},{"label":"Swim Platform","quantity":2},{"label":"Stern Boarding Ladder","quantity":""},{"label":"Beach Games","quantity":""},{"label":"Trampoline","quantity":""},{"label":"Underwater Camera","quantity":""},{"label":"Bean bags","quantity":2},{"label":"Inflatable Island Lounge","quantity":""},{"label":"SU Paddle Boards","quantity":2},{"label":"Fishing Gear","quantity":3}],"entertainment":["Salon TV","Salon Stereo","iPod/Device Hookups","Onboard Wi-Fi"],"tenders":["13ft Tender with 30 HP engine"]},"crew":[{"name":"Geoffrey Prower","avatar":"/media/media::image::c::7580663817::vessel::d5cc2590-fe8c-11ed-889f-43d4bb723744::assets::4fe87310-ac02-11ee-b09d-0bb81a7e0e5b.png/{imageVariant}","role":"Captain","bio":"Geoff & Iza are an outgoing British couple, who love the outdoors, the sea, the cruising life and meeting new friends.\n\nSeparately or together they have lived and worked in the Lebanon, Yemen Arab Republic, Seychelles, Kenya, South Africa, Saudi Arabia and Dubai in the UAE.\n\nGeoff has enjoyed a varied career in aviation, mostly in East Africa and Saudi Arabia. Assisted by Iza, he managed the creation of a new tourist seaplane service in Dubai during 2007.\n\nIza has always been a world traveler. She has managed businesses in the Yemen, worked as chef on a charter yacht in the Seychelles, managed exhibitions in London, run her own carpentry business in Kenya, taught information technology in Saudi Arabia and been involved in the creation of the Dubai airline.\n\nIza loves exploring, whether underwater or seeking that magical secluded bay or deserted island. Geoff and Iza are both PADI Rescue Divers.\n\nLuckily for Geoff, if Iza's not underwater, out kayaking or beachcombing, she's enjoying her long-standing passion for what he calls, her “culinary artistic creations.” Iza’s menus are influenced by the many cultures she has experienced and she will pamper you, matching the tastes and preferences of each individual guest. She will often bake three times a day from fresh muffins in the morning, fresh loaves for lunch and a variety of dinner rolls. She uses locally available produce wherever possible to create delicious and healthy gourmet cuisine which looks as astounding as it tastes.\n\nGeoff and Iza operated their catamaran Dreaming On for luxury crewed charters in the BVI for 5 years, then moved on to Belize for a change of scene. They fell in love with the islands of southern Belize, the phenomenal colours, the uncongested waters, and the chance to anchor at a different island every night and have the island to themselves.\n\nSo much so that they purchased and have been developing their own special piece of that paradise, Funk Caye, close to the main barrier reef. Funk Caye offers turquoise blue waters, fantastic snorkeling on the house reef all around the island, kayaking and paddle board opportunities. Nurse sharks regularly swim around under the island’s dock, and manatees have been sighted. Spotted Eagle Rays are permanent residents.\n\nThey now invite you to join them on board Dreaming On and share their knowledge and love of this quiet, unspoiled area."},{"name":"Iza Prower","avatar":"/media/media::image::c::7580663817::vessel::d5cc2590-fe8c-11ed-889f-43d4bb723744::assets::481a2890-ac02-11ee-b09d-0bb81a7e0e5b.png/{imageVariant}","role":"Chef","bio":"Geoff & Iza are an outgoing British couple, who love the outdoors, the sea, the cruising life and meeting new friends.\n\nSeparately or together they have lived and worked in the Lebanon, Yemen Arab Republic, Seychelles, Kenya, South Africa, Saudi Arabia and Dubai in the UAE.\n\nGeoff has enjoyed a varied career in aviation, mostly in East Africa and Saudi Arabia. Assisted by Iza, he managed the creation of a new tourist seaplane service in Dubai during 2007.\n\nIza has always been a world traveler. She has managed businesses in the Yemen, worked as chef on a charter yacht in the Seychelles, managed exhibitions in London, run her own carpentry business in Kenya, taught information technology in Saudi Arabia and been involved in the creation of the Dubai airline.\n\nIza loves exploring, whether underwater or seeking that magical secluded bay or deserted island. Geoff and Iza are both PADI Rescue Divers.\n\nLuckily for Geoff, if Iza's not underwater, out kayaking or beachcombing, she's enjoying her long-standing passion for what he calls, her “culinary artistic creations.” Iza’s menus are influenced by the many cultures she has experienced and she will pamper you, matching the tastes and preferences of each individual guest. She will often bake three times a day from fresh muffins in the morning, fresh loaves for lunch and a variety of dinner rolls. She uses locally available produce wherever possible to create delicious and healthy gourmet cuisine which looks as astounding as it tastes.\n\nGeoff and Iza operated their catamaran Dreaming On for luxury crewed charters in the BVI for 5 years, then moved on to Belize for a change of scene. They fell in love with the islands of southern Belize, the phenomenal colours, the uncongested waters, and the chance to anchor at a different island every night and have the island to themselves.\n\nSo much so that they purchased and have been developing their own special piece of that paradise, Funk Caye, close to the main barrier reef. Funk Caye offers turquoise blue waters, fantastic snorkeling on the house reef all around the island, kayaking and paddle board opportunities. Nurse sharks regularly swim around under the island’s dock, and manatees have been sighted. Spotted Eagle Rays are permanent residents.\n\nThey now invite you to join them on board Dreaming On and share their knowledge and love of this quiet, unspoiled area."}],"pricing":{"weekPricingFrom":{"currency":"USD","price":1125000,"displayCurrency":"USD","displayPrice":1125000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":1690500,"displayCurrency":"USD","displayPrice":1690500,"unit":"WEEK"},"pricingInfo":[{"name":"Low Season","effectiveDates":[{"from":"2023-05-01T00:00:00.000Z","to":"2023-12-14T23:59:59.999Z"},{"from":"2024-05-01T00:00:00.000Z","to":"2024-12-14T23:59:59.999Z"},{"from":"2025-05-01T00:00:00.000Z","to":"2025-12-14T23:59:59.999Z"}],"pricing":{"currency":"USD","unit":"WEEK","inputAmountTaxed":"