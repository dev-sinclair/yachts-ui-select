96b39f47","name":"Sydney","coordinates":{"latitude":-33.86380638,"longitude":151.2100953},"country":"Australia"},"builtYear":2008,"architect":"Oceanfast","interiorDesigner":"Oceanfast","refitYear":2023,"topSpeed":15,"cruiseSpeed":11,"fuelCapacity":38000,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Double Cabins","value":"2"}],"cabins":4,"bathrooms":4,"decks":2,"length":39,"beam":8.22,"draft":2.2,"hullType":"Displacement","hullConstruction":"Aluminium","tonnage":304,"superStructure":[],"engines":"2 x MTU 8V2000M72","amenities":[{"label":"Air Conditioning","quantity":1}],"toys":[{"label":"Snorkeling Gear","quantity":1},{"label":"Fishing Gear","quantity":1},{"label":"Wakeboard","quantity":1},{"label":"Towable Toys","quantity":1},{"label":"Inflatable Toys","quantity":1},{"label":"Sea Scooter","quantity":1},{"label":"Kayaking","quantity":1},{"label":"Paddle Board","quantity":1},{"label":"Slide","quantity":1},{"label":"Floating Pool","quantity":1},{"label":"Scuba Diving Gear","quantity":1},{"label":"Dive Compressor","quantity":1}],"entertainment":["Terrestrial TV","AV System","Entertainment Screens","GSM Internet","Satcom"],"tenders":["6.5-meter Brig Eagle 650 with 225hp Yamaha outboard","9.5m Grady White Bimini Customized fishing/diving tender"]},"crew":[{"name":"Paul Busk","avatar":"/media/media::image::c::8864389904::vessel::d5cc79f2-fe8c-11ed-889f-43d4bb723744::assets::4a7fec70-e733-11ee-a9b5-43870a0e8999.jpeg/{imageVariant}","role":"Captain","bio":"Paul’s boating career began at age five in the waters of Bass Straight. Learning the ropes from his father and professional mariners, Paul completed an apprenticeship and pursued a career in the maritime industry on the East Coast Barrier Reef.\nAfter five years working with his father, Paul completed his Masters/Captains tickets and left the family business to master commercial fishing industries such as tuna long lining, prawn trawling, and crab & trout fishing. Paul developed an extensive knowledge of Australia’s East Coast waters from Lord Howe Island to the outer reefs, making sure to have a dive, fish and surf along the way.\nA chance meeting with the owner of Evolution saw Paul leave the commercial industry after 24 years and begin a 12-year tenure spanning two yachts, four refits and 100,000 nautical miles, travelling all over Australia ranging from South Australia, Kimberley region of WA, The Whitsundays, Cairns and the Great Barrier Reef.\n"},{"name":"Craig Stratton","avatar":"/media/media::image::c::8864389904::vessel::d5cc79f2-fe8c-11ed-889f-43d4bb723744::assets::68aef970-e733-11ee-a9b5-43870a0e8999.jpeg/{imageVariant}","role":"Engineer","bio":" \nCraig grew up around the water and so naturally drifted into a career where he could live by it everyday. He began his career as a deckhand on Evolution in 2018, after 5 years of touring up and down the east coast of Australia he stepped into the role of Engineer, excelling in the field. \n\nWith over 6 years experience on Evolution, Craig is well equipped to ensure you have the best experience on board.  \n"},{"name":"Megan Humphries","avatar":"/media/media::image::c::8864389904::vessel::d5cc79f2-fe8c-11ed-889f-43d4bb723744::assets::aba88340-e733-11ee-a9b5-43870a0e8999.jpeg/{imageVariant}","role":"Steward","bio":"Megan’s passion for yachting began after sailing the family sail boat in regattas during her teens. She has since made it her career and spent over 4 years working on various yachts, exploring the East Coast of Australia and refining her skills. She is incredibly passionate about her job and always works to the highest standards. With her bubbly personality and welcoming smile, Megan is excited to have you on board and ensure your experience is personal and exceptional."},{"name":"Emily Fetherston","avatar":"/media/media::image::c::8864389904::vessel::d5cc79f2-fe8c-11ed-889f-43d4bb723744::assets::cc1b3eb0-e733-11ee-a9b5-43870a0e8999.jpeg/{imageVariant}","role":"Chief Stewardess","bio":"Our Chief Stewardess Emily has 9 years experience in the yachting industry working in both Australia and in Europe including Monaco, Spain, Balearic Islands and the South of France. She is well versed in guests needs and expectations and runs the interior to the highest standard. She will greet you with a smile and welcome you onboard for your perfect trip."}],"pricing":{"dayPricingFrom":{"currency":"AUD","price":360000,"displayCurrency":"AUD","displayPrice":360000,"unit":"HOUR"},"dayPricingTo":{"currency":"AUD","price":2500000,"displayCurrency":"AUD","displayPrice":2500000,"unit":"DAY"},"weekPricingFrom":{"currency":"AUD","price":15000000,"displayCurrency":"AUD","displayPrice":15000000,"unit":"WEEK"},"weekPricingTo":{"currency":"AUD","price":15000000,"displayCurrency":"AUD","displayPrice":15000000,"unit":"WEEK"},"pricingInfo":[{"name":"Term Charters - Weekly","effectiveDates":[{"from":"2023-01-01T00:00:00.000Z","to":"2023-12-31T23:59:59.999Z"},{"from":"2024-01-01T00:00:00.000Z","to":"2024-12-31T23:59:59.999Z"},{"from":"2025-01-01T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"}],"pricing":{"currency":"AUD","unit":"WEEK","inputAmountTaxed":"EXCLUSIVE","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":15000000,"amount":15000000,"taxRate":{"label":"GST","value":0.1},"conditions":"VAT & APA Excluded"},{"item":"APA","quantity":0.2,"unitPrice":15000000,"amount":3000000}],"subTotal":18000000,"totalTax":1500000,"total":19500000,"charterFee":15000000,"note":"APA: Sydney Harbour 20%, Whitsundays QLD 30%"},"inclusionZones":[{"label":"Australia","type":"Country","category":["Oceania","Australia and New Zealand","Australia"],"coordinates":[134.10701705798022,-25.516879284507734],"bbox":[112.908203125,-39.1455078125,153.61689453125,-10.0517578125]},{"label":"Queensland, AU, Australia","type":"State","category":["Queensland"],"coordinates":[144.57430167633441,-21.817616256828213],"bbox":[138.0017406465288,-29.13934582297228,153.53867239155943,-10.051698