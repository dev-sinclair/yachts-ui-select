43d4bb723744::assets::d5f3c490-116f-11f0-b53f-b93978e779d3/{imageVariant}"],"model":"","maxCrew":4,"sleeps":14,"basePort":{"uri":"a::place::d51ce592-b3ed-11ed-9373-325096b39f47","name":"Bodrum","coordinates":{"latitude":37.03482562918905,"longitude":27.42932494208488},"country":"Türkiye"},"cruisingCapacity":0,"builtYear":1996,"refitYear":2025,"topSpeed":12,"cruiseSpeed":9,"fuelCapacity":4000,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"Double Cabin","value":"4"},{"label":"Twin Cabin","value":"2"}],"cabins":7,"bathrooms":7,"length":28,"beam":7,"draft":3.44,"hullConstruction":"","superStructure":[],"engines":"2 x 330 Cummins","amenities":[{"label":"Air Conditioning"},{"label":"Hair dryers"},{"label":"Indoor and Outdoor Lounge Areas"},{"label":"Bar"},{"label":"Sunbeds","quantity":"14"},{"label":"Generators"},{"label":"Life vests (children and adults)"},{"label":"Fire extinguishers"},{"label":"First aid kit"},{"label":"Inverters"},{"label":"Portable shaded tents"},{"label":"Sunbathing Area"},{"label":"Ice Box"},{"label":"BBQ"},{"label":"Ice Machine"}],"toys":[{"label":"Water Ski"},{"label":"Wakeboard"},{"label":"Ringo"},{"label":"Paddle Boards","quantity":"3"},{"label":"Sea Kayaks","quantity":"2"},{"label":"Snorkel equipment (adults & kids)"},{"label":"Board Games"}],"entertainment":["Wi-Fi onboard","TV or Plasma","Bluetooth Speaker"],"tenders":["5.0 mt Zodiac 60 HP Yamaha outboard (6 Pax)"]},"crew":[{"name":"Levent TOK","avatar":"/media/media::image::c::31479982513::vessel::d5cccc4b-fe8c-11ed-889f-43d4bb723744::assets::ca3da8b0-3a18-11f0-9dbd-ab8d1f1d492b/{imageVariant}","role":"Captain","bio":"Age: 49\nLanguages: English (C1)\nExperience: Since 1995\nCaptain Levent Tok began his maritime career in 1995 aboard\nFortuna and became a licensed Yacht Captain in 2020. He has\nworked with Fortuna continuously throughout the years, rotating\nbetween Fortuna and other gulets within the same fleet. His\nextensive experience navigating Turkish waters and his leadership\naboard various yachts make him a trusted and capable captain.\nWith nearly three decades of experience, Captain Levent brings\ndeep knowledge of the Turkish coastline, ensuring a safe and\nmemorable experience for all guests aboard Fortuna. His\nprofessional demeanour and calm leadership style create an\nexceptional atmosphere on board.\nCertificates:500 GRT Yacht Captain License, Marine Mechanic and\nOiler Certificate, Advanced Firefighting, Radar Observation and\nWatchkeeping, Security Awareness, Security Introduction,\nPersonal Safety and Social Responsibility"},{"name":"Kamil SARI","avatar":"/media/media::image::c::31479982513::vessel::d5cccc4b-fe8c-11ed-889f-43d4bb723744::assets::e6eddde0-3a18-11f0-8b76-d3d79a25562c/{imageVariant}","role":"Captain","bio":"Age: 50\nLanguages English (B2)\nExperience Since 1997\nChef Kamil Sari has dedicated 18 years to perfecting his culinary\ncraft aboard Fortuna, in addition to 10 years of experience working\non various other yachts. His extensive background in both\ntraditional and modern Turkish cuisine, paired with his expertise in\nonboard culinary service, has allowed him to master the art of\ncreating exceptional dining experiences for yacht guests.\nChef Kamil's passion for food, attention to detail, and commitment\nto excellence ensure that every meal served on board Fortuna is a\nmemorable and delightful experience.\nCertificates: Able Seaman, Security Awareness, Security\nIntroduction, Personal Safety and Social Responsibility"},{"name":"Kaan KALKAN","avatar":"/media/media::image::c::31479982513::vessel::d5cccc4b-fe8c-11ed-889f-43d4bb723744::assets::0cd0a880-3a19-11f0-a988-b7e2600b8302/{imageVariant}","role":"Captain","bio":"Age: 25\nLanguages: English (B2)\nExperience: Since 2014\nKaan is a dedicated maritime professional with 11 years of\nexperience aboard Fortuna. With a degree in yacht captaincy, he is\ndeeply committed to ensuring guest satisfaction and fostering a\npositive, collaborative environment for the crew. His strong\ncommunication and organisational skills contribute to a smooth\nand harmonious atmosphere on board, allowing for exceptional\nservice and unforgettable holiday experiences for all guests.\nCertificates: Basic First Aid, Occupational Safety – Personal Safety\nand Social Responsibility, Advanced Firefighting, Swimmer\nCertificate, Hygiene and Sanitation, Ordinary Seaman Certificate"},{"name":"Mehmet KABA","avatar":"/media/media::image::c::31479982513::vessel::d5cccc4b-fe8c-11ed-889f-43d4bb723744::assets::2af24800-3a19-11f0-a8b5-37960508202f/{imageVariant}","role":"Captain","bio":"Age: 20\nLanguages: English (C1)\nExperience Since 2021\nMehmet has been working onboard for several seasons and\nmaintains a positive relationship with all his former employers. He\nleft each position on good terms and with full references. His\nstrong communication skills and ability to adapt easily to different\nteams and environments make him a valuable crew member.\nEducation High School Graduate\nCertificates: Ordinary Seaman and Oiler,Security Awareness,\nSecurity Introduction, Personal Safety and Social Responsibility"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1440000,"displayCurrency":"EUR","displayPrice":1440000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2300000,"displayCurrency":"EUR","displayPrice":2300000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rates: May & Oct","effectiveDates":[{"from":"2025-01-01T00:00:00.000Z","to":"2025-05-31T23:59:59.999Z"},{"from":"2026-01-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-05-31T23:59:59.999Z"},{"from":"2025-10-01T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"},{"from":"2026-10-01T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-10-01T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1440000,"inputAmountTaxed":"EXCLUSIVE","note":"%20 Broker commission included in subtotal. Last-minut