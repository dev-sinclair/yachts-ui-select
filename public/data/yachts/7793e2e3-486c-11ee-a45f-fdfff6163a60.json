:15.2,"beam":9.1,"draft":1.5,"hullType":"","superStructure":[],"engines":"2 X Yanmar 4JH4110","amenities":[{"label":"Sprayhood"},{"label":"Bimini top"},{"label":"Awning"},{"label":"Cockpit Cushions"},{"label":"Bathing platform & ladders"},{"label":"Aft shower (C/W water)"},{"label":"Transom hydraulic gangway"},{"label":"Cooker with oven"},{"label":"Refrigerator","quantity":"3"},{"label":"Wine cooler in the saloon"},{"label":"Cockpit Refrigerator"},{"label":"Ice maker"},{"label":"Microwave Oven / Grill\t"},{"label":"Dishwasher"},{"label":"Washing Machine/Dryer"},{"label":"Water maker"},{"label":"Battery charger"},{"label":"USB plugs"},{"label":"Generator"},{"label":"Inverter"},{"label":"Navigational instruments"},{"label":"Air conditioning"},{"label":"Heating system"},{"label":"Sonos Surround 5.1 (Playbar + SUB + 2x Play:1)"},{"label":"Apple Music only through Bluetooth"},{"label":"SAT Antenna"},{"label":"Speakers in Saloon & Cockpit, Flybridge, Bownet"},{"label":"TV set & Satelite"},{"label":"DVD / Blueray player"},{"label":"Internet WIFi"}],"toys":[{"label":"Water skies adult and for kids"},{"label":"Wakeboard "},{"label":"Kneeboard"},{"label":"Towable ring"},{"label":"SUP","quantity":"2"},{"label":"Snorkeling Gear: Masks & flippers"},{"label":"Beach games"},{"label":"Floating mats"}],"entertainment":["Sonos Surround 5.1 (Playbar + SUB + 2x Play:1)","Apple Music only through Bluetooth","SAT Antenna","Speakers in Saloon & Cockpit, Flybridge, Bownet","TV set & Satelite","DVD / Blueray player","Internet WIFi"],"tenders":["Zar ZF 3 tender with 70 hp outboard outboard"]},"crew":[{"name":"Vedran Banjeglav","avatar":"/media/media::image::c::8193426698::vessel::7793e2e3-486c-11ee-a45f-fdfff6163a60::assets::eccbc520-2daf-11f1-8f8d-294980853fdf/{imageVariant}","role":"Captain","bio":"NATIONALITY / AGE / LANGUAGE\nCroatian / Born 1980 / ENGLISH, CROATIAN\n\nQUALIFICATIONS\nRYA Yachtmaster Cruising Instructor, RYA/MCA Yachtmaster\nOffshore, RYA GMDSS, RYA commercial, STCW code A-VI 1\n\nVedran brings exceptional expertise, passion, with over 20 years\nat sea and more than 45,000 nautical miles sailed, and local\ninsight to every voyage. He holds a Master’s degree in Electrical\nEngineering and prestigious RYA Yachtmaster Offshore and\nGMDSS certificates (commercially endorsed), and is a Certified\nRYA Yachtmaster Cruising Instructor and lecturer at the Adria\nLibar Maritime Training Center. A three-time Croatian national\nFormula 18 catamaran racing champion, he combines high-performance\nsailing with calm, confident leadership. He has\nskippered over 200 weeks across the Adriatic, Mediterranean,\nEngland, and the Caribbean, and helped establish Croatia’s\nfirst skipper training academy. Comfortable on monohulls and\nmultihulls, sail or motor yachts up to 200 GT, he is also known\nfor his ability to resolve technical and electrical issues on board.\nWith deep knowledge of the Adriatic coast—its hidden anchorages,\nports, marinas, and restaurants—paired with a passion for\nlocal culture and gastronomy, he creates safe, relaxed, and truly\nmemorable sailing experiences."},{"name":"Vera Carli","avatar":"/media/media::image::c::8193426698::vessel::7793e2e3-486c-11ee-a45f-fdfff6163a60::assets::4a331390-17ca-11f1-a774-dfd408b00f2f/{imageVariant}","role":"Captain","bio":"NATIONALITY / AGE / LANGUAGE\nCroatian, / Born 1979 / ENGLISH, ITALIAN, CROATIAN\n\nQUALIFICATIONS\nTrained Stewardess, D2 Basic Safety (STCW) Certificate.\n\nWith over 12 years of experience in the maritime hospitality industry,\nVera brings a strong background as a former charter agency\nhousekeeper and administrator, combined with extensive onboard\nexperience as a yacht stewardess. For the past seven seasons,\nshe has worked actively as a yacht hostess, most recently completing\n16 consecutive weeks exclusively as a stewardess during\nthe charter season. She has gained hands-on experience on\nsailing yachts and catamarans up to 50 ft, as well as on a 25-metre\nmotor yacht, delivering high-standard guest service, provisioning,\ncooking, elegant food presentation, and assisting with mooring\nand anchoring procedures. During this period, Vera was also\ninvolved in fully equipping a yacht with inventory and preparing it\nfor charter following its arrival from the shipyard. She takes pride\nin creating a welcoming, well-organised, and guest-focused\nonboard environment, with strong attention to detail and a natural\nability to anticipate guest needs."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1750000,"displayCurrency":"EUR","displayPrice":1750000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":3400000,"displayCurrency":"EUR","displayPrice":3400000,"unit":"WEEK"},"pricingInfo":[{"name":"Until April 25, 2026","effectiveDates":[{"from":"2025-10-03T00:00:00.000Z","to":"2026-04-25T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1750000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1750000,"amount":1750000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0.13}},{"item":"APA","conditions":"","quantity":1,"unitPrice":700000,"amount":700000}],"total":2450000,"subTotal":2450000,"totalTax":227500},"inclusionZones":[{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910156249996,19.400976562500006,46.534619140625]}],"exclusionZones":[],"petsAllowed":false},{"name":"26 April,2026 - 30 May, 2026","effectiveDates":[{"from":"2026-04-25T00:00:00.000Z","to":"2026-05-30T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":2200000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2200000,"amount":2200000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0.13}},{"item":"APA","conditions":"","quantity":1,"unitPrice":700000,"amount":700000}],"total":29