6/{imageVariant}","/media/media::image::c::9938368400::vessel::eb4ddfa0-f060-11ee-a296-373c493b7d64::assets::bfe38460-3a32-11f0-aaa8-93e5535cd046/{imageVariant}","/media/media::image::c::9938368400::vessel::eb4ddfa0-f060-11ee-a296-373c493b7d64::assets::bfdf3ea0-3a32-11f0-aaa8-93e5535cd046/{imageVariant}","/media/media::image::a::vessel::eb4ddfa0-f060-11ee-a296-373c493b7d64::assets::924e4b90-f062-11ee-a296-373c493b7d64.jpeg/{imageVariant}","/media/media::image::a::vessel::eb4ddfa0-f060-11ee-a296-373c493b7d64::assets::924e72a0-f062-11ee-a296-373c493b7d64.jpeg/{imageVariant}","/media/media::image::a::vessel::eb4ddfa0-f060-11ee-a296-373c493b7d64::assets::924ee7d0-f062-11ee-a296-373c493b7d64.jpeg/{imageVariant}","/media/media::image::a::vessel::eb4ddfa0-f060-11ee-a296-373c493b7d64::assets::924ec0c0-f062-11ee-a296-373c493b7d64.jpeg/{imageVariant}"],"make":"Sunreef Yachts","model":"80 Sunreef Power Eco","maxCrew":4,"sleeps":10,"basePort":{"uri":"a::place::084d2f1c-b3ee-11ed-88e8-325096b39f47","name":"Olbia","coordinates":{"latitude":40.92518954,"longitude":9.507247173},"country":"Italy"},"cruisingCapacity":10,"staticCapacity":0,"builtYear":2024,"architect":"Sunreef Yachts","interiorDesigner":"Sunreef Yachts","refitYear":"","topSpeed":12,"cruiseSpeed":8,"fuelCapacity":30,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"Double Cabin","value":"3"},{"label":"Bunk Cabin","value":"1"}],"cabins":5,"bathrooms":5,"decks":"","length":23.87,"beam":11.53,"draft":2.2,"hullType":"Multi hull","hullConstruction":"Composite","tonnage":0,"superStructure":["Flybridge"],"engines":"2  x John Deere 280 HP","amenities":[{"label":"Air Conditioning"},{"label":"Solar panels"},{"label":"Jacuzzi"}],"toys":[{"label":"Jetski Sea Doo RXT 300 Triple Black"},{"label":"SUP"},{"label":"Seabobs","quantity":"2"},{"label":"eFoils","quantity":"2"},{"label":"Waterskis (Adult)"},{"label":"Wakeboard"},{"label":"Wingfoil"},{"label":"Electric Surfboard"},{"label":"Snorkel Gear & Fins "},{"label":"Kayak"},{"label":"Beach Games "},{"label":"Fishing  (casting/trawling)"}],"entertainment":["WiFi (Starlink)","Salon TV","Open-air cinema","Salon Stereo ","Device Hook Ups"],"tenders":["Williams Sportjet 520 Tender (7 x pax)"]},"crew":[{"name":"Alan Collinge","avatar":"/media/media::image::c::9938368400::vessel::eb4ddfa0-f060-11ee-a296-373c493b7d64::assets::bc85f620-3367-11f1-b49c-d9dba450e06a/{imageVariant}","role":"Captain","bio":"Nationality: South African/Irish\nLanguages: English\n\nAlan is an experienced and versatile Captain with over 10 years managing charter and private sailing vessels ranging from 14 to 24 metres. Irish/South African and born in 1991, he has logged more than 50,000 nautical miles across the Caribbean and Mediterranean. Alan brings a comprehensive skill set with great detail and care added to every trip. His background as a PADI Scuba Instructor and SPA Surf Lifesaver adds a valuable dimension to the guest experience. Alan is known for his calm adaptability, professional approach, and ability to deliver seamless charters.\n\nQualifications: RYA Yachtmaster 200GT | STCW | ENG1 | PADI Scuba Instructor | 50,000+ nm"},{"name":"Alexandra Duggan","avatar":"/media/media::image::c::9938368400::vessel::eb4ddfa0-f060-11ee-a296-373c493b7d64::assets::fac5ef80-3367-11f1-a741-17f90f5dc57b/{imageVariant}","role":"Captain","bio":"Nationality: American\nLanguages: English, Spanish\n\nAlexandra is a warm, highly capable Chief Stewardess with experience spanning 18 to 50-metre sailing and motor yachts since 2018. American by nationality and a native English speaker with advanced Spanish, she comes from a family of sailors and has lived aboard and cruised extensively, giving her a genuine passion for the sea and an intuitive understanding of the guest experience. Her skill set is broad, covering silver service, floristry, interior detailing, provisioning and wine service. Alexandra combines professionalism and meticulous attention to detail with a naturally easygoing, adventurous personality that guests consistently respond to.\n\nQualifications: STCW | ENG1 | RYA Powerboat Level 2 | G.U.E.S.T. Interior | Advanced Spanish"},{"name":"Davide Matta","avatar":"/media/media::image::c::9938368400::vessel::eb4ddfa0-f060-11ee-a296-373c493b7d64::assets::1a890a00-3368-11f1-9399-6dfdb90e8a4f/{imageVariant}","role":"Captain","bio":"Nationality: Italian\nLanguages: Italian, English\n\nDavide is an enthusiastic and hardworking deckhand from Italy. Born in 2002, he brings lots of hands-on experience to the deck. Fluent in Italian and English, Davide will be on hand managing the deck and water toys on board, a skilled tender driver and RYA Jet Ski Instructor. Polite, hands-on and full of energy, he brings real enthusiasm to every aspect of life on board, whether that's getting guests up on a surf foil for the first time or honing their jet ski skills. Davide brings his love of freediving, fishing and the sea to each day on board, making him a versatile and engaging member of the crew.\n\nQualifications: STCW | RYA Powerboat Level 2 | RYA Jetski Instructor | PADI Advanced Open"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":7900000,"displayCurrency":"EUR","displayPrice":7900000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":13000000,"displayCurrency":"USD","displayPrice":13000000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer: Mediterranean - High Season","effectiveDates":[{"from":"2026-06-15T00:00:00.000Z","to":"2026-09-15T23:59:59.999Z"},{"from":"2027-06-15T00:00:00.000Z","to":"2027-09-15T23:59:59.999Z"},{"from":"2028-06-15T00:00:00.000Z","to":"2028-09-15T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":8900000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":8900000,"amount":8900000,"conditions":"VAT & APA Excluded"},{"item":"APA","conditions":"","quantity":0.25,"unitPrice":8900000,"amount":2225000}],"total":11125000,"subTotal":11125000,"totalTax":0