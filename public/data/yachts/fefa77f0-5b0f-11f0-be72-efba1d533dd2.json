72-efba1d533dd2::assets::94ecfe50-7f31-11f0-a23d-ffd2f42ca6d7/{imageVariant}","/media/media::image::c::7646090758::vessel::fefa77f0-5b0f-11f0-be72-efba1d533dd2::assets::94ea8d50-7f31-11f0-957b-b39f0ed51369/{imageVariant}","/media/media::image::c::7646090758::vessel::fefa77f0-5b0f-11f0-be72-efba1d533dd2::assets::94eb2990-7f31-11f0-856d-4f489ef17bc4/{imageVariant}","/media/media::image::c::7646090758::vessel::fefa77f0-5b0f-11f0-be72-efba1d533dd2::assets::94ede8b0-7f31-11f0-856e-4f489ef17bc4/{imageVariant}","/media/media::image::c::7646090758::vessel::fefa77f0-5b0f-11f0-be72-efba1d533dd2::assets::94eb50a0-7f31-11f0-a23d-ffd2f42ca6d7/{imageVariant}"],"make":"Ferretti","model":"","maxCrew":5,"sleeps":12,"basePort":{"uri":"a::place::103e7ab4-b3ee-11ed-a2c5-325096b39f47","name":"Rogoznica","coordinates":{"latitude":43.52630868639182,"longitude":15.96902411338487},"country":"Croatia"},"builtYear":2013,"architect":"Ferretti Engineering Department","interiorDesigner":"","refitYear":2025,"topSpeed":27,"cruiseSpeed":12,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"Double Cabins","value":"2"},{"label":"Twin Cabins","value":"2"}],"cabins":5,"length":30.6,"beam":7.1,"draft":3.7,"hullType":"Planing","hullConstruction":"GRP","superStructure":["Flybridge"],"engines":"2 x MTU (2639 hp)","amenities":[{"label":"Air conditioning"},{"label":"Stabilisers at anchor"},{"label":"Stabilisers underway"},{"label":"Sun deck"},{"label":"Sunbeds"}],"toys":[{"label":"Yamaha Jet-ski"},{"label":"Sub surfs","quantity":"2"}],"entertainment":["Wi-Fi"],"tenders":["Tender"]},"crew":[{"name":"Franko Barac","role":"Captain","bio":"Born and raised in Split, Croatia, Franko has had a deep connection with the sea from an early age. His journey in the maritime world began as a mechanic, and through hard work and dedication, he rose through the ranks to become a highly experienced captain.\nFranko has successfully navigated charter yachts throughout the West Mediterranean and Adriatic, gaining a deep understanding of the region—especially the Adriatic, which he knows like the back of his hand. His strong leadership, technical expertise, and professional approach make him a reliable and trusted figure on board.\nKnown for his friendly nature and open-minded attitude, Franko truly enjoys meeting people from around the globe and discovering new cultures. When he's not at sea, you’ll likely find him running or hiking, always in search of new adventures on land. With Captain Franko at the helm, guests aboard M/Y MORNING STAR can look forward to a safe, relaxed, and truly memorable charter experience."},{"name":"Bartul Kacic","role":"Captain","bio":"Croatian\n\nWith over a decade of culinary experience spanning fine dining, luxury hospitality, and private yacht service, chef Bartul brings creativity, precision, and passion to the galley of M/Y Morning Star. Known for his Michelin-level approach and commitment to excellence, he crafts refined, beautifully presented dishes that consistently exceed guest expectations. Skilled in Mediterranean, Asian, Italian, and Croatian cuisines, he focuses on fresh, seasonal ingredients and tailors each menu to suit the preferences and dietary needs of those on board.\nPrior to joining the yachting industry, he honed his skills in top kitchens in Croatia, where he led culinary teams and developed high-end dining programs. He has also worked as a Private Chef in luxury villas across South Dalmatia, designing bespoke menus for discerning clientele.\n\nOrganized, calm under pressure, and deeply dedicated to guest satisfaction, the chef Bartul is an essential part of the M/Y Morning Star experience, delivering gourmet excellence at sea."},{"name":"Dino Ercegovic","role":"Captain","bio":"Croatian\n\nDino joins M/Y Morning Star for his first season with a strong technical background and hands-on experience in both engineering and deck operations. As a dual-role crew member, he efficiently manages responsibilities across both departments, ensuring the vessel's systems run smoothly while upholding high standards on deck. In addition to his engineering duties, Dino is actively involved in daily deck operations, including docking, anchoring, tender handling, and setting up water sports activities. His versatility, strong work ethic, and proactive approach make him a valuable asset to the M/Y Morning Star team."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":7000000,"displayCurrency":"EUR","displayPrice":7000000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":7500000,"displayCurrency":"EUR","displayPrice":7500000,"unit":"WEEK"},"pricingInfo":[{"name":"2026 High Rate","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":7500000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":7500000,"amount":7500000,"conditions":"VAT & APA Excluded"},{"item":"APA","conditions":"","quantity":0.4,"unitPrice":7500000,"amount":3000000}],"total":10500000,"subTotal":10500000,"totalTax":0},"inclusionZones":[{"label":"Montenegro","type":"Sovereign country","category":["Europe","Southern Europe","Montenegro"],"coordinates":[19.238839392474098,42.7889025929079],"bbox":[18.436328125000017,41.869091796875,20.34765625,43.542333984375]},{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910156249996,19.400976562500006,46.534619140625]}],"exclusionZones":[],"petsAllowed":false},{"name":"2026 Low Rate","effectiveDates":[{"from":"2025-09-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2028-06-30T23:59:59.9