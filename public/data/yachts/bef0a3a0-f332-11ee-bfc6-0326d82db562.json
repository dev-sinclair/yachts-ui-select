xperience as a professional skipper, he has worked for various charters and agencies, including Navigare Yachting, Baotic Charter, Sail Croatia, Sailweek Croatia, and Way Point, in Croatia. He has also worked as a bareboat skipper for two seasons in the Caribbean (BVI) for Moorings, where he was responsible for check-ins, outs, briefings, and interventions on malfunctioning boats."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1170000,"displayCurrency":"EUR","displayPrice":1170000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1540000,"displayCurrency":"EUR","displayPrice":1540000,"unit":"WEEK"},"pricingInfo":[{"name":"01.01. - 23.05. & 20.09. - 31.12.","effectiveDates":[{"from":"2025-01-01T00:00:00.000Z","to":"2025-05-23T23:59:59.999Z"},{"from":"2026-01-01T00:00:00.000Z","to":"2026-05-23T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-05-23T23:59:59.999Z"},{"from":"2025-09-20T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"},{"from":"2026-09-20T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-09-20T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1170000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1170000,"amount":1170000,"conditions":"Weekly"}],"total":1170000,"subTotal":1170000,"totalTax":0},"inclusionZones":[{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910156249996,19.400976562500006,46.534619140625]}],"exclusionZones":[],"petsAllowed":false},{"name":"24.05. - 27.06. & 30.08. - 19.09.","effectiveDates":[{"from":"2025-05-24T00:00:00.000Z","to":"2025-06-27T23:59:59.999Z"},{"from":"2026-05-24T00:00:00.000Z","to":"2026-06-27T23:59:59.999Z"},{"from":"2027-05-24T00:00:00.000Z","to":"2027-06-27T23:59:59.999Z"},{"from":"2025-08-30T00:00:00.000Z","to":"2025-09-19T23:59:59.999Z"},{