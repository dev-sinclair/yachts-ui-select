/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e45978a0-edbf-11ef-8059-97f0daf1aa15/{imageVariant}","/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e45d9750-edbf-11ef-8059-97f0daf1aa15/{imageVariant}","/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e4675b50-edbf-11ef-8cba-29ec0cc973fd/{imageVariant}","/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e44ddfe0-edbf-11ef-a2c5-df66a4fc12ad/{imageVariant}","/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e44fdbb0-edbf-11ef-a2c5-df66a4fc12ad/{imageVariant}","/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e423e9b0-edbf-11ef-8cb9-29ec0cc973fd/{imageVariant}","/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e48a2590-edbf-11ef-8cba-29ec0cc973fd/{imageVariant}","/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e4279330-edbf-11ef-8059-97f0daf1aa15/{imageVariant}","/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e44bbd00-edbf-11ef-8cb9-29ec0cc973fd/{imageVariant}","/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e44f8d90-edbf-11ef-8cb9-29ec0cc973fd/{imageVariant}"],"make":"Sunseeker","model":"","maxCrew":4,"sleeps":6,"basePort":{"uri":"a::place::103e7cb2-b3ee-11ed-9c4a-325096b39f47","name":"Saint Kitts and Nevis","coordinates":{"latitude":17.32594683,"longitude":-62.75331127},"country":"Saint Kitts and Nevis"},"builtYear":2024,"architect":"","interiorDesigner":"","topSpeed":22,"cruiseSpeed":15,"fuelCapacity":0,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabins","value":"2"},{"label":"Convertible Cabins","value":"2"}],"cabins":5,"bathrooms":5,"length":29,"beam":6.7,"draft":2.1,"hullType":"","hullConstruction":"GRP","tonnage":0,"superStructure":[],"engines":"2x MTU 12V 2000 M96L","amenities":[{"label":"Air Conditioning"},{"label":"Sundeck"},{"label":"Jacuzzi tub"},{"label":"Wetbar"},{"label":"Retractable awning"},{"label":"Sun pad"},{"label":"Deck Shower"},{"label":"Hairdryers"},{"label":"Ice Maker"},{"label":"Children Allowed"},{"label":"Stabilizers"}],"toys":[{"label":"SUP","quantity":"2"},{"label":"Sublu Sea Scooters","quantity":"5"},{"label":"Tube ","quantity":"2"},{"label":"Wakeboard","quantity":"1"},{"label":"Slalom Ski"},{"label":"8 x 6 Inflatable pad Nauti Boy"},{"label":"floating chairs and ring for cooler","quantity":"2"},{"label":"poles for spearfishing","quantity":"2"},{"label":"Snorkel gear","quantity":"8"}],"entertainment":["Salon Stereo","Salon TV","SAT TV","Onboard WIFI"],"tenders":["5m Williams Jet tender"]},"crew":[{"name":"Jacob Rich","avatar":"/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::e2e76780-edbe-11ef-9e7a-2984fe5f1cda/{imageVariant}","role":"Captain","bio":"Nationality: British\n\nJacob grew up on the South Coast of England sailing a small 32; family boat. He left school at 16 and has been working in the marine industry\never since, he has a passion for providing guests the most incredible experience during their time onboard. Jacob has a great love for training\nand developing new and less experienced crew members to help enable them to develop into highly skilled and professional seafarers. When\ntime allows, he can usually be found playing a round of golf, scuba diving or enjoying exploring the local area. Jacob has a wealth of\nexperience on yachts from 15m-60m and his door is always open to discuss anchorages or cruising itineraries.\n\n\n"},{"name":"Justin Claassens","avatar":"/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::03619d00-edbf-11ef-8696-d540c7aa7523/{imageVariant}","role":"Captain","bio":"Nationality: South African\n\nJustin Claassens, born in South Africa and raised on Kenyaâs coast, has a lifelong passion for the ocean and adventure. Exploring East Africaâs coastlines from a young age, he gained hands-on marine experience and a deep appreciation for nature. Known for his technical skill and warm approach, Justin creates engaging onboard experiences, blending thrilling adventures with respect for marine ecosystems.\nEach journey he leads is memorable and enriching, from navigating secluded waters to sharing his knowledge of the ocean."},{"name":"Alicia Mackenzie","avatar":"/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::46c644b0-edbf-11ef-b1a9-a5b4f3a10ad2/{imageVariant}","role":"Captain","bio":"Growing up with parents in the yachting industry, Alicia was drawn to the ocean from an early age. Originally from the UK and raised in Majorca, she brings a unique blend of British charm and Mediterranean warmth to her role. Over the past four years, she has worked as a stewardess throughout the Mediterranean, where her exceptional service, attention to detail, and creativity have set her apart. A certified Dive\nMaster, Alicia has a deep appreciation for marine life, and her love for the sea shines through in every aspect of her work. Known for crafting beautiful cocktails and designing elegant table settings, she creates a welcoming and memorable atmosphere on board, ensuring each guest enjoys a truly elevated experience.\n"},{"name":"Jennifer Swanepoel","avatar":"/media/media::image::a::vessel::5abacbb0-4074-11ef-8878-cf167aca1c3d::assets::70c06c50-edbf-11ef-934c-7f669df93556/{imageVariant}","role":"Captain","bio":"Nationality: South African\n\nJennifer is an accomplished chef from the East Coast of South Africa with over eight years of experience in land-based kitchens and one year on motor yachts, including time aboard a busy charter yacht.A true culinary professional, Jennifer is highly skilled in crafting innovative menus that cater to a wide range of dietary needs, from vegan and vegetarian to specialized dietary requirements. She excels at creating delicious,\nwell-balanced dishes that not only delight the palate but also promote healthy living. Jennifer\\'s organizational skills and attention to detail ensure smooth operations in the galley, allowing her to consistently deliver exceptional dining experiences. Her ability to plan, execute, and adapt menus ensures that guests are always treated to an unforgettable culinary journey. Known for her creativity, discipline, and passion for\ngreat food, Jennifer is a mature, non-smoking, and drama-free individual who fosters positive, collaborative relationships with her team. Her commitment to excellence and love for cooking is evident in every dish she prepares, making her an asset to any yacht galley.\n"}],"pricing":{"weekPricingFrom":{"currency":"USD","price":9500000,"displayCurrency":"USD","displayPrice":9500000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":11500000,"displayCurrency":"USD","displayPrice":11500000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer/Winter - Low Season","effectiveDates":[{"from":"2026-05-01T00:00:00.000Z","to":"2026-12-14T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-12-14T23:59:59.999Z"},{"from":"2028-05-01T00:00:00.000Z","to":"2028-12-14T23:59:59.999Z"}],"pricing":{"currency":"USD","charterFee":9500000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":9500000,"amount":9500000,"conditions":"VAT & APA Excluded"}],"total":9500000,"subTotal":9500000,"totalTax":0},"inclusionZones":[{"label":"British Virgin Is.","type":"Dependency","category":["North America","Caribbean","British Virgin Is."],"coordinates":[-64.45080373172777,18.568736231458896],"bbox":[-64.69511718749999,18.399121093749997,-64.273583984375,18.752685546875]},{"label":"U.S. Virgin Is.","type":"Dependency","category":["North America","Caribbean","U.S. Virgin Is."],"coordinates":[-64.79221690684143,18.050874527948764],"bbox":[-65.0236328125,17.701708984375003,-64.58046875,18.385205078124997]},{"label":"Anguilla","type":"Dependency","c