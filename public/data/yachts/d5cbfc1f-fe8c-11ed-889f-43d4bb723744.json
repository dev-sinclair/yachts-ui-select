::c::7580644139::vessel::d5cbfc1f-fe8c-11ed-889f-43d4bb723744::assets::53281030-9e79-11ee-ae0d-9db43ce60480.jpeg/{imageVariant}","/media/media::image::c::7580644139::vessel::d5cbfc1f-fe8c-11ed-889f-43d4bb723744::assets::3d5df4b0-1915-11ef-a4a2-df0c75334a61.jpeg/{imageVariant}","/media/media::image::c::7580644139::vessel::d5cbfc1f-fe8c-11ed-889f-43d4bb723744::assets::5326b0a0-9e79-11ee-ae0d-9db43ce60480.jpeg/{imageVariant}"],"make":"Custom","model":"","maxCrew":4,"sleeps":8,"basePort":{"uri":"a::place::d51ce592-b3ed-11ed-9373-325096b39f47","name":"Bodrum","coordinates":{"latitude":37.03482562918905,"longitude":27.42932494208488},"country":"Türkiye"},"builtYear":2007,"architect":"","interiorDesigner":"","refitYear":2019,"topSpeed":10,"cruiseSpeed":"","fuelCapacity":"","cabinLayout":[{"label":"Master Cabin","value":"2"},{"label":"VIP Cabin","value":"2"}],"cabins":4,"bathrooms":"","decks":"","length":32,"beam":7.4,"draft":0,"hullType":"","hullConstruction":"","tonnage":"","superStructure":[],"engines":"","amenities":[{"label":"Air Conditioning"},{"label":"Heating"},{"label":"Dishwasher"},{"label":"Oven"},{"label":"Refrigerator"}],"toys":[{"label":"Banana"},{"label":"Fishing Equipment"},{"label":"Hamburger/Ringo"},{"label":"Jet Ski"},{"label":"Paddle Board"},{"label":"Snorkeling Equipment"},{"label":"Water Ski"}],"entertainment":["Internet","DVD","TV","Satellite","Music Player","Game Console"],"tenders":[]},"crew":[{"name":"Yılmaz Akgül","avatar":"/media/media::image::c::7580644139::vessel::d5cbfc1f-fe8c-11ed-889f-43d4bb723744::assets::594c1870-1cf1-11ef-8b60-c9be471191a8.png/{imageVariant}","role":"Captain","bio":"Yilmaz is 29 years old and he is holding a Class Captain's Diploma (Yacht Captain). He also holds Certificates in First Aid and he is an expert in several Survival Techniques, counting many years of experience in the yachting industry. Captain Yilmaz will take good care of the guests, being a hardworking and responsible person. The lucky guests will surely enjoy their cruise in the hands of Cpt. Yilmaz , as they will visit truly amazing destinations with turquoise waters. In his free time, he likes travelling with his family. Speaks Turkish and English."},{"name":"Alim Uygun","avatar":"/media/media::image::c::7580644139::vessel::d5cbfc1f-fe8c-11ed-889f-43d4bb723744::assets::678573f0-1cf1-11ef-8b60-c9be471191a8.png/{imageVariant}","role":"Captain","bio":"Alim chef is 60 years old and he is very experienced with the yachting kitchen. He has all certificates about the kitchen and he worked luxury yachts for more than 25 years and now he will prepare for the our guests delicious dishes of the Mediterranean cuisine, using the freshest ingredients and giving great attention to each detail on the presentation too. Alim chef has also some special recipes about the some different cuisine for his guests. He has a pleasant character with a genuine smile on his face that will make the guests feel very comfortable on board. In his spare time, he likes to be with his family and spending time with his friends. Speaks Turkish and middle level English."},{"name":"Umur Yıldırım","avatar":"/media/media::image::c::7580644139::vessel::d5cbfc1f-fe8c-11ed-889f-43d4bb723744::assets::7b376a20-1cf1-11ef-8b60-c9be471191a8.png/{imageVariant}","role":"Captain","bio":"Umur is 22 years old and he has been working for 5 years with the quality yachts as stewardess and deck hand. He is looking forward to welcoming the guests onboard with his wonderful smile, applying his excellent organisational skills and offering the best service. Umur will try to create for the guests an unforgettable cruising experience with his team! In his free time, he likes to watch movie and reading books. Speaks Turkish and middle level English"},{"name":"Ahmet Önder","avatar":"/media/media::image::c::7580644139::vessel::d5cbfc1f-fe8c-11ed-889f-43d4bb723744::assets::8a24ac50-1cf1-11ef-8b60-c9be471191a8.png/{imageVariant}","role":"Captain","bio":"Ahmet is 20 years old and he has been working for 3 years with the quality yachts as stewardess and deck hand. He is graduated from Seamen high scholl in Bodrum and he is working for us in 2 years. He is looking forward to welcoming the guests onboard with his wonderful smile, applying his excellent organisational skills and offering the best service. Ahmet will try to create for the guests an unforgettable cruising experience with his team! In his free time, he likes to watch movie and reading books. Speaks Turkish and basic level English."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1750000,"displayCurrency":"EUR","displayPrice":1750000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":3220000,"displayCurrency":"EUR","displayPrice":3220000,"unit":"WEEK"},"pricingInfo":[{"name":"May & October","effectiveDates":[{"from":"2024-05-01T00:00:00.000Z","to":"2024-05-31T23:59:59.999Z"},{"from":"2025-05-01T00:00:00.000Z","to":"2025-05-31T23:59:59.999Z"},{"from":"2026-05-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2024-10-01T00:00:00.000Z","to":"2024-10-31T23:59:59.999Z"},{"from":"2025-10-01T00:00:00.000Z","to":"2025-10-31T23:59:59.999Z"},{"from":"2026-10-01T00:00:00.000Z","to":"2026-10-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1750000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1750000,"amount":1750000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0.2}}],"total":2100000,"subTotal":1750000,"totalTax":350000},"inclusionZones":[{"label":"Turkey","type":"Sovereign country","category":["Asia","Western Asia","Turkey"],"coordinates":[35.10531997715448,39.093802942376584],"bbox":[25.6689453125,35.831445312499994,44.81718750000002,42.09326171875]}],"exclusionZones":[],"petsAllowed":false},{"name":"June & September","effectiveDates":[{"from":"2024-06-01T00:00:00.000Z","to":"2024-06-30T23:59:59.999Z"},{"from":"2025-06-01T00:00:00.000Z","to":"2025-06-30T23:59:59.999Z"},{"from":"2026-0