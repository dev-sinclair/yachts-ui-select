7646090758::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::e3d00720-5b09-11f0-87d7-4b77643e0e03/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::e3ce3260-5b09-11f0-b012-61e1f17add17/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::e3ce0b50-5b09-11f0-87d5-4b77643e0e03/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::e3d0f180-5b09-11f0-87d7-4b77643e0e03/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::e3ce5970-5b09-11f0-87d6-4b77643e0e03/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::e3d0ca70-5b09-11f0-87d7-4b77643e0e03/{imageVariant}","/media/media::image::c::7646090758::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::e3cd4800-5b09-11f0-b012-61e1f17add17/{imageVariant}"],"make":"Custom","model":"","maxCrew":8,"sleeps":12,"basePort":{"uri":"a::place::27c28dba-b3ee-11ed-9755-325096b39f47","name":"Split","coordinates":{"latitude":43.51359615,"longitude":16.43884676},"country":"Croatia"},"cruisingCapacity":"","builtYear":2023,"topSpeed":12,"cruiseSpeed":10,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"6"}],"cabins":6,"bathrooms":6,"length":41.78,"beam":8.4,"draft":2.6,"hullType":"Displacement","hullConstruction":"Steel","superStructure":["Flybridge"],"engines":" 2 x Cummins 455HP","amenities":[{"label":"Air Conditioning"},{"label":"Deck Jacuzzi"},{"label":"Flybridge"},{"label":"Bar"},{"label":"BBQ"},{"label":"Generator"}],"toys":[{"label":"Jet ski Seadoo GTI 130","quantity":"2"},{"label":"Seabob FS","quantity":"2"},{"label":"Efoil"},{"label":"SUP"},{"label":"Water Slide"},{"label":"Water ski (adults and children)"},{"label":"Sea scooters","quantity":"2"},{"label":"Wakeboard"},{"label":"Kayaks"},{"label":"Donuts"},{"label":"Tube for 3 persons"},{"label":"Snorkeling equipment"}],"entertainment":[],"tenders":["Tender Rib Marine 650 Exclusive with outboarder Mercury 150 HP"]},"crew":[{"name":"Antonio Pusic","avatar":"/media/media::image::a::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::dc3e6c60-0eea-11f0-bf54-1d971ca4fbc4/{imageVariant}","role":"Captain","bio":"Croatian\n\nCaptain Antonio is an eloquent and proficient sailor with a decade-long career aboard prestigious yachts, ensuring an unforgettable voyage. Fluent in English and Croatian, and holding a B1 proficiency in German, Antonio is highly dedicated to his career, with a keen focus on details and leadership skills. He holds various licenses, including Yachtmaster Offshore 500 GT, and excels in a wide range of tasks, from navigation to maintenance, making him the ideal captain for a luxurious charter experience.\n\n"},{"name":"Josip Babic","avatar":"/media/media::image::a::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::ef0195c0-0eea-11f0-bf54-1d971ca4fbc4/{imageVariant}","role":"Captain","bio":"Croatian\n\nA Croatian culinary maestro, Chef Josip, brings exceptional dishes and expertise to the luxury yacht’s kitchen. His education and certifications reflect a commitment to meeting the highest standards of fine dining. Modest yet exceptionally hardworking and creative, Chef Josip’s reliability and dedication make him an invaluable asset in crafting delicious and unique meals for guests."},{"name":"Marina Mihanovic","avatar":"/media/media::image::a::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::0a9c3c40-0eeb-11f0-9f5d-c98fb411bf73/{imageVariant}","role":"Captain","bio":"Croatian\n\nMarina is an enthusiastic and positive individual who excels in creativity, teamwork, and effective communication. Known for her attention to detail and attentiveness, she has many years of experience in fine dining restaurants, making her highly skilled at delivering exceptional service. In her free time, Marina enjoys DIY projects, producing olive oil, fishing and spearfishing,and exploring new foods and cuisines."},{"name":"Petra Jakšić","role":"Captain","bio":"Petra is a dynamic yacht stewardess with a passion for the sea and a knack for keeping guests happy and active. For the past three seasons, Petra has worked as a stewardess on private yachts in the Mediterranean, where she excelled in ensuring guest satisfaction by planning trips, booking restaurants, and ..Petra’s got a talent for adapting to any situation and person, and her energy is contagious. When she’s not on board, you’ll find her swimming, dancing, horse riding, or hiking. She’s hardworking, organized, and always up for the next adventure!"},{"name":"Suncica Pivcevic","avatar":"/media/media::image::a::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::2a27cc00-0eeb-11f0-a40a-3b4923640f49/{imageVariant}","role":"Captain","bio":"Croatian\n\nSuncica is a responsible, open, and resourceful individual, always bringing a positive attitude and a smile. With experience as a deckhand and junior stewardess on luxury yachts, she is enthusiastic and dedicated to providing excellent service. Her skills and positive energy make her a valuable addition to the crew onboard MARALLURE."},{"name":"Ivan Marović","avatar":"/media/media::image::a::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::39eea550-0eeb-11f0-a40a-3b4923640f49/{imageVariant}","role":"Captain","bio":"Croatian\n\nBorn in Split, in the heart of the Croatian coast, Ivan naturally gravitated toward a career at sea. After graduating from the Technical School of Engineering and Mechanics in Split in 2008, he began working as a marine mechanic, focusing on yacht maintenance and upgrading various systems and equipment. Over the years, Ivan continued to expand his skills and knowledge, gaining valuable experience as a deckhand and engineer on private yachts. Today, his expertise and dedication make him a highly valued member of the crew onboard MARALLURE. Ivan is always willing to go the extra mile to ensure tasks are completed to the highest standard, consistently demonstrating initiative and a broad range of job knowledge."},{"name":"Jakov Mandić","avatar":"/media/media::image::a::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::7bd53880-0eeb-11f0-a3d2-f1769417d5bb/{imageVariant}","role":"Captain","bio":"Croatian\n\nJakov is a friendly and hardworking deckhand, dedicated to ensuring guests have the best experience onboard. Approachable and attentive, he takes pride in keeping the yacht running smoothly, from maintaining the vessel to assisting guests. Reliable and always ready to help with a smile, Jakov is an invaluable part of the team."},{"name":"Mihael Juric","avatar":"/media/media::image::a::vessel::d5cbd359-fe8c-11ed-889f-43d4bb723744::assets::906077b0-0eeb-11f0-a3d2-f1769417d5bb/{imageVariant}","role":"Captain","bio":"Croatian\n\nMihael is a hardworking and self-motivated deckhand with three seasons of yachting experience. He is committed to advancing his career in the industry, consistently contributing to team dynamics and fostering a collaborative work environment. With a passion for the sea and travel, Mihael combines his technical knowledge, hospitality skills, and positive attitude to enhance the charter experience for every guest."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":7900000,"displayCurrency":"EUR","displayPrice":7900000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":8900000,"displayCurrency":"EUR","displayPrice":8900000,"unit":"WEEK"},"pricingInfo":[{"name":"High Season (May, July and August)","effectiveDates":[{"from":"2026-05-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-05-31T23:59:59.999Z"},{"from":"2028-05-01T00:00:00.000Z","to":"2028-05-31T23:59:59.999Z"},{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"p