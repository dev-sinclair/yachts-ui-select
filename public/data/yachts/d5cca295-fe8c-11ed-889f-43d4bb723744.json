09c1a.jpeg/{imageVariant}","/media/media::image::c::7580644139::vessel::d5cca295-fe8c-11ed-889f-43d4bb723744::assets::c33678d0-f752-11ee-9746-156bf8809c1a.jpeg/{imageVariant}","/media/media::image::c::7580644139::vessel::d5cca295-fe8c-11ed-889f-43d4bb723744::assets::ad4a4a10-f752-11ee-9746-156bf8809c1a.jpeg/{imageVariant}"],"make":"","model":"","maxCrew":6,"sleeps":12,"builtYear":2005,"architect":"","interiorDesigner":"","refitYear":2022,"topSpeed":11,"cruiseSpeed":"","fuelCapacity":"","cabinLayout":[{"label":"Master Cabins","value":"2"},{"label":"Double Cabin","value":"1"},{"label":"Twin Cabins","value":"2"}],"cabins":5,"bathrooms":"","length":40,"beam":8,"draft":"","hullType":"","hullConstruction":"Timber","tonnage":"","superStructure":[],"engines":"","amenities":[{"label":"Dishwasher"},{"label":"Satellite"},{"label":"Oven"},{"label":"Music Player"},{"label":"Air Conditioning"},{"label":"Game Console"},{"label":"DVD"},{"label":"TV"}],"toys":[{"label":"Banana"},{"label":"Canoe"},{"label":"Fishing Equipment"},{"label":"Hamburger/Ringo"},{"label":"Jet Ski"},{"label":"Knee Board"},{"label":"Paddle Board"},{"label":"Snorkeling Equipment"},{"label":"Wake Board"},{"label":"Water Ski"}],"entertainment":["Music Player","Satellite","Game Console","DVD","TV"],"tenders":[]},"crew":[{"name":"Hasan Atık","avatar":"/media/media::image::c::7580644139::vessel::d5cca295-fe8c-11ed-889f-43d4bb723744::assets::5a14e3c0-14fb-11ef-8dd9-555757fb0739.png/{imageVariant}","role":"Captain","bio":"I was born in Mugla, Koycegiz in 1986. I have always been\npassionate about the water, and participated heavily in water\nsports during high school. My professional career started when\nI was 18, working as a seaman on charter yachts and ships. I\nthen graduated to first-mate on larger motor yachts and\nworked on a variety of builds, including Canados, Sunseeker\nand Azimut. At the age of 30, I graduated to Captain and have\nbeen Captaining Gulets for the last 8 years.\nI have extensive cruising experience in Turkey and throughout\nthe Mediterranean and I look forward to welcoming you\nonboard DOUBLE EAGLE and showing you our magnificent\ncruising area."},{"name":"Akın Ünal","avatar":"/media/media::image::c::7580644139::vessel::d5cca295-fe8c-11ed-889f-43d4bb723744::assets::7bfcb300-14fb-11ef-8dd9-555757fb0739.png/{imageVariant}","role":"Chef","bio":"I was born in 1994 in Tekirdag, Turkey. I graduated from\nTekirdag Anatolian Vocational School of Tourism in the\nDepartment of Culinary Arts. I have been working\nprofessionally as a chef since 2009. In addition to working in\ninternational 5-star hotels and chain restaurants, I also\ncontinue my profession as a culinary instructor. In 2012, I won\nbronze at an international gastronomy festival, and in 2023 I\nreceived the honours award at the TYBA Boat Show.\nSince 2020, I have been working as a yacht chef. Cooking on\nthe sea not only nourishes my soul but also turns the dishes I\ncreate into works of art inspired by the sea. For me, cooking is\nfar beyond ordinary, it's an art. When I'm not cooking, I work\nas a yoga and breath instructor, which is my second profession.\nMy hobbies include traveling, canoeing, and listening to music."},{"name":"Batuhan Yorulmaz","avatar":"/media/media::image::c::7580644139::vessel::d5cca295-fe8c-11ed-889f-43d4bb723744::assets::a424b2b0-14fb-11ef-8dd9-555757fb0739.png/{imageVariant}","role":"Deckhand","bio":"I am 22 years old and was born in the Ortaca district of Muğla\nso I’ve always been around the sea. I graduated from maritime\nhigh school and have been working as a as Master Sailor on\nGulets both within Turkey and overseas. I am proficient in\nwater sports and sailing and look forward to getting our guests\nout on the water."},{"name":"Mert Müküs","avatar":"/media/media::image::c::7580644139::vessel::d5cca295-fe8c-11ed-889f-43d4bb723744::assets::bf591d50-14fb-11ef-8dd9-555757fb0739.png/{imageVariant}","role":"Deckhand","bio":""},{"name":"Nuray Demir","avatar":"/media/media::image::c::7580644139::vessel::d5cca295-fe8c-11ed-889f-43d4bb723744::assets::d0c987f0-14fb-11ef-8dd9-555757fb0739.png/{imageVariant}","role":"Chief Stewardess","bio":"I was born in İstanbul in 1995. Following the completion of my\nuniversity degree, I moved to Bodrum to complete my associate\ndegree in Business. During these years, I found a love for working in\ntourism and with my passion for travel and progress, the charter\nyacht industry is my perfect fit. It is a great joy for me to care for\nguests and to respond instantly to their needs. I love being a part of\na team and contributing to providing unforgettable memories for\nour guests. As a staff member who has worked in the sector for\nalmost 3 years, I am still excited to host our guests every day!"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":3000200,"displayCurrency":"EUR","displayPrice":3000200,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":4900000,"displayCurrency":"EUR","displayPrice":4900000,"unit":"WEEK"},"pricingInfo":[{"name":"May & October","effectiveDates":[{"from":"2024-05-01T00:00:00.000Z","to":"2024-05-31T23:59:59.999Z"},{"from":"2025-05-01T00:00:00.000Z","to":"2025-05-31T23:59:59.999Z"},{"from":"2026-05-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2024-10-01T00:00:00.000Z","to":"2024-10-31T23:59:59.999Z"},{"from":"2025-10-01T00:00:00.000Z","to":"2025-10-31T23:59:59.999Z"},{"from":"2026-10-01T00:00:00.000Z","to":"2026-10-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":3000200,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":3000200,"amount":3000200,"conditions":"per week","taxRate":{"label":"VAT","value":0.2}}],"total":3600240,"subTotal":3000200,"totalTax":600040},"inclusionZones":[{"label":"Turkey","type":"Sovereign country","category":["Asia","Western Asia","Turkey"],"coordinates":[35.10531997715448,39.093802942376584],"bbox":[25.6689453125,35.831445312499994,44.8171875000000