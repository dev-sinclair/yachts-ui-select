"cabinLayout":[{"label":"Double Cabins","value":"6"}],"cabins":6,"bathrooms":4,"length":15.15,"beam":8.1,"draft":1.7,"hullType":"Catamaran","engines":"2 x 80 ","amenities":[{"label":"Fridge"},{"label":"Freezer"},{"label":"Sink"},{"label":"Cooker/Stove"},{"label":"Oven"},{"label":"BBQ/Grill"},{"label":"Coffee Machine"},{"label":"Microwave "},{"label":"Kitchen Utensils "},{"label":"Water Maker"},{"label":"Ice Maker"},{"label":"Dishwasher"},{"label":"Washing Machine"},{"label":"Air Conditioning"},{"label":"Heating System"},{"label":"Pillows and blankets in cockpit"},{"label":"Shower"},{"label":"Outside Shower"},{"label":"Sun Pads"},{"label":"Black water tank"},{"label":"Inside (saloon) GPS plotter"},{"label":"Outside GPS plotter"},{"label":"Solar Panels"},{"label":"Teak deck "},{"label":"Electric winches"},{"label":"Radar"},{"label":"Inverter"},{"label":"Autopilot"},{"label":"Bimini"},{"label":"Bow thruster"},{"label":"Bathing platform"},{"label":"Generator"}],"toys":[{"label":"Water toys"}],"entertainment":["Inside speakers","Outside deck speakers","Radio CD / MP3 player / Audio system","Flat screen TV"],"tenders":[]},"crew":[{"name":"Panagiotis Panagiotopoulos","avatar":"/media/media::image::c::19057481779::vessel::e7455840-3a0e-11f0-8892-61970e8f798b::assets::e9a9b200-2777-11f1-89e8-237fba4600ff/{imageVariant}","role":"Captain","bio":"Panagiotis is an experienced and approachable yacht skipper with many years in professional charter sailing. \nHe combines a deep love for the sea with a strong understanding of what creates a truly memorable yachting experience.\nHaving worked extensively in Greece and abroad, he brings both international charter expertise and in-depth local knowledge to every voyage. He has sailed across all major Greek cruising areas—including the Cyclades, Ionian, Dodecanese, and Saronic Gulf—and excels at tailoring each itinerary to weather conditions, guest preferences, and hidden local highlights.\nFluent in English, with working knowledge of Italian and basic Spanish, Panagiotis ensures smooth communication and a welcoming onboard atmosphere. Guests can expect not only safe and seamless sailing, but also authentic experiences, beautiful anchorages, and thoughtfully designed routes away from the crowds.\nWith a solid technical background and hands-on experience in yacht systems and maintenance, he operates every yacht with care, efficiency, and attention to detail. Calm, organized, and safety-conscious, Panagiotis creates a relaxed environment where guests can fully unwind and enjoy their time at sea.\nFriendly, professional, and genuinely hospitable, Panagiotis is a captain guests trust—and one they look forward to sailing with again."},{"name":"Nikos Tzilakos","avatar":"/media/media::image::c::19057481779::vessel::e7455840-3a0e-11f0-8892-61970e8f798b::assets::051de4c0-2778-11f1-89e8-237fba4600ff/{imageVariant}","role":"Captain","bio":"Nikos is a dynamic, reliable, and highly motivated steward who brings a strong work ethic and a versatile skill set to every vessel he joins. He is widely recognized as a hard-working and valuable crew member, always proactive and willing to support his colleagues, contributing to a positive, cooperative, and efficient onboard environment. His team-oriented mindset and excellent communication skills allow operations to run smoothly and professionally at all times.\nIn addition to his solid maritime experience, Nikos holds certifications in First Aid, a sailing license, and a scuba diving certification, adding significant value to the overall safety and capability of the crew. He is confident, safety-aware, and comfortable taking responsibility when needed. One of his strongest additional assets is his passion and talent for cooking. Although not a professional chef, Nikos is an excellent cook who consistently prepares high-quality, delicious meals, greatly enhancing crew morale and onboard life. His genuine love for the sea, combined with his enthusiasm, adaptability, and positive energy, makes him a well-rounded and dependable steward who elevates the experience for both crew and guests alike."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1300000,"displayCurrency":"EUR","displayPrice":1300000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1500000,"displayCurrency":"EUR","displayPrice":1500000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rate - High Season","effectiveDates":[{"from":"2026-06-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-06-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-06-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1500000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1500000,"amount":1500000,"conditions":"VAT and APA not included","taxRate":{"label":"VAT","value":0.12}},{"item":"APA","conditions":"","quantity":1,"unitPrice":375000,"amount":375000}],"total":2055000,"subTotal":1875000,"totalTax":180000},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]},{"label":"Mykonos","type":"Custom Area","category":["Mykonos"],"coordinates":[25.417890518546145,37.444344530734035],"bbox":[25.283314533252252,37.37813369198719,25.614171339867283,37.50947159695451]},{"label":"Athens, Attiki, Greece","type":"Custom Area","category":["Athens"],"coordinates":[23.754167000000002,38.033333],"bbox":[23.591667,37.908333,23.916667,38.158333]}],"exclusionZones":[],"petsAllowed":true},{"name":"Weekly Rate - Low Season ","effectiveDates":[{"from":"2026-04-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2027-04-01T00:00:00.000Z","to":"2027-05-31T23:59:59.999Z"},{"from":"2028-04-01T00:00:00.000Z","to":"2028-05-31T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2