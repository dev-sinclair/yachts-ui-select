e::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::81a91d90-a03c-11ee-9209-29ad3ed1d3b4.jpeg/{imageVariant}","/media/media::image::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::829be200-a03c-11ee-9209-29ad3ed1d3b4.jpeg/{imageVariant}","/media/media::image::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::838075a0-a03c-11ee-9209-29ad3ed1d3b4.jpeg/{imageVariant}","/media/media::image::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::84a74260-a03c-11ee-9209-29ad3ed1d3b4.jpeg/{imageVariant}","/media/media::image::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::8615c680-a03c-11ee-9209-29ad3ed1d3b4.jpeg/{imageVariant}","/media/media::image::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::87bdd130-a03c-11ee-9209-29ad3ed1d3b4.jpeg/{imageVariant}","/media/media::image::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::88b131e0-a03c-11ee-9209-29ad3ed1d3b4.jpeg/{imageVariant}"],"make":"Ferretti","model":"Ferretti 68","maxCrew":4,"sleeps":8,"basePort":{"uri":"a::place::5e595eb8-b3ed-11ed-be02-325096b39f47","name":"Athens","coordinates":{"latitude":37.986174,"longitude":23.7268443},"country":"Greece"},"builtYear":2001,"refitYear":2022,"cruiseSpeed":26,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Twin Cabin","value":"2"}],"cabins":4,"bathrooms":3,"length":21.16,"beam":5.64,"draft":2,"hullType":"","superStructure":[],"engines":"2 x 1200hp MAN","amenities":[{"label":"Generators","quantity":2},{"label":"Sun Deck","quantity":1},{"label":"Bimini","quantity":1},{"label":"Flybridge","quantity":1},{"label":"Sun Loungers","quantity":2},{"label":"Wi-Fi","quantity":1},{"label":"Salon TV","quantity":1},{"label":"TV in Master cabin","quantity":1},{"label":"TV in VIP cabin","quantity":1},{"label":"Sonos System","quantity":1},{"label":"Underwater lights","quantity":1}],"toys":[{"label":"Dinghy","quantity":1},{"label":"Swim Platform","quantity":1},{"label":"Jet Ski SeaDoo Sparx Trixx 2UP (2-seater)","quantity":1},{"label":"SeaBob Platin Silver F5S","quantity":1},{"label":"SU paddle boards","quantity":1},{"label":"Canoe (2-seater)","quantity":1},{"label":"Water ski (for adult & children)","quantity":1},{"label":"Snorkeling Equipment","quantity":1},{"label":"Fishing Equipment","quantity":1},{"label":"Various tubes","quantity":1},{"label":"Bikes","quantity":2}],"entertainment":["Wi-Fi","Salon TV","TV in Master cabin","TV in VIP cabin","Sonos System"],"tenders":["3.80m Tender with Honda 50hp 4 strokes engine"]},"crew":[{"name":"Giorgos Papandreou","avatar":"/media/media::image::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::499c9750-a829-11f0-bea9-edbb49aba9df/{imageVariant}","role":"Captain","bio":"Captain Giorgos graduated from Hellenic Naval Academy in 2014. He holds speed and sail boat licenses. Among other certifications he also holds Seaman's Book, Master 200GT/Malta and Advanced Ship Handling and Maneuvering by HELMEPA Maritime Training Center. He joined the yachting industry in 2022 as a deckhand onboard M/Y APANEMIA. His last working experience was onboard M/Y LETTOULI III - an 20 meters yacht as Captain, responsible for maintainging ultimate safety for passengers, crew, environment and vessel. He has extensive knowledge of moorings and secluded bays throughout the Greek islands. He is very reliable, hard-working, and professional. In his free time Captain Giorgos likes sailing, and travelling. He speaks Greek and English."},{"name":"Konstantinos Trikkas","avatar":"/media/media::image::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::bfeaffa0-a829-11f0-bea9-edbb49aba9df/{imageVariant}","role":"Captain","bio":"Konstantinos was born in 1977 in Chalkida and he lives in Athens. He has graduated from the Technical Vocational High School but his passion and love for cooking led him to the Cooking School Chef d’Oeuvre in Athens where he graduated with a Culinary Degree. Konstantinos has not only a great experience in Mediterranean cuisine but also in Asian such as sushi and sashimi. He has worked in many hotels such as Metropolitan, Hilton Byzantine and restaurants such as Caprice in Kolonaki and Big Greek Tasty in England. In 2005 he entered the yachting industry and has been the head Chef in 30m and 40m yachts. The last 10 years he has his own restaurant in Kimi Evias. Konstantinos is communicative, social, hardworking and has a team spirit. In his free time, he enjoys doing craftsmanship, moto sports and gardening. He speaks Greek and English."},{"name":"Melanie Guinabar","avatar":"/media/media::image::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::da128e20-a829-11f0-bea9-edbb49aba9df/{imageVariant}","role":"Captain","bio":"Melanie is 45 years old and is onboard M/Y MIREN for the last three years. She is an adaptable, flexible and easy-going person. Also, she is a good communicator with a great eye for detail. As a reliable hardworking crew member, she thrives as a part of the team and likes to bring a positive uplifting energy.  Melanie will warmly welcome the guests onboard M/Y MIREN and will work hard during the charters to ensure a relaxing and unforgettable cruise. She speaks English."},{"name":"Athanasios Kitsikopoulos","avatar":"/media/media::image::c::8344947358::vessel::d5cca299-fe8c-11ed-889f-43d4bb723744::assets::03057ef0-a82a-11f0-bea9-edbb49aba9df/{imageVariant}","role":"Captain","bio":"Athanasios is a motivated and experienced watersports professional with a background in Physical Education and Sport Science, also certified in First Aid..With several seasons working at high-end resorts such as the Four Seasons Astir Vouliagmeni, he has developed strong skills in waterskiing, wakeboarding, and VIP customer service. He speaks English and French."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":2150000,"displayCurrency":"EUR","displayPrice":