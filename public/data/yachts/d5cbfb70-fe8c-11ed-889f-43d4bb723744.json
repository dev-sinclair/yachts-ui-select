ture":[],"engines":"2 x 803Hp CATERPILLAR","amenities":[{"label":"Air Conditioning","quantity":""},{"label":"Salon TV","quantity":""},{"label":"Sat TV","quantity":""},{"label":"iPod / Device Hookups","quantity":""},{"label":"Deck Shower","quantity":""},{"label":"Dine In","quantity":""},{"label":"Hairdryers","quantity":""},{"label":"Generator","quantity":""},{"label":"Inverter","quantity":""},{"label":"Water Maker","quantity":""},{"label":"Ice Maker","quantity":""},{"label":"Onboard WIFI","quantity":""}],"toys":[{"label":"Water Ski (adult, child)","quantity":"3"},{"label":"Jetski Seadoo Wake pro 230hp","quantity":2},{"label":"Wakeboard 143cm adult","quantity":"1"},{"label":"Wakeboard 124cm child","quantity":"1"},{"label":"Stand Up Pedal Board","quantity":"2"},{"label":"Fun air water slide 12 mt","quantity":""},{"label":"Floating parking","quantity":"4"},{"label":"Ringo","quantity":2},{"label":"Seabob F5S","quantity":4},{"label":"SUP","quantity":"0"},{"label":"Kayak","quantity":""}],"entertainment":["Salon TV","Satellite TV","Wi-Fi","Salon Stereo"],"tenders":["Tender Techohull Omega 45 15mt with 3 x 400 Hp"]},"crew":[{"name":"Emir Karaman","avatar":"/media/media::image::c::7819143053::vessel::d5cbfb70-fe8c-11ed-889f-43d4bb723744::assets::854ac230-ad76-11ef-86a1-a144e7b8af07/{imageVariant}","role":"Captain","bio":"Emir is 31 years old. Fully licensed, he rapresented Turkey in the National Sailing Team. 13 years ago he decided to join the yachting industry (private and commercial). This is the fourth year as Capt on All About U 2. He speaks Turkish and english."},{"name":"Yigit Gazi Uzunkaya","avatar":"/media/media::image::c::7819143053::vessel::d5cbfb70-fe8c-11ed-889f-43d4bb723744::assets::9d0b62d0-ad76-11ef-a638-77b4452a7953/{imageVariant}","role":"Captain","bio":"He's born in Turkey and he is half turkish and half Montenegron. After graduating at Maritime school, he worked on several yachts in West Med, Adriatic and East Med. Before joining All About U 2, before he worked on yacht Infinity."},{"name":"Koran Sakar","avatar":"/media/media::image::c::7819143053::vessel::d5cbfb70-fe8c-11ed-889f-43d4bb723744::assets::f8f581c0-ad76-11ef-b56e-797d3a0d59fb/{imageVariant}","role":"Captain","bio":"Born 1973, he is married married and have 2 children. He speaks english and turkish. He started cooking in restaurants, private and commercial yachts more than 20 years ago. He loves spend the free time with his family and discovering new tastes and recipes. Before joining All About U he worked on Yacht Meira."},{"name":"Burak Emanet","avatar":"/media/media::image::c::7819143053::vessel::d5cbfb70-fe8c-11ed-889f-43d4bb723744::assets::19f0ce20-ad77-11ef-a4a5-f9c9a1310041/{imageVariant}","role":"Captain","bio":"In the last 4 years he worked for the owning company, following the construction of the yacht as supervisor. He graduated at maritime high school and marine enineering university. He sailed almost all around the world."},{"name":"Erim Cicek","avatar":"/media/media::image::c::7819143053::vessel::d5cbfb70-fe8c-11ed-889f-43d4bb723744::assets::38386c30-ad77-11ef-b3a9-550b279f4c39/{imageVariant}","role":"Captain","bio":"Born in England and grew up in Turkey, Erim is a son of a Captain, so he sailed with him since a was a child."},{"name":"Zafer Yilmaz","avatar":"/media/media::image::c::7819143053::vessel::d5cbfb70-fe8c-11ed-889f-43d4bb723744::assets::60d54dc0-ad77-11ef-93a1-930c8e34afd7/{imageVariant}","role":"Captain","bio":"Zafer is working on water sports since 2000. He worked in the last 8 years for the same company on yachts Grandemare and Bellamare, before joining Alla About U. He is a deckhand but he has also ther responsability to teach e manage the watersports onboard."},{"name":"Zumrut Dural","avatar":"/media/media::image::c::7819143053::vessel::d5cbfb70-fe8c-11ed-889f-43d4bb723744::assets::982093c0-ad77-11ef-ab85-b5056d44194f/{imageVariant}","role":"Captain","bio":"Zumurut is 42 years old. She worked in hotel business for 10 years until 4 years ago, when she joined All About U."},{"name":"Omer Sisman","avatar":"/media/media::image::c::7819143053::vessel::d5cbfb70-fe8c-11ed-889f-43d4bb723744::assets::ad756480-ad77-11ef-9e4a-c73d47b260a6/{imageVariant}","role":"Captain","bio":"Omer graduated in Anatolian Vacational High School. He is always positive and hardworker. Before joining the yachting industry, since 2017, he was a manager of restaurants. He speaks Turkish and English."},{"name":"TBA","role":"Captain"},{"name":"TBA","role":"Captain"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":12000000,"displayCurrency":"EUR","displayPrice":12000000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":20000000,"displayCurrency":"EUR","displayPrice":20000000,"unit":"WEEK"},"pricingInfo":[{"name":"July, August","effectiveDates":[{"from":"2025-07-01T00:00:00.000Z","to":"2025-08-31T23:59:59.999Z"},{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":20000000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":20000000,"amount":20000000,"taxRate":{"label":"VAT","value":0.2},"conditions":"per week"},{"item":"APA","conditions":"","quantity":0.35,"unitPrice":20000000,"amount":7000000}],"total":31000000,"subTotal":27000000,"totalTax":4000000},"inclusionZones":[{"label":"Turkey","type":"Sovereign country","category":["Asia","Western Asia","Turkey"],"coordinates":[35.10531997715448,39.093802942376584],"bbox":[25.6689453125,35.831445312499994,44.81718750000002,42.09326171875]}],"exclusionZones":[],"petsAllowed":false},{"name":"June, September","effectiveDates":[{"from":"2025-06-01T00:00:00.000Z","to":"2025-06-30T23:59:59.999Z"},{"from":"2025-09-01T00:00:00.000Z","to":"2025-09-30T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":17000000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item