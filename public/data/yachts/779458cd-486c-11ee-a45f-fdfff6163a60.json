Kneeboard","quantity":1},{"label":"Water ski","quantity":1},{"label":"Snorkeling Equipment","quantity":1},{"label":"Fishing Equipment","quantity":1},{"label":"Various tubes","quantity":1}],"entertainment":["TV in all cabins"],"tenders":["Tender with Mariner 30hp engine"]},"crew":[{"name":"Vasilis Avdis","avatar":"/media/media::image::c::8344947358::vessel::779458cd-486c-11ee-a45f-fdfff6163a60::assets::35feb370-a82b-11f0-bea9-edbb49aba9df/{imageVariant}","role":"Captain","bio":"Vasilis is 55 years old and is a graduate of navy. He has a great experience as he is more than 25 years on this job as a Captain and Chief Officer in the past. He joined the yachting industry 8 years ago and has worked in both private and charter yachts. When not working he loves cooking with his children. He speaks Greek & English."},{"name":"Ioanna Androulaki","role":"Captain","bio":"Ioanna Androulaki is a dynamic hospitality and wellness professional with over 13 years of experience in the food and beverage industry, including service, bar, and front-of-house operations. She has also worked three summer seasons in Mykonos, gaining valuable high-end service experience in fast-paced environments, and has completed one year as a hostess in the yachting sector, offering premium-level guest interaction and support. She is also a certified Pilates instructor (IEK), combining hospitality expertise with a strong interest in wellness and personal care. Ioanna is known for her professionalism, adaptability, and positive energy, making her a valuable team member in both land-based and onboard settings. She speaks Greek and English."},{"name":"Shomon Akmad Ali","avatar":"/media/media::image::c::8344947358::vessel::779458cd-486c-11ee-a45f-fdfff6163a60::assets::76684390-a82b-11f0-bea9-edbb49aba9df/{imageVariant}","role":"Captain","bio":"Shomon is 31 years old and has been working onboard daily yachts for years, as he was always dreaming being near the sea since a young child. He has a very kind personality and is always willing to assist the guests. His dedication and willingness make him a great asset for the team of SUMMER THERAPY. When not working, he enjoys making videos on TikTok, playing cricket and listening to music. He speaks Greek and English."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1700000,"displayCurrency":"EUR","displayPrice":1700000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1900000,"displayCurrency":"EUR","displayPrice":1900000,"unit":"WEEK"},"pricingInfo":[{"name":"High Season (July - August)","effectiveDates":[{"from":"2023-07-01T00:00:00.000Z","to":"2023-08-31T23:59:59.999Z"},{"from":"2024-07-01T00:00:00.000Z","to":"2024-08-31T23:59:59.999Z"},{"from":"2025-07-01T00:00:00.000Z","to":"2025-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","unit":"WEEK","inputAmountTaxed":"NONE","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1900000,"amount":1900000,"conditions":"High Season"},{"item":"APA","quantity":0.35,"unitPrice":665000,"amount":232749.99999999997},{"item":"VAT","conditions":"","quantity":0.12,"unitPrice":228000,"amount":27360}],"subTotal":2160110,"totalTax":0,"total":2160110,"charterFee":1900000},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]}],"exclusionZones":[],"petsAllowed":false},{"name":"Low Season (All other months)","effectiveDates":[{"from":"2025-01-01T00:00:00.000Z","to":"2025-06-30T23:59:59.999Z"},{"from":"2026-01-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2025-09-01T00:00:00.000Z","to":"2025-09-01T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-01T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-09-01T23:59:59.999Z"}],"pricing":{"currency":"EUR","unit":"WEEK","inputAmountTaxed":"N