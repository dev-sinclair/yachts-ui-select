el::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::5389bfd0-a7f4-11ef-8a7d-ab86b9658f45/{imageVariant}","/media/media::image::a::vessel::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::530b19f0-a7f4-11ef-bd64-f3543e48165f/{imageVariant}","/media/media::image::a::vessel::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::530e4e40-a7f4-11ef-8a7d-ab86b9658f45/{imageVariant}","/media/media::image::a::vessel::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::3fabfeb0-a7f4-11ef-a937-4718790997fd/{imageVariant}","/media/media::image::a::vessel::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::3fab3b60-a7f4-11ef-8a7d-ab86b9658f45/{imageVariant}","/media/media::image::a::vessel::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::52fe6fc0-a7f4-11ef-a93d-4718790997fd/{imageVariant}"],"make":"Cantieri Navali Baglietto","model":"Baglietto 100","maxCrew":6,"sleeps":8,"basePort":{"uri":"a::place::f8cee918-b3ed-11ed-bd14-325096b39f47","name":"Mykonos","coordinates":{"latitude":37.44697826,"longitude":25.32875984},"country":"Greece"},"cruisingCapacity":12,"staticCapacity":12,"builtYear":2003,"interiorDesigner":"Francesco Paszkowski","refitYear":2023,"topSpeed":29,"cruiseSpeed":20,"fuelCapacity":19000,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"2"},{"label":"Twin Cabin - Convertible to Double ","value":"1"}],"cabins":4,"bathrooms":4,"decks":2,"length":30.4,"beam":7,"draft":2.45,"hullType":"Monohull ","hullConstruction":"Aluminum ","tonnage":150.57,"superStructure":["Aluminum"],"engines":"2 x MTU 2000 hp","amenities":[{"label":"Free 5G Wifi"},{"label":"Air conditioning  "},{"label":"Refrigerator  "},{"label":"Miele Dishwasher  "},{"label":"Miele Washing Machine  "},{"label":"Oven"},{"label":"Miele Microwave Oven  "},{"label":"Fresh Water Maker  "},{"label":"Teak Cockpit  "},{"label":"Teak Side decks "}],"toys":[{"label":"Snorkeling equipment | included  "},{"label":"Inflatable water toys | additional charge for daily charters - included in weekly charters"},{"label":"Seabob | additional charge for daily charters - included in weekly charters"},{"label":"Seabed | additional charge for daily charters - included in weekly charters"},{"label":"Paddle Boards | additional charge for daily charters - included in weekly charters"},{"label":"eFoil | with extra charge"}],"entertainment":["TV","Surround sound system"],"tenders":["Grand G380N "]},"crew":[{"name":"Panagiotis Georgiadis ","avatar":"/media/media::image::c::9974682422::vessel::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::630a44e0-d434-11ef-a126-2bca359ad6db/{imageVariant}","role":"Captain","bio":"Captain Panagiotis Georgiadis has been passionate about the sea since childhood, which led him to a 15-year career as a professional captain. He is also a qualified mechanical engineer with another 15 years of experience in the field. Panagiotis is an RYA Yachtmaster and holds first aid certifications, ensuring a safe and smooth journey for everyone onboard. He loves diving, scuba diving, and water sports. With extensive knowledge of Mediterranean destinations, he’s dedicated to creating unforgettable yachting experiences. Panagiotis has proudly captained Sofia Y for the last two years."},{"name":"Andreas Favios","avatar":"/media/media::image::c::9974682422::vessel::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::402caa20-d417-11ef-8ed6-955aa9159fd5/{imageVariant}","role":"Captain","bio":"Andreas Favios has over a decade of experience in maritime engineering, serving on renowned yacht. He joined Sofia Y in May 2024 and has since been responsible for its engineering operations. His certifications include STCW 95 Advanced Safety Training, advanced firefighting, and a speedboat operator license. He also holds qualifications as a Chief Engineer for vessels with engine rooms up to 2250kW. Andreas’s professional knowledge ensures the smooth and safe operation of the yacht. His background also includes experience on tankers and large private yachts, where he honed his technical skills."},{"name":"Eleni Nika ","avatar":"/media/media::image::c::9974682422::vessel::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::babe44f0-d418-11ef-882e-fd48d3b1f27c/{imageVariant}","role":"Captain","bio":"Eleni Nika has nearly eight years of experience in yachting, bringing passion and precision to her role. She has been part of Sofia Y’s team for the last two years, ensuring guests receive outstanding service. Eleni’s skills include Greek and European cuisine, as well as a keen eye for detail in hospitality. She’s also trained in first aid and defibrillator use, adding an extra layer of care to her work. Her background in child care and hospitality gives her a unique ability to cater to every guest’s needs"},{"name":"Christina Stani","avatar":"/media/media::image::c::9974682422::vessel::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::4b0df430-d4cb-11ef-a49b-69a2484210c1/{imageVariant}","role":"Captain","bio":"Christina Stani has been part of the yachting industry since 2021, with experience on renowned yachts. Skilled in Mediterranean and Greek cooking, child care, and hospitality, Christina also brings additional expertise as a trained hairdresser which adds a special service for guests. Over the past five years, including two years on Sofia Y, Christina has impressed guests with her professionalism and dedication"},{"name":"Fenis Sherwin","avatar":"/media/media::image::c::9974682422::vessel::4a675e60-a7f1-11ef-a750-ff0a255dd098::assets::1e3f7dd0-dc95-11ef-806f-d5ea9f62f262/{imageVariant}","role":"Captain","bio":"Fenis Sherwin is a hardworking deckhand with a speedboat operator license and extensive experience as a seaman on international ships. He has worked on multiple motor yachts, building his skills in safety, teamwork, and handling sea toys. For the past five years, including two with Sofia Y, Fenis has been a friendly and dependable team member, ensuring smooth operations and safe, enjoyable water activities for guests."},{"name":"Zacharias Karatarakis","role":"Captain"}],"pricing":{"dayPricingFrom":{"currency":"EUR","price":1365000,"displayCurrency":"EUR","displayPrice":1365000,"unit":"DAY"},"dayPricingTo":{"currency":"EUR","price":1365000,"displayCurrency":"EUR","displayPrice":1365000,"unit":"DAY"},"weekPricingFrom":{"currency":"EUR","price":7475000,"displayCurrency":"EUR","displayPrice":7475000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":7475000,"displayCurrency":"EUR","displayPrice":7475000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rate","effectiveDates":[{"from":"2025-01-01T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"},{"from":"2026-01-01T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":7475000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":7475000,"amount":7475000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0.065}},{"item":"APA (Advanced Provisioning Allowance)","conditions":"","quantity":0.4,"unitPrice":7475000,"amount":2990000,"taxRate":{"label":"VAT","value":0}}],"total":10950875,"subTotal":10465000,"totalTax":485875},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]},{"label":"Aegean Sea","type":"Custom Area","category":["Aegean Sea"],"coordinates":[25.17433827229007,38.821119014422294],"bbox":[22.569093051857664,36.51149262139869,28.2422868181564,40.99460399023168]},{"label":"Mykonos","type":"Custom Area","category":["Mykonos"],"coordinates":[25.417890518546145,37.444344530734035],"bbox":[25.283314533252252,37.37813369198719,25.614171339867283,37.50947159695451]}],"exclusionZones":[],"petsAllowed":true},{"name":"Daily Rate ","effectiveDates":[{"from":"2025-01-01T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"},{"from":"2026-01