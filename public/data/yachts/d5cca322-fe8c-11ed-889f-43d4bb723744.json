1ed-889f-43d4bb723744::assets::dfe99300-edcd-11ef-affa-3db9728da06b/{imageVariant}","/media/media::image::a::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::dfe944e0-edcd-11ef-aff8-3db9728da06b/{imageVariant}","/media/media::image::a::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::dfb367d0-edcd-11ef-aff5-3db9728da06b/{imageVariant}","/media/media::image::a::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::dff97180-edcd-11ef-affb-3db9728da06b/{imageVariant}","/media/media::image::a::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::dff4b690-edcd-11ef-9c50-a5b42feb859e/{imageVariant}","/media/media::image::a::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::dff24590-edcd-11ef-affa-3db9728da06b/{imageVariant}","/media/media::image::a::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::dff37e10-edcd-11ef-affb-3db9728da06b/{imageVariant}"],"make":"Crescent Yachts","model":"","maxCrew":6,"sleeps":9,"basePort":{"uri":"a::place::4cc5a8f0-5d16-11ee-9985-2b2c74f6bb12","name":"Bahamas","coordinates":{"latitude":25.03433399832838,"longitude":-77.39626659454655},"country":"Bahamas"},"builtYear":2004,"architect":"","interiorDesigner":"","refitYear":2023,"topSpeed":21,"cruiseSpeed":17,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabins","value":"3"},{"label":"Twin Cabin","value":"1"}],"cabins":4,"bathrooms":4,"length":36.6,"beam":7.8,"draft":1.9,"hullType":"","hullConstruction":"","tonnage":0,"superStructure":[],"engines":"2000HP Twin MTU 16v2000","amenities":[{"label":"Jacuzzi"},{"label":"Sun Lounger"},{"label":"Hairdryers"},{"label":"Ice Maker"},{"label":"Gym/Exercise"},{"label":"Children Allowed"}],"toys":[{"label":"3 Person Yamaha VX Wave Runners (2019)","quantity":"2"},{"label":"Waterslide"},{"label":"Sea Bob","quantity":"2"},{"label":"E-Foil"},{"label":"7x7 Inflatable dock"},{"label":"Inflatable Swim platform and jet ski dock"},{"label":"Towable banana"},{"label":"Towable Tubes"},{"label":"Floating lounge"},{"label":"Lazy Bun floaties"},{"label":"Wakeboards"},{"label":"Snorkeling equipment"},{"label":"Full Beach set up including canopies, tables, chairs, umbrella, beach toys"},{"label":"Inflatable paddleboards","quantity":"2"},{"label":"2-man inflatable kayaks","quantity":"2"},{"label":"Water skis"}],"entertainment":["Salon Stereo","Salon TV","Sat TV","Onboard WIFI"],"tenders":["39' HCB 2019 ( x3 350 hp engines)- fully equipped for professional fishing, deep drop reels, tender has bathroom and small cabin"]},"crew":[{"name":"Marco Ravanello","avatar":"/media/media::image::c::7580644256::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::01655e50-c588-11f0-8e48-430aaa1e36ba/{imageVariant}","role":"Captain","bio":"Nationality: Antiguan/British\n\nBorn at the Antigua Yacht Club, Captain Marco Ravanello was truly raised in the world of yachting. With over 20 years of experience in the industry and 9 years as captain on yachts between 30 and 45 meters, Marco combines professionalism, calm leadership, and a lifelong connection to the ocean. Sailing runs in his blood—his mother crossed the Atlantic in 1970 on a classic schooner, and Marco has since completed 15 Atlantic crossings of his own. His knowledge of the Caribbean is second to none, and he takes pride in showing guests the region’s most beautiful and lesser-known spots.When off duty, Marco lives in the UK countryside with his wife and dog, enjoying a quieter life on a smallholding. A keen sportsman, he enjoys rugby, golf, football, tennis, and scuba diving."},{"name":"Brandon Scholtz","avatar":"/media/media::image::a::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::52ce2e50-edcc-11ef-a54b-43d07289d6fa/{imageVariant}","role":"Captain","bio":"Nationality: South African\n\nFor Brandon, adventure and boating are his true passions. He has spent his whole life on boats for various reasons, with fishing standing out as his favorite activity. Born and raised in South Africa, he set off at 22 to travel and work abroad. When he’s not on a boat, he’s likely racing around on his MX dirt bike or spending quality time with family. He finds joy in yachting, especially in meeting new people and experiencing diverse cultures. His long-term goal is clear: to embrace this lifestyle for as long as possible, with his sights set on becoming a captain one day."},{"name":"Marija Martens","avatar":"/media/media::image::a::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::0a07cf50-edcc-11ef-ac97-89e17a83e503/{imageVariant}","role":"Captain","bio":"Nationality: Macedonia\n\nMarija was born and raised in Macedonia. She began her first journey to England after leaving home some 20+ years ago. Shortly after England, she set sail to the Caribbean and now counting 15+ years of professional work experience in the yachting industry. Once she set foot on the beautiful island of St. Maarten, she started bartending which resulted in winning two competitions. Her eagerness to travel, explore and broaden her horizons led her to the first job as a stew on a mega yacht. The promotion to chief stew came shortly thereafter and has been her passion ever since. As chief stew, she shares her loyalty, enthusiasm, hard work, charisma, and positive energy with both the crew and the guests. You will always be greeted by her smiling face and be prepared for the contagious laughter she enjoys spreading on board. "},{"name":"Genevieve Smuts","avatar":"/media/media::image::c::7580644256::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::310bdad0-c588-11f0-8e48-430aaa1e36ba/{imageVariant}","role":"Captain","bio":"Nationality: South African\n\nOriginally from South Africa, Genevieve has always been drawn to travel, culture, and the ocean. Her adventurous spirit has taken her across the world, where she has combined her love for exploring with a passion for hospitality. When she’s not on board, she enjoys fitness, yoga, and outdoor adventures that keep her grounded and full of energy.\nOn charter, Genevieve brings that same enthusiasm and positivity into her work. She has a natural eye for detail and a calm, friendly presence that makes guests feel instantly comfortable. Whether setting a beautiful table, planning a themed evening, or making sure every cabin feels like home, she prides herself on creating warm, elegant experiences. Her goal is always to ensure guests leave with lasting memories and a feeling of true care."},{"name":"Luke Van Dalen","avatar":"/media/media::image::c::7580644256::vessel::d5cca322-fe8c-11ed-889f-43d4bb723744::assets::5dbfcb40-c588-11f0-8e48-430aaa1e36ba/{imageVariant}","role":"Captain","bio":"Nationality: South African\n\nBorn and raised in South Africa, Divan grew up on a farm near Stanford, where the land meets the sea. Immersed in a community of seafarers, he developed a profound connection to both the waves and the wilderness, fostering a work-hard, play-hard ethos that has fueled his success as an automotive business owner. His love for speed extends to racing boats and competing as a professional driver. Surfing and fishing deepens his bond with the ocean, while travel broadens his perspective through diverse cultures. "}],"pricing":{"weekPricingFrom":{"currency":"USD","price":8000000,"displayCurrency":"USD","displayPrice":8000000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":9000000,"displayCurrency":"USD","displayPrice":9000000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer/Winter: Bahamas & Caribbean - High Season","effectiveDates":[{"from":"2025-12-15T00:00:00.000Z","to":"2026-04-30T23:59:59.999Z"},{"from":"2026-12-15T00:00:00.000Z","to":"2027-04-30T23:59:59.999Z"},{"from":"2027-12-15T00:00:00.000Z","to":"2028-04-30T23:59:59.999Z"}],"pricing":{"currency":"USD","charterFee":9000000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":9000000,"amount":9000000,"conditions":"VAT & APA Excluded"}],"total":9000000,"subTotal":9000000,"totalTax":0},"inclusionZones":[{"label":"Bahamas","type":"Sovereign country