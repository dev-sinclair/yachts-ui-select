dfff6163a60::assets::c7d67490-d4be-11ef-aff6-a5f79f701fc8/{imageVariant}"],"make":"Yener Yachts","model":"","maxCrew":4,"sleeps":14,"basePort":{"uri":"a::place::93e783b0-5d9c-11f0-9148-adf7d9d7e85c","name":"Kaštel Gomilica","coordinates":{"latitude":43.54932136252094,"longitude":16.39632508308426},"country":"Croatia"},"builtYear":2008,"refitYear":2023,"topSpeed":11,"cruiseSpeed":9,"fuelCapacity":9000,"cabinLayout":[],"cabins":6,"bathrooms":6,"length":27,"beam":7.5,"draft":2.6,"hullType":"","hullConstruction":"","superStructure":[],"engines":"2 x Iveco 450.0 HP","amenities":[{"label":"Air Conditioning"},{"label":"Generator"},{"label":"Bar"},{"label":" Battery charger"}],"toys":[{"label":"Banana boat"},{"label":"Fishing equipment"},{"label":"Stand up paddle (SUP)"},{"label":"Water skis"},{"label":"Donut"},{"label":"Kayak"},{"label":"Snorkeling equipment"}],"entertainment":[" Wi-Fi Internet 20GB/day"," TV + DVD"," Radio CD player"],"tenders":["Tender with 60HP engine"]},"crew":[{"name":"Goran Rogulj","avatar":"/media/media::image::c::10007754414::vessel::77943145-486c-11ee-a45f-fdfff6163a60::assets::e3c061a0-d4c0-11ef-a19c-c7ce8dd3ead7/{imageVariant}","role":"Captain","bio":"English\n\nThe captain Goran is a skilled and enthusiastic captain with extensive experience in the yachting industry since 2010. Born in 1977, he is an electromechanic by profession, which helps him to effectively apply his experience in ship maintenance. Even though he's professional and\nsilent person, he's very knowledgeable and can always advise on best places to visit. Before he fell in love with gulets, he worked as a skipper on sailboats and went shell diving. Diving still remained one of his favorite hobbies and occasionally he also engages in sport fishing. Goran is fluent in Croatian and English. During his free time, the Captain can often be seen racing the ski slopes, enjoying his second love – skiing."},{"name":"Stipe Bajan","avatar":"/media/media::image::c::10007754414::vessel::77943145-486c-11ee-a45f-fdfff6163a60::assets::f2b0ff30-d4c0-11ef-a19c-c7ce8dd3ead7/{imageVariant}","role":"Captain","bio":"Born in 2001, Stipe completed his education at a technical traffic school. During his summer breaks, he frequently found himself cleaning sailboats, which marked the beginning of his journey. In 2019, following his father's encouragement, he embarked on a new chapter by becoming a sailor in the crew of a gulet. He is responsible for various tasks to ensure the smooth operation of the boat and the safety and comfort of guests on board. Stipe is fluent in Croatian and English. When interacting with guests, he enjoys listening to their stories, learning about their culture, customs and language. During his leisure time, he makes an effort to relax and explore as much as possible, sometimes escaping to the mountains for a well-deserved break."},{"name":"Ivan Čavka","avatar":"/media/media::image::c::10007754414::vessel::77943145-486c-11ee-a45f-fdfff6163a60::assets::00c8f000-d4c1-11ef-a19c-c7ce8dd3ead7/{imageVariant}","role":"Captain","bio":"The gulet chef plays a key role in ensuring a pleasant and memorable experience for passengers. Meet Ivan Čavka, affectionately known as Cavkenzoo, a culinary maestro born on April 11, 1998, with a passion as vast as the Adriatic itself. Fluent in English and German, he effortlessly navigates through international cuisines, leaving guests astounded with his culinary creations. Since the tender age of 16, Ivan has been honing his skills in the kitchen, achieving mastery in both commercial and private culinary endeavors. His dedication and talent have earned him a reputation for excellence, setting him apart as a culinary virtuoso. When he's not busy tantalizing taste buds, Ivan indulges in his other passions: fishing and playing football with his friends. During his downtime, he relishes the tranquility of winter vacations and embarks on journeys to explore new horizons."}],"pricing":{"weekPricingFrom":{"currency":"EUR"