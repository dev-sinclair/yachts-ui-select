:a::vessel::100f3f50-42a0-11ef-b99a-65cef4489bbd::assets::51d73f10-ed67-11ef-8d19-533fcd37cf78/{imageVariant}","/media/media::image::a::vessel::100f3f50-42a0-11ef-b99a-65cef4489bbd::assets::9d498430-ed67-11ef-9588-cdc024ce6e18/{imageVariant}"],"make":"Hatteras","model":"","maxCrew":4,"sleeps":8,"basePort":{"name":"Palm Beach, Florida, United States","coordinates":{"longitude":-80.036503,"latitude":26.70222},"country":"United States"},"cruisingCapacity":"","staticCapacity":"","builtYear":2005,"architect":"","interiorDesigner":"Patrick Knowles","refitYear":2023,"topSpeed":25,"cruiseSpeed":19,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Double Cabin","value":"1"},{"label":"Twin Cabin","value":"1"}],"cabins":4,"bathrooms":4,"length":25.9,"beam":6.1,"draft":1.8,"hullType":"GRP","hullConstruction":"Fiberglass","tonnage":"","engines":"","amenities":[{"label":"Air Conditioning"},{"label":"Hairdryers"},{"label":"Ice Maker"},{"label":"Gym/Exercise"},{"label":"BBQ"},{"label":"Underway Stabilizers"}],"toys":[{"label":"Snorkel Gear"},{"label":"Beach Games"},{"label":"Swim Platform"},{"label":"Fishing Gear"}],"entertainment":["Salon Stereo","Salon TV","Sat TV","Onboard Wi-Fi"],"tenders":["26' Norticstar w/ Twin Yamaha 200HP (For Bahamas/FLL)","AB Nautilus w/ single 70HP Yamaha Outboard (For New England)"]},"crew":[{"name":"Paul Warner","avatar":"/media/media::image::a::vessel::100f3f50-42a0-11ef-b99a-65cef4489bbd::assets::ff8bb340-ed65-11ef-8b53-f9546b8aa643/{imageVariant}","role":"Captain","bio":"USA/UK\nCaptain Paul, born in Malta as a Royal Airforce military brat, moved frequently throughout his childhood until his family settled in Tortola, British Virgin Islands. Paul's maritime journey began at 17 when he sailed away aboard a 282' Schooner, and he then earned his first captains role at 21 on a 170'dive ship. With extensive navigation and charter experience along the US East Coast, Bahamas, and Caribbean, he has also navigated Mediterranean waters and South America. As a professionally trained maritime engineer, Paul takes a hands-on approach to ensure the vessel's smooth operation and loves personally taking guests on tender excursions. Outside of work, he enjoys traveling, camping, cooking, and participating in Boy Scout events with his two boys, both Eagle Scouts, with one now serving in the Navy.\nPaul is excited to welcome you aboard and ensure you have an unforgettable experience where every detail is tailored to create cherished memories for you and your guests."},{"name":"Andrew Ventres","avatar":"/media/media::image::a::vessel::100f3f50-42a0-11ef-b99a-65cef4489bbd::assets::3c627fb0-ed66-11ef-9045-af54896007a2/{imageVariant}","role":"Captain","bio":"USA\nAndrew was born and raised in a small town in the Connecticut River, sailing around Long Island Sound since childhood. Obtaining a free sailboat as a high school project cemented his love for the sea and respect for the work required to maintain a sea-worthy vessel. He enjoys any time outdoors, from scuba-diving to windsurfing to kicking back and enjoying the quiet sunset at anchor. He has been a full-time professional crew member for four years and loves every moment of it.\nAndrew is dedicated to providing a fun, safe, and unforgettable experience for all guests aboard M/Y Indy."},{"name":"Jim Ruch","avatar":"/media/media::image::a::vessel::100f3f50-42a0-11ef-b99a-65cef4489bbd::assets::77d10990-ed66-11ef-b394-9598fa1718b4/{imageVariant}","role":"Captain","bio":"USA\nAs a seasoned chef with over two decades of culinary expertise, my journey has taken me from the bustling kitchens of top restaurants to the exclusive realms of high-net-worth individuals and luxury yachts. Whether orchestrating gourmet experiences or entertaining guests through my guitar performances., I bring a blend of professionalism and passion to every occasion. With a foundation rooted in classical European and Asian cuisines, and formal training from culinary capitals like Tokyo, Bangkok, London, and New York, I'm dedicated to crafting exceptional dining experiences tailored to your unique preferences. I look forward to the opportunity to create unforgettable culinary memories together."}],"pricing":{"weekPricingFrom":{"currency":"USD","price":3999900,"displayCurrency":"USD","displayPrice":3999900,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":4999900,"displayCurrency":"USD","displayPrice":4999900,"unit":"WEEK"},"pricingInfo":[{"name":"Summer: New England - Low Season","effectiveDates":[{"from":"2026-05-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-05-31T23:59:59.999Z"},{"from":"2028-05-01T00:00:00.000Z","to":"2028-05-31T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-30T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-09-30T23:59:59.999Z"},{"from":"2028-09-01T00:00:00.000Z","to":"2028-09-30T23:59:59.999Z"}],"pricing":{"currency":"USD","charterFee":3999900,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":3999900,"amount":3999900,"conditions":"VAT & APA Excluded"}],"total":3999900,"subTotal":3999900,"totalTax":0},"inclusionZones":[{"label":"Connecticut, US, United States","type":"State","category":["Connecticut"],"coordinates":[-72.72549337781919,41.62693724196049],"bbox":[-73.72301474458291,40.99186046560217,-71.79579299137774,42.05556778157003]},{"label":"Maine, US, United States","type":"State","category":["Maine"],"coordinates":[-69.18910809526241,45.33339970652574],"bbox":[-71.08454906776156,43.07003437300324,-66.98702205598455,47.4629947456595]},{"label":"Massachusetts, US, United States","type":"State","category":["Massachusetts"],"coordinates":[-71.56845108942264,42.14243561026627],"bbox":[-73.50728719729106,41.24946789730413,-69.93384101605304,42.881563906829285]},{"label":"New Hampshire, US, United States","type":"State","category":["New Hampshire"],"coo