a039-11ee-a7ac-d7be8742705d.jpeg/{imageVariant}"],"make":"Sunseeker Predator","model":"","maxCrew":3,"sleeps":6,"basePort":{"uri":"a::place::5e595eb8-b3ed-11ed-be02-325096b39f47","name":"Athens","coordinates":{"latitude":37.986174,"longitude":23.7268443},"country":"Greece"},"builtYear":2009,"architect":"","interiorDesigner":"","refitYear":2021,"topSpeed":34,"cruiseSpeed":24,"fuelCapacity":"","cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Twin Cabin","value":"1"}],"cabins":3,"bathrooms":3,"decks":"","length":22.25,"beam":5.46,"draft":1.65,"hullType":"","hullConstruction":"","tonnage":"","superStructure":[],"engines":"2 x MAN 1360hp V12","amenities":[{"label":"Bimini","quantity":1},{"label":"Generator","quantity":1},{"label":"Sunpads","quantity":1}],"toys":[{"label":"Jet Ski","quantity":1},{"label":"Seascooter","quantity":1},{"label":"Seabob","quantity":1},{"label":"SUP","quantity":1},{"label":"Wakeboard","quantity":1},{"label":"Two people Sofa","quantity":1},{"label":"Water ski","quantity":1},{"label":"Tubes","quantity":1},{"label":"Snorkeling equipment","quantity":1},{"label":"Swim platform","quantity":1}],"tenders":["Tender 40 HP engine"]},"crew":[{"name":"Fanis Klonis","avatar":"/media/media::image::c::8344947358::vessel::d5cca461-fe8c-11ed-889f-43d4bb723744::assets::9f879300-a814-11f0-b12f-5387bd7c75ba/{imageVariant}","role":"Captain","bio":"Fanis was born in Greece in 1991 and currently resides in Athens. He holds a license to command vessels up to 200GT (31 meters) and a sailing license in Plymouth. He prioritizes onboard guests’ safety, having received training in First Aid, Fire Fighting and Sea Survival. Fanis has a pleasant personality, a great sense of humor and enjoys taking his guests to explore his favorite islands. He is fluent in English and also speaks German. Fanis has a passion for travelling and adventure. During his free time, he enjoys sailing, surfing, snow skiing and cycling. Moreover, he makes delicious cocktails and surprises his guests with his signature cocktails. Fani’s professionalism, skills and friendly personality make him a valuable member of the team. He speaks Greek and English."},{"name":"Ariadni Iordania Koukou","avatar":"/media/media::image::c::8344947358::vessel::d5cca461-fe8c-11ed-889f-43d4bb723744::assets::f5945010-a816-11f0-bea9-edbb49aba9df/{imageVariant}","role":"Captain","bio":"Ariadni was born in 1981 in Serres and lives in Athens. She joined the yachting industry two years ago and has many years of experience working in high-end restaurants i.e. Nammos in Mykonos and as hosting in Four Seasons. Ariadni loves cooking and particularly the Mediterranean cuisine, using fresh and healthy ingredients. She will warmly welcome the guests onboard M/Y ELENTARI and will work hard during the charters. She pays great attention to detail and has a team spirit. She is also a yoga instructor and if guests wish so, they can have yoga classes at some bays. In her free time, she enjoys aerial yoga, swimming, and meditation. She also holds a life coaching diploma from the National and Kapodistrian University of Athens. She speaks Greek and English.\n"},{"name":"Fotis Chotza","avatar":"/media/media::image::c::8344947358::vessel::d5cca461-fe8c-11ed-889f-43d4bb723744::assets::d86b4bf0-a817-11f0-bea9-edbb49aba9df/{imageVariant}","role":"Captain","bio":"Fotis was born in 1997. He holds a speed boat license and is a snowboard instructor as well. This is his second year onboard M/Y ELENTARI.  Fotis will take care of guests’ daily needs and will assist with the yacht’s operations. He is a smiley, trustworthy person and a great asset to the yacht’s team. When not working, he enjoys travelling, hiking, snowboarding, diving and playing basketball. He speaks Greek and English."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":2200000,"displayCurrency":"EUR","displayPrice":2200000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2450000,"displayCurr