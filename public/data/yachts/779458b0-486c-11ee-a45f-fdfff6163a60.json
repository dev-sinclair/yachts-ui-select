779458b0-486c-11ee-a45f-fdfff6163a60::assets::0871c420-7783-11f0-b8fd-355a2b7d5d19/{imageVariant}","/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::0a4328c0-7783-11f0-b8fd-355a2b7d5d19/{imageVariant}","/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::0ba9e4b0-7783-11f0-b8fd-355a2b7d5d19/{imageVariant}","/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::0d1eaa60-7783-11f0-b8fd-355a2b7d5d19/{imageVariant}","/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::0e7783a0-7783-11f0-b8fd-355a2b7d5d19/{imageVariant}","/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::0fa4e010-7783-11f0-b8fd-355a2b7d5d19/{imageVariant}","/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::1144fb80-7783-11f0-b8fd-355a2b7d5d19/{imageVariant}"],"make":"Custom","model":"Custom","maxCrew":7,"sleeps":12,"basePort":{"uri":"a::place::a0203186-b3ee-11ed-9cd1-325096b39f47","name":"Zadar","coordinates":{"latitude":44.11936462,"longitude":15.23122828},"country":"Croatia"},"cruisingCapacity":12,"staticCapacity":30,"builtYear":2024,"architect":"","interiorDesigner":"NO.MAD INTERIORS","refitYear":"","topSpeed":12.5,"cruiseSpeed":8.5,"fuelCapacity":"","cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Twin Cabin (convertible to double)","value":"4"}],"cabins":6,"bathrooms":6,"decks":3,"length":39.15,"beam":8.2,"draft":2.3,"hullType":"","hullConstruction":"","tonnage":270,"superStructure":["Steel"],"engines":"2 x BAUDOUIN 450 HP","amenities":[{"label":"Sundeck"},{"label":"Open-air Cinema"},{"label":"BBQ"},{"label":"Bar"},{"label":"Jacuzzi"},{"label":"Lounge area"},{"label":"TV in all cabins"},{"label":"Air Conditioning"},{"label":"Wi-Fi"},{"label":"Indoor audio system"},{"label":"Satellite TV"},{"label":"Sun loungers"},{"label":"Special diets"},{"label":"Outdoor audio system"},{"label":"Sun Pads"},{"label":"Ice maker"},{"label":"Salon TV"}],"toys":[{"label":"Jetski"},{"label":"E-foil"},{"label":"Seabob"},{"label":"Waterski"},{"label":"Wakeboard"},{"label":"Ringo"},{"label":"Water slide"},{"label":"Paddleboard","quantity":"4"},{"label":"Floating swimming platform"},{"label":"Dinghy"},{"label":"Tube - towable"},{"label":"Snorkeling gear"}],"entertainment":["Open-air Cinema","TV in all cabins","Wi-Fi","Indoor audio system","Satellite TV","Outdoor audio system","Salon TV"]},"crew":[{"name":"Hrvoje Vučemil Korać","avatar":"/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::3e732a10-b0c7-11ef-9570-c5a2e43618b2/{imageVariant}","role":"Captain","bio":"Captain Hrvoje boasts a wealth of knowledge and extensive experience in the maritime industry, with a career spanning over 15 years in the tourism and hospitality sectors. He has held various positions, from deckhand to captain, continually upgrading his skills and certifications. He has captained numerous vessels, including M/Y Romantic Star and M/S Queen Eleganza, demonstrating his expertise in managing both small cruise ships and yachts. His proficiency extends engine room operations, and even carpentry, showcasing his versatile skill set. Hrvoje's experience includes working on newly built ships from construction to completion, ensuring a thorough understanding of vessel operations from the ground up. Fluent in English and Croatian, Hrvoje excels in communicating with diverse crews and guests, ensuring a seamless and enjoyable experience for all aboard."},{"name":"Nikolina Arambašić","avatar":"/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::a8f1e3e0-b0c7-11ef-a58e-63f9588179c6/{imageVariant}","role":"Chef","bio":"With a rich background in hospitality and nearly two decades of experience, Nikolina brings exceptional skills and dedication to our crew. Most recently, she served as the Second Stewardess on M/Y Stella Maris, where she led a team of five stewardesses, ensuring that every aspect of the yacht's interior operations met the highest standards. Before that, she excelled in her role as a Stewardess on M/Y Lady Mrd and held several key positions in ultra-high-net-worth family households. Nikolina's expertise extends to event planning, fine dining service, and personal assistant duties, all of which are complemented by her certifications from prestigious institutions, such as the British Butler Institute. Her calm and empathetic management style, combined with her creativity and strong organizational skills, make her an invaluable asset onboard. Fluent in English and Croatian, with basic German, Nikolina ensures seamless and uxurious experiences for our guests, catering to their diverse needs with precision and care."},{"name":"Nikola Krcatović","avatar":"/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::c9e3ba60-b0c7-11ef-bd98-27b6b25ca0f2/{imageVariant}","role":"Chief Stewardess","bio":"Introducing our accomplished chef, whose culinary journey spans from the shores of Omiš to the enchanting Pakleni Islands. He has honed his skills in prestigious establishments, including the acclaimed Laganini restaurant mentored by Croatia's top chef, Hrvoje Zirojević. Under his guidance, the restaurant earned the title of the best in Croatia in 2018. Having also served on luxury yachts, our chef brings a wealth of experience and creativity to our kitchen. Prepare to indulge in an unforgettable culinary adventure curated by his expert hands. In his leisure hours, Chef Nikola enjoys swimming, playing water polo, going on extended walks, and cycling."},{"name":"Toni Smoljanović","avatar":"/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::edaf16b0-b0c7-11ef-9e70-7f8e3deb0123/{imageVariant}","role":"Captain","bio":"Toni Smoljanović brings extensive maritime experience and a strong commitment to safety and excellence as our First Mate. His recent roles include First Mate on yacht 'Life is good' Second Mate on 'Labrador' and Deckhand on 'Majestic’. Fluent in Croatian and English, his strong work ethic and calm demeanor make him an invaluable member of our team."},{"name":"Leonardo Kumanović","avatar":"/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::10bbddf0-b0c8-11ef-9ac7-9f7f6d5d1259/{imageVariant}","role":"Captain","bio":"A passionate seafarer and Croatian national champion in boat fishing, Leonardo is\na welcome addition to our crew as a Deckhand. Though new to the maritime\nindustry, Leonardo's love for the sea and natural affinity for guest relations make\nhim a favorite among our guests.\nHis enthusiasm and positive personality contribute to a warm and enjoyable\natmosphere on board, ensuring every voyage is memorable."},{"name":"Anđela Ševerdija","avatar":"/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::3b5b9460-b0c8-11ef-8316-0158f66e2671/{imageVariant}","role":"Captain","bio":"Anđela joins us as 2nd Stewardess, bringing her extensive hospitality experience from top restaurants in Croatia and Norway. Although new to yachting, she has seamlessly adapted to her role, impressing all guests with her exceptional service and warm demeanor. Anđela's strong work ethic and ability to connect with guests make her a standout member of our crew, ensuring a delightful experience on every voyage."},{"name":"Sara Pecić","avatar":"/media/media::image::c::8164602117::vessel::779458b0-486c-11ee-a45f-fdfff6163a60::assets::7b5d3af0-b0c8-11ef-b989-31f61e8bc2fa/{imageVariant}","role":"Captain","bio":"Sara, our dedicated Housekeeper, brings extensive experience from her previous roles on various yachts. Her exceptional skills and attention to detail make her outstanding in her work, ensuring that every corner of the yacht is impeccably maintained. Sara's expertise and commitment to excellence contribute to a pristine and luxurious environment, enhancing the overall guest experience on board."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":7500000,"displayCurrency":"EUR","displayPrice":7500000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":8500000,"displayCurrency":"EUR","displayPrice":8500000,"unit":"WEEK"},"pricingInfo":[{"name":"SEASON A (From 18 April 2026 till 27 May 2026) & SEASON E (From 03 October 2026 till 03 November 2026)","effectiveDates":[{"from":"2026-04-18T00:00:00.000Z","to":"2026-05-27T23:59:59.999Z"},{"from":"2026-10-03T00:00:00.000Z","to":"2026-11-03T23:59:59.999Z"}],"pricing":{"currency":"EUR","unit":"WEEK","inputAmountTaxed":"EXCLUSIVE","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":7500000,"amount":7500000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0}},{"item":"APA","quantity":0.3,"unitPrice":7500000,"amount":2250000,"conditions":""},{"item":"VAT","conditions":"","quantity":0.13,"unitPrice":7500000,"amount":975000}],"subTotal":10725000,"totalTax":0,"total":10725000,"note":"","charterFee":7500000},"inclusionZones":[{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910156249996,19.400976562500006,46.534619140625]}],"exclusionZones":[],"petsAllowed":false},{"name":"SEASON B (From 28 May 2026 till 20 June 2026) & SEASON D (From 01 September 2026 till 02 October 2026)","effectiveDates":[{"from":"2026-05-28T00:00:00.000Z","to":"2026-06-20T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-10-02T23:59:59.999Z"}],"pricing":{"currency":"EUR","unit":"WEEK","inputAmountTaxed":"EXCLUSIVE","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":7800000,"amount":7800000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0.13}},{"item":"APA","quantity":0.3,"unitPrice":7800000,"amount":2340000,"conditions":""},{"item":"VAT",