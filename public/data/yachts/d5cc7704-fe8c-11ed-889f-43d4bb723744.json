:1.3,"hullType":"Catamaran","hullConstruction":"","tonnage":"","superStructure":[],"engines":"2 x 375HP","amenities":[{"label":"Air Conditioning"},{"label":"Onboard WIFI"},{"label":"Salon TV"},{"label":"Ice Maker"},{"label":"Hairdryers"},{"label":"Water Maker"},{"label":"Iron"},{"label":"Safe in master cabin"},{"label":"Fusion Sound System"},{"label":"Flybridge with bar"}],"toys":[{"label":"SU Paddle Boards","quantity":"2"},{"label":"Hydraulic Swimming Platform"},{"label":"Snorkeling Gear","quantity":"6"},{"label":"Fishing Gear"},{"label":"Inflatable Couch for 2 pax","quantity":"1"},{"label":"Board games: backgammon, cards"},{"label":"Boarding Ladder (Hydraulic aft)"}],"entertainment":["Onboard WIFI","Salon TV","Fusion Sound System"],"tenders":["Grand Boat Tender with 40 HP outboard (4 pax)"]},"crew":[{"name":"Konstantis Giannoulis","role":"Captain","bio":"Konstantis was born in 1981. He is a multifaceted individual with a profound blend of technical and nautical expertise. Holding degrees in Architectural Engineering and Landscape Architecture, Konstantis brings a meticulous and creative approach to all his endeavors. His passion for the sea is evident through his Offshore Sailing Licence and Motor Boat Licence, underscoring his capabilities in navigating and commanding vessels. Known for his exceptional communication, leadership, and teamwork skills, Konstantis excels in critical thinking and problem-solving, making him an adept leader in challenging situations. Outside his professional life, he is an avid enthusiast of spearfishing, spinning, skiing/snowboarding, weightlifting, motorbike enduro, and cooking. Fluent in both English and Greek, Konstantis effortlessly bridges cultures, enriching his interactions both on and off the water."},{"name":"Electra Papanastasiou","role":"Captain","bio":"Electra was born in 1994 in Greece. She has joined the yachting industry only 2 years ago, after working as a hairdresser and hotel receptionist for a few years, always focusing on customer service and impeccable customer relations. In the last two years she has learned to adapt herself to work on a yacht, to work in a team, organize and optimize her time as efficient as possible to provide the best experience to her guests!! She is friendly, trustworthy, and very hard working. With her keen eye to detail and discreet and pleasant attitude, she will know her guests’ desires before they do! She is always happy to assist! Electra is a certified PADI diver, learning to become a PADI rescuer, she is fit and loves to hike, climb and being active. She speaks Greek and English."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1400000,"displayCurrency":"EUR","displayPrice":1400000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1750000,"displayCurrency":"EUR","displayPrice":1750000,"unit":"WEEK"},"pricingInfo":[{"name":"High Season","effectiveDates":[{"from":"2026-08-31T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-08-31T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-08-31T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1750000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1750000,"amount":1750000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.12}},{"item":"APA","conditions":"","quantity":0.3,"unitPrice":1750000,"amount":525000}],"total":2485000,"subTotal":2275000,"totalTax":210000},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]}],"exclusionZones":[],"petsAllowed":false},{"name":"Mid Season","effectiveDates":[{"from":"2026-06-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-06-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2028-06-01T00:00:00.