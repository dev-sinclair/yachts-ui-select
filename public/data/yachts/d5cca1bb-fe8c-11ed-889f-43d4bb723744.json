":8,"fuelCapacity":700,"cabinLayout":[{"label":"Double Cabins","value":"3"}],"cabins":3,"bathrooms":3,"length":14.02,"beam":7.31,"draft":1.37,"hullType":"Catamaran","hullConstruction":"Fibreglass","superStructure":[],"engines":"2 x 54 hp Yanmar","amenities":[{"label":"Air Conditioning"},{"label":"Sun Awning"},{"label":"Windscoops"},{"label":"Deck Shower"},{"label":"Bimini"},{"label":"Special Diets"},{"label":"Hairdryers"},{"label":"Port Hatches"},{"label":"Generator"},{"label":"Ice Maker"},{"label":"Water Maker"},{"label":"Purified drinking water"},{"label":"Re-usable water bottles"},{"label":"SeaDek"},{"label":"VHF Radio"},{"label":"Emergency Satellite Phone"}],"toys":[{"label":"Snorkel Gear"},{"label":"Tube"},{"label":"Floating Mats"},{"label":"Boarding Ladder"},{"label":"Beach Games"},{"label":"SU Paddle Boards","quantity":"2"},{"label":"Fishing Gear"},{"label":"Underwater Camera"},{"label":"Underwater Video"},{"label":"Sea Scooters"},{"label":"Subwing"}],"entertainment":["Salon TV","Media server","Salon Stereo","iPod/Device Hookups","Onboard Wi-Fi"],"tenders":["Highfield CL380 with 25 HP engine (7 pax)"]},"crew":[{"name":"Scott Clark","avatar":"/media/media::image::c::8275378522::vessel::d5cca1bb-fe8c-11ed-889f-43d4bb723744::assets::eebf6d10-9f8a-11ee-b1a9-b724d181716e.png/{imageVariant}","role":"Captain","bio":"Scott & Holly are a fun, adventure seeking couple from Florida. They have been a team since 1995 and have raised 2 fine, young men, Quinn and Aiden, who help crew on occasion.\n\nScott was raised in Houston, TX before he packed up, set sail, cruised the Caribbean and ended up in Fort Lauderdale where he met Holly. Scott's hobbies and talents are too numerous to list, but has a flare for all things electrical. He has poured his blood, sweat and tears into making The Space Between what she is today."},{"name":"Holly Clark","avatar":"/media/media::image::c::8275378522::vessel::d5cca1bb-fe8c-11ed-889f-43d4bb723744::assets::f4dd4870-9f8a-11ee-b1a9-b724d181716