TIONAL MEALS TO HIGH STANDARDS."},{"name":"MARINA ŠEGVIĆ","avatar":"/media/media::image::c::9333019154::vessel::b68f6650-8d08-11ee-8898-310d64ea482b::assets::86774000-99b0-11ee-b165-43321e293344.jpeg/{imageVariant}","role":"Steward","bio":"MARINA IS A SKILLED CREW MEMBER WHO HAS EXPERIENCE WORKING AS A HOSTESS ON A CHARTER YACHT WHERE SHE TOOK CARE OF THE INTERIOR, COOKED AND HELPED IN MOORING THE BOAT. SHE HAS EXCELLENT COMMUNICATION AND SERVICE SKILLS AND IS A RESPONSIBLE AND AMBITIOUS PERSON. MARINA ALSO HAS EXPERIENCE DRIVING BOATS\nUP TO 7 METERS AND HAS WORKED AS A SECOND SKIPPER ON A SPEEDBOAT FOR DAY TRIPS. SHE IS CURRENTLY STUDYING AT THE UNIVERSITY DEPARTMENT OF MARINE STUDIES IN SPLIT. WITH HER POSITIVE ATTITUDE AND DEDICATION TO CLIENT SATISFACTION, SHE IS A VALUABLE ASSET TO THIS CHARTER YACHT."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":3000000,"displayCurrency":"EUR","displayPrice":3000000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":3200000,"displayCurrency":"EUR","displayPrice":3200000,"unit":"WEEK"},"pricingInfo":[{"name":"Low Season","effectiveDates":[{"from":"2026-01-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2028-01-01T00:00:00.000Z","to":"2028-06-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"},{"from":"2028-09-01T00:00:00.000Z","to":"2028-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","inputAmountTaxed":"EXCLUSIVE","subTotal":3000000,"totalTax":0,"total":3000000,"lineItems":[{"item":"Charter Fee","conditions":"VAT & APA Excluded","quantity":1,"unitPrice":3000000,"amount":3000000}],"note":"","charterFee":3000000,"unit":"WEEK"},"inclusionZones":[{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910