erStructure":[],"engines":"2 x 57HP Yanmar","amenities":[{"label":"Air conditioning"},{"label":"Sun Awning"},{"label":"Special Diets"},{"label":"Generator"},{"label":"Ice Maker"},{"label":"Hairdryers"},{"label":"BBQ"},{"label":"Port Hatches"},{"label":"Deck shower"},{"label":"Water Maker"},{"label":"Bimini"},{"label":"Purified drinking water"},{"label":"Re-usable water bottles"}],"toys":[{"label":"Snorkeling Gear"},{"label":"Tube"},{"label":"Wakeboard","quantity":"1"},{"label":"10ft Floating Dock"},{"label":"Swim Platform"},{"label":"Boarding Ladder"},{"label":"Beach Games"},{"label":"Stand Up Paddle Boards","quantity":"2"},{"label":"Fishing Gear"},{"label":"Underwater Camera"},{"label":"Underwater Video"},{"label":"Sea Scooters"},{"label":"Subwing","quantity":"1"},{"label":"Floats/Noodles"},{"label":"Underwater Lights"},{"label":"Onshore Games"}],"entertainment":["Salon TV","Salon Stereo","iPod/Device Hookups","Onboard Wi-Fi"],"tenders":["12ft\tDinghy with 40 HP engine (6 pax)"]},"crew":[{"name":"Tina Mraovic","avatar":"/media/media::image::c::8275378522::vessel::d5cca39c-fe8c-11ed-889f-43d4bb723744::assets::db486ef0-9f88-11ee-b13a-f50df0a0e7e5.png/{imageVariant}","role":"Captain","bio":"Born and raised in Zagreb, the capital of Croatia, Tina studied at the Faculty of Kinesiology. As an elective, she took a class on sailing, and as she says, \"Once you try sailing, you get hooked for life!\" She has been a captain now for the last six years, sailing the Mediterranean, from Turkey to Greece and Croatia.\n\nDuring the winter seasons, she went from sailing, to being a ski instructor all over Europe. This year, she is trading in her skis for the tropical waters of the Caribbean! She is passionate about sailing, water sports, diving, running, hiking and just enjoys being physically fit in general. She can’t wait to explore the Caribbean waters and showcase for guests the beauty that the islands hold."},{"name":"Elena Bellotti","avatar":"/media/media::image::c::8275378522::vessel::d5cca39c-fe8c-11ed-889f-43d4bb723744::assets::e4993ac0-9f88-11ee-b13a-f50df0a0e7e5.png/{imageVariant}","role":"Chef","bio":"Leaving behind a career in online marketing and a \"conventional\" life, Elena travelled extensively, followed her passion for cooking, got certified as a chef, and found her real calling in the yachting service industry. Sourcing and purchasing high-quality ingredients, and preparing rich, healthy and delicious gourmet meals with a creative plating is where she finds her pleasure. She loves taking care of guests and making them happy. Elena has a very friendly personality, and adapts fast. Being genuinely happy to work on yachts, you will always see a smile on her face."}],"pricing":{"weekPricingFrom":{"currency":"USD","price":2370000,"displayCurrency":"USD","displayPrice":2370000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":2700000,"displayCurrency":"USD","displayPrice":2700000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer/Winter - Low Season","effectiveDates":[{"from":"2026-05-01T00:00:00.000Z","to":"2026-12-14T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-12-14T23:59:59.999Z"},{"from":"2028-05-01T00:00:00.000Z","to":"2028-12-14T23:59:59.999Z"}],"pricing":{"currency":"USD","charterFee":2370000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2370000,"amount":2370000,"conditions":"VAT & APA Excluded"}],"total":2370000,"subTotal":2370000,"totalTax":0},"inclusionZones":[{"label":"British Virgin Is.","type":"Dependency","category":["North America","Caribbean","British Virgin Is."],"coordinates":[-64.45080373172777,18.568736231458896],"bbox":[-64.69511718749999,18.399121093749997,-64.273583984375,18.752685546875]},{"label":"U.S. Virgin Is.","type":"Dependency","category":["North America","Caribbean","U.S. Virgin Is."],"coordinates":[-64.79221690684143,18.050874527948764],"bbox":[-65.0236328125,17.701708984375003,-64.58046875,18.385205078124997