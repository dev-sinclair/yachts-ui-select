s::947c6630-aa45-11ee-8dcf-4df3956208f6.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::85291250-7f1b-11ee-bfa7-af046f7fa5ba::assets::4968bbd0-aa45-11ee-8dcf-4df3956208f6.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::85291250-7f1b-11ee-bfa7-af046f7fa5ba::assets::dfa5d7f0-aa44-11ee-8dcf-4df3956208f6.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::85291250-7f1b-11ee-bfa7-af046f7fa5ba::assets::a4b569a0-aa42-11ee-8dcf-4df3956208f6.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::85291250-7f1b-11ee-bfa7-af046f7fa5ba::assets::9f2cc960-aa42-11ee-8dcf-4df3956208f6.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::85291250-7f1b-11ee-bfa7-af046f7fa5ba::assets::965f5e60-aa42-11ee-8dcf-4df3956208f6.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::85291250-7f1b-11ee-bfa7-af046f7fa5ba::assets::9a1c6660-aa42-11ee-8dcf-4df3956208f6.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::85291250-7f1b-11ee-bfa7-af046f7fa5ba::assets::d64b8d30-67c1-11f0-a373-cf689b58f09d/{imageVariant}"],"make":"Fountaine Pajot","model":"Saba 50","maxCrew":2,"sleeps":10,"basePort":{"uri":"a::place::16e17940-6187-11f0-b716-09fc9d01b6f6","name":"Marina Trogir","coordinates":{"latitude":43.51398901922514,"longitude":16.11026639252227},"country":"Croatia"},"cruisingCapacity":0,"staticCapacity":0,"builtYear":2017,"architect":"","refitYear":2025,"topSpeed":13,"cruiseSpeed":6,"fuelCapacity":940,"cabinLayout":[{"label":"Double Cabins","value":"6"},{"label":"Front peak","value":"1"}],"cabins":6,"bathrooms":6,"length":15.24,"beam":7.99,"draft":1.25,"hullType":"Catamaran","hullConstruction":"","tonnage":28,"engines":"2 x Volvo 75.0 HP","amenities":[{"label":"Air Conditioning"},{"label":"Generator"},{"label":"Inverter"},{"label":"Watermaker "},{"label":"Heating"},{"label":"Solar panels"},{"label":"Bimini top"},{"label":"Cockpit/stern, outside shower hot water"},{"label":"Flybridge"},{"label":"Coffee machine"},{"label":"Dishwasher"},{"label":"Ice maker"},{"label":"Microwave"},{"label":"Refrigerator","quantity":"3"},{"label":"Teak deck"},{"label":"Grill/Barbecue/Plancha Gas operated"},{"label":"Liferaft"},{"label":"Life jackets"},{"label":"Autopilot"},{"label":"Underwater lights"}],"toys":[{"label":"Stand Up Paddles (SUP)","quantity":"2"},{"label":"Snorkeling gear: mask & flippers"}],"entertainment":["Wi-Fi","Bose Sound System","Fusion radio (DVD/CD/USB/Bluetooth + AM/FM)","LCD TV"],"tenders":["RIB 3.9m with 50hp engine (operated by Skipper)"]},"crew":[{"name":"Sandre Stoić","avatar":"/media/media::image::c::10218162598::vessel::85291250-7f1b-11ee-bfa7-af046f7fa5ba::assets::8f94b7d0-67c2-11f0-81cf-0d584f45621c/{imageVariant}","role":"Captain","bio":"Sandre Stoić born in 1978 and raised in a small town in the heart of the region Slavonija called Đakovo. He successfully finished in Zagreb university, where he acquired a bachelor’s degree in civil aviation management. Sandre father who is a karate sensei instilled love for sports and japanese culture so after college, during employment, he took 5 semesters of faculty of Japanese language and culture. Throughout life he practiced all kinds of sports, from karate as a kid, football, volleyball, basketball, even chess, ultimately ending up in rock climbing which he does whenever possible. Finally in 2013 Sandre realized the comfort zone and corporate life was no longer an option and decided to do a radical career change and went to Academia Navalis Adriatica sailing school on island Murter to learn how to sail and become a professional skipper, where he also later occasionally worked as a sailing instructor. He called his career change a “mission”, aimed at learning everything there is to know about the sea and sharpen the naval skills. That mission immediately turned into “love at first sail”. Working for various companies he sailed the Adriatic coast from Venice to Greece. Always trying to get his clients the best possible option during their vacation with a strong awareness of safety, his proficiency in navigating is complemented by commendable cooking skills, ensuring a well-rounded skill-set on and off the deck. Professionally as well as individually he kept expanding his skillet by taking new courses regularly like RYA/MCA Yacht master offshore and GMDSS certificates in 2016 & 2017. In the UK sailing in the Solent channel, STCW D2 course and SSI Open water scuba in 2018.\n\nWHAT MAKES HIM HAPPY BESIDE WORK: He has a vast range of interests like movies & tv shows, pub quizzes, history, working out, absolutely loves travelling and trying street food, reading books and graphic novels, gaming, anime, essentially being an odd mix of an activity-loving adventurer."},{"name":"Nikolina Petričević","avatar":"/media/media::image::c::10218162598::vessel::85291250-7f1b-11ee-bfa7-af046f7fa5ba::assets::d8fd9860-67c2-11f0-81cf-0d584f45621c/{imageVariant}","role":"Captain","bio":"Nikolina Petričević was born in 2001 in Croatia and is currently a fifth-year student at the Faculty of Kinesiology, specializing in sailing. She is an active and adventurous person who spends most of her free time outdoors, engaging in all kinds of physcal activities such as running, kayaking, hiking, cycling, etc. Her love for nature and movement is a defining part of her character. She loves cooking and takes great joy in preparing meals that bring happiness to those around her. Additionally, she is organized, detail-oriented, and self-reliant in her work. Nikolina has a natural affinity for working with children, who are drawn to her warm and energetic personality. Her ability to combine physical activity, hospitality, and culinary skills ensures that guests and crew members feel comfortable, well-fed, and entertained.”\n\nWHAT MAKES HER HAPPY BESIDE WORK: Nikolina enjoys exploring new places, discovering hidden nature spots, and spending quality time with friends and family. Cooking for loved ones and seeing them enjoy her meals is one of her greatest pleasures. She also finds joy in training both her mind and body, constantly striving for personal growth and self-improvement."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":390000,"displayCurrency":"EUR","displayPrice":390000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1605500,"displayCurrency":"EUR","displayPrice":1605500,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rate 2025: 06/25/2025 - 08/27/2025","effectiveDates":[{"from":"2025-06-25T00:00:00.000Z","to":"2025-08-27T23:59:59.999Z"},{"from":"2026-06-25T00:00:00.000Z","to":"2026-08-27T23:59:59.999Z"},{"from":"2027-06-25T00:00:00.000Z","to":"2027-08-27T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1521000,"inputAmountTaxed":"INCLUSIVE","note":"Wednesday-Wednesday","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1690000,"amount":1521000,"conditions":"VAT is Inclusive","taxRate":{"label":"VAT","value":0.13},"discount":{"type":"PERCENTAGE","value":0.1}}],"total":1521000,"subTotal":1521000,"totalTax":197730},"inclusionZones":[{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910156249996,19.400976562500006,46.534619140625]}],"exclusionZones":[],"petsAllowed":false},{"name":"Weekly Rate 2025: 08/27/2025 - 09/03/2025","effectiveDates":[{"from":"2025-08-27T00:00:00.000Z","to":"2025-09-03T23:59:59.999Z"},{"from":"2026-08-27T00:00:00.000Z","to":"2026-09-03T23:59:59.999Z"},{"from":"2027-08-27T00:00:00.000Z","to":"2027-09-03T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1190000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1190000,"amount":1190000,"conditions":"VAT is Inclusive","taxRate":{"label":"VAT","value":0.13}}],"total":1190000,"subTotal":1190000,"totalTax":154700},"inclusionZones":[{"label":"