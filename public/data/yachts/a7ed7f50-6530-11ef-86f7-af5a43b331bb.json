78fe81e0-67cc-11f0-b218-59b21826ea6f/{imageVariant}","/media/media::image::a::vessel::a7ed7f50-6530-11ef-86f7-af5a43b331bb::assets::78b3e450-67cc-11f0-b217-59b21826ea6f/{imageVariant}","/media/media::image::a::vessel::a7ed7f50-6530-11ef-86f7-af5a43b331bb::assets::78b3e450-67cc-11f0-b218-59b21826ea6f/{imageVariant}","/media/media::image::a::vessel::a7ed7f50-6530-11ef-86f7-af5a43b331bb::assets::78b32100-67cc-11f0-b217-59b21826ea6f/{imageVariant}","/media/media::image::a::vessel::a7ed7f50-6530-11ef-86f7-af5a43b331bb::assets::78b39630-67cc-11f0-b217-59b21826ea6f/{imageVariant}","/media/media::image::a::vessel::a7ed7f50-6530-11ef-86f7-af5a43b331bb::assets::78b2abd0-67cc-11f0-b217-59b21826ea6f/{imageVariant}"],"make":"Lagoon-Bénéteau","model":"Lagoon 51","maxCrew":2,"sleeps":10,"basePort":{"uri":"a::place::16e17940-6187-11f0-b716-09fc9d01b6f6","name":"Marina Trogir","coordinates":{"latitude":43.51398901922514,"longitude":16.11026639252227},"country":"Croatia"},"cruisingCapacity":14,"builtYear":2025,"architect":"","interiorDesigner":"","topSpeed":13,"cruiseSpeed":6,"fuelCapacity":1040,"cabinLayout":[],"cabins":6,"bathrooms":4,"length":15.55,"beam":8.1,"draft":1.4,"hullType":"Catamaran","tonnage":24,"engines":"Yanmar 2×80 HP","amenities":[{"label":"Air Conditioning in all cabins"},{"label":"Generator"},{"label":"Inverter"},{"label":"Heating in all cabins"},{"label":"Watermaker"},{"label":"Flybridge"},{"label":"Swimming ladder","quantity":"2"},{"label":"Teak deck"},{"label":"Grill/Barbecue/Plancha Electric"},{"label":"Coffee machine"},{"label":"Oven  gas"},{"label":"Dishwasher "},{"label":"Ice maker"},{"label":"Microwave "},{"label":"Refrigerator ","quantity":"3"},{"label":"Fridge"},{"label":"Freezer"},{"label":"Underwater lights","quantity":"6"}],"toys":[{"label":"Snorkeling equipment Mask + flippers"},{"label":"Stand up paddle","quantity":"2"}],"entertainment":["Bose Sound System","LCD TV Samsung ","Fusion radio Fusion APOLLO MS-RA 670","Wi-Fi Internet 4 LTE"],"tenders":["RIB 3.8 m with 50 HP"]},"crew":[{"name":"Lucian Sostarcic","avatar":"/media/media::image::a::vessel::a7ed7f50-6530-11ef-86f7-af5a43b331bb::assets::aacfd500-67c9-11f0-8f1b-95d302e27d19/{imageVariant}","role":"Captain","bio":"Lucian Sostarcic, born 1985 in Rijeka, Croatia where he graduated Faculty of Maritime Studies. Since a young age he developed interest for the sea and sailing. He start sailing in sailing club at age of 10, and progress through different classes to professional sailor. Lucian was representing Croatia on several State, European and World Championships with notable results. He started working as a professional skipper in 2004 on sailing and motor boats, catamarans, as well as sailing instructor. Lucian is certified Yacht Master and holds D2 Basic Safety, GMDSS and ECDIS (STCW) certificates. With his experience as a professional skipper he gained noteworthy navigational experience, excellent communication and relationship skills to provide nice and relaxing time on board. He is fluent English speaker with excellent knowledge of Adriatic coast, history, restaurants and wine tasting routes. Lucian is very patient and approachable person which makes him pleasant to be on board.\nHe likes to entertain kids with water toys, which we have on board, and parents likes him also very much because can fully relax as well 🙂\n\nWHAT MAKES HIM HAPPY BESIDE WORK: He is very keen to develop existing and adopt new skills, he likes to travel and establish new friendships however reading is one of his top hobbies."},{"name":"Paula Krmpotic","avatar":"/media/media::image::a::vessel::a7ed7f50-6530-11ef-86f7-af5a43b331bb::assets::c59fd880-67c9-11f0-a788-a3f0ad9ed614/{imageVariant}","role":"Captain","bio":"Paula Krmpotić was born in 1998 in Zagreb, Croatia. She graduated from the Faculty of Kinesiology with a major in sailing. Paula’s passion for sports and physical activity has driven her to work extensively with children as a sports coach with focus on leading programs in volleyball. Her love for the sea led her to work as a hostess on sailboats and catamarans along the Adriatic, blending warm hospitality with her nautical knowledge. Paula is fluent in English and German, with a C-category skipper license. Known for her adaptability, excellent communication and teamwork, she consistently creates enriching and positive experiences for all guests including the kids and teenagers.\n\nWHAT MAKES HER HAPPY BESIDE WORK: In her free time, she enjoys spending time outdoors, reading books, listening to music or playing volleyball with friends, always finding joy in these simple yet fulfilling activities."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":590000,"displayCurrency":"EUR","displayPrice":590000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1990000,"displayCurrency":"EUR","displayPrice":1990000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rate 2025: 06/25/2025 - 08/27/2025","effectiveDates":[{"from":"2025-06-25T00:00:00.000Z","to":"2025-08-27T23:59:59.999Z"},{"from":"2026-06-25T00:00:00.000Z","to":"2026-08-27T23:59:59.999Z"},{"from":"2027-06-25T00:00:00.000Z","to":"2027-08-27T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1990000,"inputAmountTaxed":"INCLUSIVE","note":"Wednesday-Wednesday","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1990000,"amount":1990000,"conditions":"VAT is Inclusive","taxRate":{"label":"VAT","value":0.13}},{"item":"Security Deposit","conditions":"","quantity":0,"unitPrice":300000,"amount":0},{"item":"APA","conditions":"","quantity":1,"unitPrice":300000,"amount":300000}],"total":2290000,"subTotal":2290000,"totalTax":258700},"inclusionZones":[{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910156249996,19.400976562500006,46.534619140625]}],"exclusionZones":[],"petsAllowed":false},{"name":"Weekly Rate 2025: 08/27/2025 -