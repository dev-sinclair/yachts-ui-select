79668770::vessel::d5cc2591-fe8c-11ed-889f-43d4bb723744::assets::58f692e0-3f76-11ef-9dad-7944beed4bcc.jpeg/{imageVariant}"],"make":"Fountaine Pajot","model":"Ipanema 58","maxCrew":3,"sleeps":6,"basePort":{"uri":"a::place::a20615e0-5634-11ee-8859-f145b73b1327","name":"France","coordinates":{"latitude":46.22774345327576,"longitude":2.213656257425771},"country":"France"},"builtYear":2018,"architect":"","interiorDesigner":"","refitYear":2024,"topSpeed":"","cruiseSpeed":"","fuelCapacity":1100,"cabinLayout":[],"cabins":3,"bathrooms":3,"length":17.8,"beam":8.8,"draft":1.4,"hullType":"Catamaran","hullConstruction":"Composite","tonnage":"","superStructure":[],"engines":"2 x 110HP Volvo","amenities":[{"label":"Sunbathing Area"},{"label":"Flybridge"},{"label":"Lounge Area"},{"label":"Air Conditioning"},{"label":"Wi-Fi"}],"toys":[{"label":"Tender"},{"label":"SUP","quantity":"2"},{"label":" Kayak"},{"label":"Snorkeling equipment"},{"label":"Fishing equipment"},{"label":"Donut"}],"entertainment":["Wi-Fi"],"tenders":["4.20m with 50 HP Highfield Ocean Master"]},"crew":[{"name":"Baptiste Le Risbé","avatar":"/media/media::image::c::7579668770::vessel::d5cc2591-fe8c-11ed-889f-43d4bb723744::assets::d5bfdee0-370d-11f1-927d-17162d3ac154/{imageVariant}","role":"Captain","bio":"Sail and Work Experience\nBaptiste is an experienced Captain with a strong sailing background, having commanded several sailing yachts on both private and charter cruises. His experience includes skippering vessels such as S/Y TRISKEL and S/Y GARDEN, as well as working with TRADEWINDS, where he managed vessel preparation, navigation, and onboard operations. He has also completed multiple deliveries and Atlantic crossings as Second and crew, and brings additional offshore experience from time spent working on fishing vessels in the Channel and North Atlantic. \n\nJob Description\nBaptiste is responsible for navigation, safety, and the overall running of the vessel, including maintenance, crew management, and ensuring smooth and enjoyable experiences for guests. He oversees daily operations, passage planning, and compliance with maritime regulations.\n\nLicences and Qualifications\nCaptain 200 Sail\nMedical Care Level III\nGMDSS (CGO)\nValid Medical Certificate\n\nLanguages\nFrench, English\n"},{"name":"Pauline Legrand Garcia","avatar":"/media/media::image::c::7579668770::vessel::d5cc2591-fe8c-11ed-889f-43d4bb723744::assets::dc09d350-370d-11f1-927d-17162d3ac154/{imageVariant}","role":"Captain","bio":"Sail and Work Experience\nPauline is an experienced Deck/Stew with a strong dual skillset across interior, deck, and galley responsibilities. She has worked on both private and charter sailing yachts, including with TRADEWINDS in French Polynesia, where she combined chef and hostess duties. Her experience includes Mediterranean and Caribbean cruising, as well as involvement in deliveries and coastal cruising, with responsibilities ranging from meal preparation and service to navigation support, watchkeeping, and general vessel maintenance. \n\nJob Description\nPauline supports both interior and deck operations, managing housekeeping, service, and guest care while also assisting with navigation, mooring, and general maintenance. She contributes to meal preparation and provisioning, ensuring smooth day-to-day operations and a high standard of guest experience onboard.\n\nLicences and Qualifications\nDeckhand Certificate\nCFBS\nMedical I\nFood Safety & Hygiene Level 2\n\nLanguages\nFrench, English\n"},{"name":"Christelle Vannier","avatar":"/media/media::image::c::7579668770::vessel::d5cc2591-fe8c-11ed-889f-43d4bb723744::assets::2db9ead0-e3a6-11ef-b970-4fe69b634b7e/{imageVariant}","role":"Captain","bio":"Sail and Work Experience\nChristelle has over two decades of experience in the yachting industry as a chef, hostess, and deckhand on both sailing and motor yachts. She has catered to high-end clients aboard yachts like LOOMA, CILIAM, SEMPER FIDELIS, and MAYRILOU, while also gaining hands-on experience in guest service, sailing maneuvers, and yacht maintenance. She has held long-term positions on HOUBARA, LADY M, PIXELION, and GARUDA. A passionate sailor, she has competed in regattas like the Heineken Regatta on SONADIO and Les Voiles de St. Tropez on PIXELION, and has completed transatlantic crossings, including LOOMA from Saint-Tropez to Saint-Martin and GARUDA from Monaco to Fort-de-France.\n\nJob Description\nAs the chef, Christelle is responsible for the crew and guest meals throughout the charter, ensuring that the food is enjoyable, the interior of the yacht is clean and serviceable, and that all dietary requirements are met. He is a creative cook, varying her meals to provide variety and according to the location of ARAOK, to have as much relevance as possible to the region being visited.\n\nLicenses and Qualifications\n•\tCIN (2016)\n•\tCRO (2016)\n•\tCFBS (2006, revalidated)\n•\tSea and Inland Waterway License\n•\tUp-to-date Medical Certificate\n•\tHACCP (2020)\n•\tCommis Chef Certificate (2020)\n•\tSST (First Aid & Safety at Work) (2019)\n•\tMedical III (2022)\n"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":2500000,"displayCurrency":"EUR","displayPrice":2500000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2900000,"displayCurrency":"EUR","displayPrice":2900000,"unit":"WEEK"},"pricingInfo":[{"name":"Low Season (Mediterranean) - Summer Price","effectiveDates":[{"from":"2025-05-01T00:00:00.000Z","to":"2025-06-30T23:59:59.999Z"},{"from":"2026-05-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2025-09-01T00:00:00.000Z","to":"2025-10-31T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-10-31T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-10-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":2500000,"inputAmountTaxed":"NONE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":