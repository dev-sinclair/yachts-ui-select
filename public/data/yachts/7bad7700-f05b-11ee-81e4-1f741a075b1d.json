mage::a::vessel::7bad7700-f05b-11ee-81e4-1f741a075b1d::assets::efed47b0-dc89-11ef-b06f-ed215af5060b/{imageVariant}","/media/media::image::a::vessel::7bad7700-f05b-11ee-81e4-1f741a075b1d::assets::efe8dae0-dc89-11ef-b9c4-7d4b1ba80391/{imageVariant}","/media/media::image::a::vessel::7bad7700-f05b-11ee-81e4-1f741a075b1d::assets::f01a9940-dc89-11ef-b9c4-7d4b1ba80391/{imageVariant}","/media/media::image::a::vessel::7bad7700-f05b-11ee-81e4-1f741a075b1d::assets::efe27240-dc89-11ef-846e-d73c57779eff/{imageVariant}"],"make":"Sunreef Yachts","model":"Sunreef 60","maxCrew":3,"sleeps":8,"basePort":{"uri":"a::place::738f24c0-dada-11ed-befa-d7914edd5e3a","name":"Marina Kastela","coordinates":{"latitude":43.54601254691691,"longitude":16.40283517494042},"country":"Croatia"},"cruisingCapacity":8,"builtYear":2022,"architect":"Sunreef Yachts","interiorDesigner":"Sunreef Yachts","cruiseSpeed":10,"fuelCapacity":1750,"cabinLayout":[{"label":"Double Cabins","value":"4"}],"cabins":4,"bathrooms":4,"length":18.3,"beam":10.2,"draft":1.6,"hullType":"Catamaran","hullConstruction":"","engines":"2 X Volvo Penta D4-175","amenities":[{"label":"Air Conditioning"},{"label":"Wi-Fi"},{"label":"Bimini Top"},{"label":"Hairdryers"},{"label":"Children Allowed"},{"label":"Inverter"},{"label":"Generator"},{"label":"Ice Maker"},{"label":"Deck shower"},{"label":"Yoga Mats","quantity":"2"},{"label":"Gym/Exercise Equipment"},{"label":"iPod/Device Hookups"},{"label":"Watermaker"},{"label":"Heating"},{"label":"Bow thruster"}],"toys":[{"label":"Dinghy (6 pax)"},{"label":"Adult Water skis"},{"label":"Kids Water skis"},{"label":"Kneeboard"},{"label":"Sea Bobs"},{"label":"Snorkel Gear"},{"label":"Towable ring"},{"label":"Wake Board"},{"label":"2-Man Kayak"},{"label":"Floating Mats"},{"label":"Stand up paddleboards","quantity":"2"},{"label":"Beach Games"},{"label":"Fishing Gear"},{"label":"Jobe Lunar Towable 3P"},{"label":"Board Games"}],"entertainment":["Wi-Fi","Salon TV","DVD Player","Salon Stereo","iPod/Device Hookups","Audio System"],"tenders":["Rib with 70 hp outboard"]},"crew":[{"name":"PEPI JARDAS","role":"Captain","bio":"NATIONALITY / AGE / LANGUAGE\nCroatian / Born 1993 /  ENGLISH, ITALIAN, RUSSIAN, CROATIAN\n\nQUALIFICATIONS\nOff shore Yacht Master category A 100GT, D2 Basic Safety (SWTCW), D11 GMDSS\n\nCaptain Pepi Jardas was born and raised in Opatia. Growing up in vicinity of the sea, he was always engaged with water and sea. He has been a captain onboard  DESSUS since her launch and knows DESSUS from inside out. He can talk about her in details for hours. His experience in\ncludes navigating diverse vessels, including catamarans, motor yachts and sailing boats, both for pleasure and for competition. His career on board has resulted in great experience and vast knowledge of the Croatian coats, islands, beautiful beaches and coves and also historical sights and gastronomic scene. Pepi is fluent in English and Italian language, and can get by in Russian language. With his calm attitude, responsible and hardworking approach, captain Pepi will always make sure the guests onboard Sunreef 60 DESSUS have an unforgettable and unique Croatian charter experience.\n\nCaptian’s favorite nautical part on Croatian coast is island Korcula and surrounding sea area because of its perfect combination of beautiful nature, rich history and great restaurants."},{"name":"MARKO JAGNJIĆ","role":"Captain","bio":"Marko Jagnjić is an accomplished Croatian yacht chef with over 15 years of experience working on luxury yachts and charter vessels throughout the Adriatic Sea. He began his culinary journey at a young age and has since built a strong career at sea, serving as head and sole chef on both motor yachts and traditional gulets. Marko has worked on vessels such as Delphinus Yachts, S/Y Dolce Vita, and S/Y Perla, where he was responsible for all galley operations, high-end menu creation, provisioning, and guest satisfaction. Deeply inspired by seafood and Mediterranean cuisine, he is known for using fresh, locally sourced ingredients, adapting effortlessly to dietary requirements, and delivering creative, refined dining experiences with passion and professionalism. Creative, communicative, and highly organized, he is dedicated to delivering exceptional culinary experiences and continuously developing his skills with confidence and passion.\n"},{"name":"KATJA BLAGONIĆ","role":"Captain","bio":"Katja is a professional and warm yacht stewardess who enjoys taking care of guests and making them feel at home on board. \nWith extensive experience on motor yachts and catamarans, she has worked as both solo and chief stewardess, confidently managing all interior duties while providing personalized service. \nHer hospitality background and natural understanding of people allow her to adapt easily to different guest preferences and rhythms. \nWhether guests seek quiet relaxation, active exploration, or celebrating special moments, Katja ensures every detail is taken care of for an enjoyable holiday. \nShe creates a calm and welcoming atmosphere, offering elegant meal and drink service, thoughtfully arranged spaces, and discreet yet attentive care. \nFrom morning coffee to evening cocktails, her focus is always on guest comfort, enjoyment, and a stress-free experience at sea.\nFor Katja, the most rewarding part of her work is seeing guests fully relax during those golden Mediterranean sunsets, cocktail in hand, with nothing else to do but enjoy the moment."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":2400000,"displayCurrency":"EUR","displayPrice":2400000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":4250000,"displayCurrency":"EUR","displayPrice":4250000,"unit":"WEEK"},"pricingInfo":[{"name":"Until April 25, 2026","effectiveDates":[{"from":"2025-11-01T00:00:00.000Z","to":"2026-04-25T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":2400000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quanti