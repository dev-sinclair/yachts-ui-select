s::3938c731-0f09-11f0-82cd-d126ad00a286/{imageVariant}","/media/media::image::a::vessel::d5cc4ea5-fe8c-11ed-889f-43d4bb723744::assets::39387910-0f09-11f0-82cd-d126ad00a286/{imageVariant}","/media/media::image::a::vessel::d5cc4ea5-fe8c-11ed-889f-43d4bb723744::assets::393fa500-0f09-11f0-8541-7f277a7ecf4c/{imageVariant}","/media/media::image::a::vessel::d5cc4ea5-fe8c-11ed-889f-43d4bb723744::assets::39398a80-0f09-11f0-82cd-d126ad00a286/{imageVariant}","/media/media::image::a::vessel::d5cc4ea5-fe8c-11ed-889f-43d4bb723744::assets::39393c60-0f09-11f0-82cd-d126ad00a286/{imageVariant}","/media/media::image::a::vessel::d5cc4ea5-fe8c-11ed-889f-43d4bb723744::assets::393767a0-0f09-11f0-82cd-d126ad00a286/{imageVariant}"],"make":"Princess","model":"Princess 85 Fly","maxCrew":4,"sleeps":8,"basePort":{"uri":"a::place::a0201e12-b3ee-11ed-9c67-325096b39f47","name":"Trogir","coordinates":{"latitude":43.51634848,"longitude":16.2502206},"country":"Croatia"},"cruisingCapacity":12,"staticCapacity":0,"builtYear":2009,"architect":"Princess Yachts","interiorDesigner":"Princess Yachts","refitYear":2024,"topSpeed":30,"cruiseSpeed":19,"fuelCapacity":0,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"2"},{"label":"Bunk Cabin","value":"1"}],"cabins":4,"bathrooms":4,"decks":"","length":25.99,"beam":6.25,"draft":1.8,"hullType":"Planing","hullConstruction":"GRP","tonnage":98,"superStructure":["Flybridge"],"engines":"2x MTU 12V/2000 M93 (2x1825hp) 2 Onan generators, each 27 Kw","amenities":[{"label":"Air Conditioning"},{"label":"Deck Jacuzzi"},{"label":"Al Fresco dining"},{"label":"Stabilisers at anchor "},{"label":"Stabilisers underway"}],"toys":[{"label":"Jetski: Seadoo 230 Wake Pro - 2021 (3-seater)"},{"label":"Seabob F5S","quantity":"2"},{"label":"SUP","quantity":"2"},{"label":"Waterski"},{"label":"Fun tube"},{"label":"Snorkeling equipment"},{"label":"Wakeboard"},{"label":"Doughnut"}],"entertainment":["Wi-Fi"],"tenders":["Rib Tender 640, 175 PS Outboard engine (8 seater)"]},"crew":[{"name":"Stipe Peran","avatar":"/media/media::image::a::vessel::d5cc4ea5-fe8c-11ed-889f-43d4bb723744::assets::c681dd80-0f08-11f0-9b4f-9b10b060ff99/{imageVariant}","role":"Captain","bio":"Nationality: Croatian\n\nAfter finishing College of Nautical Studies and with a love for the sea, exploration, and teamwork Stipe made his first miles on the sea 10+ years ago. Through Fisherman's vessels, the Merchant Navy, and the Yachting Industry valuable experiences were gathered and now Stipe presents a blend of a fun, organized, and safety-focused Captain.\n\nWell-versed in managing the challenging environment, always delivering high standards and great knowledge of all hidden gems of the Adriatic gives you a guarantee for a perfect vacation."},{"name":"Dražen Puđa","avatar":"/media/media::image::a::vessel::d5cc4ea5-fe8c-11ed-889f-43d4bb723744::assets::d5c38140-0f08-11f0-9b4f-9b10b060ff99/{imageVariant}","role":"Captain","bio":"Nationality: Bosnian\n\nAn enthusiastic professional chef with nearly 20 years of experience, Dražen offers guests an unforgettable culinary journey. With extensive restaurant experience, Dražen decided to venture into the yachting industry, and he has exceeded expectations! Since 2018, he has been delighting guests with delicious menus aboard yachts, taking great pride and joy in his role. Dražen serves only the freshest, highest-quality ingredients, carefully selected from local markets, expertly prepared, and served to ensure guests receive the finest dining experience possible. Always positive and smiling, combined with his exceptional culinary skills, Dražen is a person you'll always be delighted to encounter."},{"name":"Matea Poljski","avatar":"/media/media::image::a::vessel::d5cc4ea5-fe8c-11ed-889f-43d4bb723744::assets::f6e2f770-0f08-11f0-8413-c9c576061e78/{imageVariant}","role":"Captain","bio":"Nationality: Croatian\n\nMatea has a very lively and active personality which is proved by her Master's degree in Physical education. During her studies, she also implemented her passion for swimming as a coach, both for small children and students. In 2018 she joined the on- board hospitality position for the first time and decided this is where she wants to develop her career. With her positive attitude, a constant smile on her face and a burst of energy, Matea is always around to fulfil all your wishes."},{"name":"Luka Tomić","avatar":"/media/media::image::a::vessel::d5cc4ea5-fe8c-11ed-889f-43d4bb723744::assets::0d813820-0f09-11f0-a60b-613b6f125440/{imageVariant}","role":"Captain","bio":"Nationality: Croatian\n\nSince becoming a registered skipper in 2017, Luka has honed his skills on smaller yachts and transitioned into his current role as a deckhand in January 2024. His passion for the maritime industry drives him to excel in his responsibilities, ensuring the yacht is always charter-ready while enhancing the guest experience. He prides himself on being both enthusiastic and reliable, qualities that make him a valuable asset to any crew.\n\nHis background as a successful athlete and certified fitness coach has instilled in him a strong work ethic and a commitment to teamwork.\nFurthermore, his interests in deep-sea fishing, diving, and cooking allow him to connect with guests on various levels, enriching their overall experience aboard. He is fluent in English and a native Croatian speaker."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":3900000,"displayCurrency":"EUR","displayPrice":3900000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":4900000,"displayCurrency":"EUR","displayPrice":4900000,"unit":"WEEK"},"pricingInfo":[{"name":"High Season Charter Rate:","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","unit":"WEEK","inputAmountTaxed":"EXCLUSIVE","lineItems":[{"item":"Char