f0-9eae-11ee-ae63-238241601caf.jpeg/{imageVariant}"],"make":"Broward","model":"","maxCrew":3,"sleeps":8,"basePort":{"uri":"a::place::dc73d6ca-b3ed-11ed-907c-325096b39f47","name":"Fort Lauderdale ","coordinates":{"latitude":26.12063116545865,"longitude":-80.10978381132306},"country":"United States"},"builtYear":1999,"architect":"","interiorDesigner":"","refitYear":2017,"topSpeed":19,"cruiseSpeed":16,"fuelCapacity":"","cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Double Cabin","value":"1"},{"label":"Twin Cabin","value":"1"}],"cabins":4,"bathrooms":4,"length":30.5,"beam":6.1,"draft":1.52,"hullType":"","hullConstruction":"","tonnage":"","superStructure":[],"engines":"2 x 3412TA Caterpillar","amenities":[{"label":"Air Conditioning"},{"label":"Children Allowed"},{"label":"Stabilizers Underway"}],"toys":[{"label":"Tubes"},{"label":"Waverunner"},{"label":"Kneeboard"},{"label":"1 Person Kayak"},{"label":"Snorkeling Gear"}],"entertainment":["Wi-Fi","Salon Stereo","Salon TV"],"tenders":["16ft AB Tender"]},"crew":[{"name":"James Paul Michie","avatar":"/media/media::image::c::8275378522::vessel::d5cc4e6d-fe8c-11ed-889f-43d4bb723744::assets::797f70e0-9f71-11ee-8a02-a772179a024c.png/{imageVariant}","role":"Captain","bio":"James has 30+ years professional experience on vessels up to 215’ with 2000+ Days at sea. He has extensive cruising experience and knowledge on the US East Coast, Bahamas, Great Lakes, Europe, Mediterranean, and Caribbean. He is a \"hands on\" Captain with strong engineering skills and experience with knowledge of the latest equipment and vessel types, vessel operation, maintenance, safety procedures, and boat restoration. He enjoys busy guest programs, with a strong focus on guest hospitality. Guests find him to be very pleasant and personable.\nJames has mentored several young and new Captains over a 30 year career."},{"name":"Christiano Rossi","role":"Chef","bio":"From the coastal city of San Benedetto Del Tronto, in the Marche region of Italy, Cristiano is an experienced 3rd generation chef. Aside from learning first hand at home from his mother and grandmother, Cristiano grew up working in the kitchens of their family owned fine dining restaurants, with his father and grandfather as master chefs. These authentic culinary skills, of course, were passed down to him at a very young age. With his close proximity to the Adriatic Sea, Cristiano’s adventurous spirit lead him to pursue a career as a yacht chef. Venturing out on his own, Cristiano has worked on yachts of all shapes and sizes, all over the world. While specializing in authentic and fusion Italian, French, and Mediterranean Cuisines, Cristiano’s abilities in the galley are limitless. Even in high stress situations, Cristiano’s calm and kind nature personality prevails."},{"name":"Jordyn Myers - Stewardess","avatar":"/media/media::image::c::8275378522::vessel::d5cc4e6d-fe8c-11ed-889f-43d4bb723744::assets::a0a0aef0-9f71-11ee-8a02-a772179a024c.png/{imageVariant}","role":"Chief Stewardess","bio":"Jordyn is an eager and upbeat native Floridian that has many years of customer service and hospitality experience that creates experiences that are enjoyable for everyone on board. Her hobbies include Swimming, Graphic Design, Photography, Painting, Fitness, Yoga, Hiking, Fishing, Cooking"}],"pricing":{"weekPricingFrom":{"currency":"USD","price":4000000,"displayCurrency":"USD","displayPrice":4000000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":4400000,"displayCurrency":"USD","displayPrice":4400000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer: North America - Low Season","effectiveDates":[{"from":"2025-05-01T00:00:00.000Z","to":"2025-05-31T23:59:59.999Z"},{"from":"2026-05-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-05-31T23:59:59.999Z"},{"from":"2025-09-01T00:00:00.000Z","to":"2025-09-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-30T23:59:5