72a00-3a7c-11ee-be55-3fa954721f05","name":"Marina Zeas","coordinates":{"latitude":37.93739170976762,"longitude":23.64612599437243},"country":"Greece"},"builtYear":2021,"architect":"","interiorDesigner":"","refitYear":"","topSpeed":10,"cruiseSpeed":9,"fuelCapacity":0,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"Double Cabins","value":"3"}],"cabins":4,"bathrooms":4,"decks":"","length":20.36,"beam":9.85,"draft":1.7,"hullType":"Catamaran","hullConstruction":"","tonnage":0,"superStructure":[],"engines":"2 x 150 HP Volvo Penta","amenities":[{"label":"Air Conditioning"},{"label":"Jacuzzi"},{"label":"Sun Awning\t"},{"label":"Children Allowed"},{"label":"Generator"},{"label":"Ice Maker"},{"label":"Hairdryers"},{"label":"Inverter"},{"label":"Gym/Exercise"},{"label":"Water Maker\t","quantity":"2"},{"label":"Bimini\t"},{"label":"Full teak deck"},{"label":"BBQ"},{"label":"Filtration system for drinking water (mineral & sparkling water)"}],"toys":[{"label":"Dinghy (8 pax)"},{"label":"Tube"},{"label":"SU Paddle Boards","quantity":"2"},{"label":"Fishing Gear"},{"label":"Kneeboard Jobe","quantity":"1"},{"label":"Wakeboard Jobe Maddox","quantity":"1"},{"label":"Boarding Ladder"},{"label":"Water Skis Adult\t"},{"label":"Water Skis Kids\t"},{"label":"SeaBobs (one with Seabob Cam) with quick chargers","quantity":"2"},{"label":"Snorkel Gear"},{"label":"Jobe Binar Towable 3P","quantity":"1"},{"label":"Jobe Multi board","quantity":"2"},{"label":"Banana (3 seater)"},{"label":"Jet Surf (1) - (upon request)"},{"label":"Hydraulic Bathing platform"}],"entertainment":["Wi-Fi","Sonos Stereo system","Portable sonos speakers","Bluetooth speakers","Satellite TV","Salon Stereo","Salon TV","Board games"],"tenders":["Highfield 4.20m 70 HP engine"]},"crew":[{"name":"Stavros Dritsas","avatar":"/media/media::image::a::vessel::d5cc7910-fe8c-11ed-889f-43d4bb723744::assets::278911e0-b89f-11ef-a704-9bb29f9d5ddf/{imageVariant}","role":"Captain","bio":"Captain Stavros, born on November 27, 1978, embarked on his sailing journey at the young age of 7, and since then, sailing has become an integral part of his life. This early initiation has provided him with extensive experience, allowing him to actively participate in numerous sailboat racing events and regattas.\n\nWith a solid foundation as a sailing instructor, Captain Dritsas prioritizes the safety of Guests, Crew, and the vessel above all else. His exceptional engineering skills, coupled with a background as a mechanic-electrician, provide him with the expertise to address and assist in mechanical operations on board. Known for his high adaptability to various situations and demands, he maintains excellent communication with both guests and his crew."},{"name":"Themis Tzounakos","avatar":"/media/media::image::a::vessel::d5cc7910-fe8c-11ed-889f-43d4bb723744::assets::3ef725b0-b89f-11ef-96d7-3975e1b193bf/{imageVariant}","role":"Captain","bio":"Themis, born in 1991 and a graduate of Le Monde Athens Institute, is a passionate and hardworking individual with more than 12 years of experience in the hospitality and restaurant sector. With a solid foundation of three years in the yachting industry, he has honed his skills as a sous and head chef in various establishments across Athens, Santorini, and Rhodes. Themis eagerly anticipates welcoming guests on board Kimata and sharing his culinary expertise, particularly in Greek and Mediterranean cuisine. Fluent in English and unfailingly polite, Themis possesses a lovable personality, ensuring that he will go above and beyond to create unforgettable vacation experiences for all."},{"name":"Nikos Nikolaou","avatar":"/media/media::image::a::vessel::d5cc7910-fe8c-11ed-889f-43d4bb723744::assets::5855e5f0-b89f-11ef-a455-9f379f400f3a/{imageVariant}","role":"Captain","bio":"Nikos was born in 1974 in Athens, Greece where he lives today with his wife and family. For 9 years, he owned a restaurant in Athens and has also worked as a Sous Chef. His sailing experience began in 1993- he holds both his sailing and motorboat licenses. With his passion for the sea, he joined the yachting world a few seasons ago as a deckhand and this year is his second season on board Kimata. In his free time, he loves to spend time with his family, cook, play basketball, and head off sailing with friends.\nLanguages: Greek and English (fluent)"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":3150000,"displayCurrency":"EUR","displayPrice":3150000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":4250000,"displayCurrency":"EUR","displayPrice":4250000,"unit":"WEEK"},"pricingInfo":[{"name":"High Season (July-August)","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":4250000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":4250000,"amount":4250000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.065}},{"item":"APA","conditions":"","quantity":0.2,"unitPrice":4250000,"amount":850000}],"total":5376250,"subTotal":5100000,"totalTax":276250},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]}],"exclusionZones":[],"petsAllowed":false},{"name":"Mid Season (June and Sept)","effectiveDates":[{"from":"2026-06-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-06-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2028-06-01T00:00:00.000Z","to":"2028-06-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-30T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-09-30T23:59:59.999Z"},{"from":"2028-09-01T00:00:00.000Z","to":"2028-09