2,"cruiseSpeed":10,"fuelCapacity":1500,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"2"},{"label":"Twin cabin with pullman bed","value":"1"}],"cabins":4,"bathrooms":4,"length":29.5,"beam":6.63,"draft":3.81,"hullType":"","superStructure":[],"engines":"2 × CAT 355 hp","amenities":[{"label":"Air Conditioning"},{"label":"Generators","quantity":"2"},{"label":"Watermaker "},{"label":"Bar"},{"label":"Lounge Area"},{"label":"Dining Area"},{"label":"Safety box in master cabin"}],"toys":[{"label":"Single Canoes","quantity":"2"},{"label":"Paddle Boards","quantity":"2"},{"label":"Adult Water Ski","quantity":"1"},{"label":"Child Water Ski","quantity":"1"},{"label":"Wakeboard","quantity":"1"},{"label":"Mono Ski","quantity":"1"},{"label":"Ringos","quantity":"2"},{"label":"Snorkeling Equipment"},{"label":"Fishing Equipment (2x rods, 2x longlines, 6x basic lines)"},{"label":"Sea Scooter","quantity":"2"}],"entertainment":["Bluetooth Speakers","IPTV in Saloon, Aft Deck and in Master Cabin","DVD/CD Player in Saloon","Board Games","Wi-Fi","Sunbathing Area","Flybridge"],"tenders":["3.60m Tender with 50 hp outboard (6 guests) "]},"crew":[{"name":"CAFER KAYA","avatar":"/media/media::image::c::7819217464::vessel::d5cccd28-fe8c-11ed-889f-43d4bb723744::assets::4df6b450-38d1-11f1-9595-fd9083320b10/{imageVariant}","role":"Captain","bio":"Captain Cafer started his career at sea in 1988 as a chef onboard private vessels. Since then he has been working onboard yachts along the Turkish coast and Greek Islands. He became a captain in 1996 and has been serving onboard Caneren since 2020. Cafer has great communications skills and is a great team leader. He is an animal lover, a keen football fan and enjoys spending his free time in his garden.  He speaks Turkish and beginner level English."},{"name":"GÖNÜL KAYA","avatar":"/media/media::image::c::7819217464::vessel::d5cccd28-fe8c-11ed-889f-43d4bb723744::assets::76c1f8e0-38d1-11f1-9595-fd9083320b10/{imageVariant}","role":"Captain","bio":"Gönül and Cafer Captain make a great team onboard Caneren.  After many years working at high-end hotels in the Bodrum area, Gönül began her yachting career in 2024 as chef. Specialising in Turkish cuisine, she focuses on seasonal, locally sourced ingredients.  Her fresh bakes are a delight for breakfast and her homemade ice cream is a real treat for the children.  A nature lover, Gönul enjoys swimming, fishing and hiking in her free time.  Gönul speaks Turkish with beginner level English."},{"name":"UMUT CAMCI","avatar":"/media/media::image::c::7819217464::vessel::d5cccd28-fe8c-11ed-889f-43d4bb723744::assets::a2c9cad0-38d1-11f1-9595-fd9083320b10/{imageVariant}","role":"Captain","bio":"Umut was born April 2002 in the historical town of Bodrum. He began his maritime career in 2019 onboard the yacht Cobalt, where he gained his first industry experience.\nHe has since worked on the yachts Caneren, and Lord Byron, operating in both Turkey and Greece. Known for his positive attitude and strong work ethic, Umut is a reliable and motivated crew member.\nIn his spare time, he enjoys fishing, playing football, and diving.\nUmut speaks Turkish and beginner level English.\n"},{"name":"TBA","role":"Captain","bio":""}],"pricing":{"dayPricingFrom":{"currency":"EUR","price":200000,"displayCurrency":"EUR","displayPrice":200000,"unit":"DAY"},"dayPricingTo":{"currency":"EUR","price":325000,"displayCurrency":"EUR","displayPrice":325000,"unit":"DAY"},"pricingInfo":[{"name":"Daily Charter Rates: April / May / October / November","effectiveDates":[{"from":"2026-04-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2026-10-01T00:00:00.000Z","to":"2026-11-30T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":200000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"DAY","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":200000,"amount":200000,"conditions":"Daily"}],"total":200000,"subTotal":200000,"totalTax":0},"inclusionZones":[{"label":"Turkey",