34ceff::assets::39416e10-3a1c-11f0-90c7-43c3a9a124a2/{imageVariant}","/media/media::image::a::vessel::c034eca0-3a1a-11f0-acbd-29907c34ceff::assets::39451790-3a1c-11f0-b0ec-43f456f5659b/{imageVariant}"],"make":"Sunreef Yachts","maxCrew":4,"sleeps":8,"basePort":{"uri":"a::place::27c27d8e-b3ee-11ed-a807-325096b39f47","name":"Sardinia","coordinates":{"latitude":40.10123877866832,"longitude":9.039317942072053},"country":"Italy"},"cruisingCapacity":8,"builtYear":2025,"architect":"Sunreef Yachts","topSpeed":0,"cruiseSpeed":7,"cabinLayout":[{"label":"Double Cabins","value":"4"}],"cabins":4,"bathrooms":0,"length":21.33,"beam":10.87,"draft":2.3,"hullType":"Multi hull","hullConstruction":"Composite","superStructure":["Flybridge"],"amenities":[{"label":"Hydraulic Gangway"},{"label":"Balcony"},{"label":"Liferaft"},{"label":"Underwater Lights"},{"label":"Swimming Ladder"},{"label":"Solar Panel"},{"label":"At-anchor Stabilizers"},{"label":"Underway Stabilizers"},{"label":"Beach Club"},{"label":"Jacuzzi"},{"label":"Sauna / Steam Room"},{"label":"Exercise Equipment"}],"toys":[{"label":"Kayaks","quantity":"2"},{"label":"Stand up Paddle boards","quantity":"2"},{"label":"3 person towable sofa"},{"label":"Snorkel gear"},{"label":"Electric bikes","quantity":"2"}],"entertainment":["CD Player","Cinema","Satelite TV","Piano","Wi-Fi","DVD Player"],"tenders":["Highfield 460 Sport dinghy with Yamaha 70 HP"]},"crew":[{"name":"Grzegorz Kotlęga","avatar":"/media/media::image::c::9938368400::vessel::c034eca0-3a1a-11f0-acbd-29907c34ceff::assets::f699df20-cac6-11f0-885e-f70ec4081c13/{imageVariant}","role":"Captain","bio":"Polish\n\nGrzegorz is a dedicated and professional yacht captain with over a decade of sailing experience. Raised in northern Poland, he began sailing at the age of 10 and quickly developed a strong passion for both life at sea and yacht maintenance. He holds an RYA Yachtmaster Offshore license along with multiple Polish sailing and powerboat captain certifications.\n\nAs the captain of Ankawer VI, Grzegorz brings a wealth of experience from his work across the Caribbean, Mediterranean, and U.S. East Coast aboard Bali, Lagoon, Sunreef Yachts, and Azimut yachts. He is known for his calm leadership, technical skills, and guest-focused approach that ensures smooth and safe voyages.\n\nBeyond sailing, Grzegorz enjoys mountain climbing, mechanics, and water sports. Friendly, organized, and always eager to share his passion, he creates a welcoming and professional atmosphere on board Ankawer VI."},{"name":"Jéan-Richard Knipe","avatar":"/media/media::image::c::9938368400::vessel::c034eca0-3a1a-11f0-acbd-29907c34ceff::assets::e41df7f0-cac6-11f0-885e-f70ec4081c13/{imageVariant}","role":"Captain","bio":"South African\n\nChef Jéan-Richard is a versatile and highly trained culinary professional with extensive experience across private homes, luxury hospitality, and the yachting industry. Known for his precision, creativity, and calm execution under pressure, he has cooked for high-profile families, managed galley operations on new-build yachts, and delivered refined menus on vessels ranging from 60–100 ft.\n\nWith a Culinary Arts Diploma, comprehensive food-safety training, and a strong background in international cuisines, Jéan-Richard excels in menu development, provisioning, and adapting dishes to diverse dietary needs. His structured approach, strong communication skills, and commitment to high standards make him a reliable and elevated addition to any charter experience."},{"name":"Alyssa Jefferis","avatar":"/media/media::image::c::9938368400::vessel::c034eca0-3a1a-11f0-acbd-29907c34ceff::assets::00749b70-cac7-11f0-885e-f70ec4081c13/{imageVariant}","role":"Captain","bio":"Alyssa is an enthusiastic and fast-advancing deckhand with hands-on experience across sailing yachts, catamarans, and motor yachts up to 100 ft. After rising from deckhand to captain within two years, she now brings captain-level discipline, strong seamanship, and exceptional attention to detail to every role.\n\nWith experience ranging from Caribbean solo charters to yacht detailing in Miami and deckhand duties aboard a Sunreef Yacht, Alyssa excels in line handling, tender driving, navigation support, vessel upkeep, and guest assistance. Known for her calm under pressure, tidy work habits, and problem-solving mindset, she is a reliable and motivated addition to any crew."},{"name":"Kornelia Maj","avatar":"/media/media::image::c::9938368400::vessel::c034eca0-3a1a-11f0-acbd-29907c34ceff::assets::159a45e0-cac7-11f0-885e-f70ec4081c13/{imageVariant}","role":"Captain","bio":"Kornelia is a dedicated and detail-oriented Stewardess with strong experience across luxury catamarans and crewed charters, delivering warm hospitality and impeccably maintained interiors. With four years in the yachting industry, she excels in guest service, housekeeping, table settings, provisioning, and event support, always ensuring a welcoming and beautifully presented onboard atmosphere.\n\nKnown for her cheerful personality, professionalism, and adaptability, Kornelia brings additional strengths in barista work, bartending, cooking, and creative presentation. Her combination of service expertise, a guest-focused approach, and a genuine love for life at sea makes her a valuable and versatile addition to any charter program."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":6000000,"displayCurrency":"EUR","displayPrice":6000000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":9000000,"displayCurrency":"USD","displayPrice":9000000,"unit":"WEEK"},"pricingInfo":[{"name":"Med Low Season","effectiveDates":[{"from":"2026-05-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-05-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2028-05-01T00:00:00.000Z","to":"2028-06-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-30T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-09-30T23:59:59.999Z"},{"from":"2028-09-01T0