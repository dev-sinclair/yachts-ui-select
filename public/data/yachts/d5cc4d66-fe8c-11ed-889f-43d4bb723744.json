23744::assets::ad0434d0-c4c9-11f0-85f8-f58e238733ca/{imageVariant}","/media/media::image::a::vessel::d5cc4d66-fe8c-11ed-889f-43d4bb723744::assets::acfb0d10-c4c9-11f0-85f8-f58e238733ca/{imageVariant}","/media/media::image::a::vessel::d5cc4d66-fe8c-11ed-889f-43d4bb723744::assets::acfae600-c4c9-11f0-85f8-f58e238733ca/{imageVariant}"],"make":"Sanlorenzo","model":"","maxCrew":4,"sleeps":8,"basePort":{"uri":"a::place::5e595eb8-b3ed-11ed-be02-325096b39f47","name":"Athens","coordinates":{"latitude":37.986174,"longitude":23.7268443},"country":"Greece"},"builtYear":2007,"architect":"","interiorDesigner":"","refitYear":2022,"topSpeed":27,"cruiseSpeed":19.5,"fuelCapacity":8000,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Twin Cabins","value":"2"}],"cabins":4,"bathrooms":4,"decks":"","length":24,"beam":6.17,"draft":1.6,"hullType":"","hullConstruction":"","tonnage":121.05,"superStructure":[],"engines":"2 x 1650HP Caterpillar C32","amenities":[{"label":"Zero Speed Stabilizers"},{"label":"Shaded al fresco dining area"},{"label":"Sunbathing Area"},{"label":"Sundeck"},{"label":"Flybridge"}],"toys":[{"label":"Seadoo Spark Jetski"},{"label":"Tubes"},{"label":"Seascooters","quantity":"2"},{"label":"Waterski"},{"label":"Wakeboard"},{"label":"SUP","quantity":"2"},{"label":"Swimming platform (3x4)","quantity":"1"},{"label":"Snorkelling gear"}],"entertainment":[],"tenders":["3.60m Tender Highfield"]},"crew":[{"name":"Christos Georgopoulos","avatar":"/media/media::image::a::vessel::d5cc4d66-fe8c-11ed-889f-43d4bb723744::assets::ebe45b40-c4c8-11f0-8198-8f49797df99a/{imageVariant}","role":"Captain","bio":"Greek\n\nEnglish, Greek\n\nCaptain Christos holds a Captain’s Diploma from the Merchant Marine Academy of Aspropyrgos. He began his yachting career in 2006 after several years of service in the merchant navy and has since captained both private and charter yachts throughout Greece. \nWith nearly 24 years of experience at sea, Christos is known for his professionalism, strong leadership, and hands-on approach. His attention to detail ensures smooth operations and a safe, enjoyable experience for guests.\n\nPrevious Yachts: M/Y AKIRA ONE, M/Y DANA, M/Y IRIS, M/Y ZOI, S/Y LIANA H, M/Y NOTUS, M/Y OASIS, M/Y TROPICANA"},{"name":"Stratos Karatzas","avatar":"/media/media::image::a::vessel::d5cc4d66-fe8c-11ed-889f-43d4bb723744::assets::1f8759c0-c4c9-11f0-8198-8f49797df99a/{imageVariant}","role":"Captain","bio":"Greek\n\nEnglish, Greek\n\nStratos has been working in the culinary and yachting industry since 1992. A graduate of Le Monde Chef Training School in Greece, he brings exceptional skill and creativity to Mediterranean, Italian, and Asian cuisines.\nKnown for his kindness, sense of humor, and calm demeanor, Stratos is a valued team member who consistently delights guests with his flavorful creations. In his free time, he enjoys travelling and discovering new culinary inspirations.\n\nPrevious Yachts: M/Y OCEANE II, M/Y LADY ELLEN, M/Y SUGAR, M/Y ZOI, M/Y KENTAVROS, S/Y GITANA, M/Y MELINA C, S/Y ARKTOS"},{"name":"Katerina Grylli","avatar":"/media/media::image::a::vessel::d5cc4d66-fe8c-11ed-889f-43d4bb723744::assets::4f2b8c50-c4c9-11f0-8198-8f49797df99a/{imageVariant}","role":"Captain","bio":"Greek\n\nEnglish, Greek\n\nKaterina is an energetic and dedicated team player with over four years of experience in the hospitality industry. She brings enthusiasm, strong communication skills, and a warm, approachable personality. Her positive attitude and commitment to excellence make her a key member of Alegria’s Crew."},{"name":"Dionysis Giannitsanos","avatar":"/media/media::image::a::vessel::d5cc4d66-fe8c-11ed-889f-43d4bb723744::assets::75258870-c4c9-11f0-85f8-f58e238733ca/{imageVariant}","role":"Captain","bio":"Greek\n\nEnglish, Greek\n\nDionysis is a highly skilled maritime professional with over 20 years of experience aboard private yachts and commercial passenger vessels. Experienced as a Bosun, Sailor, and Steward, he combines expert seamanship with a strong focus on guest comfort and safety. Dionysis is known for his reliability, attention to detail, and dedication to ensuring every charter experience runs smoothly and effortlessly. \n\nPrevious Yachts: M/Y ELEGANT 007, M/Y ENTRE CIELOS, M/Y LIBRA, M/Y SUNCOCO, M/Y BAGHEERA, M/Y HAPPY DOLPHIN 2, M/Y PRINCESS L"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":3200000,"displayCurrency":"EUR","displayPrice":3200000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":3600000,"displayCurrency":"EUR","displayPrice":3600000,"unit":"WEEK"},"pricingInfo":[{"name":"Regular","effectiveDates":[{"from":"2026-01-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2028-01-01T00:00:00.000Z","to":"2028-06-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"},{"from":"2028-09-01T00:00:00.000Z","to":"2028-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":3200000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":3200000,"amount":3200000,"conditions":"VAT & APA Excluded"}],"total":3200000,"subTotal":3200000,"totalTax":0},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]}],"exclusionZones":[],"petsAllowed":false},{"name":"High (July, August)","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":3600000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Ch