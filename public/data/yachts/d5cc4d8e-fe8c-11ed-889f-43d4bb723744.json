89f-43d4bb723744::assets::a426a900-1458-11f0-bebb-fbded6db6b09/{imageVariant}","/media/media::image::a::vessel::d5cc4d8e-fe8c-11ed-889f-43d4bb723744::assets::4770c3b0-145a-11f0-961e-41048c279fb5/{imageVariant}"],"make":"Custom","model":"","maxCrew":4,"sleeps":12,"basePort":{"uri":"a::place::27c28dba-b3ee-11ed-9755-325096b39f47","name":"Split","coordinates":{"latitude":43.51359615,"longitude":16.43884676},"country":"Croatia"},"cruisingCapacity":12,"builtYear":2008,"architect":"","interiorDesigner":"","refitYear":2019,"topSpeed":0,"cruiseSpeed":8,"fuelCapacity":7500,"cabinLayout":[{"label":"Double Cabins","value":"4"},{"label":"Twin Cabins","value":"2"}],"cabins":6,"bathrooms":6,"length":24.5,"beam":7.5,"draft":2.2,"hullType":"","hullConstruction":"Steel","superStructure":["Steel"],"engines":"2 x John Deere 235 KS","amenities":[{"label":"Air Conditioning"},{"label":"Bar"},{"label":"Sunbathing mattress"},{"label":"Hairdryer"},{"label":"Lounging area"},{"label":"Grill"},{"label":"Refrigerator"},{"label":"Deep freezer"}],"toys":[{"label":"Paddle board"},{"label":"Snorkelling equipment"},{"label":"Jet ski Sea Doo Spark 90HP (for 2 pax)"},{"label":"Donut ride/Ringo ride"},{"label":"Water ski"}],"entertainment":["TV","DVD/CD Player","Wi-Fi mobile internet connection"],"tenders":["4.50 m tender with an outboard 40 HP engine"]},"crew":[{"name":"Duje Antišić","avatar":"/media/media::image::a::vessel::d5cc4d8e-fe8c-11ed-889f-43d4bb723744::assets::1ec56b00-116c-11f0-a451-5d482645de3e/{imageVariant}","role":"Captain","bio":"Duje Antišić was born in 1997 in the coastal city of Split, Croatia. His father, a seasoned sailor, introduced him to the sea’s vastness and taught him the ways of the waves from a tender age.\n\nFrom the moment he could walk, Duje found himself aboard the ship Konkordia, his second home amidst the rolling tides. His childhood was colored by the sights and sounds of maritime life as he shadowed his father’s every move, absorbing the intricate knowledge of marine mechanics and navigation like a sponge.\n\nAs he matured, Duje’s passion for the sea only deepened. Eager to expand his horizons, he ventured beyond the confines of Konkordia, joining crews on various vessels, each voyage offering new lessons and challenges to conquer. His versatility as a sailor became evident as he transitioned between roles – from sailor to machinist, helmsman to diving master, and eventually earning the prestigious title of yacht master.\n\nBut Duje’s passions extend beyond the confines of the sea’s embrace. When he’s not navigating the high seas, you’ll likely find him astride a roaring motorbike, the wind in his hair, and the thrill of the open road beneath his wheels. An avid professional diving and water sports enthusiast, he finds solace and exhilaration in exploring the depths and embracing the elements in all their splendor."},{"name":"Šimun","avatar":"/media/media::image::a::vessel::d5cc4d8e-fe8c-11ed-889f-43d4bb723744::assets::329aeec0-116c-11f0-a451-5d482645de3e/{imageVariant}","role":"Captain"},{"name":"Dušan Škarić","avatar":"/media/media::image::a::vessel::d5cc4d8e-fe8c-11ed-889f-43d4bb723744::assets::3bbeb720-116c-11f0-a451-5d482645de3e/{imageVariant}","role":"Captain","bio":"Dule’s journey through the world of culinary arts is as diverse and rich as the flavors he masterfully crafts. With a plethora of experience spanning many years, Dule’s expertise in catering knows no bounds. His culinary odyssey began amidst the ebb and flow of the ocean waves as he embarked on a series of adventures aboard various ships, donning the role of a waiter and honing his hospitality skills.\n\nAs fate would have it, Dule found himself serving meals and preparing them, delving into the realm of cooking with an insatiable passion. His time spent on foreign cruise ships broadened his culinary horizons, exposing him to many tastes and techniques from around the globe. During these formative years, Dule cultivated a deep appreciation for Mediterranean cuisine, drawn to its vibrant flavors and wholesome ingredients.\n\nRenowned for his mastery of local specialties, Dule’s culinary repertoire shines brightest in terms of seafood delicacies. Fresh fish, succulent crabs, and delectable shellfish are his canvas, and he paints culinary masterpieces that leave guests craving more. With each dish, he effortlessly captures the essence of the sea, infusing it with his creative flair and unwavering dedication to excellence.\n\nHis journey is a testament to the transformative power of passion and perseverance, reminding us all that the true essence of culinary artistry lies in the unwavering pursuit of perfection."},{"name":"Ana","avatar":"/media/media::image::a::vessel::d5cc4d8e-fe8c-11ed-889f-43d4bb723744::assets::646869f0-116c-11f0-b965-833f2706352c/{imageVariant}","role":"Captain"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1750000,"displayCurrency":"EUR","displayPrice":1750000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2100000,"displayCurrency":"EUR","displayPrice":2100000,"unit":"WEEK"},"pricingInfo":[{"name":"26.04. - 31.05.2025. & 20.09. - 18.10.2025.","effectiveDates":[{"from":"2025-04-26T00:00:00.000Z","to":"2025-05-31T23:59:59.999Z"},{"from":"2026-04-26T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2027-04-26T00:00:00.000Z","to":"2027-05-31T23:59:59.999Z"},{"from":"2025-09-20T00:00:00.000Z","to":"2025-10-18T23:59:59.999Z"},{"from":"2026-09-20T00:00:00.000Z","to":"2026-10-18T23:59:59.999Z"},{"from":"2027-09-20T00:00:00.000Z","to":"2027-10-18T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1750000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1750000,"amount":1750000,"conditions":"Weekly","taxRate":{"label":"VAT","value":0.13}}],"total":1750000,"subTotal":1750000,"totalTax":227500},"inclusionZones":[{"label":"Adriatic Sea","type":"Custom Area","category":["Adriatic Sea"],"coordinates":[16.01030688354