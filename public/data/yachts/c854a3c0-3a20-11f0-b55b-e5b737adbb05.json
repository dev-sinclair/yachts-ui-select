::image::a::vessel::c854a3c0-3a20-11f0-b55b-e5b737adbb05::assets::c4e1e3d0-3a23-11f0-b1fd-2dbbd73a087a/{imageVariant}","/media/media::image::a::vessel::c854a3c0-3a20-11f0-b55b-e5b737adbb05::assets::c4e25900-3a23-11f0-b112-45957421a7b2/{imageVariant}","/media/media::image::a::vessel::c854a3c0-3a20-11f0-b55b-e5b737adbb05::assets::c4e31c50-3a23-11f0-b1fd-2dbbd73a087a/{imageVariant}","/media/media::image::a::vessel::c854a3c0-3a20-11f0-b55b-e5b737adbb05::assets::c4e2f540-3a23-11f0-b1fd-2dbbd73a087a/{imageVariant}","/media/media::image::a::vessel::c854a3c0-3a20-11f0-b55b-e5b737adbb05::assets::c4de8870-3a23-11f0-adbe-29976eb91dd4/{imageVariant}","/media/media::image::a::vessel::c854a3c0-3a20-11f0-b55b-e5b737adbb05::assets::c4e231f0-3a23-11f0-adbe-29976eb91dd4/{imageVariant}"],"make":"Sunreef Yachts","model":"Sunreef 80","maxCrew":5,"sleeps":8,"basePort":{"uri":"a::place::084d2f1c-b3ee-11ed-88e8-325096b39f47","name":"Olbia","coordinates":{"latitude":40.92518954,"longitude":9.507247173},"country":"Italy"},"cruisingCapacity":8,"builtYear":2025,"architect":"Sunreef Yachts","cruiseSpeed":8,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Convertible VIP Cabin","value":"1"},{"label":"Twin Cabin with Pullman","value":"1"}],"cabins":4,"length":23.9,"beam":11.5,"draft":2.2,"hullType":"Multi hull","hullConstruction":"Composite","superStructure":["Flybridge"],"engines":"2 x John Deere 280HP","amenities":[{"label":"Barista station"},{"label":"Lounge Area"},{"label":"Private Hammam"},{"label":"Flybridge"},{"label":"Hammock chair"},{"label":"Bar"},{"label":"Generators"}],"toys":[{"label":"e-Foil “Audi e-tron eFoil Board Adventure” by Aerofoils","quantity":"1"},{"label":"e-surfboard “'Electric 2” by Jetsurf","quantity":"1"},{"label":"Seabob F5 SR","quantity":"2"},{"label":"Wakeboard Hybrid “Supreme” by Ronix","quantity":"1"},{"label":"Waterski by Yamaha ","quantity":"1"},{"label":"Inflatable SUP by Cala","quantity":"2"},{"label":"Dive blu 3 “Nemo” by Dive Blu","quantity":"1"},{"label":"Dive blue 3 “Nomad mini” by Dive Blu","quantity":"1"},{"label":"Funtube “Revolve tube” by JOBE ","quantity":"1"},{"label":"Snorkels Sets in all sizes ","quantity":"8"},{"label":"Vests in all sizes (wakeboard, collision) ","quantity":"8"},{"label":"Helmets","quantity":"4"},{"label":"e-Bike \"G4i” by GoCycle","quantity":"2"},{"label":"\"Egret One\" by E-scooter","quantity":"2"}],"entertainment":["Indoor/outdoor cinema"],"tenders":["1 x JetTender 16 by Castoldi"]},"crew":[{"name":"Mark Barter","avatar":"/media/media::image::c::9938368400::vessel::c854a3c0-3a20-11f0-b55b-e5b737adbb05::assets::98beb860-6088-11f0-bdb0-27026d33bb74/{imageVariant}","role":"Captain","bio":"Nationality: South African\nLanguages: French, English\n\nOriginally from South Africa, Mark is a natural waterman whose passion for the ocean began with surfing, fishing, and sailing along his country’s coastline. Now based in the South of France, he has built a strong career as a Captain and First Mate, with experience navigating both motor and sailing yachts throughout the Mediterranean, Arabian Sea, and Indian Ocean.\n\nDespite his young age, Mark brings impressive leadership, technical skills, and a calm, professional attitude on board. Guests appreciate his positive, can-do approach and expertise in watersports. In his free time, you’ll find him surfing, spearfishing, or perfecting his carpentry skills."},{"name":"Onur İhtiyar","role":"Captain","bio":"Nationality: Turkish\nLanguages: Turkish, English\n\nOnur is a seasoned first mate and chase boat captain with experience aboard both private and charter vessels. He brings strong practical knowledge of boat systems, equipment, and technical maintenance, alongside solid experience in deck operations, rope handling, tender driving, navigation, and anchoring. Having worked aboard vessels such as M/Y Athena Too, S/Y Marie-Joseph, and M/Y Vesta 1 Sevil, Onur has developed a reliable and hands-on approach to daily deck duties while maintaining high standards of safety and efficiency on board. \n\nFluent in both English and Turkish, he is a capable and versatile crew member with a strong background in deck maintenance and vessel support."},{"name":"Aushi Walalam Caceres Pina","avatar":"/media/media::image::c::9938368400::vessel::c854a3c0-3a20-11f0-b55b-e5b737adbb05::assets::70006c20-6088-11f0-90e4-7908f033857b/{imageVariant}","role":"Captain","bio":"Nationality: Italian- Venezuelan\nLanguages: Spanish, Italian, English\n\nWith over 20 years of experience in the yachting and hospitality industry, Chef Aushi is a culinary expert known for his innovative approach to fine dining on luxury yachts. A graduate of the Italian Culinary Institute for Foreigners, he has mastered international cuisines, gourmet plating, and dietary customization, creating bespoke dining experiences for charter guests.\n\nHis career spans Mediterranean, Caribbean, and Pacific regions, where he skillfully sources premium ingredients to craft exquisite, personalized menus. Fluent in Spanish, Italian, and English, Aushi thrives in high-end, fast-paced charter environments, ensuring every meal is an unforgettable culinary journey.\n"},{"name":"Maël Cesar","avatar":"/media/media::image::c::9938368400::vessel::c854a3c0-3a20-11f0-b55b-e5b737adbb05::assets::9130d240-6088-11f0-9229-b3172644c9d1/{imageVariant}","role":"Captain","bio":"Nationality: Spanish\nLanguages: English, French, Spanish\n\nWith a strong background in both hospitality and deck operations, Maël Cesar is a dynamic stewardess and deckhand with extensive experience on luxury sailing yachts. Having worked on high-profile charter and private vessels, including Sunreef, Swan, and Lagoon yachts, she excels in guest service, interior detailing, and deck duties.\n\nFluent in English, French, and Spanish, Maël is highly adaptable and thrives in multicultural environments. Her expertise includes table and beverage service, provisioning, turnarounds, watchkeeping, water sports assistance, and tender handling. With a natural passion for the sea, an energetic attitude, and a keen eye for detail, Maël ensures an exceptional experience for charter guests."},{"name":"Julia Robberts","role":"Captain","bio":"Nationality: South African\nLanguages: English\n\nJulia is a highly experienced stewardess with over eight years of experience aboard private and charter yachts, ranging from sailing catamarans to large luxury motor yachts. She is known for delivering exceptional guest service with a calm, discreet, and detail-oriented approach, while maintaining the highest standards across housekeeping, fine dining service, provisioning, and interior presentation. With experience in leadership roles including Head of Housekeeping, Chief Stewardess, and 2nd Stewardess, Julia brings a strong hospitality background combined with professionalism, adaptability, and a genuine passion for life at sea.\n \nHer qualifications in yacht service, culinary training, yoga, diving, and sailing further reflect her well-rounded skill set and value on board."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":7700000,"displayCurrency":"EUR","displayPrice":7700000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":10000000,"displayCurrency":"USD","displayPrice":10000000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer: Mediterranean - High Season","effectiveDates":[{"from":"2026-06-15T00:00:00.000Z","to":"2026-09-15T23:59:59.999Z"},{"from":"2027-06-15T00:00:00.000Z","to":"2027-09-15T23:59:59.999Z"},{"from":"2028-06-15T00:00:00.000Z","to":"2028-09-15T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":8500000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":8500000,"amount":8500000,"conditions":"VAT & APA Excluded"},{"item":"APA","conditions":"","quantity":0.25,"unitPrice":8500000,"amount":2125000}],"total":10625000,"subTotal":10625000,"totalTax":0},"inclusionZones":[{"label