essel::d7e9f070-ccd4-11ee-81c2-b375d968d73a::assets::62464cc0-0404-11f0-8163-271a08cfa9a1/{imageVariant}","/media/media::image::a::vessel::d7e9f070-ccd4-11ee-81c2-b375d968d73a::assets::6251e580-0404-11f0-8163-271a08cfa9a1/{imageVariant}","/media/media::image::a::vessel::d7e9f070-ccd4-11ee-81c2-b375d968d73a::assets::6250d410-0404-11f0-8163-271a08cfa9a1/{imageVariant}","/media/media::image::a::vessel::d7e9f070-ccd4-11ee-81c2-b375d968d73a::assets::624f9b90-0404-11f0-8163-271a08cfa9a1/{imageVariant}","/media/media::image::a::vessel::d7e9f070-ccd4-11ee-81c2-b375d968d73a::assets::623e3670-0404-11f0-8163-271a08cfa9a1/{imageVariant}","/media/media::image::a::vessel::d7e9f070-ccd4-11ee-81c2-b375d968d73a::assets::6267b770-0404-11f0-8163-271a08cfa9a1/{imageVariant}"],"make":"Custom","model":"Gulet","maxCrew":4,"sleeps":16,"basePort":{"uri":"a::place::27c28dba-b3ee-11ed-9755-325096b39f47","name":"Split","coordinates":{"latitude":43.51359615,"longitude":16.43884676},"country":"Croatia"},"cruisingCapacity":16,"staticCapacity":16,"builtYear":1997,"refitYear":2026,"topSpeed":9,"cruiseSpeed":7,"fuelCapacity":10000,"cabinLayout":[{"label":"Double Cabins","value":"8"}],"cabins":8,"bathrooms":8,"decks":2,"length":33.5,"beam":7.5,"draft":2.7,"hullType":"","hullConstruction":"Wood","superStructure":["Wood"],"amenities":[{"label":"Air Conditioning"},{"label":"Sun mattresses","quantity":"12"},{"label":"Deck shower"},{"label":"Sun loungers"},{"label":"Coffee machine"},{"label":"Ice maker"},{"label":"Dining table for 12"},{"label":"Cocktail table"}],"toys":[{"label":"Donut"},{"label":"Kayaks","quantity":"2"},{"label":"Floaties"},{"label":"Water skis"},{"label":"Snorkelling equipment"},{"label":"SUP","quantity":"2"},{"label":"Wakeboard"}],"entertainment":["Wi-Fi","TV","DVD","USB and radio","Board games, cards"],"tenders":["5.2m (17') - Tender 60 HP engine"]},"crew":[{"name":"Deni Špar","avatar":"/media/media::image::a::vessel::d7e9f070-ccd4-11ee-81c2-b375d968d73a::assets::e3ee1790-0403-11f0-aead-8599847e191a/{imageVariant}","role":"Captain","bio":"Deni was born in 1995. and lives on the island of Ugljan. After graduating from maritime high school, majoring in marine engineering and doing an assistantship on a long voyage, he decided to fulfill his desire to work on a yacht. He worked for several seasons as a mechanic on yachts in Croatia and 4 years ago he decided to go abroad. He went to Monaco to work on a yacht, also as a machinist.\n\nDue to his desire to return home and start his own business, he passed the captain's exam and together with his family rented a gulet and embarked on a new adventure. He hopes to own a\nyacht one day. Deni is a very ambitious and responsible worker. He is communicative, quick and resourceful. He likes to work in a group and he treats guests professionally and is always ready to listen to their wishes and suggestions and if possible, fulfill them."},{"name":"Marin Jurin","avatar":"/media/media::image::a::vessel::d7e9f070-ccd4-11ee-81c2-b375d968d73a::assets::ef06ab10-0403-11f0-aead-8599847e191a/{imageVariant}","role":"Captain","bio":"He was born on the island of Ugljan in 1978. After graduating from high school for chefs in Zadar he worked for years as a chef in hotels and restaurants throughout Dalmatia. Love took him to Zagreb, where he has been living for the last 8 years. During those 8 years he worked professionally in top level hotels and well known restaurants in Zagreb.\n\nHowever, since his love for the sea is still strong, last year he decided to try his luck on yachts and that's how he came to Gideon. Marin is highly regarded by guests and receives great reviews and praise from them. All guests are delighted with his dishes. Marin cooks traditional Dalmatian dishes with a touch of modernity, which he introduces through various spices and the presentation of the dishes on the plate."},{"name":"Šime Šatalić","avatar":"/media/media::image::a::vessel::d7e9f070-ccd4-11ee-81c2-b375d968d73a::assets::4d766370-0404-11f0-8163-271a08cfa9a1/{imageVariant}","role":"Captain","bio":"Šime was born in 1992, also on the island of Ugljan. After finishing high school he devoted himself to catering.\n\nHe has many years of experience working as a waiter in restaurants, both on the island of Ugljan and abroad, in Ireland and the USA. Last year, he decided to share his knowledge and experience with us and go to sea and sail with Gideon. Šime is maximally dedicated to his work. As a world traveler, he handles languages  very well. He is very active and pays attention to details.\n\nŠime is open in his communication with guests and they gladly accept him into their company to tell them about life in Croatia. He gets great reviews from the guests and everyone is delighted with his appearance/personality and often keep in touch with him even after leaving the\nyacht.\n\nHe is adventurous, he likes to travel and get to know other places and people, so going on a yacht was the fulfillment of his wish - to wake up in a different place every morning."},{"name":"Karlo Brkljačić Kereš","role":"Captain","bio":"The youngest member of our crew was born in 2000. He lives on the island of Ugljan and graduated from tourism school in Zadar. So far, he has tried himself in different jobs, as a waiter in a restaurant, as a diver at a fish farm, and as a sailor on a yacht.\n\nThis year he decided to become a new crew member on the Gideon. He is communicative, meticulous and active. Karlo has no problem working in a group and he loves the sea and everything related to it."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1850000,"displayCurrency":"EUR","displayPrice":1850000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2390000,"displayCurrency":"EUR","displayPrice":2390000,"unit":"WEEK"},"pricingInfo":[{"name":"Season D: 11.04. - 23.05. and 19.09. - 17.10.","effectiveDates":[{"from":"2026-04-11T00:00:00.000Z","to":"2026-05-23T23:59:59.999Z"},{"from":"2026-09-19T00:00:00.000Z","to":"2026-10-17T2