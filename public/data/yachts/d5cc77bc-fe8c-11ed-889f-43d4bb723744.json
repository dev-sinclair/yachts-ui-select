"amenities":[{"label":"Air Conditioning","quantity":""},{"label":"Wi-Fi","quantity":""},{"label":"Deck Jacuzzi","quantity":""},{"label":"Salon TV","quantity":""},{"label":"Sun Awning","quantity":""},{"label":"Special Diets","quantity":""},{"label":"Children Allowed","quantity":""},{"label":"Generator","quantity":""},{"label":"Ice Maker","quantity":""},{"label":"Salon Stereo","quantity":""},{"label":"Hairdryers","quantity":""},{"label":"Inverter","quantity":""},{"label":"BBQ","quantity":""},{"label":"Water Maker","quantity":""},{"label":"Bimini","quantity":""},{"label":"Deck shower","quantity":""},{"label":"DVD Player","quantity":""},{"label":"Laptop","quantity":""},{"label":"Printer","quantity":""},{"label":"Satellite phone","quantity":""},{"label":"Assorted reading materials","quantity":""},{"label":"USB charging socket","quantity":""},{"label":"Tablet & Air Speaker in each cabin","quantity":""},{"label":"Surround Sound Speakers","quantity":""},{"label":"Bluetooth","quantity":""},{"label":"High Definition Video Projector and Large screen in the Salon","quantity":""},{"label":"HI-FI set Radio in the Salon","quantity":""}],"toys":[{"label":"Dinghy","quantity":8},{"label":"Swim Platform","quantity":""},{"label":"Paddles Board \"SUP\" (inflatable)","quantity":2},{"label":"Underwater Camera","quantity":""},{"label":"Fishing gear (Big fish)","quantity":""},{"label":"Underwater Video","quantity":""},{"label":"Wakeboard","quantity":1},{"label":"Boarding Ladder","quantity":""},{"label":"Adult (bi & mono) ski performer \"O-Brien\"","quantity":""},{"label":"Junior (bi & mono) ski Celebrity \"O-Brien\"","quantity":""},{"label":"Snorkeling Equipment","quantity":""},{"label":"Kayaks with underwater vision (for 3 people each)","quantity":2},{"label":"F5S SeaBobs with video camera onboard","quantity":2},{"label":"Inflatable towable buoy 3 people \"Slacker 3\" \" O-Brien\"","quantity":1},{"label":"Swimming Noodles","quantity":""},{"label":"Beach Games","quantity":""},{"label":"Board Games","quantity":""},{"label":"Inflatable Party Lounge 8 people","quantity":""},{"label":"Runway 12 feet","quantity":""}],"entertainment":["Wi-Fi","Salon TV","Salon Stereo","DVD Player","Laptop","Assorted reading materials","Tablet & Air Speaker","Surround Sound Speakers","High Definition Video Projector and Large screen in the Salon","HI-FI set Radio in the Salon"],"tenders":["4.60m Tender Highfield with 80 HP engine"]},"crew":[{"name":"Adrien Rolland","avatar":"/media/media::image::c::8181076994::vessel::d5cc77bc-fe8c-11ed-889f-43d4bb723744::assets::dfe3ac50-1494-11ef-a805-7b2c3c9892e0.jpeg/{imageVariant}","role":"Captain","bio":"Captain Adrien is a seasoned seafarer with a lifelong passion for the ocean. Starting as a young sailor aboard the family boat, he honed his skills and knowledge over the years. With an RYA Yachtmaster Offshore certification and a degree in nautical marketing engineering, Adrien is a skilled captain known for his meticulous boat maintenance and repair abilities.\n\nHaving navigated the waters of the Mediterranean, Caribbean, Atlantic, Indian and Brittany, Adrien ensures the safety and comfort of his passengers and crew in all conditions. His patient and approachable demeanor, coupled with his dedication to boat care, make him a trusted leader.\n\nCombining French art de vivre with British nautical tradition, Adrien brings a unique perspective to every voyage aboard Lisa Of The Seas. Cruising with Captain Adrien guarantees an unforgettable experience filled with lasting memories."},{"name":"Martin","avatar":"/media/media::image::c::8181076994::vessel::d5cc77bc-fe8c-11ed-889f-43d4bb723744::assets::650ded40-17ac-11ef-b213-f5ab0a796d24.jpeg/{imageVariant}","role":"Chef","bio":"Chef Martin will indulge in a cuisine that is both gourmet and original, crafted by the skilled hands of our young French chef, Martin Vigneron. His culinary journey, rooted in a lifelong passion for food, spans from his grandmother's kitchen to esteemed establishments in Paris and Bordeaux, as well as provincial family restaurant. Reflective of his character, his cuisine embodies both generosity and authenticity. For you, he will be showcasing his talents at sea, ensuring a culinary experience beyond compare."},{"name":"Pierre","avatar":"/media/media::image::c::8181076994::vessel::d5cc77bc-fe8c-11ed-889f-43d4bb723744::assets::8770dff0-17ac-11ef-b213-f5ab0a796d24.jpeg/{imageVariant}","role":"Steward","bio":"Stew Pierre was born and raised in France, Pierre sailed since his childhood all over the Mediterranean sea on the family yacht. After college he began a career as a real estate counsellor and marketing consultant. However with a strong human relationship background fueled by a deep knowledge of boating, Pierre decided to shift gear. He naturally oriented his career toward yachting and towards the very art of making guests feel at home . Drawing on his skills gained through his former job Pierre displays a high level of attention to details and organisation.\nEasy going, friendly, caring and good mannered, Pierre has a natural gift for children as well. If you feel adventurous, Pierre can organize unforgettable fishing sessions and will be at his best to put up for you the best cruise ever."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":4000000,"displayCurrency":"EUR","displayPrice":4000000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":5600000,"displayCurrency":"USD","displayPrice":5600000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer: Mediterranean -  High Season","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","unit":"WEEK","inputAmountTaxed":"EXCLUSIVE","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":4250000,"amount":4250000,"conditions":"VAT & APA Excluded"},{"item":"APA","quantity":0.3,"