place::6bd662a0-8874-11ee-96de-65d662e46fa2","name":"Volos","coordinates":{"latitude":39.36025518184668,"longitude":22.94166514431308},"country":"Greece"},"builtYear":2024,"architect":"","interiorDesigner":"","refitYear":"","topSpeed":9,"cruiseSpeed":7,"fuelCapacity":0,"cabinLayout":[{"label":"Double Cabin","value":"4"}],"cabins":4,"bathrooms":4,"decks":"","length":13.94,"beam":7.71,"draft":1.19,"hullType":"Catamaran","engines":"2 x 60HP Volvo Penta D2","amenities":[{"label":"Air Conditioning"},{"label":"Salon TV"},{"label":"Salon Stereo"},{"label":"Sun Awning"},{"label":"Deck Shower"},{"label":"BBQ"},{"label":"Hairdryers"},{"label":"Fusion Sound System"},{"label":"Flybridge"},{"label":"Teak in cockpit and Flybridge"}],"toys":[{"label":"Jobe SUP","quantity":"2"},{"label":"Snorkeling Set","quantity":"8"},{"label":"Jobe Sea scooters","quantity":"2"},{"label":"Hydraulic Swimming Platform"},{"label":"Fishing Gear"},{"label":"Boarding Ladder (Hydraulic aft)"},{"label":"Inflatable Towable (2 pax)"},{"label":"Noodles"},{"label":"Board games: chess, backgammon"}],"entertainment":["Salon TV","Salon Stereo","Fusion Sound System"],"tenders":["Highfield Cl 360 with Bow Step Orca Hypalon Dark Grey (Suzuki 30 ATS)"]},"crew":[{"name":"Yiannis Perivoliotis","role":"Captain","bio":"Meet Captain Yiannis Perivoliotis, a seasoned maritime expert with a rich tapestry of education, skills, and experiences that make him a standout figure in the world of sailing. A graduate of the Control Data Institute in Athens, Yiannis has honed his analytical and computer programming prowess, providing a solid foundation for his maritime endeavors.\nFluent in Greek and possessing fair proficiency in English, Captain Yiannis maintains excellent health, abstaining from both smoking and drinking. Beyond the helm, his vibrant personality finds expression in a range of hobbies, including sailing competitions, diving, fishing, and skiing.\nHis extensive credentials include diplomas from the Greek Ministry of Culture and Sport, the Volos Offshore Sailing Club, and a Motorboat License from the Greek Port Police. Certified by NAUI in scuba diving, Yiannis is a multifaceted mariner.\nWith over 30,000 sea miles under his belt, Captain Yiannis has captained chartered sailing boats, navigating the challenging waters of the North Aegean, Northern Sporades, Pagasitikos Gulf, and Dodecanese. Not just a captain, he has also served as a coach for Optimist and Laser classes at the OEA-NAV Nautical Club and the Offshore Sailing Club of Volos from 2008 to 2019. His passion for the sea is not just a profession; it's a way of life."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1160000,"displayCurrency":"EUR","displayPrice":1160000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1425000,"displayCurrency":"EUR","displayPrice":1425000,"unit":"WEEK"},"pricingInfo":[{"name":"High Season","effectiveDates":[{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"},{"from":"2028-07-01T00:00:00.000Z","to":"2028-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1425000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1425000,"amount":1425000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.12}},{"item":"APA","conditions":"","quantity":0.3,"unitPrice":1425000,"amount":427500}],"total":2023500,"subTotal":1852500,"totalTax":171000},"inclusionZones":[{"label":"Greece","type":"Sovereign country","category":["Europe","Southern Europe","Greece"],"coordinates":[24.261736188816826,38.42232351533858],"bbox":[19.646484375,34.934472656249994,28.231835937500023,41.743798828124994]}],"exclusionZones":[],"petsAllowed":false},{"name":"Mid Season","effectiveDates":[{"from":"2026-06-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-06-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2028-06-0