f0-9fdf-657a5505ab7c/{imageVariant}","/media/media::image::a::vessel::4bafb9f0-9155-11ef-ae28-db98f755ffe0::assets::4e18f510-29a0-11f0-9fdf-657a5505ab7c/{imageVariant}","/media/media::image::a::vessel::4bafb9f0-9155-11ef-ae28-db98f755ffe0::assets::4e261470-29a0-11f0-9fdf-657a5505ab7c/{imageVariant}","/media/media::image::a::vessel::4bafb9f0-9155-11ef-ae28-db98f755ffe0::assets::4df0fab0-29a0-11f0-9fdf-657a5505ab7c/{imageVariant}","/media/media::image::a::vessel::4bafb9f0-9155-11ef-ae28-db98f755ffe0::assets::4e3c0d70-29a0-11f0-9fdf-657a5505ab7c/{imageVariant}","/media/media::image::a::vessel::4bafb9f0-9155-11ef-ae28-db98f755ffe0::assets::4e38d920-29a0-11f0-9fdf-657a5505ab7c/{imageVariant}"],"make":"Amer","model":"Amer F100","maxCrew":5,"sleeps":10,"basePort":{"uri":"a::place::084d40a6-b3ee-11ed-af25-325096b39f47","name":"Poltu Quatu","coordinates":{"latitude":41.13557795,"longitude":9.496307881},"country":"Italy"},"cruisingCapacity":12,"builtYear":2020,"architect":"","interiorDesigner":"","refitYear":2024,"topSpeed":30,"cruiseSpeed":23,"fuelCapacity":0,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabins","value":"2"},{"label":"Double Cabins","value":"2"}],"cabins":5,"bathrooms":5,"decks":0,"length":29.9,"beam":7,"draft":1.95,"hullType":"","hullConstruction":"","tonnage":0,"superStructure":[],"engines":"4 x Volvo penta IPS 1200 hp","amenities":[{"label":"Double Stabilizers"}],"toys":[{"label":"Seabobs F5","quantity":"2"},{"label":"SUP"},{"label":"Snorkeling equipment"},{"label":"Inflatables"}],"entertainment":["Wi-Fi"],"tenders":["Tender AEROMARINE 420 Suzuki 40"]},"crew":[{"name":"Domenico Misuraca","avatar":"/media/media::image::a::vessel::4bafb9f0-9155-11ef-ae28-db98f755ffe0::assets::763bac50-299a-11f0-b8b5-975f1e083df8/{imageVariant}","role":"Captain","bio":"Nationality: Italian\nLanguages: Italian, English\n\nDomenico is dynamic Sicilian mariner whose passion for the sea is matched by his peerless problem-solving skills and ability to forge deep connections with his guests. His natural empathy and warm hospitality transform every journey into a personalized adventure, while his extensive nautical expertise ensures safe and smooth sailing. Whether steering through tranquil waters or guiding you to the hidden jewels of the Mediterranean, Captain Domenico's vibrant spirit and local knowledge promise an unforgettable charter experience. During the last 17 years, Captain Domenico had the chance to travel all around the Mediterranean Sea. Some of the luxury yachts he has managed in the past include: Alena 52, Aicon 56, Azimut 68S, Aicon 72SL, Maiora 23, Leonard 72 and Azimut 86s, Pershing 80 and a Pershing 90."},{"name":"Antonio Muroni","avatar":"/media/media::image::a::vessel::4bafb9f0-9155-11ef-ae28-db98f755ffe0::assets::b3f78190-299a-11f0-a2ce-5f94181d49ae/{imageVariant}","role":"Captain","bio":"Nationality: Italian\nLanguages: Italian, English\n\nAntonio is an outstanding deckhand whose keen eye for detail ensures a flawless experience on board. His strong work ethic and dedication to excellence make him an invaluable asset to the ALTUS crew. Having already collaborated successfully with Captain Domenico in the previous season, he brings both experience and seamless teamwork to every charter.\n\nBeyond his technical skills, Antonio is also a talented photographer, capturing the essence of each journey through stunning imagery. His ability to blend precision on deck with a creative touch behind the lens allows guests to relive their most cherished moments long after their voyage. With Antonio on board, every detail is meticulously taken care of, and every memory is beautifully preserved."},{"name":"Andrea Conti","avatar":"/media/media::image::a::vessel::4bafb9f0-9155-11ef-ae28-db98f755ffe0::assets::e337e940-299a-11f0-82bf-4f01065770e4/{imageVariant}","role":"Captain","bio":"Nationality: Italian\nLanguages: Italian, English, Spanish\n\nChef Andrea Conti is a culinary talent with a rich background in high-end hospitality. He has honed his craft in the kitchens of prestigious 5-star hotels and at the iconic Alfredo alla Scrofa in Rome—famous worldwide as the birthplace of the original Fettuccine Alfredo. Andrea’s cuisine is rooted in authentic Italian tradition, but elevated by his creativity, attention to detail, and passion for fresh, seasonal ingredients.\n\nBeyond the kitchen, Andrea is a dynamic and enthusiastic professional with a strong passion for the sea. A keen sailor himself, he fully embraces life on board and understands the rhythm and atmosphere of yachting, bringing harmony between gastronomy and the onboard lifestyle.\n\nGuests aboard M/Y ALTVS can expect not just exquisite meals, but a personalized and immersive dining experience—whether it’s a refined multicourse dinner under the stars, or a relaxed Mediterranean lunch after a day at sea. Andrea’s warm personality and dedication to excellence ensure that every moment at the table is a highlight of the journey."},{"name":"ADELE MARROCCU","avatar":"/media/media::image::a::vessel::4bafb9f0-9155-11ef-ae28-db98f755ffe0::assets::22ed6ba0-299b-11f0-b744-bdbe89c96d90/{imageVariant}","role":"Captain","bio":"Nationality: Italian\nLanguages: Italian, English, Spanish, French\n\nAdele is a highly accomplished Italian stewardess with extensive experience in luxury yacht charters. Fluent in four languages, she effortlessly ensures seamless communication and an impeccable level of service on board. Her exceptional attention to detail guarantees that every aspect of the charter is meticulously managed, creating an atmosphere of refined hospitality.\nBeyond her professionalism, Adele’s warm and empathetic nature makes guests feel instantly at home. Her ever-present smile and gracious demeanor enhance every moment, ensuring a\nwelcoming and elegant experience. With Adele leading the hospitality on ALTUS, every journey is marked by effortless luxury and unforgettable memories.ight of the journey.\nRozerin is committed to continuous growth and embraces every opportunity to learn and exceed expectations, making her a valuable asset to any crew."},{"name":"Irene Zacco","avatar":"/media/media::image::a::vessel::4bafb9f0-9155-11ef-ae28-db98f755ffe0::assets::75795140-299b-11f0-b744-bdbe89c96d90/{imageVariant}","role":"Captain","bio":"Nationality: Italian\nLanguages: Italian, English\n\nWith a deep dedication to guest comfort and an unwavering work ethic, Irene is a stewardess who ensures every onboard experience is seamless and exceptional. Having traveled extensively and immersed herself in diverse cultures, she brings a refined understanding of international hospitality, attention to detail, and an innate ability to anticipate guest needs.\n\nIrene’s commitment to excellence is matched by her restless energy and proactive approach. She thrives in dynamic environments, adapting effortlessly to the ever-changing demands of life at sea. Whether it’s creating an inviting atmosphere, delivering top-tier service, or ensuring that every detail is perfectly arranged, she takes pride in making guests feel at home, no matter where they are.\n\nHer passion for hospitality and cultural awareness elevate the onboard experience with warmth, professionalism, and an impeccable eye for detail."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":8700000,"displayCurrency":"EUR","displayPrice":8700000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":9700000,"displayCurrency":"EUR","displayPrice":9700000,"unit":"WEEK"},"pricingInfo":[{"name":"July & August","effectiveDates":[{"from":"2025-07-01T00:00:00.000Z","to":"2025-08-31T23:59:59.999Z"},{"from":"2026-07-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"},{"from":"2027-07-01T00:00:00.000Z","to":"2027-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":9700000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":9700000,"amount":9700000,"conditions":"Weekly","taxRate":