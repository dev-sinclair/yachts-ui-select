40a-170081584f94/{imageVariant}","/media/media::image::c::10218162598::vessel::d7559cd0-822f-11ee-bb51-976bcca658ae::assets::b3414b10-67ce-11f0-940a-170081584f94/{imageVariant}","/media/media::image::c::10218162598::vessel::d7559cd0-822f-11ee-bb51-976bcca658ae::assets::b341c040-67ce-11f0-940a-170081584f94/{imageVariant}","/media/media::image::c::10218162598::vessel::d7559cd0-822f-11ee-bb51-976bcca658ae::assets::b351c5d0-67ce-11f0-940a-170081584f94/{imageVariant}","/media/media::image::c::10218162598::vessel::d7559cd0-822f-11ee-bb51-976bcca658ae::assets::fe84aba0-8231-11ee-bb51-976bcca658ae.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::d7559cd0-822f-11ee-bb51-976bcca658ae::assets::b33f4f40-67ce-11f0-940a-170081584f94/{imageVariant}","/media/media::image::c::10218162598::vessel::d7559cd0-822f-11ee-bb51-976bcca658ae::assets::c9a4f1c0-1489-11ef-a805-7b2c3c9892e0.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::d7559cd0-822f-11ee-bb51-976bcca658ae::assets::b360e100-67ce-11f0-940a-170081584f94/{imageVariant}"],"make":"Fountaine Pajot","model":"Saba 50","maxCrew":2,"sleeps":10,"basePort":{"uri":"a::place::16e17940-6187-11f0-b716-09fc9d01b6f6","name":"Marina Trogir","coordinates":{"latitude":43.51398901922514,"longitude":16.11026639252227},"country":"Croatia"},"builtYear":2016,"architect":"","interiorDesigner":"","refitYear":2025,"topSpeed":13,"cruiseSpeed":6,"fuelCapacity":940,"cabinLayout":[{"label":"Double Cabins","value":"6"}],"cabins":6,"bathrooms":6,"decks":"","length":15.24,"beam":7.99,"draft":1.25,"hullType":"Catamaran","hullConstruction":"","tonnage":28,"engines":"2 x Volvo 75.0 HP","amenities":[{"label":"Air Conditioning"},{"label":"Generator"},{"label":"Inverter"},{"label":"Watermaker"},{"label":"Heating"},{"label":"Solar panels"},{"label":"Bimini top"},{"label":"Cockpit/stern, outside shower hot water"},{"label":"Flybridge"},{"label":"Grill/Barbecue/Plancha Gas operated"},{"label":"Teak deck"},{"label":"Coffee machine"},{"label":"Dishwasher"},{"label":"Ice maker"},{"label":"Microwave"},{"label":"Refrigerator"},{"label":"Liferaft"},{"label":"Life jackets"},{"label":"Autopilot"},{"label":"Underwater lights"}],"toys":[{"label":"Stand Up Paddles (SUP)","quantity":"2"},{"label":"Snorkeling gear: mask & flippers"}],"entertainment":["Wi-Fi","Bose Sound System","Fusion radio (DVD/CD/USB/Bluetooth + AM/FM)","LCD TV"],"tenders":["RIB 3.9m with 50hp engine (operated by Skipper)"]},"crew":[{"name":"Martin Šutalo","avatar":"/media/media::image::c::10218162598::vessel::d7559cd0-822f-11ee-bb51-976bcca658ae::assets::18012ee0-67ce-11f0-9a03-411dc49a03be/{imageVariant}","role":"Captain","bio":"Martin Šutalo, born in 1996 in Metković, Croatia. From a young age, he loved spending time at sea. Involved in sports since childhood, he decided to enroll in the Faculty of Kinesiology in Zagreb, where he graduated with a major in sailing. Starting with sailing in small classes, kitesurfing, RSX, and working as a sailing instructor at the Adriatic Sea, he took a few more steps. Martin is a certified Yacht Master A and also holds D2 Basic Safety and GMDSS. As a professional skipper, he gained noteworthy navigational experience and knowledge about the islands. His itineraries can be tailored to your wishes while showing you the best of Adriatic heritage, cuisine by the locals, and many hidden bays. If you have kids or teenagers, you want to have Martin on board for sure. He will take full care for water toys and their special wishes. Off-season, he runs skipper academies, sailing schools, and usually delivers new boats to Croatia, so sailing in the Atlantic and Mediterranean was and still is a proper challenge for a sailing addict like him.\n\nWHAT MAKES HIM HAPPY BESIDE WORK: He likes to compete in regattas. When he is not at sea, he likes to travel. Fitness and playing the guitar are also among his hobbies."},{"name":"Andrea Miočić","avatar":"/media/media::image::c::10218162598::vessel::d7559cd0-822f-11ee-bb51-976bcca658ae::assets::263b26a0-67ce-11f0-9a03-411dc49a03be/{imageVariant}","role":"Captain","bio":"Andrea Miočić, born in 1998 in Zadar, Croatia. Involved in sports since child hood, played volleyball in 1st state league. She graduated from the Faculty of Kinesiology in Zagreb with a major in sailing. Andrea’s passion for sports and physical activity has driven her to work with children as a sports coach in swimming and as a physical education teacher. Her parents own a restaurant by the sea, so she spent a lot of time working with food and as a waitress from young age. Later at the university she fell in love with sailing and the sea. She worked as tour guide on a ship around National park. Then she started working private boat tours as a skipper on speedboats, also as a hostess on the sailing boats. She participated in many sailing regattas. Andrea is fluent in English and Italian with a B-category skipper license. Known for her persistence, friendliness, excellent communication and teamwork, she consistently creates warm atmosphere and positive experiences for all guests including the youngest. Off season she works in school as teacher and as a private and group trainer.\n\nWHAT MAKES HER HAPPY BESIDE WORK: She likes to spend time in nature and by the sea, listen to music and cook. Fitness and travelling the world are her favorite things."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":390000,"displayCurrency":"EUR","displayPrice":390000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1690000,"displayCurrency":"EUR","displayPrice":1690000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rate 2025: 06/28/2025 - 08/30/2025","effectiveDates":[{"from":"2025-06-28T00:00:00.000Z","to":"2025-08-30T23:59:59.999Z"},{"from":"2026-06-28T00:00:00.000Z","to":"2026-08-30T23:59:59.999Z"},{"from":"2027-06-28T00:00:00.000Z","to":"2027-08-30T23:59:59.999Z"}],"pricing":{"lineItems":[{"item":"Charter Fee","conditions":"VAT is Inclusive","quantity":1,"unitPrice":169000