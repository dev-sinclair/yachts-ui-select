ts::99660f10-1387-11ef-b1e7-0f9f73de3e7e.png/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::99654bc0-1387-11ef-b1e7-0f9f73de3e7e.png/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::9965c0f0-1387-11ef-b1e7-0f9f73de3e7e.png/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::99646160-1387-11ef-b1e7-0f9f73de3e7e.png/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::99637700-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::996328e0-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::bca5a620-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::bca5f440-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::bca530f0-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::bca509e0-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::bca86540-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::bca72cc0-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::bca8b360-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::e0bb78f0-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::e0bb2ad0-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}","/media/media::image::a::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::e0bc1530-1387-11ef-b1e7-0f9f73de3e7e.jpeg/{imageVariant}"],"make":"Sunreef Yachts","model":"Sunreef 70 ECO","maxCrew":4,"sleeps":8,"basePort":{"uri":"a::place::dc73c2a2-b3ed-11ed-8120-325096b39f47","name":"Corsica","coordinates":{"latitude":42.13826501902666,"longitude":9.103623794695942},"country":"France"},"cruisingCapacity":8,"staticCapacity":"","builtYear":2023,"architect":"Sunreef Yachts","interiorDesigner":"","refitYear":"","topSpeed":"","cruiseSpeed":8,"fuelCapacity":"","cabinLayout":[{"label":"Double Cabins","value":"4"}],"cabins":4,"bathrooms":4,"decks":"","length":23.5,"beam":10.85,"draft":1.9,"hullType":"Catamaran","hullConstruction":"Composite","tonnage":"","superStructure":[],"engines":"2 x 120 kW electric engines","amenities":[{"label":"Air conditioning"}],"toys":[{"label":"Floating Sunbeds","quantity":"4"},{"label":"SUP","quantity":"4"},{"label":"Seabobs F5S","quantity":"2"},{"label":"Wing Foils","quantity":"2"},{"label":"Flite E-Foil"},{"label":"Wake Board"},{"label":"Skis"},{"label":"4-seat Spinera Buoy"},{"label":"Snorkeling gear (all sizes), Impact vests and neoprene suits."}],"entertainment":["WiFi connection on board","STARLINK high speed wireless internet","Indoor and Outdoor Home Cinema","18 ceiling speakers in total (6 indoor + 12 outdoor) + portable Devialet Mania speakers"],"tenders":["WilliamsJet Tender 110HP for 9 people"]},"crew":[{"name":"Daniel Rabasse","avatar":"/media/media::image::c::9938368400::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::5c9ac420-aa69-11f0-a596-2dc1be47febe/{imageVariant}","role":"Captain","bio":"French\n\nDaniel’s deep connection to the maritime world began with freediving and scuba diving, sparking a lifelong passion for the sea. His early career led him to become a diving instructor and work in aquaculture, both in France and abroad. During this time, he lived and travelled aboard his small sailing yacht, steadily building his knowledge and skills in sailing.\n\nIn 2000, he stepped into the world of Yachting and completed his first Mediterranean season, followed by his first Atlantic crossing. That voyage marked a turning point—he chose to pursue life as a professional sailor.\n\nSince then, Daniel has accumulated thousands of miles across various vessels, continuing his training along the way. He earned both his Yachtmaster and Master 3000GT certifications. Though experienced on a wide range of sailing and motor yachts, he has spent most of his time aboard catamarans—including the first Sunreef 74 (S/Y CHE), where he completed multiple seasons in the Mediterranean, Caribbean, and Indian Ocean. Later, he captained the Sunreef 114 (also S/Y CHE) for a five-year round-the-world voyage in rotation.\n\nDaniel’s years at sea have given him in-depth knowledge of global cruising grounds, along with a calm, confident presence at the helm, while ensuring safety and comfort of all guests aboard."},{"name":"Guillaume Sergi-Gobert","avatar":"/media/media::image::c::9938368400::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::98876b60-b661-11f0-a1a6-f73bfe5d01a7/{imageVariant}","role":"Captain","bio":"French\n\nBorn in southern France near the Mediterranean, Guillaume’s passion for the sea began at an early age. After earning his sailing instructor diploma, he spent his university holidays teaching sailing before starting a career in software development. But soon, the call of the sea grew stronger, and a transatlantic crossing convinced him to turn his passion into a profession.\n\nNow a professional captain for over 20 years, Guillaume has logged more than 100,000 nautical miles across the Mediterranean, Atlantic, and Caribbean — including three Atlantic crossings and two passages through the Panama Canal.\n\nCalm, precise, and deeply experienced, he has commanded a variety of luxury sailing yachts and catamarans. Guillaume is known for his reassuring composure in all situations, his focus on safety, and his dedication to delivering exceptional guest experiences. Passionate not only about sailing but also about the world beneath the waves, he is an excellent swimmer and diver who never misses an opportunity to visit his “underwater friends.”\n\nWith his extensive knowledge of both the Mediterranean and the Caribbean, Guillaume takes pride in creating unforgettable voyages where guests feel safe, inspired, and connected to the sea."},{"name":" Cesar Cortial","avatar":"/media/media::image::c::9938368400::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::bd327950-b661-11f0-a1a6-f73bfe5d01a7/{imageVariant}","role":"Captain","bio":"French\n\nCesar’s passion for cooking began in his grandmother’s kitchen, leading him to train under Michelin-starred chefs Georges Blanc and Edouard Loubet. He refined his skills at L’Enclume with Simon Rogan, mastering precision and ingredient-driven cuisine, and at The Peninsula in Hong Kong, deepening his understanding of Asian flavors. Most recently, he helped launch Plaisance by Mauro Colagreco, focusing on sustainable seafood.\n\nWith 10 years of experience at 1, 2 and 3-Star Michelin restaurants around the world, as well as luxury yachting experience, Cesar crafts a memorable dining experience for each guest on board One Planet.\n\nRooted in French and European traditions, his Instagrammable cuisine highlights the finest local ingredients and inspires guests to explore new flavors."},{"name":"Maxim Ballan","avatar":"/media/media::image::c::9938368400::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::86e902a0-6090-11f0-9876-13ae1924a0c3/{imageVariant}","role":"Captain","bio":"French\n\nMaxim is a seasoned yacht crew member and first mate with a global sailing background and diverse professional experience, ranging from managing a fleet of boats to navigating challenging waters. As a mate, skipper, and technician on various vessels, he excels in deck maintenance, navigation, and safety protocols, confidently handling any situation that may arise on board.\n\nHis passion for sailing began in childhood, starting with drift boat competitions at the age of six and continuing until he was twenty. Serving as an assistant sailing instructor and waterman has equipped him to teach a variety of water sports, including fishing, spearfishing, windsurfing, foiling, jet skiing, and freediving.\n\nMaxim’s adventurous spirit and expertise extend to surfing, fishing, diving, and paragliding, ensuring a memorable guest experience for those seeking excitement on the water. Exploring the world on a 50-foot monohull for four years broadened his horizons and exposed him to many cultures, enriching his ability to connect with international guests and colleagues."},{"name":"Szonja Horvath","avatar":"/media/media::image::c::9938368400::vessel::d5cc4f52-fe8c-11ed-889f-43d4bb723744::assets::88ed3710-6090-11f0-9876-13ae1924a0c3/{imageVariant}","role":"Captain","bio":"Hungarian\n\nSzonja Horvath’s journey began in Hungary and then embraced the opportunity to study in Asia at a young age. This experience ignited her open-mindedness and deep interest in diverse cultures.\n\nFluent in Hungarian, English, Chinese, and currently learning French, Szonja’s linguistic abilities reflect her global perspective. With a background in hospitality and childcare across the globe, she discovered a passion for sailing three years ago. Her 13-year career as a professional synchronized swimmer instilled in her discipline, punctuality, and a strive for perfection. An outdoor enthusiast, Szonja is also a qualified diver, proficient surfer, and a yoga instructor, blending her love for the sea with her dedication to wellness and sports."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":6800000,"displayCurrency":"EUR","displayPrice":6800000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":11400000,"displayCurrency":"USD","displayPrice":11400000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer: Mediterranean - Low Season","effectiveDates":