e-b993-0b3fde7b0598.jpeg/{imageVariant}","/media/media::image::c::7819256862::vessel::d5cc2415-fe8c-11ed-889f-43d4bb723744::assets::6f8682c0-da4c-11ee-b993-0b3fde7b0598.jpeg/{imageVariant}","/media/media::image::c::7819256862::vessel::d5cc2415-fe8c-11ed-889f-43d4bb723744::assets::6f86f7f0-da4c-11ee-b993-0b3fde7b0598.jpeg/{imageVariant}","/media/media::image::c::7819256862::vessel::d5cc2415-fe8c-11ed-889f-43d4bb723744::assets::yachts-4844-_PBXJ53JX.jpg/{imageVariant}","/media/media::image::c::7819256862::vessel::d5cc2415-fe8c-11ed-889f-43d4bb723744::assets::yachts-4844-twVaWSz4s.jpg/{imageVariant}"],"make":"International Shipyard Ancona (ISA Yachts)","model":"120 Sport","maxCrew":6,"sleeps":10,"basePort":{"uri":"a::place::27c2908a-b3ee-11ed-b78d-325096b39f47","name":"Saint Thomas","coordinates":{"latitude":18.34577280760982,"longitude":-64.92915768977362},"country":"US Virgin Islands"},"builtYear":2006,"architect":"ISA Yachts","interiorDesigner":"Cristiano Gatto Design, Luxury Projects","refitYear":2024,"topSpeed":26,"cruiseSpeed":19,"fuelCapacity":22000,"cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"Queen Cabins","value":"2"},{"label":"Twin Cabins","value":"2"}],"cabins":5,"bathrooms":6,"length":37,"beam":7.31,"draft":1.83,"hullType":"Planing","hullConstruction":"GRP","tonnage":169,"superStructure":["GRP"],"engines":"3 x MTU 12V 2000 M91 Diesel 1,491 kW, 1,999 HP","amenities":[{"label":"Wi-Fi","quantity":1},{"label":"Salon TV","quantity":1},{"label":"Bar","quantity":1},{"label":"Sun Deck","quantity":1},{"label":"Sunpads","quantity":1},{"label":"Deck shower","quantity":1},{"label":"Sat TV","quantity":1},{"label":"Bimini","quantity":1},{"label":"Generator","quantity":1},{"label":"Ice Maker","quantity":1},{"label":"Hair Dryers","quantity":1},{"label":"TV  in all cabins","quantity":1},{"label":"Stabilizers Underway","quantity":1},{"label":"Air conditioning","quantity":1},{"label":"Bluray player","quantity":1},{"label":"Deck Jacuzzi","quantity":1},{"label":"At-Anchor Stabilizers","quantity":1},{"label":"Bluray player","quantity":1},{"label":"Deck Jacuzzi","quantity":1},{"label":"Air conditioning","quantity":1},{"label":"Stabilizers Underway","quantity":1},{"label":"TV  in all cabins","quantity":1},{"label":"At-Anchor Stabilizers","quantity":1}],"toys":[{"label":"Adult Water Skies","quantity":2},{"label":"Dinghy","quantity":12},{"label":"Jet Ski","quantity":2},{"label":"Sea Bob","quantity":"2"},{"label":"Snorkel Gear","quantity":1},{"label":"1 Person Kayak","quantity":1},{"label":"2 Person Kayak","quantity":1},{"label":"Paddle-boards Stand Up (SUP)","quantity":1},{"label":"tube","quantity":1},{"label":"Fishing Gear","quantity":1},{"label":"Floating Mats","quantity":1},{"label":"Kneeboard","quantity":1},{"label":"Boarding Ladder","quantity":1},{"label":"Swim Platform","quantity":1},{"label":"Child Water Skies","quantity":2},{"label":"Wake Board","quantity":1},{"label":"Towable Toys","quantity":1}],"entertainment":["Salon TV","Satellite TV","BluRay Player","Wi-Fi"],"tenders":["30' / 9.14m Axopar with 300hp Mercury."]},"crew":[{"name":"OLEKSANDR DUBININ (ALEX)","avatar":"/media/media::image::c::7819256862::vessel::d5cc2415-fe8c-11ed-889f-43d4bb723744::assets::30982850-da49-11ee-b993-0b3fde7b0598.jpeg/{imageVariant}","role":"Captain","bio":"Experienced Captain with a proven track record of successfully operating and supervising ocean-going vessels. Captain Alex is driven, enthusiastic, with a firm passion for life at sea and around the sea. Having run multiple hard working charter vessel in the US, running YCM120 is a natural and perfect step for him. He likes to provide charterers with the best holiday they can have, but always keeps in mind the safety of his guests and the crew."},{"name":"PASCAL MICHEL FIRST","avatar":"/media/media::image::c::7819256862::vessel::d5cc2415-fe8c-11ed-889f-43d4bb723744::assets::6de38880-da49-11ee-b993-0b3fde7b0598.jpeg/{imageVariant}","role":"Deckhand","bio":"Pascal has always been passionate about the marine world. South-African born, he is enthusiastic and motivated for adventure, he loved water-based activities and making sure that the guests have lots of fun with the yacht toys, always with an eye for professionalism and safety. He is a great back up for Captain Alex."},{"name":"Jakub Scholl","avatar":"/media/media::image::c::7819256862::vessel::d5cc2415-fe8c-11ed-889f-43d4bb723744::assets::a88636e0-da49-11ee-b993-0b3fde7b0598.jpeg/{imageVariant}","role":"Chef","bio":"Jakub has always dreamed of living and working on the ocean. He is a reliable, hardworking and easy-going person, with over 20 years experience working as a chef. Working in various establishments, from restaurants, to hotel and most recently in luxury super yacht. Jakub has enlarged his cooking repertoire thanks to the countries he has visited, picking up ideas and creating dishes of his own."},{"name":"SAULIUS KLIMAS","avatar":"/media/media::image::c::7819256862::vessel::d5cc2415-fe8c-11ed-889f-43d4bb723744::assets::e8f74110-da49-11ee-b993-0b3fde7b0598.jpeg/{imageVariant}","role":"Steward","bio":"Strong of his several years in land hospitality, Saulius is excellent at building relationships on board and making sure guests feel at home on board. Very detail orientated, if guests want to have a special theme night, Saulius makes sure the best of nights is delivered. Optimistic and friendly along with hardworking are his trade mark."},{"name":"NATALIYA DUBININ","avatar":"/media/media::image::c::7819256862::vessel::d5cc2415-fe8c-11ed-889f-43d4bb723744::assets::115237a0-da4a-11ee-b993-0b3fde7b0598.jpeg/{imageVariant}","role":"Steward","bio":"With years of experience in the service industry, Nataliya has gained extensive housekeeping experience, but missing the contact with guests, switching to yachting was the ideal choice. Very family orientated, she was raised on a farm in Crimsoe where her parents ran a catered hotel. Very keen to meet new guests, she is the perfect back up for Saulius."},{"name":"ENOC URBANO GONZALES","avatar":"/media/media::image::c::7819256862::vessel::d5cc2415-fe8c-11ed-889f-43d4bb723744::assets::34338210-da4a-11ee-b993-0b3fde7b0598.jpeg/{imageVariant}","role":"Engineer","bio":"With a degree in Electrical Mechanical Engineering and 12 years experience in the yachting industry, Enoc makes sure that everything runs smoothly on board YMC120. Passionate about his work, he can obviously most often be found in the engine room, but loves to come out to help with water toys and for a chat with guests on board."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":9800000,"displayCurrency":"EUR","displayPrice":9800000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":10500000,"displayCurrency":"EUR","displayPrice":10500000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer: Mediterranean -  Low Season","effectiveDates":[{"from":"2026-04-01T00:00:00.000Z","to":"2026-05-31T23:59:59.999Z"},{"from":"2027-04-01T00:00:00.000Z","to":"2027-05-31T23:59:59.999Z"},{"from":"2028-04-01T00:00:00.000Z","to":"2028-05-31T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-30T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-09-30T23:59:59.999Z"},{"from":"2028-09-01T00:00:00.000Z","to":"2028-09-30T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":9800000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":9800000,"amount":9800000,"conditions":"VAT & APA Excluded"}],"total":9800000,"subTotal":9800000,"totalTax":0},"inclusionZones":[{"label":"France","type":"Country","category":["Europe","Western Europe","France"],"coordinates":[-3.676762491181631,13.257370810531999],"bbox":[-61.79784094999991,-21.37078215899993,55.854502800000034,51.08754088371883]},{"label":"Corsica","type":"Geo subunit","category":["Europe","Southern Europe","Corsica"],"coordinates":[9.104917129771797,42.161865413836736],"bbox":[8.565625000000011,41.384912109374994,9.55644531250001