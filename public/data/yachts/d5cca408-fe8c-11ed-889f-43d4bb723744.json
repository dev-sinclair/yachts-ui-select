/{imageVariant}","/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::77a35fc0-d74b-11f0-904c-2b8624be57b2/{imageVariant}","/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::779d9360-d74b-11f0-904c-2b8624be57b2/{imageVariant}","/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::b99b09f0-d74b-11f0-904c-2b8624be57b2/{imageVariant}","/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::b9a73ef0-d74b-11f0-904c-2b8624be57b2/{imageVariant}","/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::b99e3e40-d74b-11f0-904c-2b8624be57b2/{imageVariant}","/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::b99e6550-d74b-11f0-904c-2b8624be57b2/{imageVariant}","/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::b9b48560-d74b-11f0-904c-2b8624be57b2/{imageVariant}","/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::b9ae43d0-d74b-11f0-904c-2b8624be57b2/{imageVariant}","/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::b9ba03a0-d74b-11f0-904c-2b8624be57b2/{imageVariant}"],"make":"Lagoon","model":"Lagoon 46","maxCrew":2,"sleeps":8,"basePort":{"uri":"a::place::fcad4c70-5da8-11f0-9ece-3703daf477f7","name":"Lefkas Marina (D-Marin Lefkas)","coordinates":{"latitude":38.83012271322201,"longitude":20.71197411455054},"country":"Greece"},"cruisingCapacity":0,"builtYear":2021,"architect":"","interiorDesigner":"Nauta Design","refitYear":2024,"topSpeed":9,"cruiseSpeed":7,"fuelCapacity":1100,"cabinLayout":[{"label":"Double Cabins","value":"4"}],"cabins":4,"bathrooms":4,"length":14,"beam":8,"draft":1.35,"hullType":"Catamaran","superStructure":[],"engines":"2 Yanmar x 57 hp","amenities":[{"label":"Air Conditioning"},{"label":"Watermaker"},{"label":"Hydraulic Gangway"},{"label":"Underwater lights"},{"label":"Nespresso machine"},{"label":"Generator"},{"label":"Hairdryer","quantity":"1"},{"label":"Cockpit refrigerator ","quantity":"1"},{"label":"Forward Sun pad"},{"label":"Forward Bean Bags ","quantity":"2"},{"label":"Toaster"},{"label":"Inverter"},{"label":"Electric cabin fans "},{"label":"USB Sockets in cabins"}],"toys":[{"label":"SUP","quantity":"2"},{"label":"Funtube for kids","quantity":"1"},{"label":"Inflatable canoe","quantity":"1"},{"label":"Fishing equipment","quantity":"1"},{"label":"Snorkeling equipment","quantity":"8"},{"label":"Jobe infinity seascooter","quantity":"2"}],"entertainment":["WiFi connection on board","HiFi Fusion for music"],"tenders":["Tender Highfield with 15hp outboard engine Mercury"]},"crew":[{"name":"Apostolis Papadopoulos","avatar":"/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::1660ff60-d74b-11f0-904c-2b8624be57b2/{imageVariant}","role":"Captain","bio":"Apostolis was born in Patras in 1981.He graduated as a primary school teacher from the Educational Department of Patras University in 2003. Apostolis has always been interested in the sea and from a very young age decided that he would also like to turn his hobby into his summer work.\n\nAt the age of 17 he started working as a deck hand on crewed motor yachts during the summer period and travelled around the Greek islands many times. He acquired a large amount of knowledge which later on he put into practice when he himself became Skipper on motor yachts and sailing boats. He is a holder of offshore sailing license , speedboat license issued by the Greek coastguard and also is a licensed sailing instructor issued by the Greek Ministry of Athletics.\n\nApostolis’s passion has always been sailing and this is what he returned to when he graduated from University. He has been skippering on sailing yachts and large Catamarans in the Ionian for the last 20 years and knows the area like the back of his hand. He is also well known for his kind nature and has many clients who visit the Ionian every year just to have him as their skipper.\nApostolis is characterized by his professionalism and sea awareness – assets he acquired while working on crewed VIP motor yachts. He is a holder of offshore sailing license , speedboat license issued by the Greek coastguard and also is a licensed sailing instructor issued by the Greek Ministry of Athletics.\n\nWhen Apostolis isn’t skippering he is either taking part in sailing races, fishing or else tending to his olives and vines in his village.\nApostolis is a proud father of a daughter. He speaks English and Greek and gets on great with children as they love him."},{"name":"Juli Aragianni","avatar":"/media/media::image::c::7818345123::vessel::d5cca408-fe8c-11ed-889f-43d4bb723744::assets::37ce2060-d74b-11f0-904c-2b8624be57b2/{imageVariant}","role":"Captain","bio":"Juli was born in Greece but spent many years abroad for studies and work. Juli is a fluent English and German speaker as she has studied German at University. Juli has worked in the tourism industry for many years but decided that she prefered working on the sea . In 2019 she took a job as a hostess on a 30mt motor yacht ,catering to upscale clients and has also completed a silver service course . She has been on board El Marita since 2021. She is hard working , motivated and a team player. Her friendly personallity and adaptility make her stand out.\n\nIn her free time Juli loves playing the piano , sailing and travelling."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":995000,"displayCurrency":"EUR","displayPrice":995000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1520000,"displayCurrency":"EUR","displayPrice":1520000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rate: August","effectiveDates":[{"from":"2026-08-01T00:00:00.000Z","to":"2026-08-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1520000,"inputAmountTaxed":"EXCLUSIVE","note"