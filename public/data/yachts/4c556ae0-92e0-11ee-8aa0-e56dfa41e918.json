ia/media::image::c::9558511124::vessel::4c556ae0-92e0-11ee-8aa0-e56dfa41e918::assets::629bc430-ab21-11ee-9f34-21c440a9a97b.jpeg/{imageVariant}","/media/media::image::c::9558511124::vessel::4c556ae0-92e0-11ee-8aa0-e56dfa41e918::assets::cfc2fe30-a1b5-11ef-9241-f90c5a189032/{imageVariant}","/media/media::image::c::9558511124::vessel::4c556ae0-92e0-11ee-8aa0-e56dfa41e918::assets::d22aaf60-a1b5-11ef-9241-f90c5a189032/{imageVariant}","/media/media::image::c::9558511124::vessel::4c556ae0-92e0-11ee-8aa0-e56dfa41e918::assets::c5661990-a1b5-11ef-9241-f90c5a189032/{imageVariant}","/media/media::image::c::9558511124::vessel::4c556ae0-92e0-11ee-8aa0-e56dfa41e918::assets::bba3a030-a1b5-11ef-9241-f90c5a189032/{imageVariant}","/media/media::image::c::9558511124::vessel::4c556ae0-92e0-11ee-8aa0-e56dfa41e918::assets::04cbda30-fe63-11ee-8d53-b3fd58a8d542.jpeg/{imageVariant}"],"make":"Pershing","model":"Pershing 8X","maxCrew":3,"sleeps":9,"basePort":{"name":"Cap-d'Ail, Alpes-Maritimes, France","coordinates":{"longitude":7.39542,"latitude":43.72298},"country":"France"},"cruisingCapacity":9,"builtYear":2023,"architect":"","interiorDesigner":"Fulvio de Simoni","refitYear":"","topSpeed":48,"cruiseSpeed":42,"fuelCapacity":"","cabinLayout":[{"label":"Master Cabin","value":"1"},{"label":"VIP Cabin","value":"1"},{"label":"Twin Cabins (Pullman in starboard twin)","value":"2"}],"cabins":4,"bathrooms":3,"decks":"","length":25.55,"beam":5.86,"draft":1.4,"hullType":"Planing Hull","hullConstruction":"Carbon Fibre","tonnage":"","superStructure":[],"engines":"2 x Diesel engine MTU 16V 2638 HP","amenities":[{"label":"Air Conditioning"},{"label":"Generators"},{"label":"BBQ"},{"label":"Sunbeds"},{"label":"Foredeck Sunpads"},{"label":"Lounge area"},{"label":"Stabilizers Underway"},{"label":"At-Anchor Stabilizers"},{"label":"OLED TV in Salon"},{"label":"OLED TV in Master Cabin"},{"label":"Sound system"},{"label":"Underwater lights"},{"label":"Pepwave Internet"}],"toys":[{"label":"Sea Bob F5S Pershing edition"},{"label":"Sea Doo Spark Trixx"},{"label":"Fliteboard E-Foil"},{"label":"Jobe Double Trouble Towable"},{"label":"Cressi Snorkel Sets","quantity":"9"},{"label":"Jobe Mini Manta Floating Mats","quantity":"2"},{"label":"Foam Pool Noodles"},{"label":"Basic Fishing Gear"}],"entertainment":["Sound system","OLED TV in Salon","OLED TV in Master Cabin","Pepwave Internet"],"tenders":["Tender Williams 345 Sportjet"]},"crew":[{"name":"Steve Dent","avatar":"/media/media::image::c::9558511124::vessel::4c556ae0-92e0-11ee-8aa0-e56dfa41e918::assets::2618f770-193b-11ef-bb03-33505093d567.png/{imageVariant}","role":"Captain","bio":"Date of Birth: 27 November 1992\nPlace of Birth: Port Elizabeth, South Africa\nLanguages: English: fluent. Afrikaans: basic.\n\nMeet Steve...\n\nA seasoned yachting professional born and raised in Port Elizabeth, South Africa. Graduating with a Law degree from Nelson Mandela Metropolitan University in 2015, he swiftly transitioned into the yachting industry. His career highlights include roles such as Chief Officer on M/Y Ciao (50m) and 1st Mate on M/Y Attitude (47m). He has also served as Bosun on M/Y Samurai (60m) and Deckhand on S/Y Sarissa (42m). Steve's journey from deckhand to Captain showcases his expertise in yacht operations, teamwork, and safety. His leadership is marked by attention to detail, problem-solving skills, and a commitment to safety, making him an invaluable asset in the yachting community.\n\nWHAT IS YOUR YACHTING BACKGROUND? WHY DID YOU DECIDE TO PURSUE A CAREER IN THIS INDUSTRY?\n“One of my most exciting experiences was sailing across the Atlantic on the beautiful 55m sailing yacht, Adela. The yacht dated back to 1903, before being restored and relaunched in 1995. I’ve been very privileged to have been a part of various great yachting programs over my career, learning from various mentors along the way. What began as a chance to travel the world and meet inspiring people, quickly turned into a passionate pursuit to excel within a competitive industry and Captain my very own vessel. \n\nWHAT ARE YOUR HOBBIES AND INTERESTS? \n“My passions lie in the sport of golf. My fiancé, Kerri and I always stay active and fit by finding the nearest gym to train at or trail to run. I’m an avid stand-up comedy fan and love an intellectually stimulating conversation. \n\nOTHER RELEVANT TALENTS OR SKILLS \nPhotography and video capturing and editing."},{"name":"Kerri Ackhurst","avatar":"/media/media::image::c::9558511124::vessel::4c556ae0-92e0-11ee-8aa0-e56dfa41e918::assets::a968f400-193a-11ef-bb03-33505093d567.png/{imageVariant}","role":"Chief Stewardess","bio":"Date of Birth: 13 February 1997\nPlace of Birth: Port Elizabeth, South Africa\nLanguages: English: fluent. Afrikaans: basic.\n\nMeet Kerri...\n\nAfter high school, her journey transitioned from an interest in cruise liners to yachting at the age of 22. With an enthusiasm for makeup, fitness training, and teaching, she brings versatility to your onboard experience. With a rich background in maritime hospitality, including her most recent roles as Chief Stew on M/Y CIAO (50m) and MY ATTITUDE (47m), Kerri started climbing the yachting ladder onboard vessels like M/Y SAMURAI and M/Y TAIBA as 4th and Junior stew, respectively. Her love for sports shines through her background in field hockey, tennis, squash, and hockey. Whether it's hiking, CrossFit, or beach days, she embraces active living. Eager to explore new destinations like Turkey, Alaska, Costa Rica, and Texas, she values family and treasured moments with loved ones.\n\nWHAT IS YOUR YACHTING BACKGROUND? WHY DID YOU DECIDE TO PURSUE A CAREER IN THIS INDUSTRY?\n“The pursuit of my yachting career was serendipitous. I knew nothing about it, but I met my partner, Steve, who was already in the industry, and it intrigued me. Without hesitation, I join him but found out that we would be working on separate boats in different countries. With hard work and dedication, we eventually found each other on the same boat and never looked back.\"\n\nWHAT ARE YOUR HOBBIES AND INTERESTS? \n“My passion lies with sport and weight training but my artistic side comes through with painting, drawing and my interest in pottery.”\n\nOTHER RELEVANT TALENTS OR SKILLS \nPersonal Trainer, Makeup artist, Barista and Mixologist."},{"name":"Oscar Newman","avatar":"/media/media::image::c::9558511124::vessel::4c556ae0-92e0-11ee-8aa0-e56dfa41e918::assets::f167e450-193a-11ef-bb03-33505093d567.png/{imageVariant}","role":"Cook","bio":"Date of Birth: 10th June 2001\nPlace of Birth: Mallorca, Spain\nLanguages: English, Spanish and French: fluent. Catalan: good\n\nMeet Oscar...\n\nThe versatile Steward/Cook aboard Cherry. Native to Mallorca, Spain, Oscar brings a wealth of multicultural experiences to his role. After completing his studies at Cardiff University with a Bachelor’s in French and Spanish, Oscar's dynamic journey led him to manage a luxury chalet in Les Deux Alpes, France, where his enthusiasm for cooking flourished. With a certificate from Orchards Cookery, Level 2 Food Hygiene, as well as training in wine tasting and Avalanche Safety, Oscar brings his experience as a chalet host to Cherry’s team, showcasing his adaptable skills and commitment to hospitality.\n\nWHAT IS YOUR YACHTING BACKGROUND? WHY DID YOU DECIDE TO PURSUE A CAREER IN THIS INDUSTRY?\n “My formative journey at the age of 16 was in Ibiza, Spain aboard M/Y Gemini. While much of my time was spent on deck, I eagerly embraced opportunities to contribute to interior upkeep and lend a hand in the galley. My father is a Chief Engineer on a private yacht and my older sister has already established herself in the industry, providing exposure to the maritime world”\n\nWHAT ARE YOUR HOBBIES AND INTERESTS?\n“Aside from cooking, which I consider therapeutic, I am a keen golfer and Captained the second team at Cardiff university. I also enjoy running, I ran the Cardiff half in 1h36min. Besides cooking and sport, I am drawn to music, as a self-taught guitarist and DJ.”\n\nOTHER RELEVANT TALENTS OR SKILLS \nAdvanced level at many water sports, including open water diving"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":5400000,"displayCurrency":"EUR","displayPrice":5400000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":6500000,"displayCurrency":"EUR","displayPrice":6500000,"unit":"WEEK"},"pricingInfo":[{"name":"Summer: Low (April - June & September - October)","effectiveDates":[{"from":"2025-09-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2028-06-30T23:59:59.999Z"}],"pricing":{"lineItems":[{"item":"Charter Fee","conditions":"","quantity":1,"unitPrice":5400000,"amount":5400000}],"currency":"EUR","inputAmountTaxed":"EXCLUSIVE","subTotal":5400000,"totalTax":0,"total":5400000,"unit":"WEEK","charterFee":5400000},"inclusionZones":[{"label":"Corsica","type":"Geo subunit","category":["Europe","Southern Europe","Corsica"],"coordinates":[9.104917129771797,42.161865413836736],"bbox":[8.565625000000011,41.384912109374994,9.556445312500017,43.021484375]},{"label":"France","type":"Country","category":["Europe","Western Europe","France"],"coordinates":[-3.676762491181631,13.257370810531999],"bbox":[-61.79784094999991,-21.37078215899993,55.854502800000034,51.08754088371883]},{"label":"Italy","type":"Sovereign country","category":["Europe","Southern Europe","Italy"],"coordinates":[12.204840429521369,41.61169587639921],"bbox":[6.6027283120000675,35.48924388200004,18.517425977000073,47.08521494500006]},{"label":"Malta","type":"Sovereign country","category":["Europe","Southern Europe","Malta"],"coordinates":[14.377222348503812,35.94020291192098],"bbox":[14.180371093750011,35.820214843749994,14.566210937500017,36.07578125]},{"label":"Sardinia","type":"Geo subunit","category":["Europe","Southern Europe","Sardinia"],"coordinates":[8.96574354539669,40.12242872762209],"bbox":[8.1808593750000