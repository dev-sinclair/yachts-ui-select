0-67cc-11f0-b218-59b21826ea6f/{imageVariant}","/media/media::image::c::10218162598::vessel::fa9044f0-81fa-11ee-b1ab-ff1957b402aa::assets::fd0073e0-67cc-11f0-b218-59b21826ea6f/{imageVariant}","/media/media::image::c::10218162598::vessel::fa9044f0-81fa-11ee-b1ab-ff1957b402aa::assets::fcfaa780-67cc-11f0-b218-59b21826ea6f/{imageVariant}","/media/media::image::c::10218162598::vessel::fa9044f0-81fa-11ee-b1ab-ff1957b402aa::assets::1cbf2090-8201-11ee-b1ab-ff1957b402aa.jpeg/{imageVariant}","/media/media::image::c::10218162598::vessel::fa9044f0-81fa-11ee-b1ab-ff1957b402aa::assets::fd3f2a90-67cc-11f0-b218-59b21826ea6f/{imageVariant}","/media/media::image::c::10218162598::vessel::fa9044f0-81fa-11ee-b1ab-ff1957b402aa::assets::fd3e6740-67cc-11f0-b218-59b21826ea6f/{imageVariant}"],"make":"Lagoon-Bénéteau","model":"Lagoon 46","maxCrew":2,"sleeps":10,"basePort":{"uri":"a::place::16e17940-6187-11f0-b716-09fc9d01b6f6","name":"Marina Trogir","coordinates":{"latitude":43.51398901922514,"longitude":16.11026639252227},"country":"Croatia"},"builtYear":2022,"refitYear":2025,"topSpeed":11,"cruiseSpeed":6,"fuelCapacity":1080,"cabinLayout":[{"label":"Queen Cabin","value":"4"},{"label":"Single Cabin","value":"1"}],"cabins":4,"bathrooms":4,"length":14.03,"beam":7.96,"draft":1.3,"hullType":"Catamaran","hullConstruction":"","engines":"Yanmar 2 x 57.0 HP","amenities":[{"label":"Air Conditioning In all cabins"},{"label":"Generator "},{"label":"Inverter "},{"label":"Heating in all cabins"},{"label":"Watermaker "},{"label":"Flybridge"},{"label":"Teak deck"},{"label":"Coffee machine"},{"label":"Ice maker"},{"label":"Microwave"},{"label":"Refrigerator","quantity":"3"},{"label":"Underwater lights","quantity":"4"}],"toys":[{"label":"SEA-DOO underwater scooter ","quantity":"2"},{"label":"Stand up paddle","quantity":"2"},{"label":"Water skis jobe allegre 67\""},{"label":"Jobe Omnia multifunctional water toy"}],"entertainment":["FUSION sound system Fusion RA70N","Wi-Fi Internet 4 LTE"],"tenders":[]},"crew":[{"name":"Bruno Benčić","avatar":"/media/media::image::c::10218162598::vessel::fa9044f0-81fa-11ee-b1ab-ff1957b402aa::assets::a70b3440-67bb-11f0-b135-43001f515297/{imageVariant}","role":"Captain","bio":"Bruno Benčić was born in 1993 in Zagreb, Croatia where he graduated on Faculty of Kinesiology with majoring in sailing. From young age Bruno spend his life on the seaside where he met sailing from young age. He started working as a skipper in 2017 with his friends, and it became a passion. Working in most popular sailing area in Croatia he acquired all the contacts and secrets of the area which will make your holiday unforgettable. If you have kids Bruno is skipper to be on bord with, he loves entertaining kids with water toys while parents can relax. Bruno is very approachable and calm person. Fluent english speaker with great knowledge of Adriatic coast line. Organizing wine, bike or military tours on island Vis. Always glad to show people the hidden gems of beautiful Croatian coastline the best way possible by sailing it along the coast. Out of season Bruno works for Croatian Sailing Academy as instructor for educating new skippers and share with them his experience. Besides that, out of the season working on deliveries of new catamarans to Croatia and extend his nautical miles record to upgrade his skipper licence to bigger luxury catamarans.\n\nWHAT MAKES HIM HAPPY BESIDE WORK: Spending quality time with family and friends, engaging in outdoor activities like hiking and biking, and enjoying spearfishing and skiing. He finds joy in exploring new hobbies, listening to music, and traveling to new places to experience different cultures."},{"name":"Vida Štefan","avatar":"/media/media::image::c::10218162598::vessel::fa9044f0-81fa-11ee-b1ab-ff1957b402aa::assets::bd6280e0-67bb-11f0-bb3a-4783772869ef/{imageVariant}","role":"Captain","bio":"Vida Štefan was born in 1997 in Zagreb, Croatia where she graduated Kinesiology from the University of Zagreb. She speak fluently English, knows basic of German and Italian language. With over six years of experience Vida has developed excellent customer service skills and the ability to ensure a comfortable and enjoyable services for guests not as an hostess, but also as tour guide with a strong background in Croatia history, tourism and hospitality industry. During the years she grew distinctive enthusiasm for cooking in general, especially Mediterranean cuisine. This helps her to move from Hostess/Cook to chef level cooking services on the boat. Vida holds also a skipper license, which allows her to confidently navigate boats or works as professional deck hand with high priority on guests safety. Vida is passionate about outdoor activities, including scuba diving, kitesurfing and sailing which she like to learn the teenagers. Her friendly approachable personality and attention to detail make from her a perfect person for position of experienced hostess, which every clients want to have on board.\n\nWHAT MAKES HER HAPPY BESIDE WORK: She enjoys traveling, learning about new cultures, and embracing new challenges. She is especially passionate about the summer season and outdoor adventures."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":350000,"displayCurrency":"EUR","displayPrice":350000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":1350000,"displayCurrency":"EUR","displayPrice":1350000,"unit":"WEEK"},"pricingInfo":[{"name":"Weekly Rate 2025: 06/21/2025 - 08/23/2025","effectiveDates":[{"from":"2025-06-21T00:00:00.000Z","to":"2025-08-23T23:59:59.999Z"},{"from":"2026-06-21T00:00:00.000Z","to":"2026-08-23T23:59:59.999Z"},{"from":"2027-06-21T00:00:00.000Z","to":"2027-08-23T23:59:59.999Z"}],"pricing":{"currency":"EUR","inputAmountTaxed":"INCLUSIVE","subTotal":1650000,"totalTax":175500,"total":1650000,"lineItems":[{"item":"Charter Fee","conditions":"VAT is Inclusive","quantity":1,"unitPrice":1350000,"amount":1350000,"taxRate":{"label":"VAT","value":0.13}},{"item":"Security Deposit"