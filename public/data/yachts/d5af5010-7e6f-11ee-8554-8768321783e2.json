390044bdfd6/{imageVariant}","/media/media::image::a::vessel::d5af5010-7e6f-11ee-8554-8768321783e2::assets::ce399280-2117-11f1-89e2-3390044bdfd6/{imageVariant}","/media/media::image::a::vessel::d5af5010-7e6f-11ee-8554-8768321783e2::assets::ce3a55d0-2117-11f1-89e2-3390044bdfd6/{imageVariant}","/media/media::image::a::vessel::d5af5010-7e6f-11ee-8554-8768321783e2::assets::ce3bb560-2117-11f1-89e3-3390044bdfd6/{imageVariant}","/media/media::image::a::vessel::d5af5010-7e6f-11ee-8554-8768321783e2::assets::ce3b8e50-2117-11f1-89e4-3390044bdfd6/{imageVariant}","/media/media::image::a::vessel::d5af5010-7e6f-11ee-8554-8768321783e2::assets::0e638190-2118-11f1-bf0f-d5f0a6c8b65f/{imageVariant}"],"make":"Fountaine Pajot","model":"Fountaine Pajot Aura 51","maxCrew":2,"sleeps":8,"basePort":{"uri":"a::place::103e7ea6-b3ee-11ed-831e-325096b39f47","name":"Saint Martin","coordinates":{"latitude":18.07160506,"longitude":-63.05194744},"country":"Overseas France"},"builtYear":2022,"architect":"","interiorDesigner":"","refitYear":"","topSpeed":9,"cruiseSpeed":7,"fuelCapacity":900,"cabinLayout":[{"label":"Owner's Suite","value":"1"},{"label":"VIP Cabins","value":"3"}],"cabins":5,"bathrooms":4,"decks":"","length":15.91,"beam":8.08,"draft":1.3,"hullType":"Catamaran","hullConstruction":"","tonnage":"","engines":"2 × 75 hp","amenities":[{"label":"Deck Shower"},{"label":"BBQ"},{"label":"Hairdryers"},{"label":"Inverter"},{"label":"Swim Ladder"},{"label":"Fore-deck lounge awning"}],"toys":[{"label":"Fishing Gear"},{"label":"Snorkelling Equipment"},{"label":"Standup Paddleboard"},{"label":"Water loungers"},{"label":"Beach toys"},{"label":"Swim noodles"},{"label":"Board games"}],"entertainment":[]},"crew":[{"name":"Christophe Tesseron","avatar":"/media/media::image::a::vessel::d5af5010-7e6f-11ee-8554-8768321783e2::assets::b7002340-2117-11f1-bf0d-d5f0a6c8b65f/{imageVariant}","role":"Captain","bio":"Captain Christophe, originally from France, has more than 20 years’ experience in the yachting industry ranging from classic regattas to a long-term world trip. He has cruised to bustling must-see destinations in the Mediterranean Sea and Caribbean Island as well as organized all kinds of planning to ensure a comfortable visit of the remote areas in the Pacific Ocean. Besides being a good navigator and handyman, he acts also as a story-teller, waiter, dishwasher if needed. He will work closely with you to create a safe and relaxing vacation for everyone onboard."},{"name":"Jeanette Dombrowe","avatar":"/media/media::image::c::10549594650::vessel::d5af5010-7e6f-11ee-8554-8768321783e2::assets::119aa1b0-27b0-11f1-9428-7bb07ccddeda/{imageVariant}","role":"Captain","bio":"Jeanette is stewardess, cook or first mate… In any case… she is all three. With parents coming from Germany and Thailand, born near Munich and later spending her teenage years in Phuket, Jeanette brings a lovely Eurasian mixture onboard. She is both intuitive and attentive, so that the right atmosphere & level of service is met for you and your guests. Her multicultural heritage can also be found in her cooking. Of course, she has a flair for Asian cuisine, but she also discovered that recipes from other parts of the world have its charms.\n"},{"name":"","role":"Captain"}],"pricing":{"weekPricingFrom":{"currency":"USD","price":2590000,"displayCurrency":"USD","displayPrice":2590000,"unit":"WEEK"},"weekPricingTo":{"currency":"USD","price":2790000,"displayCurrency":"USD","displayPrice":2790000,"unit":"WEEK"},"pricingInfo":[{"name":"Caribbean/Bahamas (4 guests)","effectiveDates":[{"from":"2026-01-01T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"},{"from":"2028-01-01T00:00:00.000Z","to":"2028-12-31T23:59:59.999Z"}],"pricing":{"currency":"USD","charterFee":2590000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":2590000,"amount":2590000,"conditions":"Tax is Inclusive"}],"total":2590