imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::da16ec90-be19-11ef-8113-4b5174e559f4/{imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::da025320-be19-11ef-8112-4b5174e559f4/{imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::da140660-be19-11ef-8112-4b5174e559f4/{imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::da182510-be19-11ef-8113-4b5174e559f4/{imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::da17fe00-be19-11ef-8113-4b5174e559f4/{imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::da18c150-be19-11ef-8113-4b5174e559f4/{imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::da147b90-be19-11ef-8112-4b5174e559f4/{imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::d9dca2b0-be19-11ef-8112-4b5174e559f4/{imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::d9dca2b1-be19-11ef-8112-4b5174e559f4/{imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::da18c151-be19-11ef-8113-4b5174e559f4/{imageVariant}","/media/media::image::a::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::da136a20-be19-11ef-ac14-61911423263c/{imageVariant}"],"make":"Aegean Yacht","model":"Aegean Explorer M26","maxCrew":4,"sleeps":12,"cruisingCapacity":12,"staticCapacity":0,"builtYear":2022,"architect":"","interiorDesigner":"","refitYear":"","topSpeed":12.7,"cruiseSpeed":12,"fuelCapacity":0,"cabinLayout":[{"label":"Master Cabins","value":"3"},{"label":"VIP Cabin","value":"1"},{"label":"Twin Cabins","value":"2"}],"cabins":6,"bathrooms":6,"decks":3,"length":26,"beam":6.9,"draft":2.1,"hullType":"Displacement","hullConstruction":"Steel","tonnage":187,"superStructure":["Aluminium"],"engines":"MAN 650 HP engines","amenities":[{"label":"Air Conditioning"},{"label":"Sun bathing area"},{"label":"Sun lounging area"},{"label":"Gym equipment "},{"label":"Stabilizers (underway and at anchor)"}],"toys":[{"label":"Stand Up Paddle Boards","quantity":"2"},{"label":" Inflatable slide","quantity":"1"},{"label":"Inflatable water toys","quantity":"1"},{"label":" Snorkeling equipment","quantity":"2"},{"label":"Seabob","quantity":"2"},{"label":"E-foil","quantity":"2"},{"label":"Inflatable pool","quantity":"1"}],"entertainment":["Internet (local modems + Starlink)"],"tenders":["Chase Boat 9 M XO DFNDR 8 Length Beam 2,6 M Max number of pax. 6-8; 2 x 250 Mercury","Highfield Sport 600 - Yamaha F130 Tender"]},"crew":[{"name":"Oskar Ozen","avatar":"/media/media::image::c::26934280528::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::b6fa17d0-7e8c-11f0-b1c0-8fb4cb05b9ae/{imageVariant}","role":"Captain","bio":"Captain Coskan Ozen is a highly experienced Master 500GT with over 10 years in both private and charter yachting, holding extensive cruising knowledge across the Mediterranean, Aegean, Red Sea, and Arabian Gulf. Skilled in ISM/ISPS compliance, crew leadership, and vessel operations, he has successfully managed yachts up to 56m, overseeing refits, surveys, and high-profile guest programs. Professional, safety-focused, and guest-oriented, he brings strong management, technical, and navigational expertise to every program.\n"},{"name":"Sinan Coskuner ","avatar":"/media/media::image::c::26934280528::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::9aace550-318c-11f0-84ac-a19bd04c490e/{imageVariant}","role":"Captain","bio":"Sinan, the First Mate embarked on a diverse and dynamic journey into the maritime world. Graduating from an Open Education High School, he set his course through various profession as a store manager at Magic Life Hotels, showcasing his aptitude for management. His passion for sailing then led him to the graceful vessel named White Wings, where he first embraced the art of sailing.\n\nIn 2010, he transitioned to the Sea Lion motor yacht, further honing his maritime skills and expertise. Following this, he assumed the role of a restaurant manager, a position that allowed him to expand his talents in hospitality. His journey also took him to Dubai, where he served as a chef and deck leader on the motor yacht named Free Day, deepening his understanding of both culinary and nautical arts.\n\nToday, he continues his maritime odyssey aboard Ukiel, contributing his skills and experience to ensure every voyage is a success.\n"},{"name":"Omer Faruk Ozmen","avatar":"/media/media::image::c::26934280528::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::b6c1c4e0-318c-11f0-84ac-a19bd04c490e/{imageVariant}","role":"Captain","bio":"Ömer’s passion for the sea and dedication to excellence make him a valuable asset to the UKIEL crew. With a strong maritime foundation from Piri Reis University, he has honed his skills through hands-on experience in the yachting industry, ensuring top-tier service and seamless deck operations.\n\nHis career began in ship management, where he developed a deep understanding of seamanship, vessel maintenance, and safety procedures. Transitioning into the luxury yachting sector, Ömer brings meticulous attention to detail, ensuring the highest standards of guest experience, deck upkeep, and water sports assistance.\n\nCertified in security, safety, and emergency response, Ömer is well-prepared for the dynamic demands of high-end charters. His strong work ethic, adaptability, and commitment to guest satisfaction make him an integral part of delivering exceptional experiences aboard M/Y UKIEL.\n"},{"name":"Hilal Ozlem Ergu","avatar":"/media/media::image::c::26934280528::vessel::764623f0-017e-11ef-af1a-49a51012e18e::assets::c14e4500-318c-11f0-84ac-a19bd04c490e/{imageVariant}","role":"Captain","bio":"Hilal’s culinary journey is marked by excellence. Graduating as valedictorian, she honed her craft by studying ship cooking at university and delving into maritime tourism and cookery.\n\nHer career set sail during a university internship on the private commercial motor yacht M/Y BRONKO 1 (35 meters). Quickly gaining recognition for her talents, she continued to impress on the same vessel and the M/Y BRONKO (24 meters) within the same company.\n\nDiversifying her experience, she spent seasons on the magnificent schooner S/Y Germania Nova (60 meters). Today, she delights palates as the chef on the M/Y UKIEL (26 meters). Committed to constant improvement, she participates in industry seminars, interviews, and competitions.\n"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":4495000,"displayCurrency":"EUR","displayPrice":4495000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":6495000,"displayCurrency":"EUR","displayPrice":6495000,"unit":"WEEK"},"pricingInfo":[{"name":"Low Season","effectiveDates":[{"from":"2026-06-01T00:00:00.000Z","to":"2026-06-30T23:59:59.999Z"},{"from":"2027-06-01T00:00:00.000Z","to":"2027-06-30T23:59:59.999Z"},{"from":"2028-06-01T00:00:00.000Z","to":"2028-06-30T23:59:59.999Z"},{"from":"2025-09-01T00:00:00.000Z","to":"2025-09-30T23:59:59.999Z"},{"from":"2026-09-01T00:00:00.000Z","to":"2026-09-30T23:59:59.999Z"},{"from":"2027-09-01T00:00:00.000Z","to":"2027-09-30T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":5695000,"inputAmountTaxed":"EXCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":5695000,"amount":5695000,"conditions":"VAT & APA Excluded","taxRate":{"label":"VAT","value":0.12}},{"item":"APA","conditions":"","quantity":0.35,"unitPrice":5695000,"amount":1993249.9999999998},{"item":"","conditions":"","quantity":1,"unitPrice":0,"amount":0}],"total":8371650,"subTotal":7688250,"totalTax":683400},"inclusionZones":[{"label":"Italy","type":"Sovereign country","category":["Europe","Southern Europe","Italy"],"coordinates":[12.204840429521369,41.61169587639921],"bbox":[6.6027283