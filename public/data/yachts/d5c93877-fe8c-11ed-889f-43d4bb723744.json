}","/media/media::image::a::vessel::d5c93877-fe8c-11ed-889f-43d4bb723744::assets::3a3724f0-145a-11f0-893d-dffa1b4fa0d2/{imageVariant}","/media/media::image::a::vessel::d5c93877-fe8c-11ed-889f-43d4bb723744::assets::3a40e8f0-145a-11f0-893d-dffa1b4fa0d2/{imageVariant}","/media/media::image::a::vessel::d5c93877-fe8c-11ed-889f-43d4bb723744::assets::3a4ea490-145a-11f0-893d-dffa1b4fa0d2/{imageVariant}","/media/media::image::a::vessel::d5c93877-fe8c-11ed-889f-43d4bb723744::assets::3a43f631-145a-11f0-893d-dffa1b4fa0d2/{imageVariant}","/media/media::image::a::vessel::d5c93877-fe8c-11ed-889f-43d4bb723744::assets::3a3688b1-145a-11f0-893d-dffa1b4fa0d2/{imageVariant}"],"make":"Aegean Builders","model":"","maxCrew":4,"sleeps":12,"basePort":{"uri":"a::place::a0203186-b3ee-11ed-9cd1-325096b39f47","name":"Zadar","coordinates":{"latitude":44.11936462,"longitude":15.23122828},"country":"Croatia"},"cruisingCapacity":12,"builtYear":1994,"architect":"","interiorDesigner":"","refitYear":2014,"topSpeed":10.5,"cruiseSpeed":8.5,"fuelCapacity":7000,"cabinLayout":[{"label":"Master Cabins","value":"2"},{"label":"Double Cabins","value":"2"},{"label":"Twin Cabins","value":"2"}],"cabins":6,"bathrooms":6,"decks":"","length":33,"beam":6.3,"draft":3.4,"hullType":"Mono","hullConstruction":"Steel","tonnage":"","superStructure":["Steel"],"engines":"2 x 306 HP Volvo Penta","amenities":[{"label":"Air conditioning"},{"label":"Sun mattresses ","quantity":"12"},{"label":"Oven"},{"label":"Grill"},{"label":"Refrigerators"},{"label":"Deep freezers"},{"label":"Ice maker"},{"label":"Espresso machine"}],"toys":[{"label":"Waterski"},{"label":"Ringo ride"},{"label":"Two seat kayak ","quantity":"1"},{"label":"Paddleboard "},{"label":"Amateur fishing equipment "},{"label":"Snorkeling equipment "}],"entertainment":["TV","DVD/CD player ","USB connection for multimedia devices ","WiFi","Board games, cards "],"tenders":["Tender boat with outboard engine 5.6 meters, 100 HP "]},"crew":[{"name":"Tonči Torić","avatar":"/media/media::image::a::vessel::d5c93877-fe8c-11ed-889f-43d4bb723744::assets::1360a0f0-1459-11f0-893d-dffa1b4fa0d2/{imageVariant}","role":"Captain","bio":"Captain Tonči Torić has been a keen sailor for more than 30 years. Experience that he gathered during these years gives him confidence to bring the yacht to any small bay at night, or to sail even in rough weather.\n\nSo, you will for sure feel you are in safe hands from the first moment you step aboard. Tonči speaks some English, but his sailing skills speak all languages. Guests love to join him and the crew and give hand during the sailing, and many of them have learned sailing essentials during their vacation on Fortuna.\n\nTogether with his family Tonči has been sailing on Fortuna for about decade now, and together they have built a very good reputation for their work and commitment."},{"name":"Mirna Torić","avatar":"/media/media::image::a::vessel::d5c93877-fe8c-11ed-889f-43d4bb723744::assets::1e71e170-1459-11f0-893d-dffa1b4fa0d2/{imageVariant}","role":"Captain","bio":"Mirna Torić was working as a host and stewardess on Fortuna for many years, but in the last few seasons she started cooking for their guests and the feedback was superb..\n\nClients loved Mirna in her new role and enjoyed her culinary skills. While preparing your meals she will take care of all the little details making sure all your requirements and wishes are fulfilled and easily coordinate food and service to the table.\n\nDo not worry, your children and teenagers will have a special treatment, as Mirna has an individual approach to each guest and his eventual special needs.\n\n\n\n\n\n\n"},{"name":"Stjepan Torić","avatar":"/media/media::image::a::vessel::d5c93877-fe8c-11ed-889f-43d4bb723744::assets::5d074dd0-1459-11f0-893d-dffa1b4fa0d2/{imageVariant}","role":"Captain","bio":"Born in 1996 in Zadar. Stjepan graduated the Naval High School 2015, and went on to study at the Maritime University in Zadar. Currently holds the title as the youngest crew member, he exemplifies excellent naval skills.\n\nHe is very enthusiastic and willing to learn, all in order to one day take over helm himself. Stjepan will be at your service with a smile all the time, taking care of all the “fun stuff on board”, from waterski and water sports.\n\nHe will also drive you around with tender for all your outings, shopping, stroll around small villages or a night life, while the yacht stays in quiet bay away from crowded beaches and resorts.\n\n\n\n\n\n\n\n\n"},{"name":" Anđela Torić","avatar":"/media/media::image::a::vessel::d5c93877-fe8c-11ed-889f-43d4bb723744::assets::a47066c0-1459-11f0-893d-dffa1b4fa0d2/{imageVariant}","role":"Captain","bio":"Born in 1999 in Zadar, Anđela finished high school in her home town and just after high school she started working as waitress in cafes and restaurants so she has a plenty experience in working with people.\n\nShe loves the sea and sailing is in her blood, so opportunity to work on a gullet is her dream come true. She also enjoys fishing, so she can give you some fishing instructions. In her free time, she enjoys traveling and meeting new people. Being very cheerful person, she is right for her job and you will feel like nothing is to hard for her as she will do everything with a smile on her face.\n\nShe will take care of all the little details during your charter from housekeeping to special event organizations so you can have relaxed holiday."}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":2000000,"displayCurrency":"EUR","displayPrice":2000000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2300000,"displayCurrency":"EUR","displayPrice":2300000,"unit":"WEEK"},"pricingInfo":[{"name":" 25.04.-30.05.2026 & 12.09.-17.10.2026","effectiveDates":[{"from":"2025-05-31T00:00:00.000Z","to":"2026-05-30T23:59:59.999Z"},{"from":"2026-09-12T00:00:00.000Z","to":"2026-10-17T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":2000000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WE