ts::f784dfc1-fdd0-11ef-9195-23e41403d131/{imageVariant}","/media/media::image::a::vessel::673eef60-5668-11ef-a8a2-ed728478bcf0::assets::f784dfc0-fdd0-11ef-9195-23e41403d131/{imageVariant}","/media/media::image::a::vessel::673eef60-5668-11ef-a8a2-ed728478bcf0::assets::f7846a90-fdd0-11ef-9196-23e41403d131/{imageVariant}","/media/media::image::a::vessel::673eef60-5668-11ef-a8a2-ed728478bcf0::assets::f78729b0-fdd0-11ef-9196-23e41403d131/{imageVariant}","/media/media::image::a::vessel::673eef60-5668-11ef-a8a2-ed728478bcf0::assets::f787c5f0-fdd0-11ef-9196-23e41403d131/{imageVariant}"],"make":"Lagoon","model":"Lagoon 52F","maxCrew":2,"sleeps":10,"basePort":{"uri":"a::place::738f24c0-dada-11ed-befa-d7914edd5e3a","name":"Marina Kastela","coordinates":{"latitude":43.54601254691691,"longitude":16.40283517494042},"country":"Croatia"},"builtYear":2015,"refitYear":2023,"topSpeed":9,"cruiseSpeed":7,"cabinLayout":[{"label":"Double Cabin","value":"5"}],"cabins":5,"bathrooms":5,"length":15.84,"beam":8.6,"draft":1.5,"hullType":"Catamaran","hullConstruction":"Composite","engines":"2 x 75hp Yanmar 4JH4-TE","amenities":[{"label":"Teak deck"},{"label":"Sun loungers"},{"label":"Shaded dining area"},{"label":"Swim platform with ladder"},{"label":"Refrigerator"},{"label":"Freezer"},{"label":"Microwave oven"},{"label":"Toaster and water heater"},{"label":"Blender"},{"label":"Professional grill"},{"label":"Food fryer"},{"label":"Coffee machine"},{"label":"Ice Maker"},{"label":"Generators","quantity":"2"},{"label":"Inverter"},{"label":"Air Conditioning"},{"label":"Electric toilets"},{"label":"Watermaker"},{"label":"Cockpit cushions"},{"label":"Wi-Fi"},{"label":"Hairdryers"},{"label":"Flybridge"},{"label":"Sunbathing Area "},{"label":"Cockpit lounge"}],"toys":[{"label":"Stand Up Paddle boards","quantity":"2"},{"label":"Seascooters (2 batteries included)","quantity":"2"},{"label":"Wakeboard","quantity":"1"},{"label":"Donut Jobe"},{"label":"Snorkeling equipment (10 masks + 10 flippers)","quantity":"10"},{"label":"Basic fishing gears","quantity":"2"},{"label":"Waterskis","quantity":"1"},{"label":"Nineboot E-Scooter"}],"entertainment":["TV with lift","Radio","Speakers","Wi-Fi"],"tenders":["4.20 m Tender Highfield with 40 HP outboard engine (6 passengers) "]},"crew":[{"name":"Marko Šoba","avatar":"/media/media::image::a::vessel::673eef60-5668-11ef-a8a2-ed728478bcf0::assets::db1c80a0-fdde-11ef-8fab-a18773132fb9/{imageVariant}","role":"Captain","bio":"Citizenship: SLOVENIAN\n\nBiography:\nMarko Šoba grew up inland in Slovenia, where his passion for the sea began over 10 years ago. Starting his career on yachts early on, Marko gained his Yachtmaster 100 certification four years ago, marking a significant milestone in his journey. With experience as an engineer on superyachts, he has a unique blend of technical expertise and nautical knowledge. His strong skills in watersports and free diving have been key in providing guests with exciting, memorable experiences. Marko is particularly familiar with Mediterranean waters, ensuring safe and unforgettable adventures for those he guides.\n\nSkills/Expertise/Languages:\n•\tYachtmaster 100 certification\n•\tExpertise in Mediterranean navigation\n•\tFree diving enthusiast\n•\tStrong background in watersports\n•\tExperience as an engineer on superyachts\n•\tFluent in English, basic German\n•\tPassionate about photography with drone\n\nPersonal interests:\nWhen he’s not at the helm, Marko is an avid aerial photographer, capturing stunning vistas from the sky with his drone. His love for watersports keeps him active, and he enjoys exploring new challenges in free diving. Off the boat, Marko is always looking for opportunities to meet interesting people and immerse himself in different cultures.\n\nWhy Marko loves his Job:\n“The dynamic nature of this job is what excites me. Sailing allows me to combine my love for the sea with meeting amazing people from all over the world. It’s a perfect mix of adventure, technical expertise, and the joy of being on the water.”"}],"pricing":{"weekPricingFrom":{"currency":"EUR","price":1670000,"displayCurrency":"EUR","displayPrice":1670000,"unit":"WEEK"},"weekPricingTo":{"currency":"EUR","price":2170000,"displayCurrency":"EUR","displayPrice":2170000,"unit":"WEEK"},"pricingInfo":[{"name":"01.01. - 23.05. & 27.09. - 31.12.","effectiveDates":[{"from":"2025-01-01T00:00:00.000Z","to":"2025-05-23T23:59:59.999Z"},{"from":"2026-01-01T00:00:00.000Z","to":"2026-05-23T23:59:59.999Z"},{"from":"2027-01-01T00:00:00.000Z","to":"2027-05-23T23:59:59.999Z"},{"from":"2025-09-27T00:00:00.000Z","to":"2025-12-31T23:59:59.999Z"},{"from":"2026-09-27T00:00:00.000Z","to":"2026-12-31T23:59:59.999Z"},{"from":"2027-09-27T00:00:00.000Z","to":"2027-12-31T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1670000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Charter Fee","quantity":1,"unitPrice":1670000,"amount":1670000,"conditions":"Weekly"},{"item":"APA","conditions":"","quantity":1,"unitPrice":800000,"amount":800000}],"total":2470000,"subTotal":2470000,"totalTax":0},"inclusionZones":[{"label":"Croatia","type":"Sovereign country","category":["Europe","Southern Europe","Croatia"],"coordinates":[16.818610292079534,44.700266827856225],"bbox":[13.517187500000006,42.432910156249996,19.400976562500006,46.534619140625]}],"exclusionZones":[],"petsAllowed":false},{"name":"24.05. - 13.06. & 13.09. - 26.09.","effectiveDates":[{"from":"2025-05-24T00:00:00.000Z","to":"2025-06-13T23:59:59.999Z"},{"from":"2026-05-24T00:00:00.000Z","to":"2026-06-13T23:59:59.999Z"},{"from":"2027-05-24T00:00:00.000Z","to":"2027-06-13T23:59:59.999Z"},{"from":"2025-09-13T00:00:00.000Z","to":"2025-09-26T23:59:59.999Z"},{"from":"2026-09-13T00:00:00.000Z","to":"2026-09-26T23:59:59.999Z"},{"from":"2027-09-13T00:00:00.000Z","to":"2027-09-26T23:59:59.999Z"}],"pricing":{"currency":"EUR","charterFee":1870000,"inputAmountTaxed":"INCLUSIVE","note":"","unit":"WEEK","lineItems":[{"item":"Chart